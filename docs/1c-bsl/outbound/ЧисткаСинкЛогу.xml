<?xml version="1.0" encoding="UTF-8"?>
<!--
    ScheduledJob.ЧисткаСинкЛогу — раз на добу видаляє записи `Catalog.СинкЛог`
    старші 7 днів (TTL для idempotency-захисту).

    Викликає `СинкВхідний.ВичиститиСтаріЗаписи()`.

    ⚠ ЦЕ СКЕЛЕТ. Створити вручну у 1С Конфігураторі (2 хв):

    КРОКИ:
    1. Загальні → Регламентные задания → правий клік → Додати.
    2. Властивості:
       - Ім'я: `ЧисткаСинкЛогу`
       - Синонім: «Чистка сінк-логу»
       - Ім'я методу: `СинкВхідний.ВичиститиСтаріЗаписи`
       - Використання: Так
       - Підказка: «Видаляє записи Catalog.СинкЛог старші 7 днів (idempotency TTL).»
    3. Розклад (Розклад → Налаштувати):
       - Період повторення: 1 раз на добу
       - Початок: 03:30:00 (одразу після backup-задач)
       - Тиждень: всі дні
       - Місяці: всі місяці
    4. Зберегти + оновити конфігурацію БД.

    ⚠ Регламентні завдання працюють ТІЛЬКИ якщо у режимі Підприємства запущений
    `Регламентні завдання → Сервіс реактивації` (Адміністрування → Підтримка
    обслуговування → Регламентні та фонові завдання → Запустити).
    Для production-серверного режиму (Apache/IIS) запускається автоматично
    через `СерверЗадачНоСтартапу.exe`.

    МОНІТОРИНГ:
    Після кожного виконання — записує у журнал реєстрації подію
    `СинкВхідний.ВичиститиСтаріЗаписи` рівня «Інформація» (або «Помилка» при exception).
-->
<MetaDataObject xmlns="http://v8.1c.ru/8.3/MDClasses"
                xmlns:v8="http://v8.1c.ru/8.1/data/core"
                xmlns:xr="http://v8.1c.ru/8.3/xcf/readable"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                version="2.8">
    <ScheduledJob uuid="GENERATE-NEW-GUID-HERE">
        <Properties>
            <Name>ЧисткаСинкЛогу</Name>
            <Synonym>
                <v8:item>
                    <v8:lang>uk</v8:lang>
                    <v8:content>Чистка сінк-логу</v8:content>
                </v8:item>
            </Synonym>
            <Comment>TTL 7 днів для Catalog.СинкЛог. Викликає СинкВхідний.ВичиститиСтаріЗаписи().</Comment>
            <MethodName>СинкВхідний.ВичиститиСтаріЗаписи</MethodName>
            <Description>Видалення записів Catalog.СинкЛог старших 7 днів</Description>
            <Use>true</Use>
            <Predefined>true</Predefined>
            <RestartCountOnFailure>2</RestartCountOnFailure>
            <RestartIntervalOnFailure>60</RestartIntervalOnFailure>
            <!-- Розклад заповнюється у Конфігураторі (Schedule editor) — XML-формат
                 розкладу дуже багатослівний; простіше у GUI. -->
        </Properties>
    </ScheduledJob>
</MetaDataObject>
