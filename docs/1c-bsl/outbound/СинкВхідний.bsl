////////////////////////////////////////////////////////////////////////////////
// CommonModule.СинкВхідний — helpers для вхідної синхронізації з Node.js
// (Етап 2 master-плану `docs/1C_INTEGRATION_PLAN.md`).
//
// Властивості CommonModule (виставити у `СинкВхідний.xml`):
//   - Server = true
//   - Global = false
//   - ServerCall = true
//   - Privileged = false (auth перевіряється в ‘ПеревіритиПароль’)
//   - ReturnValuesReuse = DontUse
//
// Функції-експорти (у порядку використання):
//   - ПеревіритиПароль(ПарольВхода)
//   - ПарситиJSON(Стрічка) → Структура | Неопределено
//   - СерілізуватиJSON(Значення) → Стрічка
//   - ВідповідьУспіх(Code1C, AlreadyProcessed) → Стрічка
//   - ВідповідьУспіхЗДаними(Code1C, AlreadyProcessed, Дані) → Стрічка
//   - ВідповідьПомилкою(КодПомилки, Повідомлення) → Стрічка
//   - ЗнайтиЗаКлючем(IdempotencyKey) → ДокументПосилання | КонтрагентПосилання | Неопределено
//   - ЗареєструватиСинк(IdempotencyKey, СтворенийДокумент, ТипОперації)
//   - ВичиститиСтаріЗаписи()  — викликається з `ScheduledJob.ЧисткаСинкЛогу`
////////////////////////////////////////////////////////////////////////////////


// Auth-перевірка через `Константа.СинкСистемнийПароль`.
// Антишахрайство: завжди приводимо обидва значення до Строка + СокрЛП,
// порівнюємо case-sensitive (СтрСравнить = 0).
Функция ПеревіритиПароль(ПарольВхода) Экспорт
	УстановитьПривилегированныйРежим(Истина);
	ОчікуванийПароль = СокрЛП(Строка(Константы.СинкСистемнийПароль.Получить()));
	УстановитьПривилегированныйРежим(Ложь);
	Если ПустаяСтрока(ОчікуванийПароль) Тогда
		// Якщо константа не заповнена — нікому не довіряємо.
		Возврат Ложь;
	КонецЕсли;
	Возврат СтрСравнить(СокрЛП(Строка(ПарольВхода)), ОчікуванийПароль) = 0;
КонецФункции


// Парсить JSON-строку у Структуру.
// Повертає Неопределено при будь-якій помилці парсингу (caller обробить).
Функция ПарситиJSON(Стрічка) Экспорт
	Если ПустаяСтрока(Строка(Стрічка)) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Попытка
		Читач = Новый ЧтениеJSON;
		Читач.УстановитьСтроку(Строка(Стрічка));
		Результат = ПрочитатьJSON(Читач);
		Читач.Закрыть();
		Возврат Результат;
	Исключение
		// JSON не валідний — ПарситиJSON повертає Неопределено;
		// caller відрізнить це від «JSON валідний, але пустий».
		Возврат Неопределено;
	КонецПопытки;
КонецФункции


// Серіалізує Структура/Масив/Скаляр у JSON-строку.
// Використовується при формуванні відповіді — гарантуємо stable string output.
Функция СерілізуватиJSON(Значення) Экспорт
	Запис = Новый ЗаписьJSON;
	Параметри = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, "", Ложь);
	Запис.УстановитьСтроку(Параметри);
	ЗаписатьJSON(Запис, Значення);
	Возврат Запис.Закрыть();
КонецФункции


// Будує JSON-відповідь успіху.
// Code1C — рядок з кодом 1С (Контрагент.Код, Документ.Номер, тощо).
// AlreadyProcessed — Истина якщо це повторний виклик з тим самим IdempotencyKey.
Функция ВідповідьУспіх(Code1C, AlreadyProcessed) Экспорт
	Структура = Новый Структура;
	Структура.Вставить("ok", Истина);
	Структура.Вставить("code1C", ?(ЗначениеЗаполнено(Code1C), Строка(Code1C), Неопределено));
	Структура.Вставить("alreadyProcessed", AlreadyProcessed = Истина);
	Структура.Вставить("error", Неопределено);
	Возврат СерілізуватиJSON(Структура);
КонецФункции


// Будує JSON-відповідь успіху з додатковим payload-блоком `data`.
// Використовується для READ-операцій (напр. `ОтриматиДаніЗакриттяЗамовленьJSON`)
// і WRITE-операцій що повертають додаткові поля (напр. `ЗакритиСтаріЗамовленняJSON`
// повертає UID нового замовлення).
// Структура: {ok, code1C, alreadyProcessed, data:{...}, error:null}.
Функция ВідповідьУспіхЗДаними(Code1C, AlreadyProcessed, Дані) Экспорт
	Структура = Новый Структура;
	Структура.Вставить("ok", Истина);
	Структура.Вставить("code1C", ?(ЗначениеЗаполнено(Code1C), Строка(Code1C), Неопределено));
	Структура.Вставить("alreadyProcessed", AlreadyProcessed = Истина);
	Структура.Вставить("data", Дані);
	Структура.Вставить("error", Неопределено);
	Возврат СерілізуватиJSON(Структура);
КонецФункции


// Будує JSON-відповідь з помилкою. Caller повинен ПЕРЕД викликом
// зробити `ОтменитьТранзакцию()` якщо була розпочата транзакція.
Функция ВідповідьПомилкою(КодПомилки, Повідомлення) Экспорт
	СтрукПомилки = Новый Структура;
	СтрукПомилки.Вставить("code", Строка(КодПомилки));
	СтрукПомилки.Вставить("message", Строка(Повідомлення));

	Структура = Новый Структура;
	Структура.Вставить("ok", Ложь);
	Структура.Вставить("code1C", Неопределено);
	Структура.Вставить("alreadyProcessed", Ложь);
	Структура.Вставить("error", СтрукПомилки);
	Возврат СерілізуватиJSON(Структура);
КонецФункции


// Шукає запис у `Catalog.СинкЛог` за IdempotencyKey (= Найменування).
// Повертає посилання на створений документ/контрагента (Реквізит.СтворенийДокумент)
// або Неопределено якщо запис не знайдено.
Функция ЗнайтиЗаКлючем(IdempotencyKey) Экспорт
	Если ПустаяСтрока(IdempotencyKey) Тогда
		Возврат Неопределено;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Истина);
	Запит = Новый Запрос;
	Запит.Текст = "ВЫБРАТЬ
		|	СинкЛог.СтворенийДокумент
		|ИЗ
		|	Справочник.СинкЛог КАК СинкЛог
		|ГДЕ
		|	СинкЛог.Наименование = &Ключ
		|	И НЕ СинкЛог.ПометкаУдаления";
	Запит.УстановитьПараметр("Ключ", IdempotencyKey);
	Виб = Запит.Выполнить().Выбрать();
	УстановитьПривилегированныйРежим(Ложь);
	Если Виб.Следующий() Тогда
		Если ЗначениеЗаполнено(Виб.СтворенийДокумент) Тогда
			// Якщо це посилання на документ — повернемо його Номер;
			// якщо на Контрагента — Код. Caller передасть це у ВідповідьУспіх.
			Попытка
				Возврат Виб.СтворенийДокумент.Номер;
			Исключение
				Попытка
					Возврат Виб.СтворенийДокумент.Код;
				Исключение
					Возврат Строка(Виб.СтворенийДокумент);
				КонецПопытки;
			КонецПопытки;
		КонецЕсли;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции


// Реєструє запис у `Catalog.СинкЛог` для idempotency-захисту.
// Викликається ПІД час транзакції, ПЕРЕД ‘ЗафиксироватьТранзакцию’.
Процедура ЗареєструватиСинк(IdempotencyKey, СтворенийДокумент, ТипОперації) Экспорт
	Если ПустаяСтрока(IdempotencyKey) Тогда
		Возврат;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Истина);
	Запис = Справочники.СинкЛог.СоздатьЭлемент();
	Запис.Наименование = IdempotencyKey;
	Запис.СтворенийДокумент = СтворенийДокумент;
	Запис.ДатаСтворення = ТекущаяДата();
	Запис.ТипОперації = Строка(ТипОперації);
	Запис.Записать();
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры


// Викликається з `ScheduledJob.ЧисткаСинкЛогу` раз на добу.
// Видаляє записи `Catalog.СинкЛог` старші за 7 днів — TTL для idempotency.
// Це ще не порушує бізнес-логіку: за 7 днів усі retry-storms давно завершились.
Процедура ВичиститиСтаріЗаписи() Экспорт
	УстановитьПривилегированныйРежим(Истина);
	Кордон = ТекущаяДата() - (60 * 60 * 24 * 7); // 7 днів
	Запит = Новый Запрос;
	Запит.Текст = "ВЫБРАТЬ
		|	СинкЛог.Ссылка
		|ИЗ
		|	Справочник.СинкЛог КАК СинкЛог
		|ГДЕ
		|	СинкЛог.ДатаСтворення < &Кордон";
	Запит.УстановитьПараметр("Кордон", Кордон);
	Виб = Запит.Выполнить().Выбрать();
	Поки Виб.Следующий() Цикл
		Попытка
			Об_єкт = Виб.Ссылка.ПолучитьОбъект();
			Об_єкт.Удалить();
		Исключение
			ЗаписьЖурналаРегистрации(
				"СинкВхідний.ВичиститиСтаріЗаписи",
				УровеньЖурналаРегистрации.Предупреждение,,,
				"Не вдалось видалити " + Строка(Виб.Ссылка) + ": " + ОписаниеОшибки()
			);
		КонецПопытки;
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
КонецПроцедуры
