// ─── ЗібратиЗамовлення (приватний хелпер) ───────────────────────────────────

// Повертає Масив структур, узгоджено з
// `apps/store/lib/validations.ts::syncOrdersImportSchema` (це масив, тобто
// тут — масив елементів). Кожен елемент:
//   {
//     "code1C": "<Номер документа>",
//     "customer": {
//       "code1C": "<Контрагент.Код>",
//       "name": "<Контрагент.Наименование>",
//       "phone": "<основний телефон>",
//       "city": "<...>"
//     },
//     "status": "new"|"confirmed"|"processing"|"shipped"|"completed"|"cancelled",
//     "totalEur": <число>,
//     "totalUah": <число>,
//     "exchangeRate": <число>,
//     "notes": "<коментар>" або null,
//     "createdAt": "<ISO-дата>",
//     "items": [{
//        "barcode": "<штрих-код лоту>" або null,
//        "productCode1C": "<Номенклатура.Код>",
//        "priceEur": <число>,
//        "weight": <число>,
//        "quantity": <число цілое>
//     }]
//   }
//
// ⚠ STUB: повертає порожній масив. Реальна реалізація — за прикладом
//   `ДобавитьЗаказПокупателя` (line 2541 у ОбменАРМ). Зверни увагу:
//     - Беремо ТІЛЬКИ нові (телефонні) замовлення, які створені в 1С
//       і ще не синхронізовані на сайт. Фільтр: `Документ.Заказ.Изменения` де
//       `ДатаЗапису >= &Курсор`.
//     - Свої (саме створені нашим Етапом 2 `СтворитиЗамовленняJSON`)
//       тут НЕ повертати — Caller вже їх знає. Маркер: `Документ.ВнешнийИД`
//       заповнений = наше походження.
//     - Map 1С-статусів на наші:
//         "Новий"|"" → "new"
//         "Підтверджено"|"Утверждено" → "confirmed"
//         "В обробці" → "processing"
//         "Відвантажено" → "shipped"
//         "Виконано" → "completed"
//         "Скасовано" → "cancelled"
//     - Phone бажано формату E.164 (`+380XXXXXXXXX`); інакше Zod-validator
//       на нашій стороні дасть warning у `errors[]` array, але не зламається.
Функция ЗібратиЗамовлення(КурсорДата)
	Результат = Новый Массив;
	// TODO Реальна реалізація — `ДобавитьЗаказПокупателя` (line 2541 у ОбменАРМ).
	Возврат Результат;
КонецФункции
