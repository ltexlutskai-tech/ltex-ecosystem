	СтрокаТаблицы.ИмяКонфигурации = "БП"; 															 // определяет макет с правилами обмена
	СтрокаТаблицы.ИмяПланаОбмена = "ОбменУправлениеТорговлейБухгалтерия"; 							 // определяет имя плана обмена откуда брать данные
