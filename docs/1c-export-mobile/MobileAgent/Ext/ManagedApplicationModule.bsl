	ViberОбновлениеКлиент.ВыполнитьОбменСообщениями();
	
	
КонецПроцедуры	

Процедура ПриПолученииУведомления(Уведомление, Локальное, Показано) Экспорт 
	Попытка 
		ДанныеУведомления = Уведомление.Данные;
		//Сообщить(ДанныеУведомления);
		Если ТипЗнч(ДанныеУведомления) = Тип("Строка") Тогда 
			ДанныеУведомления = Общий.ПолучитьДанныеИзСтроки(ДанныеУведомления);
		КонецЕсли;
		
		
		Если ДанныеУведомления["Действие"] = "НовоеСообщение" Тогда 
			ОткрытьФорму("Обработка.Чат1с.Форма.Форма");
		ИначеЕсли ДанныеУведомления["Действие"] = "Напоминание" Тогда
			ПараметрыФормы = Новый Структура("ТекстНагадування",  Уведомление.Текст);
			ПараметрыФормы.Вставить("ДатаНагадування",  ДанныеУведомления["Дата"]);
			ПараметрыФормы.Вставить("УИД_Уведомления",  ДанныеУведомления["УИД_Уведомления"]);
			ПараметрыФормы.Вставить("УИД_Напоминание", ДанныеУведомления["УИД_Напоминание"]);
			Если ДанныеУведомления["НапоминаниеОТоваре"] = "1" Тогда
				
				ПараметрыФормы.Вставить("УИД_Номенклатура", ДанныеУведомления["УИД_Номенклатуры"]);
				 
			КонецЕсли; 
			
			ОткрытьФорму("Обработка.Нагадування.Форма.ФормаПерегляду", ПараметрыФормы);
			
			//
			//Если МассивОткрытыхОконНапоминаний.Найти(ДанныеУведомления["УИД_Уведомления"]) = Неопределено Тогда
			//	МассивОткрытыхОконНапоминаний.Добавить(ДанныеУведомления["УИД_Уведомления"]);
			//	
			//	//ОткрытьФорму("Обработка.Нагадування.Форма.ФормаПерегляду", ПараметрыФормы,,ДанныеУведомления["УИД_Уведомления"],,,,РежимОткрытияОкнаФормы.Независимый);
			//	ОткрытьФорму("Обработка.Нагадування.Форма.ФормаПерегляду", ПараметрыФормы,,ДанныеУведомления["УИД_Уведомления"]);			
			//КонецЕсли;			
			
		КонецЕсли;
	Исключение
		Сообщить(ОписаниеОшибки())
	КонецПопытки;
	
КонецПроцедуры



