#Если Не МобильноеПриложениеКлиент Тогда
	
	&НаКлиенте
	Процедура ПолучитьУведомления() Экспорт 
		мДатаУведомления = ТекущаяДата();
		мПолученыеСообщения = Общий.ПолучитьУведомленияНаСервере(ДатаУведомления - 3); 
		
		Для Каждого Сообщения Из мПолученыеСообщения Цикл 
			Оповещение = Новый ОписаниеОповещения("ОткрытьЧат", Клієнтський, Сообщения.ГруппаЧата); 
			ПоказатьОповещениеПользователя(СокрЛП("" + Сообщения.ГруппаЧата  + " " + Сообщения.Відправник), Оповещение, Сообщения.Текст, Сообщения.Картинка);
		КонецЦикла;
		
		ДатаУведомления = мДатаУведомления;
	КонецПроцедуры
	
#КонецЕсли

