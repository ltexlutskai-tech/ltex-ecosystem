Процедура АвтообновлениеЧатаНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Сообщения.Сообщение КАК Сообщение,
	//|	Сообщения.ИндексЕлемента КАК ИндексЕлемента,
	|	Сообщения.Дата КАК Дата
	|ПОМЕСТИТЬ вт_сообщения
	|ИЗ
	|	&Сообщения КАК Сообщения
	|
	|ИНДЕКСИРОВАТЬ ПО
	|	Сообщение
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВходящиеСообщения.Дата КАК Дата,
	|	ВходящиеСообщения.Відправник КАК Відправник,
	|	ВходящиеСообщения.ГруппаЧата КАК ГруппаЧата,
	|	ВходящиеСообщения.Уид_Сообщения КАК Уид_Сообщения,
	|	ВходящиеСообщения.Повідомлення КАК Повідомлення,
	//|	ЕСТЬNULL(вт_сообщения.ИндексЕлемента, 0) КАК ИндексЕлемента
	|ПОМЕСТИТЬ НовыеСообщения
	|ИЗ
	|	РегистрСведений.ВходящиеСообщения КАК ВходящиеСообщения
	|		ЛЕВОЕ СОЕДИНЕНИЕ вт_сообщения КАК вт_сообщения
	|		ПО ВходящиеСообщения.Уид_Сообщения = вт_сообщения.Сообщение
	|ГДЕ
	//|	вт_сообщения.ИндексЕлемента ЕСТЬ NULL
	|	 ВходящиеСообщения.ГруппаЧата В(&ГруппаЧата)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|УНИЧТОЖИТЬ вт_сообщения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НовыеСообщения.Дата КАК Дата,
	|	НовыеСообщения.Відправник КАК Відправник,
	|	НовыеСообщения.ГруппаЧата КАК ГруппаЧата,
	|	НовыеСообщения.Уид_Сообщения КАК Уид_Сообщения,
	|	НовыеСообщения.Повідомлення КАК Повідомлення,
	//|	НовыеСообщения.ИндексЕлемента КАК ИндексЕлемента,
	|	ЕСТЬNULL(ВложенныйЗапрос.Уид_Сообщения, НЕОПРЕДЕЛЕНО) КАК Уид_СообщенияСлед
	|ИЗ
	|	НовыеСообщения КАК НовыеСообщения
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ИсходящиеСообщения.Получатель КАК Получатель,
	|			ИсходящиеСообщения.Дата КАК Дата,
	|			ИсходящиеСообщения.Уид_Сообщения КАК Уид_Сообщения,
	|			ВложенныйЗапрос.Уид_НовогоСообщения КАК Уид_НовогоСообщения
	|		ИЗ
	|			РегистрСведений.ИсходящиеСообщения КАК ИсходящиеСообщения
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|					МИНИМУМ(ИсходящиеСообщения.Дата) КАК Дата,
	|					ИсходящиеСообщения.Получатель КАК Получатель,
	|					НовыеСообщения.Уид_Сообщения КАК Уид_НовогоСообщения
	|				ИЗ
	|					НовыеСообщения КАК НовыеСообщения
	|						ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ИсходящиеСообщения КАК ИсходящиеСообщения
	|						ПО НовыеСообщения.Дата < ИсходящиеСообщения.Дата
	|							И НовыеСообщения.ГруппаЧата = ИсходящиеСообщения.Получатель
	|				
	|				СГРУППИРОВАТЬ ПО
	|					ИсходящиеСообщения.Получатель,
	|					НовыеСообщения.Уид_Сообщения) КАК ВложенныйЗапрос
	|				ПО ИсходящиеСообщения.Дата = ВложенныйЗапрос.Дата
	|					И ИсходящиеСообщения.Получатель = ВложенныйЗапрос.Получатель) КАК ВложенныйЗапрос
	|		ПО НовыеСообщения.Уид_Сообщения = ВложенныйЗапрос.Уид_НовогоСообщения
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата
	|ИТОГИ ПО
	|	ГруппаЧата";
	мОткрытыеЧаты = ОткрытыеЧаты.Выгрузить();
	
	Запрос.УстановитьПараметр("Сообщения", Объект.Сообщения.Выгрузить());
	Запрос.УстановитьПараметр("ГруппаЧата", мОткрытыеЧаты.ВыгрузитьКолонку("Чат"));
	
	РезультатЗапроса  = Запрос.Выполнить();	
	ВыборкаГрупы = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	//Исходящее = РезультатЗапроса[1].Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаГрупы.Следующий() Цикл 
		УникальныйИдентификатор_Чат = ВыборкаГрупы.ГруппаЧата.УникальныйИдентификатор();
		Имя = ПолучитьИмяЭлемента("Чат",УникальныйИдентификатор_Чат);
		ГруппаЧат = Элементы.Найти(Имя);
		Если ГруппаЧат = Неопределено Тогда 
			Продолжить;
		КонецЕсли;
		
		Выборка = ВыборкаГрупы.Выбрать();
		Пока Выборка.Следующий() Цикл 
			
			ИндексиСообщений = Объект.Сообщения.Добавить();
			ИндексиСообщений.Чат = УникальныйИдентификатор_Чат;
			ИндексиСообщений.Сообщение = Выборка.Уид_Сообщения;
			ИндексиСообщений.Дата = Выборка.Дата;
			ПрорисовкаФормы_ДобавитьВходящееСообщение(Выборка, Имя, Истина, Выборка.Уид_СообщенияСлед, Ложь);
			//ИндексиСообщений.ИндексЕлемента = ИндексЕлемента;
			
		КонецЦикла;
		
		
	КонецЦикла;
КонецПроцедуры

