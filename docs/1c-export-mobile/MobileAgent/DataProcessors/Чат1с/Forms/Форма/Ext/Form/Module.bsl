&НаСервере
Процедура ПрорисовкаФормы_ДобавитьВходящееСообщение(ДанныеСообщения, ИмяЧата, ОтображатьОтправителя, ПередСообщением = Неопределено, Создано)
	перем ПередЭлементом;
	прПоиск = "";
	Если СтрНайти(ИмяЧата, "Поиск") Тогда 
		прПоиск = "Поиск";
	КонецЕсли;
	
	Имя = ПолучитьИмяЭлемента("ВходящееСообщение" + прПоиск, ДанныеСообщения.Уид_Сообщения);
	
	Если Не Элементы.Найти(Имя) = Неопределено Тогда 
		выводитьДату = Ложь;
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПередСообщением) Тогда
		ПередЭлементом = Элементы.Найти(ПолучитьИмяЭлемента("ВходящееСообщение", ПередСообщением));
		Если ПередЭлементом = Неопределено Тогда 	
			ПередЭлементом = Элементы.Найти(ПолучитьИмяЭлемента("ИсходящееСообщение", ПередСообщением));
		КонецЕсли;
		Если ПередЭлементом = Неопределено Тогда 
				 ПередЭлементом = Элементы.Найти(ПередСообщением);
			КонецЕсли;

	КонецЕсли;
	
	#Область ВходящееСообщение
	Группа = Элементы.Вставить(Имя, Тип("ГруппаФормы"), Элементы[ИмяЧата], ПередЭлементом);
	Группа.Вид 								= ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	Группа.РастягиватьПоВертикали			= Ложь;
	Группа.ОтображатьЗаголовок 				= Ложь;
	Группа.ГоризонтальноеПоложениеВГруппе 	= ГоризонтальноеПоложениеЭлемента.Лево;
	Группа.ЦветФона 						= ЦветФона;
	
	
	
	// ТелоСообщенияГоризонт
	мГруппа = Элементы.Добавить(Имя + "ТелоСообщенияГоризонт", Тип("ГруппаФормы"), Группа);
	мГруппа.Вид 							= ВидГруппыФормы.ОбычнаяГруппа;
	мГруппа.Группировка 					= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	
	мГруппа.ОтображатьЗаголовок 			= Ложь;
	мГруппа.ЦветФона 						= ЦветФонаБелый;
	
	
	#Область ГруппаРеакция
	ГруппаРеакция =  Элементы.Добавить(Имя + "ДанныеРеакции", Тип("ГруппаФормы"), Группа);
	ГруппаРеакция.Вид 							= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаРеакция.Группировка 					= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;	
	ГруппаРеакция.ОтображатьЗаголовок 			= Ложь;	
	ГруппаРеакция.ВертикальноеПоложениеВГруппе 	= ВертикальноеПоложениеЭлемента.Центр;

	// Реакция
	Элемент = Элементы.Добавить(Имя + "Реакция", Тип("ПолеФормы"), ГруппаРеакция);
	Элемент.Вид 							= ВидПоляФормы.ПолеКартинки;
	Элемент.Ширина 							= 2;
	Элемент.Высота 							= 1;
	Элемент.ПутьКДанным 					= ?(ДанныеСообщения.МояРеакция, "МояРеакция", "Реакция");
	Элемент.ПоложениеЗаголовка 				= ПоложениеЗаголовкаЭлементаФормы.Нет;
	Элемент.РазмерКартинки 					= РазмерКартинки.Пропорционально;	
	Элемент.Гиперссылка 					= Истина;
	Элемент.Подсказка 						= ДанныеСообщения.Уид_Сообщения; 
	Элемент.РастягиватьПоВертикали 			= Ложь;
	Элемент.РастягиватьПоГоризонтали 		= Ложь;
	Элемент.Рамка  							= Новый Рамка(ТипРамкиЭлементаУправления.БезРамки);
	Элемент.ВертикальноеПоложениеВГруппе 	= ВертикальноеПоложениеЭлемента.Центр;
	Элемент.УстановитьДействие("Нажатие", "РеакияНажатие");
	
	// КоличествоРеакция
	Элемент = Элементы.Добавить(Имя + "КоличествоРеакция", Тип("ДекорацияФормы"), ГруппаРеакция);
	Элемент.Вид 							= ВидДекорацииФормы.Надпись;
	Элемент.Ширина 							= 2;
	Элемент.ГоризонтальноеПоложение 		= ГоризонтальноеПоложениеЭлемента.Центр;
	Элемент.Заголовок						= Формат(ДанныеСообщения.КоличествоРеакций, "ЧДЦ=0");
	Элемент.Шрифт							= Новый Шрифт(,6);
	#КонецОбласти
	
	// Отступ
	Элемент = Элементы.Добавить(Имя + "Отступ", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид 							= ВидДекорацииФормы.Надпись;
	Элемент.Ширина 							= 0;
	
	
	#Область ТелоСообщенияГоризонт
	
	//ОтступСЛева
	Элемент = Элементы.Добавить(Имя + "ОтступСЛева", Тип("ДекорацияФормы"), мГруппа);
	Элемент.Вид 							= ВидДекорацииФормы.Надпись;
	Элемент.Ширина 							= 0;
	
	
	#Область ТелоСообщения
	Группа = Элементы.Добавить(Имя + "ТелоСообщения", Тип("ГруппаФормы"), мГруппа);
	Группа.Вид 								= ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;	
	Группа.ОтображатьЗаголовок 				= Ложь;
	
	
	//Отправитель
	Если ОтображатьОтправителя Тогда 
		Элемент 							= Элементы.Добавить(Имя + "Отправитель", Тип("ДекорацияФормы"), Группа);
		Элемент.Вид 						= ВидДекорацииФормы.Надпись;
		Элемент.Шрифт 						= Новый Шрифт(,,Истина);
		Элемент.Заголовок 					= "" + ДанныеСообщения.Відправник + ":";
		Элемент.ЦветТекста 					= Новый Цвет(0, 38, 255);
	КонецЕсли;
	
	//ТекстСообщения
	//Группа = Элементы.Добавить(Имя + "ТекстСообщения", Тип("ГруппаФормы"), Группа);
	//Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	//Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	
	//Группа.ОтображатьЗаголовок = Ложь;
	
	//Текст
	Элемент = Элементы.Добавить(Имя + "Текст", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид 							= ВидДекорацииФормы.Надпись;
	Элемент.Заголовок 						= СокрЛП(ДанныеСообщения.Повідомлення);
	Элемент.ГоризонтальноеПоложение 		= ГоризонтальноеПоложениеЭлемента.Лево;
	
	#КонецОбласти
	
	#Область ДопМеню
	Группа = Элементы.Вставить(Имя + "ДопМеню", Тип("ГруппаФормы"), мГруппа);
	Группа.Вид 								= ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Группировка 						= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Группа.ОтображатьЗаголовок 				= Ложь;
	Группа.РастягиватьПоВертикали  			= Истина;
	//Группа.ЦветФона = Новый Цвет(255,255,255);
	
	//Меню
	Элемент 								= Элементы.Добавить(Имя + "Меню", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид 							= ВидДекорацииФормы.Картинка;
	Элемент.Ширина							= 1;
	Элемент.Высота 							= 1;
	Элемент.ГоризонтальноеПоложениеВГруппе 	= ГоризонтальноеПоложениеЭлемента.Право;
	Элемент.ВертикальноеПоложениеВГруппе 	= ВертикальноеПоложениеЭлемента.Верх;
	Элемент.Картинка 						= БиблиотекаКартинок.Меню;
	Элемент.Гиперссылка 					= Истина;
	Элемент.Подсказка 						= ДанныеСообщения.Уид_Сообщения; 
	Элемент.РазмерКартинки 					= РазмерКартинки.АвтоРазмер;
	 Элемент.УстановитьДействие("Нажатие", "МенюСообщенияНажатие");

	//Время
	Элемент = Элементы.Добавить(Имя + "Время", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид 							= ВидДекорацииФормы.Надпись;
	Элемент.Заголовок 						= Формат(ДанныеСообщения.Дата, "ДФ=ЧЧ:мм");;
	Элемент.Шрифт 							= Новый Шрифт(,5);
	Элемент.ГоризонтальноеПоложениеВГруппе  = ГоризонтальноеПоложениеЭлемента.Право;
	Элемент.ВертикальноеПоложениеВГруппе 	= ВертикальноеПоложениеЭлемента.Низ;
	
	#КонецОбласти
	
	#КонецОбласти
	
	#КонецОбласти
	
	Создано = Истина;
КонецПроцедуры

&НаСервере
Процедура ПрорисовкаФормы_ДобавитьИсходящееСообщение(ДанныеСообщения, ИмяЧата, ПередСообщением = Неопределено, Создано);
	
	прПоиск = "";
	Если СтрНайти(ИмяЧата, "Поиск") Тогда 
		прПоиск = "Поиск";
	КонецЕсли;
	
	Имя = ПолучитьИмяЭлемента("ИсходящееСообщение" + прПоиск, ДанныеСообщения.Уид_Сообщения);
	
	
	Если Не Элементы.Найти(Имя) = Неопределено Тогда 
		выводитьДату = Ложь;
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПередСообщением) Тогда
		ПередЭлементом = Элементы.Найти(ПолучитьИмяЭлемента("ВходящееСообщение", ПередСообщением));
		Если ПередЭлементом = Неопределено Тогда 	
			ПередЭлементом = Элементы.Найти(ПолучитьИмяЭлемента("ИсходящееСообщение", ПередСообщением));
		КонецЕсли;
		Если ПередЭлементом = Неопределено Тогда 
			ПередЭлементом = Элементы.Найти(ПередСообщением);
		КонецЕсли;
		
	КонецЕсли;
	
	
	Группа = Элементы.Вставить(Имя, Тип("ГруппаФормы"), Элементы[ИмяЧата], ПередЭлементом);
	Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
	Группа.ОтображатьЗаголовок 				= Ложь;
	Группа.ГоризонтальноеПоложениеВГруппе 	= ГоризонтальноеПоложениеЭлемента.Право;
	Группа.РастягиватьПоГоризонтали 		= Ложь;
	Группа.РастягиватьПоВертикали			= Ложь;
	Группа.ЦветФона 						= ЦветФона;
	
	
	Элемент = Элементы.Добавить(Имя + "Отступ", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид = ВидДекорацииФормы.Надпись;
	Элемент.Ширина = 0;
	
	#Область ГруппаРеакция
	ГруппаРеакция = Элементы.Добавить(Имя + "ДанныеРеакции", Тип("ГруппаФормы"), Группа);
	ГруппаРеакция.Вид 							= ВидГруппыФормы.ОбычнаяГруппа;
	ГруппаРеакция.Группировка 					= ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;	
	ГруппаРеакция.ОтображатьЗаголовок 			= Ложь;	
	ГруппаРеакция.ВертикальноеПоложениеВГруппе 	= ВертикальноеПоложениеЭлемента.Центр;

	// Реакция
	Элемент = Элементы.Добавить(Имя + "Реакция", Тип("ПолеФормы"), ГруппаРеакция);
	Элемент.Вид 							= ВидПоляФормы.ПолеКартинки;
	Элемент.Ширина 							= 2;
	Элемент.Высота 							= 1;
	Элемент.ПутьКДанным 					= ?(ДанныеСообщения.МояРеакция, "МояРеакция", "Реакция");
	Элемент.ПоложениеЗаголовка 				= ПоложениеЗаголовкаЭлементаФормы.Нет;
	Элемент.РазмерКартинки 					= РазмерКартинки.Пропорционально;	
	Элемент.Гиперссылка 					= Истина;
	Элемент.Подсказка 						= ДанныеСообщения.Уид_Сообщения; 
	Элемент.РастягиватьПоВертикали 			= Ложь;
	Элемент.РастягиватьПоГоризонтали 		= Ложь;
	Элемент.Рамка  							= Новый Рамка(ТипРамкиЭлементаУправления.БезРамки);
	Элемент.ВертикальноеПоложениеВГруппе 	= ВертикальноеПоложениеЭлемента.Центр;
	Элемент.УстановитьДействие("Нажатие", "РеакияНажатие");
	
	// КоличествоРеакция
	Элемент = Элементы.Добавить(Имя + "КоличествоРеакция", Тип("ДекорацияФормы"), ГруппаРеакция);
