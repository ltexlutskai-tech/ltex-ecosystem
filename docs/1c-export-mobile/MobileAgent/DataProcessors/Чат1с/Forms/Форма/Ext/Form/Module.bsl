&НаСервере
Процедура  СоздатьРеквизитиДляИзображений()
	МассивРеквизитов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ГруппыЧата.Ссылка КАК Ссылка,
	|	ГруппыЧата.КартинкаГруппы КАК КартинкаГруппы
	|ИЗ
	|	Справочник.ГруппыЧата КАК ГруппыЧата";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Имя = ПолучитьИмяЭлемента("к_", Выборка.Ссылка.УникальныйИдентификатор());
		ТипЗначения = Новый ОписаниеТипов("строка");
		РеквизитФормы = Новый РеквизитФормы(Имя, ТипЗначения);
		
		МассивРеквизитов.Добавить(РеквизитФормы);
	КонецЦикла;
	
	ИзменитьРеквизиты(МассивРеквизитов);	
	
	Выборка.Сбросить();
	
	мКартинка = Новый Картинка(Обработки.Чат1с.ПолучитьМакет("ИконкаЧата"));
	Пока Выборка.Следующий() Цикл
		
		Картинка = Выборка.КартинкаГруппы.Получить();
		
		Если ТипЗнч(Картинка) = Тип("ДвоичныеДанные") Тогда
			Картинка = Новый Картинка(Картинка, Истина);
		ИначеЕсли Не ТипЗнч(Картинка) = Тип("Картинка") Тогда
			Картинка = мКартинка;
		КонецЕсли;
		ЭтаФорма[ПолучитьИмяЭлемента("к_", Выборка.Ссылка.УникальныйИдентификатор())] =  ПоместитьВоВременноеХранилище(Картинка, Новый УникальныйИдентификатор);

	КонецЦикла;
	
	Реакция = ПоместитьВоВременноеХранилище(Новый Картинка(Обработки.Чат1с.ПолучитьМакет("ИконкаРеакция")), Новый УникальныйИдентификатор);
	МояРеакция = ПоместитьВоВременноеХранилище(Новый Картинка(Обработки.Чат1с.ПолучитьМакет("ИконкаМояРеакция")), Новый УникальныйИдентификатор);
	
КонецПроцедуры


&НаСервере
Процедура ПрорисовкаФормы_СтраницаЧаты();
	
	СтраницаЧат = Элементы.Чаты;
	
	//мЭкраны = ПолучитьИнформациюЭкрановКлиента();
	//Сообщить( "ВысотаЭкрана = " + Формат(мЭкраны[0].Высота, "ЧГ=") + "ШиринаЭкрана = " Формат(мЭкраны[0].Ширина, "ЧГ="));
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.ГруппаЧата КАК ГруппаЧата,
	|	ВложенныйЗапрос.Дата КАК Дата,
	|	ВЫРАЗИТЬ(ВложенныйЗапрос.Повідомлення КАК СТРОКА(40)) КАК Повідомлення
	|ПОМЕСТИТЬ ПоследниеСообщения
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВходящиеСообщения.ГруппаЧата КАК ГруппаЧата,
	|		ВходящиеСообщения.Дата КАК Дата,
	|		ВходящиеСообщения.Повідомлення КАК Повідомлення
	|	ИЗ
	|		РегистрСведений.ВходящиеСообщения КАК ВходящиеСообщения
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				ВходящиеСообщения.ГруппаЧата КАК ГруппаЧата,
	|				МАКСИМУМ(ВходящиеСообщения.Дата) КАК Дата
	|			ИЗ
	|				РегистрСведений.ВходящиеСообщения КАК ВходящиеСообщения
	|					ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УдаленныеСообщения КАК УдаленныеСообщения
	|					ПО ВходящиеСообщения.Уид_Сообщения = УдаленныеСообщения.УИД_Сообщения
	|			ГДЕ
	|				УдаленныеСообщения.УИД_Сообщения ЕСТЬ NULL
	|			
	|			СГРУППИРОВАТЬ ПО
	|				ВходящиеСообщения.ГруппаЧата) КАК ВложенныйЗапрос
	|			ПО ВходящиеСообщения.Дата = ВложенныйЗапрос.Дата
	|				И ВходящиеСообщения.ГруппаЧата = ВложенныйЗапрос.ГруппаЧата
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ИсходящиеСообщения.Получатель,
	|		ИсходящиеСообщения.Дата,
	|		ИсходящиеСообщения.Повідомлення
	|	ИЗ
	|		РегистрСведений.ИсходящиеСообщения КАК ИсходящиеСообщения
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				МАКСИМУМ(ИсходящиеСообщения.Дата) КАК Дата,
	|				ИсходящиеСообщения.Получатель КАК Получатель
	|			ИЗ
	|				РегистрСведений.ИсходящиеСообщения КАК ИсходящиеСообщения
	|					ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УдаленныеСообщения КАК УдаленныеСообщения
	|					ПО ИсходящиеСообщения.Уид_Сообщения = УдаленныеСообщения.УИД_Сообщения
	|			ГДЕ
	|				УдаленныеСообщения.УИД_Сообщения ЕСТЬ NULL
	|			
	|			СГРУППИРОВАТЬ ПО
	|				ИсходящиеСообщения.Получатель) КАК ВложенныйЗапрос
	|			ПО ИсходящиеСообщения.Дата = ВложенныйЗапрос.Дата
	|				И ИсходящиеСообщения.Получатель = ВложенныйЗапрос.Получатель) КАК ВложенныйЗапрос
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ГруппыЧата.Код КАК Код,
	|	ГруппыЧата.Наименование КАК Наименование,
	|	ВложенныйЗапрос.Дата КАК Дата,
	|	ВложенныйЗапрос.Повідомлення КАК Повідомлення,
	|	ГруппыЧата.Ссылка КАК Ссылка,
	|	ЕСТЬNULL(НепрочитаныеСообщенияСрезПоследних.кол, 0) КАК НеПрочитаные
	|ИЗ
	|	Справочник.ГруппыЧата КАК ГруппыЧата
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ПоследниеСообщения.ГруппаЧата КАК ГруппаЧата,
	|			ПоследниеСообщения.Дата КАК Дата,
	|			ПоследниеСообщения.Повідомлення КАК Повідомлення
	|		ИЗ
	|			(ВЫБРАТЬ
	|				ПоследниеСообщения.ГруппаЧата КАК ГруппаЧата,
	|				МАКСИМУМ(ПоследниеСообщения.Дата) КАК Дата
	|			ИЗ
	|				ПоследниеСообщения КАК ПоследниеСообщения
	|			
	|			СГРУППИРОВАТЬ ПО
	|				ПоследниеСообщения.ГруппаЧата) КАК ВложенныйЗапрос
	|				ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПоследниеСообщения КАК ПоследниеСообщения
	|				ПО ВложенныйЗапрос.ГруппаЧата = ПоследниеСообщения.ГруппаЧата
	|					И ВложенныйЗапрос.Дата = ПоследниеСообщения.Дата) КАК ВложенныйЗапрос
	|		ПО ГруппыЧата.Ссылка = ВложенныйЗапрос.ГруппаЧата
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НепрочитаныеСообщения.СрезПоследних(, ) КАК НепрочитаныеСообщенияСрезПоследних
	|		ПО ГруппыЧата.Ссылка = НепрочитаныеСообщенияСрезПоследних.Отправитель
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ
	|ИТОГИ ПО
	|	Код";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаГруппыЧатов = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаГруппыЧатов.Следующий() Цикл
		Имя = "Чат" + ВыборкаГруппыЧатов.Код;
		
		ЧатКод = Элементы.Добавить(Имя, Тип("ГруппаФормы"), СтраницаЧат);
		ЧатКод.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		ЧатКод.Группировка =  ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;
		ЧатКод.ОтображатьЗаголовок = Ложь;
		//ЧатКод.ВертикальныйИнтервал =  ИнтервалМеждуЭлементамиФормы.Половинный;
		Выборка = ВыборкаГруппыЧатов.Выбрать();
		Выборка.Следующий();
		
		
		Элемент = Элементы.Добавить(Имя + "Картинка", Тип("ПолеФормы"), ЧатКод);
		Элемент.Вид = ВидПоляФормы.ПолеКартинки;
		Элемент.Ширина = 6;
		Элемент.Высота = 2;
		//Элемент.Картинка = БиблиотекаКартинок.группаЧат1с;
		Элемент.ПутьКДанным = ПолучитьИмяЭлемента("к_", Выборка.Ссылка.УникальныйИдентификатор());
		Элемент.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
		Элемент.РазмерКартинки = РазмерКартинки.Пропорционально;
		Элемент.УстановитьДействие("Нажатие", "ЧатКодНаименованиеНажатие");
		Элемент.Гиперссылка = Истина;
		Элемент.Подсказка = Выборка.Ссылка.УникальныйИдентификатор(); 
		Элемент.РастягиватьПоВертикали = Ложь;
		Элемент.РастягиватьПоГоризонтали = Ложь;
		Элемент.Рамка = Новый Рамка(ТипРамкиЭлементаУправления.БезРамки);
		Элемент.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
		Элемент.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Центр;
		
		ЧатКодГруппа = Элементы.Добавить(Имя + "Группа", Тип("ГруппаФормы"), ЧатКод);
		ЧатКодГруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		ЧатКодГруппа.Группировка =  ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
		ЧатКодГруппа.ОтображатьЗаголовок = Ложь;
		ЧатКодГруппа.РастягиватьПоГоризонтали = Истина;
		
		Элемент = Элементы.Добавить(Имя + "Наименование", Тип("ДекорацияФормы"), ЧатКодГруппа);
		Элемент.Вид = ВидДекорацииФормы.Надпись;
		Элемент.Шрифт = Новый Шрифт(,10, Истина);
		Элемент.Гиперссылка = Истина;
		Элемент.Подсказка = Выборка.Ссылка.УникальныйИдентификатор(); 
		Элемент.Заголовок = Выборка.Наименование;
		Элемент.УстановитьДействие("Нажатие", "ЧатКодНаименованиеНажатие");
		
		Элемент = Элементы.Добавить(Имя + "Сообщение", Тип("ДекорацияФормы"), ЧатКодГруппа);
		Элемент.Вид = ВидДекорацииФормы.Надпись;
		Элемент.Заголовок = СтрЗаменить(Выборка.Повідомлення, Символы.ПС, " ");
		Элемент.РастягиватьПоВертикали = ложь;
		Элемент.Высота = 1;
		
		Элемент = Элементы.Добавить(Имя + "Непрочитаные", Тип("ДекорацияФормы"), ЧатКод);
		Элемент.Вид = ВидДекорацииФормы.Надпись;
		Элемент.Заголовок = Формат(Выборка.НеПрочитаные, "ЧН=' '");
		Элемент.Шрифт = Новый Шрифт(,10);
		Элемент.ЦветТекста = Новый Цвет(225,0,0);
		Элемент.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Низ;
		Элемент.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
		Элемент.Ширина = 5;
		
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ПрорисовкаФормы_СтраницаЧат(Имя, УИД_Чата)
	
	
	Страница = Элементы.Добавить(Имя, Тип("ГруппаФормы"), элементы.ОсновнаяСтарница);
	Страница.Вид = ВидГруппыФормы.Страница;
	Страница.РастягиватьПоГоризонтали = Истина;
	Страница.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная; 
	Страница.Подсказка = УИД_Чата; 
	//ПрорисовкаФормы_СтраницаЧат_Шапка(Имя, Чат.Наименование);
	//Страница.ВертикальныйИнтервал = ИнтервалМеждуЭлементамиФормы.Половинный;
	Страница.ВертикальнаяПрокруткаПриСжатии = Истина;
	
	Элемент = Элементы.Добавить(Имя + "Картинка", Тип("ДекорацияФормы"), Страница);
	Элемент.Вид = ВидДекорацииФормы.Картинка;
	Элемент.Высота = 1;
	Элемент.РастягиватьПоГоризонтали = Истина;
	Элемент.Картинка = БиблиотекаКартинок.Обновить;
	Элемент.РазмерКартинки = РазмерКартинки.Пропорционально;
	Элемент.УстановитьДействие("Нажатие", "ЧатЭлементПолучитьЕщeНажатие");
	Элемент.Подсказка = УИД_Чата;
	Элемент.Гиперссылка = истина;
	
	ПрорисовкаФормы_Сообщения(Имя, УИД_Чата);
	
КонецПроцедуры

&НаСервере
процедура ПрорисовкаФормы_Сообщения(Имя, УИД_Чата) 
	Перем Отправитель, Дата;
	
	ЦветФона = Новый Цвет(242, 242, 242);
	ЦветФонаБелый = Новый Цвет(255, 255, 255);
	
	УникальныйИдентификатор_Чат = Новый УникальныйИдентификатор(УИД_Чата);
	Чат = Справочники.ГруппыЧата.ПолучитьСсылку(УникальныйИдентификатор_Чат);
	//ОткрытыеЧаты.ДОбавить().чат = чат;
	ТЗ_СообщенияЧата = Объект.Сообщения.Выгрузить(Новый Структура("Чат", УникальныйИдентификатор_Чат));
	
	Запрос = Новый Запрос;
	Запрос.Текст = // ПЕРВЫЕ "  + ТЗ_СообщенияЧата.Количество() + 20 + "
   
	"ВЫБРАТЬ  ПЕРВЫЕ "  + (ТЗ_СообщенияЧата.Количество() + 20) + "
	|	ВложенныйЗапрос.Дата КАК Дата,
	|	ВложенныйЗапрос.Відправник КАК Відправник,
	|	ВложенныйЗапрос.Уид_Сообщения КАК Уид_Сообщения,
	|	ВложенныйЗапрос.Повідомлення КАК Повідомлення,
	|	ВложенныйЗапрос.Входящее КАК Входящее,
	|	ЕСТЬNULL(Реакции.КоличествоРеакций, 0) КАК КоличествоРеакций,
	|	ЕСТЬNULL(Реакции.МояРеакция, ЛОЖЬ) КАК МояРеакция
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВходящиеСообщения.Дата КАК Дата,
	|		ВходящиеСообщения.Відправник КАК Відправник,
	|		ВходящиеСообщения.Уид_Сообщения КАК Уид_Сообщения,
	|		ВходящиеСообщения.Повідомлення КАК Повідомлення,
	|		ИСТИНА КАК Входящее
	|	ИЗ
	|		РегистрСведений.ВходящиеСообщения КАК ВходящиеСообщения
	|	ГДЕ
	|		ВходящиеСообщения.ГруппаЧата = &ГруппаЧата
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ИсходящиеСообщения.Дата,
	|		NULL,
	|		ИсходящиеСообщения.Уид_Сообщения,
	|		ИсходящиеСообщения.Повідомлення,
	|		ЛОЖЬ
	|	ИЗ
	|		РегистрСведений.ИсходящиеСообщения КАК ИсходящиеСообщения
	|	ГДЕ
	|		ИсходящиеСообщения.Получатель = &ГруппаЧата) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УдаленныеСообщения КАК УдаленныеСообщения
	|		ПО ВложенныйЗапрос.Уид_Сообщения = УдаленныеСообщения.УИД_Сообщения
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			РекацииНаСобщения.УИД_Сообщения КАК УИД_Сообщения,
	|			КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РекацииНаСобщения.УчастникЧата) КАК КоличествоРеакций,
	|			МАКСИМУМ(РекацииНаСобщения.УчастникЧата = &ЭтотТорговый) КАК МояРеакция
	|		ИЗ
	|			РегистрСведений.РекацииНаСобщения КАК РекацииНаСобщения
	|		ГДЕ
	|			РекацииНаСобщения.Реакция
	|		
	|		СГРУППИРОВАТЬ ПО
	|			РекацииНаСобщения.УИД_Сообщения) КАК Реакции
	|		ПО ВложенныйЗапрос.Уид_Сообщения = Реакции.УИД_Сообщения
	|ГДЕ
	|	УдаленныеСообщения.УИД_Сообщения ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ ПЕРВЫЕ 20
	|	ВТ.Дата КАК Дата,
	|	ВТ.Відправник КАК Відправник,
	|	ВТ.Уид_Сообщения КАК Уид_Сообщения,
	|	ВТ.Повідомлення КАК Повідомлення,
	|	ВТ.Входящее КАК Входящее,
	|	ВТ.КоличествоРеакций КАК КоличествоРеакций,
	|	ВТ.МояРеакция КАК МояРеакция
	|ИЗ
	|	ВТ КАК ВТ
	|
	|УПОРЯДОЧИТЬ ПО
	|	ВТ.Дата";
	
	Запрос.УстановитьПараметр("ЭтотТорговый", Константы.Пользователь1с.Получить());
	Запрос.УстановитьПараметр("ГруппаЧата", Чат);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ТЗ_СообщенияЧата.Сортировать("Дата");
	//НовоеСообщение = Ложь;
	Если ТЗ_СообщенияЧата.Количество() Тогда 
		Предедущий = Имя + Формат(ТЗ_СообщенияЧата[0].Дата, "ДФ=ddMMyy");//ТЗ_СообщенияЧата[0].Сообщение;
		//Дата = НачалоДня(ТЗ_СообщенияЧата[0].Дата); 
		//НовоеСообщение = Истина;
	КонецЕсли;
	
	Выборка = Запрос.Выполнить().Выбрать();
	//ИндексЕлемента = 1;
	выводитьДату = Истина;
	Пока Выборка.Следующий() Цикл 
		Создано = Ложь;
		Если выводитьДату И Дата <> НачалоДня(Выборка.Дата) Тогда 
			
			ПрорисовкаФормы_СтраницаЧат_Дата(Имя, Выборка.Дата, Предедущий);
			Дата = НачалоДня(Выборка.Дата);
			
		//ИначеЕсли НовоеСообщение Тогда 
		//	
		//	НовоеСообщение = Ложь;
		//	ИмяЭлемента = 
		//	Предедущий = Элементы.Найти(ИмяЭлемента);
			
		КонецЕсли;
		
		Если Выборка.Входящее Тогда 
			ОтображатьОтправителя = Не Отправитель = Выборка.Відправник;
			ПрорисовкаФормы_ДобавитьВходящееСообщение(Выборка, Имя, ОтображатьОтправителя, Предедущий, Создано);
		Иначе 
			ПрорисовкаФормы_ДобавитьИсходящееСообщение(Выборка, Имя, Предедущий, Создано);
		КонецЕсли;
		
		Если Создано Тогда 
			ИндексиСообщений = Объект.Сообщения.Добавить();
			ИндексиСообщений.Чат = УникальныйИдентификатор_Чат;
			ИндексиСообщений.Сообщение = Выборка.Уид_Сообщения;
			ИндексиСообщений.Дата = Выборка.Дата; 
		КонецЕсли;
		
		
		
		Отправитель = Выборка.Відправник;
		//ИндексЕлемента = ИндексЕлемента + 1;
	КонецЦикла;
	
КонецПроцедуры

