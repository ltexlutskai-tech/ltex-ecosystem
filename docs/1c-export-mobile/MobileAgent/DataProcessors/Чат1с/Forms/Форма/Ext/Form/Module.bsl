		Элемент.Гиперссылка = Истина;
		Элемент.Подсказка = УИД_Чат; 
		Элемент.Заголовок = ВыборкаГруппыЧатов.Наименование;
		Элемент.УстановитьДействие("Нажатие", "ЧатКодНаименованиеНажатие");
		
		Элемент = Элементы.Добавить(Имя + "Сообщение", Тип("ДекорацияФормы"), ЧатКодГруппа);
		Элемент.Вид = ВидДекорацииФормы.Надпись;
		Элемент.Заголовок = "Знайдено " + Выборка.Количество() + " повідомлень"; 
		Элемент.РастягиватьПоВертикали = ложь;
		Элемент.Высота = 1;
		
		//Элемент = Элементы.Добавить(Имя + "Непрочитаные", Тип("ДекорацияФормы"), ЧатКод);
		//Элемент.Вид = ВидДекорацииФормы.Надпись;
		//Элемент.Заголовок = Формат(Выборка.Количество(), "ЧН=' '");
