&НаСервере
Процедура ТекстПоискаПриИзмененииНаСервере()
	
	ЦветФона = Новый Цвет(242, 242, 242);
	ЦветФонаБелый = Новый Цвет(255, 255, 255);
	
	Попытка
		УидЧата = Новый УникальныйИдентификатор(Элементы.ОсновнаяСтарница.ТекущаяСтраница.Подсказка);
		ТекущийЧат = Справочники.ГруппыЧата.ПолучитьСсылку(УидЧата);
		Если ТекущийЧат.Пустая() Тогда 
			ТекущийЧат = Справочники.УчасникиЧата.ПолучитьСсылку(УидЧата);
		КонецЕсли;
		
	Исключение
		ТекущийЧат = Неопределено;
	КонецПопытки;
	
	мИмя = Новый Массив;
	Для Каждого Элемент из Элементы.ЧатыПошук.ПодчиненныеЭлементы Цикл 
		мИмя.Добавить(Элемент.Имя);
	КонецЦикла;
	
	Для Каждого Элемент Из  элементы.ОсновнаяСтарница.ПодчиненныеЭлементы Цикл 
		Если СтрНайти(Элемент.Имя, "ЧатПоиск") Тогда
			мИмя.Добавить(Элемент.Имя);
		КонецЕсли;
		
	КонецЦикла;
	
	
	Для Каждого Элемент Из мИмя Цикл 
		Элементы.Удалить(Элементы[Элемент]);
	КонецЦикла;
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Дата КАК Дата,
	|	ВложенныйЗапрос.Відправник КАК Відправник,
	|	ВложенныйЗапрос.ГруппаЧата КАК Ссылка,
	|	ВложенныйЗапрос.Уид_Сообщения КАК Уид_Сообщения,
	|	ВложенныйЗапрос.Повідомлення КАК Повідомлення,
	|	ВложенныйЗапрос.ГруппаЧата.Код КАК Код,
	|	ВложенныйЗапрос.ГруппаЧата.Наименование КАК Наименование,
	|	ВложенныйЗапрос.Входящее КАК Входящее,
	|	ЕСТЬNULL(Реакции.КоличествоРеакций, 0) КАК КоличествоРеакций,
	|	ЕСТЬNULL(Реакции.МояРеакция, ЛОЖЬ) КАК МояРеакция
	|ИЗ
	|	(ВЫБРАТЬ
	|		ВходящиеСообщения.Дата КАК Дата,
	|		ВходящиеСообщения.Відправник КАК Відправник,
	|		ВходящиеСообщения.ГруппаЧата КАК ГруппаЧата,
	|		ВходящиеСообщения.Уид_Сообщения КАК Уид_Сообщения,
	|		ВходящиеСообщения.Повідомлення КАК Повідомлення,
	|		ИСТИНА КАК Входящее
	|	ИЗ
	|		РегистрСведений.ВходящиеСообщения КАК ВходящиеСообщения
	|	ГДЕ
	|		ВходящиеСообщения.Повідомлення ПОДОБНО &Повідомлення
	|		И ВЫБОР
	|				КОГДА &ТекущийЧат = НЕОПРЕДЕЛЕНО
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ВходящиеСообщения.ГруппаЧата = &ТекущийЧат
	|			КОНЕЦ
	|	
	|	ОБЪЕДИНИТЬ ВСЕ
	|	
	|	ВЫБРАТЬ
	|		ИсходящиеСообщения.Дата,
	|		NULL,
	|		ИсходящиеСообщения.Получатель,
	|		ИсходящиеСообщения.Уид_Сообщения,
	|		ИсходящиеСообщения.Повідомлення,
	|		ЛОЖЬ
	|	ИЗ
	|		РегистрСведений.ИсходящиеСообщения КАК ИсходящиеСообщения
	|	ГДЕ
	|		ИсходящиеСообщения.Повідомлення ПОДОБНО &Повідомлення
	|		И ВЫБОР
	|				КОГДА &ТекущийЧат = НЕОПРЕДЕЛЕНО
	|					ТОГДА ИСТИНА
	|				ИНАЧЕ ИсходящиеСообщения.Получатель = &ТекущийЧат
	|			КОНЕЦ) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.УдаленныеСообщения КАК УдаленныеСообщения
	|		ПО ВложенныйЗапрос.Уид_Сообщения = УдаленныеСообщения.УИД_Сообщения
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			РекацииНаСобщения.УИД_Сообщения КАК УИД_Сообщения,
	|			КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РекацииНаСобщения.УчастникЧата) КАК КоличествоРеакций,
	|			МАКСИМУМ(РекацииНаСобщения.УчастникЧата = &ЭтотТорговый) КАК МояРеакция
	|		ИЗ
	|			РегистрСведений.РекацииНаСобщения КАК РекацииНаСобщения
	|		ГДЕ
	|			РекацииНаСобщения.Реакция
	|		
	|		СГРУППИРОВАТЬ ПО
	|			РекацииНаСобщения.УИД_Сообщения) КАК Реакции
	|		ПО ВложенныйЗапрос.Уид_Сообщения = Реакции.УИД_Сообщения
	|ГДЕ
	|	УдаленныеСообщения.УИД_Сообщения ЕСТЬ NULL
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата
	|ИТОГИ ПО
	|	Ссылка";
	Запрос.УстановитьПараметр("ТекущийЧат", ТекущийЧат);
	Запрос.УстановитьПараметр("Повідомлення", "%" + ТекстПоиска + "%");
	Запрос.УстановитьПараметр("ЭтотТорговый", Константы.Пользователь1с.Получить());
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаГруппыЧатов = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Если Не  ВыборкаГруппыЧатов.Количество() Тогда 
		Сообщить("Повідомлень не знайдено!");
		ТекстПоиска = "";
		Возврат;
	КонецЕсли;
	
	
	Пока ВыборкаГруппыЧатов.Следующий() Цикл 
		Выборка = ВыборкаГруппыЧатов.Выбрать();
		
		Имя = "ЧатПошук" + ВыборкаГруппыЧатов.Код;
		
