		Элемент.Подсказка =  УИД_Чат;
		Элемент.Гиперссылка = истина;
		
		
		выводитьДату = Истина;
		Дата = Неопределено;
		Пока Выборка.Следующий() Цикл
			
			Если выводитьДату И Дата <> НачалоДня(Выборка.Дата) Тогда 
				ПрорисовкаФормы_СтраницаЧат_Дата(Имя, Выборка.Дата);
				Дата = НачалоДня(Выборка.Дата);
			КонецЕсли;
			
			Если Выборка.Входящее Тогда 
				//ОтображатьОтправителя = Не Отправитель = Выборка.Відправник;
				ПрорисовкаФормы_ДобавитьВходящееСообщение(Выборка, Имя, Истина,,);
			Иначе 
				ПрорисовкаФормы_ДобавитьИсходящееСообщение(Выборка, Имя,,);
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если ТекущийЧат = Неопределено Тогда 
		Элементы.ОсновнаяСтарница.ТекущаяСтраница = Элементы.ЧатыПошук;
	Иначе
		Имя = ПолучитьИмяЭлемента("ЧатПоиск", УидЧата);
		Элементы.ОсновнаяСтарница.ТекущаяСтраница = Элементы[Имя];
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ТекстПоискаПриИзменении(Элемент)
	Если ПустаяСтрока(ТекстПоиска) Тогда 
		Возврат;
	КонецЕсли;
	
	ТекстПоискаПриИзмененииНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ОтменаПоискаНажатие(Элемент)
	ДекорацияПоискНажатие(Элемент);
	ТекстПоиска = "";
	Попытка
		УидЧата = Новый УникальныйИдентификатор(Элементы.ОсновнаяСтарница.ТекущаяСтраница.Подсказка);
		Имя = ПолучитьИмяЭлемента("Чат", УидЧата);
		Элементы.ОсновнаяСтарница.ТекущаяСтраница = Элементы[Имя];	
	Исключение
		Элементы.ОсновнаяСтарница.ТекущаяСтраница = Элементы.Чаты;
		Элементы.ОтправкаСообщения.Видимость = Ложь;
		Элементы.ПерепискаГМНазад.Видимость = Ложь;
		
	КонецПопытки;
	
	ПодключениеДрайверБуфераОбмена();
	
КонецПроцедуры

&НаКлиенте
Процедура ПодключениеДрайверБуфераОбмена()
	
	Если ПодключитьВнешнююКомпоненту("ОбщийМакет.Component", "Broadcasts", ТипВнешнейКомпоненты.Native) Тогда // com_iksoftware_unimes     		
		мБуферОбмена = Новый ("AddIn.Broadcasts.Clipboard");		
		//Сообщить(мБуферОбмена.СодержимоеБуфера); 
		//
	Иначе
				СообщениеПользователю = Новый СообщениеПользователю();
		СообщениеПользователю.Текст = "Ошибка подключения компоненты ""UniversalBroadcast""";
		СообщениеПользователю.Сообщить();		
	КонецЕсли;	
КонецПроцедуры


Процедура СоздатьЭлементРеакцияНаФорме(Имя, Уид_Сообщения, ПутьКДанным);
	
	Группа = Элементы.Найти(ПолучитьИмяЭлемента("ВходящееСообщение", Уид_Сообщения)+ "ДанныеРеакции");
	Если Группа = Неопределено Тогда 	
		Группа = Элементы.Найти(ПолучитьИмяЭлемента("ИсходящееСообщение", Уид_Сообщения)+ "ДанныеРеакции");
	КонецЕсли;
	Текст = Группа.ПодчиненныеЭлементы[0];
	
	Элемент = Элементы.Вставить(Имя, Тип("ПолеФормы"), Группа, Текст);
	Элемент.Вид 							= ВидПоляФормы.ПолеКартинки;
	Элемент.Ширина 							= 2;
	Элемент.Высота 							= 1;
	Элемент.ПутьКДанным 					= ПутьКДанным;
	Элемент.ПоложениеЗаголовка 				= ПоложениеЗаголовкаЭлементаФормы.Нет;
	Элемент.РазмерКартинки 					= РазмерКартинки.Пропорционально;	
	Элемент.Гиперссылка 					= Истина;
	Элемент.Подсказка 						= Уид_Сообщения; 
	Элемент.РастягиватьПоВертикали 			= Ложь;
	Элемент.РастягиватьПоГоризонтали 		= Ложь;
	Элемент.Рамка  							= Новый Рамка(ТипРамкиЭлементаУправления.БезРамки);
	Элемент.ВертикальноеПоложениеВГруппе 	= ВертикальноеПоложениеЭлемента.Центр;
	Элемент.УстановитьДействие("Нажатие", "РеакияНажатие");
	
	Попытка 
		мЧисло = Число(Текст.Заголовок); 
	Исключение
		мЧисло = 0;
	КонецПопытки;
	
	Текст.Заголовок = Формат(мЧисло + ?(ПутьКДанным = "Реакция", -1, 1), "ЧДЦ=0");
	
КонецПроцедуры

&НаКлиенте
Процедура ПоставитьРеакцию();
	
	РеакцияНажатиеНаСервере(РеакцияДляЭлемента);
	
КонецПроцедуры

