		//ЧатКод.ВертикальныйИнтервал =  ИнтервалМеждуЭлементамиФормы.Половинный;
		УИД_Чат = ВыборкаГруппыЧатов.Ссылка.УникальныйИдентификатор();
		Элемент = Элементы.Добавить(Имя + "Картинка", Тип("ДекорацияФормы"), ЧатКод);
		Элемент.Вид = ВидДекорацииФормы.Картинка;
