&НаСервере
Процедура ОтправкаСообщенияОтправитьНажатиеНаСервере(Отказ)
	
	
	Если ПустаяСтрока(ТекстВвода) Тогда 
		Возврат;
	КонецЕсли;
	ЦветФона = Новый Цвет(242, 242, 242);
	ЦветФонаБелый = Новый Цвет(255, 255, 255);

	
	ТекущаяСтраница = Элементы.ОсновнаяСтарница.ТекущаяСтраница;
	УИД = Новый УникальныйИдентификатор(ТекущаяСтраница.Подсказка);
	Получатель = Справочники.ГруппыЧата.ПолучитьСсылку(УИД);
	
	Менеджер = РегистрыСведений.ИсходящиеСообщения.СоздатьМенеджерЗаписи();
	Менеджер.Получатель = Получатель; 
	Менеджер.Дата = ТекущаяДата();
	Менеджер.Уид_Сообщения = Новый УникальныйИдентификатор();
	Менеджер.Повідомлення = ТекстВвода;
	Менеджер.Записать();
	
	ОтправитьСМС_НаСервер(Менеджер, Отказ);

	Данные = Новый Структура("Уид_Сообщения, Повідомлення, КоличествоРеакций, МояРеакция, Дата");
	ЗаполнитьЗначенияСвойств(Данные, Менеджер);
	Данные.КоличествоРеакций = 0;
	Данные.МояРеакция = ложь;

	
	ПрорисовкаФормы_ДобавитьИсходящееСообщение(Данные, ТекущаяСтраница.Имя,,Ложь);  
	Элементы["Чат" + Получатель.Код + "Сообщение"].Заголовок = Лев(ТекстВвода, 40);
