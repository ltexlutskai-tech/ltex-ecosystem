	Группа.Группировка 					= ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	
	Группа.ОтображатьЗаголовок 			= Ложь;
	Группа.ЦветФона 					= ЦветФонаБелый;

	Элемент = Элементы.Добавить(Имя + "Текст", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид = ВидДекорацииФормы.Надпись;
	Элемент.Заголовок = СокрЛП(ДанныеСообщения.Повідомлення);
	Элемент.АвтоМаксимальнаяШирина = Ложь;
	Элемент.МаксимальнаяШирина = 32;
	Элемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Лево;
	Элемент.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Центр;
	//Элемент.ЦветФона = ЦветФонаБелый;
	
	Группа = Элементы.Вставить(Имя + "ДопМеню", Тип("ГруппаФормы"), Группа);
	Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.РастягиватьПоВертикали  = Истина;
	//Группа.ЦветФона = ЦветФонаБелый;
	
	Элемент = Элементы.Добавить(Имя + "Меню", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид = ВидДекорацииФормы.Картинка;
	Элемент.Ширина = 1;
	Элемент.Высота = 1;
	Элемент.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
	Элемент.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Верх;
	Элемент.Картинка = БиблиотекаКартинок.Меню;
	Элемент.Гиперссылка = Истина;
	Элемент.УстановитьДействие("Нажатие", "МенюСообщенияНажатие");
	Элемент.Подсказка = ДанныеСообщения.Уид_Сообщения; 
	Элемент.РазмерКартинки = РазмерКартинки.АвтоРазмер;
	
	Элемент = Элементы.Добавить(Имя + "Время", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид = ВидДекорацииФормы.Надпись;
	Элемент.Заголовок = Формат(ДанныеСообщения.Дата, "ДФ=ЧЧ:мм");;
	Элемент.Шрифт = Новый Шрифт(,5);
	Элемент.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
	Элемент.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Низ;
	
	
	
	Создано = Истина;
КонецПроцедуры

Процедура ПрорисовкаФормы_СтраницаЧат_Дата(ИмяЧата, Дата, ПередСообщением = Неопределено)
	
	ИмяЭлемента = ИмяЧата + Формат(Дата, "ДФ=ddMMyy");
	Если ИмяЭлемента = ПередСообщением Тогда 
		Возврат;
	КонецЕсли;
	
	Элемент = Элементы.Найти(ИмяЭлемента);
	Если Элемент <> Неопределено Тогда 
		Элементы.Удалить(Элемент);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПередСообщением) Тогда
		ПередЭлементом = Элементы.Найти(ПолучитьИмяЭлемента("ВходящееСообщение", ПередСообщением));
		Если ПередЭлементом = Неопределено Тогда 	
			ПередЭлементом = Элементы.Найти(ПолучитьИмяЭлемента("ИсходящееСообщение", ПередСообщением));
			Если ПередЭлементом = Неопределено Тогда 
				 ПередЭлементом = Элементы.Найти(ПередСообщением);
			КонецЕсли;
			
		КонецЕсли;
	КонецЕсли;
	
	
	//Элементы.Вставить(ИмяЭлемента, 
	Элемент = Элементы.Вставить(ИмяЭлемента, Тип("ДекорацияФормы"), Элементы[ИмяЧата], ПередЭлементом);
	Элемент.Вид = ВидДекорацииФормы.Надпись;
	Элемент.Заголовок = Формат(Дата, "ДФ='dd MMMM'");
	Элемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
	Элемент.РастягиватьПоГоризонтали = истина;
	
КонецПроцедуры


