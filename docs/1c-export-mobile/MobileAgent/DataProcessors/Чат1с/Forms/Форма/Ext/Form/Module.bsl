&НаКлиенте
Процедура ЧатКодНаименованиеНажатие(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	Если Найти(Элемент.Имя, "Пошук") Тогда 
		Имя = ПолучитьИмяЭлемента("ЧатПоиск", Элемент.Подсказка);
	Иначе			
		Имя = ПолучитьИмяЭлемента("Чат", Элемент.Подсказка);
		Элементы[СтрЗаменить(Элемент.Имя, "Наименование", "Непрочитаные")].Заголовок = "";
		ОновитьНепрочитаные(Элемент.Подсказка);
		
	КонецЕсли;
	
	
	Если Элементы.Найти(Имя) = Неопределено Тогда 
		ПрорисовкаФормы_СтраницаЧат(Имя, Элемент.Подсказка);
	Иначе
		
	КонецЕсли;
	Попытка
		Элементы.ПерепискаГМНаименование.Заголовок = НаименованиеГруппыЧата(Элемент.Подсказка);
	Исключение
	КонецПопытки;
	
	Элементы.ОсновнаяСтарница.ТекущаяСтраница = элементы[Имя];
	Элементы.ОтправкаСообщения.Видимость = Истина;
	
	Элементы.ПерепискаГМНазад.Видимость = Истина;
	Элементы.ПерепискаГМНаименование.Видимость = Истина;
	
КонецПроцедуры

