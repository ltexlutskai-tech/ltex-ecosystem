&НаСервере
Процедура РеакцияНажатиеНаСервере(ИмяЭлемента);
	Элемент = Элементы[ИмяЭлемента];
	УИД_Сообщения = Новый УникальныйИдентификатор(Элемент.Подсказка);
	УчастникЧата = Константы.Пользователь1с.Получить();
	
	Набор = РегистрыСведений.РекацииНаСобщения.СоздатьНаборЗаписей();
	Набор.Отбор.УИД_Сообщения.Установить(УИД_Сообщения);
	Набор.Отбор.УчастникЧата.Установить(УчастникЧата);
	Запись = Набор.Добавить();
	Запись.УИД_Сообщения = УИД_Сообщения;
	Запись.УчастникЧата = УчастникЧата;
	Запись.Дата = ТекущаяДата();
	Если Элемент.ПутьКДанным = "Реакция" Тогда 
		Запись.Реакция = Истина;
		ПутьКДанным = "МояРеакция";
	Иначе
		Запись.Реакция = Ложь;
		ПутьКДанным = "Реакция";
	КонецЕсли;
	Набор.Записать();
	
	Элементы.Удалить(Элемент);
	СоздатьЭлементРеакцияНаФорме(ИмяЭлемента, УИД_Сообщения, ПутьКДанным);  
КонецПроцедуры


