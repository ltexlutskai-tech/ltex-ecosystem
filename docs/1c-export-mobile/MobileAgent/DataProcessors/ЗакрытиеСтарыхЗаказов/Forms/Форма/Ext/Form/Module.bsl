&НаСервереБезКонтекста
Функция ПолучитьСкладКонтрагента(Контрагент)
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	          |	СкладыКонтрагентов.Ссылка КАК Склад
	          |ИЗ
	          |	Справочник.СкладыКонтрагентов КАК СкладыКонтрагентов
	          |ГДЕ
	          |	СкладыКонтрагентов.Контрагент = &Контрагент";
	з.УстановитьПараметр("Контрагент",Контрагент);
	Выборка = З.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Склад;
	Иначе 
		Возврат Справочники.СкладыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
	
КонецФункции
