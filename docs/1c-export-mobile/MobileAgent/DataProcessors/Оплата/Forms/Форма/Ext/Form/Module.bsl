		НовВз.Запустить(Истина);
	#Иначе 
		Сообщить(ТекстСообщения);
	#КонецЕсли
КонецПроцедуры

&НаСервере
Процедура ВидДвиженияДенежныхСредствПриИзмененииНаСервере()
	Если Объект.ВидДвиженияДенежныхСредств = Перечисления.ВидДвиженияДенежныхСредств.Приход Тогда
		Элементы.СтатьяДвиженияДенежныхСредств.Видимость = Ложь;
		Элементы.Контрагент.Видимость = Истина;
		Элементы.СдачаUAH.Видимость = Истина;
		Элементы.ГруппаСдачаUAH.Видимость = Истина;
		Элементы.ГруппаСдачаEUR.Видимость = Истина;
		Элементы.ГруппаСдачаUSD.Видимость = Истина;
		Элементы.СуммаКОплате.Видимость = Истина;
		Элементы.Борги.Видимость = Истина;		
	Иначе	
		Элементы.СтатьяДвиженияДенежныхСредств.Видимость = Истина;
		Элементы.Контрагент.Видимость = Ложь; 
		Элементы.ГруппаСдачаUAH.Видимость = Ложь;
		Элементы.ГруппаСдачаEUR.Видимость = Ложь;
		Элементы.ГруппаСдачаUSD.Видимость = Ложь; 
		Элементы.СуммаКОплате.Видимость = Ложь; 
		Элементы.Борги.Видимость = Ложь;
	КонецЕсли;	
КонецПроцедуры

