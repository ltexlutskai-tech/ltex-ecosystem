&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
	Если Элементы.Товары.ТекущиеДанные.Количество = 0 Тогда 
		Элементы.Товары.ТекущиеДанные.Количество = 1;
	КонецЕсли;	
	
КонецПроцедуры



&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора) Экспорт
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Номенклатура") Тогда 
		ШКТовара = Общий.ПолучитьШтрихкодТовара(ВыбранноеЗначение);
		
		СтруктураТовара = Общий.ПолучитьДанныеТовараПоШК(Строка(ШКТовара));		
		ДобавитьТовар(ВыбранноеЗначение,ВыбранноеЗначение.ХарактеристикаНоменклатуры,СтруктураТовара.ЕдиницаИзмерения,1,СтруктураТовара.Штрихкод);
		ФормаДобавления = ПолучитьФорму("Справочник.Номенклатура.ФормаСписка",Новый Структура("РежимВыбора",Истина),ЭтаФорма);
		ФормаДобавления.Открыть();
		
	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		Объект.Коментар = ВыбранноеЗначение;
	Иначе
		Если ВыбранноеЗначение.УИД <> УИДФормы Тогда 
			Возврат;
		КонецЕсли;
		
		Если ВыбранноеЗначение.Количество = 0 Тогда 
			Сообщить("Не хватает остатка: "+ВыбранноеЗначение.Номенклатура+", "+ВыбранноеЗначение.ХарактеристикаНоменклатуры);
			Возврат;
		КонецЕсли;
		ДобавитьТовар(ВыбранноеЗначение.Номенклатура,ВыбранноеЗначение.ХарактеристикаНоменклатуры,ВыбранноеЗначение.ЕдиницаИзмерения,ВыбранноеЗначение.Количество,ВыбранноеЗначение.Штрихкод);
		ФормаДобавления = ПолучитьФорму("Справочник.Номенклатура.ФормаСписка",Новый Структура("РежимВыбора",Истина),ЭтаФорма);
		ФормаДобавления.Открыть();
		
	КонецЕсли;	
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)

	Если ИмяСобытия = "Подбор" Тогда 
		Если Параметр.УИД <> УИДФормы Тогда 
			Возврат;
		КонецЕсли;
		
		ВыбранноеЗначение =  Параметр;
		Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Номенклатура") Тогда 
			ШКТовара = Общий.ПолучитьШтрихкодТовара(ВыбранноеЗначение);
			
			СтруктураТовара = Общий.ПолучитьДанныеТовараПоШК(Строка(ШКТовара));		
			ДобавитьТовар(ВыбранноеЗначение,,СтруктураТовара.ЕдиницаИзмерения,1,СтруктураТовара.Штрихкод);
			//Сообщить("Товар додано");
			
		ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
			Объект.Коментар = ВыбранноеЗначение;
		Иначе		
			Если ВыбранноеЗначение.Количество = 0 Тогда 
				Сообщить("Не хватает остатка: "+ВыбранноеЗначение.Номенклатура+", "+ВыбранноеЗначение.ХарактеристикаНоменклатуры);
				Возврат;
			КонецЕсли;
			ДобавитьТовар(ВыбранноеЗначение.Номенклатура,ВыбранноеЗначение.ХарактеристикаНоменклатуры,ВыбранноеЗначение.ЕдиницаИзмерения,ВыбранноеЗначение.Количество,ВыбранноеЗначение.Штрихкод);
			//ДобавитьТовар(ВыбранноеЗначение.Номенклатура,,ВыбранноеЗначение.ЕдиницаИзмерения,ВыбранноеЗначение.Количество,ВыбранноеЗначение.Штрихкод);
			
			//Сообщить("Товар додано");
		КонецЕсли;	
	КонецЕсли;
	
	ЗаписатьПриИзменении(); //intrata_wald_02072021
	
КонецПроцедуры



