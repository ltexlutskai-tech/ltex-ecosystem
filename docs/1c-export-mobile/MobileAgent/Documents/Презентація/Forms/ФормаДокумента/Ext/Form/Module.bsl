&НаСервере
Процедура ПроверкаТЧТовары(Параметры)
	Товары =Объект.Товары;
	Параметры = Новый  Структура("Отказ, Ошибка", Ложь, "");
	УдалитьСтроки = Новый Массив;
	ВыдатьОшибку = Новый Массив;
	
	ДЛя Каждого Стр Из Товары Цикл
		
		Если НЕ (ЗначениеЗаполнено(Стр.Номенклатура)
			И ЗначениеЗаполнено(Стр.ХарактеристикаНоменклатуры)
			И ЗначениеЗаполнено(Стр.Количество)
			И ЗначениеЗаполнено(Стр.Цена)) Тогда 
			
			Если ЗначениеЗаполнено(Стр.Номенклатура)
				Или ЗначениеЗаполнено(Стр.ХарактеристикаНоменклатуры)
				Или ЗначениеЗаполнено(Стр.Количество)
				Или ЗначениеЗаполнено(Стр.Цена) Тогда 
				
				Колонки = "";
				Если Не ЗначениеЗаполнено(Стр.Номенклатура) Тогда 
					Колонки = "номенклатура"
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(Стр.ХарактеристикаНоменклатуры) Тогда 
					Колонки = Колонки + ?(ЗначениеЗаполнено(Колонки), ", ", "") + "вага";
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(Стр.Количество) Тогда 
					Колонки = Колонки + ?(ЗначениеЗаполнено(Колонки), ", ", "") + "кількість"
				КонецЕсли;
				
				Если Не ЗначениеЗаполнено(Стр.Цена) Тогда 
					Колонки = Колонки + ?(ЗначениеЗаполнено(Колонки), ", ", "") + "ціна"
				КонецЕсли;
				мСтруктура = Новый  Структура("Стр, Колонки", Стр, Колонки);
				ВыдатьОшибку.Добавить(мСтруктура);
			Иначе
				УдалитьСтроки.Добавить(Стр);
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;
	
	ДЛя Каждого Стр Из УдалитьСтроки Цикл
		Товары.Удалить(Стр);
	КонецЦикла;
	
	ДЛя Каждого элемент Из ВыдатьОшибку Цикл
		Параметры.Отказ  = Истина;
		Параметры.Ошибка = Параметры.Ошибка + Символы.ПС + "В рядку №" + (Товары.Индекс(элемент.Стр) + 1)  + " не заповнено колонки: " + элемент.Колонки;	
	КонецЦикла;
	

	
КонецПроцедуры


