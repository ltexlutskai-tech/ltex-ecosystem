&НаСервереБезКонтекста
Функция КонтрольОплати(ЗаказПокупателя)
	
	Если Не ЗначениеЗаполнено(ЗаказПокупателя) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КассовыйОрдер.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.КассовыйОрдер КАК КассовыйОрдер
		|ГДЕ
		|	КассовыйОрдер.ЗаказПокупателя = &ЗаказПокупателя";
	
	Запрос.УстановитьПараметр("ЗаказПокупателя", ЗаказПокупателя);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат Выборка.Следующий();

КонецФункции

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	//123!"№
	Если Объект.Доставка = ПредопределенноеЗначение("Перечисление.НаявністьДоставки.Почта") и Объект.Наложка = Ложь  Тогда
		
		Оплаты = Общий.ПолучитьДанныеПоОплате(Объект.Ссылка);
