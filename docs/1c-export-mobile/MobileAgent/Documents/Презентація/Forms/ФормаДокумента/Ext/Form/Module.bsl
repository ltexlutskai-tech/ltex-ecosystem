			Режим = РежимДиалогаВопрос.ДаНет;
			Ответ = Вопрос("Ви дійсно хочете створити реалізацію без повної оплати?", Режим);
			Если Ответ = КодВозвратаДиалога.Нет Тогда
				Отказ = Истина;
				Возврат;
			КонецЕсли;	
			
		КонецЕсли;
		
	КонецЕсли;
	
		//////////////////////////////////////////////////////
	Если НЕ мЗакрытиеСПараметром Тогда 
		//Отказ = Истина;
		//СтандартнаяОбработка = Ложь;
		мЗакрытиеСПараметром = Истина;
		Закрыть(Объект.Ссылка);
		Возврат;
	КонецЕсли;
	Если Отказ Тогда 
		мЗакрытиеСПараметром = Ложь;
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Функция ПолучитьКонтрагентаПоЗначению()
	СЗ = Новый СписокЗначений;	
	Элементы.Контрагент.СписокВыбора.Очистить();
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка,
		|	Контрагенты.Город КАК Город,
		|	Контрагенты.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты";
	
	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СЗ.Добавить(ВыборкаДетальныеЗаписи.Ссылка, ВыборкаДетальныеЗаписи.Наименование + " (" + ВыборкаДетальныеЗаписи.Город + ")");
		//Элементы.Контрагент.СписокВыбора.Добавить(ВыборкаДетальныеЗаписи.Ссылка, ВыборкаДетальныеЗаписи.Наименование + " (" + ВыборкаДетальныеЗаписи.Город + ")");

	КонецЦикла;
	
	Возврат СЗ;
КонецФункции

&НаКлиенте
Процедура ОтправитьУЧат(Команда)
	
		
	
	Записать(); 	
	сз_Чаты = ПолучитьАктуалныеЧаты();
	Чат = сз_Чаты.ВыбратьЭлемент("Відправити у чат");
	Если Чат = Неопределено Тогда 
		Возврат;
	КонецЕсли;

	НомераТелефонов = ТелефонКонтрагента();
	Если НомераТелефонов.Количество() > 1 Тогда 
		ВыбрЗнач = НомераТелефонов.ВыбратьЭлемент("Номер телефона клієнта");
		Если ВыбрЗнач = Неопределено Тогда 
			Возврат;
		КонецЕсли;
		Телефон = ВыбрЗнач.Значение;
	ИначеЕсли  НомераТелефонов.Количество() = 1 Тогда 
		Телефон = НомераТелефонов[0].Значение;
	КонецЕсли;

	
	ОтправитьУЧатНаСервере(Чат.Значение, Телефон);
	Объект.ВідправленоВВайбер = Истина;
	//Объект.ВивантажуватиВ1С = Истина;
	//Элементы.ВивантажуватиВ1С.Доступность = Истина;

КонецПроцедуры

&НаСервереБезКонтекста
Функция  ПолучитьАктуалныеЧаты();
	сз_Чаты = Новый СписокЗначений;
	Чаты = Справочники.ГруппыЧата.Выбрать();
	Пока  Чаты.Следующий() Цикл 
		Если Чаты.ПометкаУдаления Тогда 
			Продолжить;
		КонецЕсли;
		
		сз_Чаты.Добавить(Чаты.Ссылка);
	КонецЦикла;
	Возврат сз_Чаты;
КонецФункции

&НаСервере
Процедура ОтправитьУЧатНаСервере(Чат, Телефон)
	
	Текст = Общий.ПолучитьТекстСообщенияВайберДляПрезентации(Объект, Ложь, Телефон);
	
	Менеджер = РегистрыСведений.ИсходящиеСообщения.СоздатьМенеджерЗаписи();
	Менеджер.Получатель = Чат; 
	Менеджер.Дата = ТекущаяДата();
	Менеджер.Уид_Сообщения = Новый УникальныйИдентификатор();
	Менеджер.Повідомлення = Текст;
	Менеджер.Записать();

КонецПроцедуры

&НаКлиенте
Процедура ТоварыЦенаПродажиВесПриИзменении(Элемент)
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	//ТекущиеДанные.ЦенаПродажиВес = Цена;
	ТекущиеДанные.Цена = ТекущиеДанные.ЦенаПродажиВес * ВесХарактеристики(ТекущиеДанные.ХарактеристикаНоменклатуры);
	ТекущиеДанные.Сума = ТекущиеДанные.Цена * ТекущиеДанные.Количество
КонецПроцедуры

