	//Для Каждого Строка Из Объект.Товары Цикл
	//	НовСтрока = ФормаДобавления.ТаблицаВыбора.Добавить();
	//	ЗаполнитьЗначенияСвойств(НовСтрока,Строка);
	//КонецЦикла;
	
	ФормаДобавления.Открыть();
	ЗаписатьПриИзменении(); //intrata_wald_02072021
	
КонецПроцедуры

&НаСервере
Функция ПолучитьТоварыДокумента()
	сз = Новый СписокЗначений;
	Для Каждого Строка Из Объект.Товары Цикл
		сз.Добавить(Строка.Номенклатура);
	КонецЦикла;
	Возврат сз;
КонецФункции



