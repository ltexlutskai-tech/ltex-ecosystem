&НаСервере
Функция  СтворитиОплатуНаСервере()
	ПКО = Документы.КассовыйОрдер.СоздатьДокумент();
	ПКО.Основание = Объект.Ссылка; 
	ПКО.Контрагент = Объект.Ссылка.Контрагент;
	ПКО.КурсEUR = Объект.КурсEUR;
	ПКО.КурсUSD = Объект.КурсUSD;
	
	ПКО.Дата = ТекущаяДата();
	ПКО.Записать();
	Возврат ПКО.Ссылка;
КонецФункции

&НаКлиенте
Процедура СтворитиОплату(Команда)
	Если НЕ ЗначениеЗаполнено(Объект.Ссылка) Тогда
		ЗаписатьНаСервере();	
	КонецЕсли;
	Если ЗначениеЗаполнено(Объект.Ссылка) Тогда 
		
		Если КонтрольОплати(Объект.Сделка) Тогда 
			ПоказатьПредупреждение(,"По даній реалізації вже є оплата!");
			Возврат;
		КонецЕсли;
		
		ОповещениеСоздания 	= Новый ОписаниеОповещения("ОбработатьСозданиеОплаты", ЭтотОбъект);
		ПараметрыЗаполнения = Новый Структура;
		Если ЗначениеЗаполнено(Объект.МаршрутныйЛист) Тогда 
			ПараметрыЗаполнения.Вставить("МаршрутныйЛист", Объект.МаршрутныйЛист);
		Иначе
			ПараметрыЗаполнения.Вставить("МаршрутныйЛист", Неопределено);
		КонецЕсли;
		ПараметрыЗаполнения.Вставить("ЗаказПокупателя",  Объект.Сделка);
		ПараметрыЗаполнения.Вставить("Реализация", Объект.Ссылка);
		ПараметрыЗаполнения.Вставить("Контрагент", Объект.Контрагент);
		ПараметрыЗаполнения.Вставить("СуммаКОплате", Объект.Сума);
		ОткрытьФорму("Обработка.Оплата.Форма", ПараметрыЗаполнения, ВладелецФормы, , , , ОповещениеСоздания);		
		
		//ОткрытьЗначение(СтворитиОплатуНаСервере());
	Иначе 
		Сообщить("Збережіть документ");
	КонецЕсли;
	ЗаписатьПриИзменении(); //intrata_wald_02072021
КонецПроцедуры


