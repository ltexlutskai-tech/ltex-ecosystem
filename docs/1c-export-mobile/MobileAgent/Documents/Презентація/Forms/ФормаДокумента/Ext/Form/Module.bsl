&НаКлиенте
Процедура ДобавитьШКБыстро(Команда)
	ДобавитьШКБыстроКод = Формат(ДобавитьШКБыстро,"ЧДЦ=; ЧГ=0");
	СтруктураТовара = Общий.ПолучитьДанныеТовараПоШК(Строка(ДобавитьШКБыстроКод));
	Если СтруктураТовара = "" Тогда 
		Сообщить("Не найден товар "+ДобавитьШКБыстроКод);
		Возврат;
	КонецЕсли;
	
	УжеВТаблице = 0;
	СтрокиТовара = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура,ХарактеристикаНоменклатуры,ЕдиницаИзмерения",СтруктураТовара.Номенклатура,СтруктураТовара.Характеристика,СтруктураТовара.ЕдиницаИзмерения));
	Для Каждого Строка Из СтрокиТовара Цикл
		УжеВТаблице = УжеВТаблице + Строка.Количество;
	КонецЦикла;
	СтруктураТовара.Вставить("УжеВТаблице",УжеВТаблице);
	
	
	ФормаПодтверждения = ПолучитьФорму("Документ.Презентація.Форма.ФормаПодтверждения",СтруктураТовара,ЭтаФорма);	
	ФормаПодтверждения.Открыть();
	//ДобавитьТовар(СтруктураТовара.Номенклатура,СтруктураТовара.Характеристика,СтруктураТовара.ЕдиницаИзмерения,1,ДобавитьШКБыстроКод);
	ДобавитьШКБыстро = 0;
	
	ЗаписатьПриИзменении(Истина); //intrata_wald_02072021
КонецПроцедуры

