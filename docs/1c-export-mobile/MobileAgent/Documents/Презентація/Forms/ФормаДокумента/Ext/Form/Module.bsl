&НаСервере
Функция ПолучитьСтатусОплаты()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ВложенныйЗапрос.СуммаОборот, 0) КАК СуммаОборот
	|ИЗ
	|	(ВЫБРАТЬ
	|		СУММА(ДенежныеСредстваОбороты.СуммаОборот) КАК СуммаОборот
	|	ИЗ
	|		Документ.КассовыйОрдер КАК КассовыйОрдер
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ДенежныеСредства.Обороты(, , Регистратор, ) КАК ДенежныеСредстваОбороты
	|			ПО КассовыйОрдер.Ссылка = ДенежныеСредстваОбороты.Регистратор
	|	ГДЕ
	|		КассовыйОрдер.Основание = &Основание) КАК ВложенныйЗапрос";
	
	Запрос.УстановитьПараметр("Основание", Объект.Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Статус = "в борг";
	
	Если Выборка.Следующий() Тогда 
		Если Выборка.СуммаОборот >= Объект.Сума Тогда 
			Статус = " по передплаті"
		КонецЕсли;
	КонецЕсли;
	Возврат Статус;
	
КонецФункции


