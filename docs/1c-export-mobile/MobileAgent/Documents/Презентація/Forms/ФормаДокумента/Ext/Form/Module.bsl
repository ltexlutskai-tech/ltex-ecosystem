&НаКлиенте
Процедура ОбработатьСозданиеОплаты(МассивДокументов, Параметры) Экспорт 
	Прочитать();
	Если МассивДокументов <> Неопределено Тогда 
		Попытка
			Если ВладелецФормы.ИмяФормы = "Документ.МаршрутныйЛист.Форма.ФормаДокумента" Тогда    
				ВладелецФормы.ЗаполнитьСозданнуюОплату(МассивДокументов);
			КонецЕсли;
		Исключение
		КонецПопытки;
		
	КонецЕсли;
	
	ЗаписатьПриИзменении();
	
КонецПроцедуры



&НаКлиенте
Процедура ОткритьОплаты(Команда)
	Форма = ПолучитьФорму("Документ.КассовыйОрдер.Форма.ФормаСписка");
	ОтборНастройки = Форма.Список.Отбор;
	Отбор = Форма.Список.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Основание");
	Отбор.Использование = Истина;
	Отбор.ВидСравнения  = ВидСравненияКомпоновкиДанных.Равно;
	Отбор.ПравоеЗначение = Объект.Ссылка;
	Форма.Открыть();
	ЗаписатьПриИзменении(); //intrata_wald_02072021
КонецПроцедуры


