&НаСервере
Функция ПроверитьРекомендации() Экспорт 
	
	СписокРекомендаций = Новый СписокЗначений;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Номенклатура.Ссылка
	               |ИЗ
	               |	Справочник.Номенклатура КАК Номенклатура
	               |ГДЕ
	               |	Номенклатура.Рекомендация";
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура",Выборка.Ссылка)).Количество() = 0 Тогда
			СписокРекомендаций.Добавить(Выборка.Ссылка);
		КонецЕсли;	
	КонецЦикла;
	
	Возврат СписокРекомендаций;
	
КонецФункции

&НаСервере
Процедура ТипЦенПриИзмененииНаСервере()
	
	Для Каждого Строка ИЗ Объект.Товары Цикл
		Строка.ЦенаПродажиВес = Общий.ПолучитьЦенуНоменклатуры(Строка.Номенклатура,Строка.ХарактеристикаНоменклатуры,Объект.ТипЦен);
		Вес = Строка.ХарактеристикаНоменклатуры.Вага;
		Если Вес = 0 Тогда 
			Попытка
				Вес = Число(Строка(Строка.ХарактеристикаНоменклатуры));
			Исключение
				Вес = 20;
			КонецПопытки;
		КонецЕсли;
	
		Строка.Цена = Строка.ЦенаПродажиВес * Вес;
		Строка.Сума = Строка.Цена * Строка.Количество;
	КонецЦикла;

КонецПроцедуры

