&НаКлиенте
Процедура КонтрагентПриИзменении(Элемент)
	Перем ДанныеПроверки;
	
	ЗаповнитиСпосібДоставки();
	ТипЦенКонтрагента = ПолучитьТипЦенКонтрагента(Объект.Контрагент);
	Если ЗначениеЗаполнено(ТипЦенКонтрагента) Тогда 
		Объект.ТипЦен = ТипЦенКонтрагента;
	КонецЕсли;
	Объект.СкладКонтрагента = ПолучитьСкладКонтрагента(Объект.Контрагент);
	Объект.ПершаФорма = Ложь;
	ИнфоБорг();
	Общий.ПоискАктуальныхЗаказов(Объект.Контрагент, ДанныеПроверки);
	
	Если ДанныеПроверки.Свойство("Предупреждение") Тогда 
		Предупреждение(ДанныеПроверки.Предупреждение);
		Если ДанныеПроверки.Свойство("ОткрытьЗакрытиеЗаказа") Тогда 
			форма = ПолучитьФорму("Обработка.ЗакрытиеСтарыхЗаказов.Форма.Форма");
			форма.объект.Контрагент = Объект.Контрагент;
			форма.Открыть();
		ИначеЕсли ДанныеПроверки.Свойство("Заказ") Тогда 
			ОткрытьЗначение(ДанныеПроверки.Заказ);
		КонецЕсли;	
		Модифицированность = Ложь;
		ПодключитьОбработчикОжидания("ЗакрытьФорму", 1, Истина);

	ИначеЕсли ДанныеПроверки.Свойство("Ошибка") Тогда 
		Предупреждение(ДанныеПроверки.Ошибка);
	Иначе
		ЗаписатьПриИзменении();
	КонецЕсли;

	
	//ЗаписатьПриИзменении(); //intrata_wald_02072021
	
КонецПроцедуры

&НаСервере
Процедура ЗаповнитиСпосібДоставки()
