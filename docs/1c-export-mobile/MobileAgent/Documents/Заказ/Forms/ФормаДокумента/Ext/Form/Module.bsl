		//Объект.Доставка = Перечисления.НаявністьДоставки.Доставка;
		Если Объект.Контрагент.СпособДоставки = Справочники.СпособыДоставки.НайтиПоКоду("000000001") Тогда
			Объект.Доставка = Перечисления.НаявністьДоставки.Доставка;
		ИначеЕсли Объект.Контрагент.СпособДоставки = Справочники.СпособыДоставки.НайтиПоКоду("000000004") Тогда
			Объект.Доставка = Перечисления.НаявністьДоставки.Почта;
		ИначеЕсли Объект.Контрагент.СпособДоставки = Справочники.СпособыДоставки.НайтиПоКоду("000000005") Тогда
			Объект.Доставка = Перечисления.НаявністьДоставки.Самовывоз;
		//Иначе
		//	Объект.Доставка = "";
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры


