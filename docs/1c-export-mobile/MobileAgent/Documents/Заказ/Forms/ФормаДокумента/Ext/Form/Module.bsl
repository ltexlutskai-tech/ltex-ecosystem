&НаКлиенте
Процедура ТоварыНоменклатураПриИзменении(Элемент)
	Если Элементы.Товары.ТекущиеДанные.Количество = 0 Тогда 
		Элементы.Товары.ТекущиеДанные.Количество = 1;
	КонецЕсли;	
КонецПроцедуры


&НаКлиенте
Процедура ТоварыКоличествоПриИзменении(Элемент)
	ТекущиеДанные = Элементы.Товары.ТекущиеДанные;
	ТекущиеДанные.Сума = ТекущиеДанные.ЦенаПродажиВес * ТекущиеДанные.Количество;
	ТоварыКоличествоПриИзмененииНаСервере(ТекущиеДанные.Номенклатура, ТекущиеДанные.ХарактеристикаНоменклатуры, ТекущиеДанные.Сума);

КонецПроцедуры

&НаСервере
Процедура ТоварыКоличествоПриИзмененииНаСервере(нНоменклатура, нХарактеристикаНоменклатуры, Сумма)
	Номенклатура = Справочники.Номенклатура.НайтиПоНаименованию(нНоменклатура, Истина);

	нХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.НайтиПоНаименованию(нХарактеристикаНоменклатуры,Истина,,Номенклатура);
	Сумма = нХарактеристикаНоменклатуры.Вага * Сумма
КонецПроцедуры





&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора) Экспорт
	Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Номенклатура") Тогда 
		ШКТовара = Общий.ПолучитьШтрихкодТовара(ВыбранноеЗначение);

		СтруктураТовара = Общий.ПолучитьДанныеТовараПоШК(Строка(ШКТовара));		
		ДобавитьТовар(ВыбранноеЗначение,,СтруктураТовара.ЕдиницаИзмерения,1,СтруктураТовара.Штрихкод,Объект.ТипЦен);
		ФормаДобавления = ПолучитьФорму("Справочник.Номенклатура.ФормаСписка",Новый Структура("РежимВыбора",Истина),ЭтаФорма);
		ФормаДобавления.Открыть();

	ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
		Объект.Коментар = ВыбранноеЗначение;
	Иначе
		Если ВыбранноеЗначение.УИД <> УИДФормы Тогда 
			Возврат;
		КонецЕсли;
		
		Если ВыбранноеЗначение.Количество = 0 Тогда 
			Сообщить("Не хватает остатка: "+ВыбранноеЗначение.Номенклатура+", "+ВыбранноеЗначение.ХарактеристикаНоменклатуры);
			Возврат;
		КонецЕсли;
		ДобавитьТовар(ВыбранноеЗначение.Номенклатура,ВыбранноеЗначение.ХарактеристикаНоменклатуры,ВыбранноеЗначение.ЕдиницаИзмерения,ВыбранноеЗначение.Количество,ВыбранноеЗначение.Штрихкод,Объект.ТипЦен);
		ФормаДобавления = ПолучитьФорму("Справочник.Номенклатура.ФормаСписка",Новый Структура("РежимВыбора",Истина),ЭтаФорма);
		ФормаДобавления.Открыть();
	
	КонецЕсли;
	ЗаписатьПриИзменении(); //intrata_wald_02072021
КонецПроцедуры

&НаКлиенте
Процедура ОбработкаОповещения(ИмяСобытия, Параметр, Источник)
	Если ИмяСобытия = "Подбор" Тогда 
		Если Параметр.УИД <> УИДФормы Тогда 
			Возврат;
		КонецЕсли;

		ВыбранноеЗначение =  Параметр;
		Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Номенклатура") Тогда 
		ШКТовара = Общий.ПолучитьШтрихкодТовара(ВыбранноеЗначение);

		СтруктураТовара = Общий.ПолучитьДанныеТовараПоШК(Строка(ШКТовара));		
		ДобавитьТовар(ВыбранноеЗначение,,СтруктураТовара.ЕдиницаИзмерения,1,СтруктураТовара.Штрихкод,Объект.ТипЦен, Параметр.Цена);
		//Сообщить("Товар додано");

		ИначеЕсли ТипЗнч(ВыбранноеЗначение) = Тип("Строка") Тогда
			Объект.Коментар = ВыбранноеЗначение;
		Иначе		
			Если ВыбранноеЗначение.Количество = 0 Тогда 
				Сообщить("Не хватает остатка: "+ВыбранноеЗначение.Номенклатура+", "+ВыбранноеЗначение.ХарактеристикаНоменклатуры);
				Возврат;
			КонецЕсли;
			ДобавитьТовар(ВыбранноеЗначение.Номенклатура,ВыбранноеЗначение.ХарактеристикаНоменклатуры,ВыбранноеЗначение.ЕдиницаИзмерения,ВыбранноеЗначение.Количество,ВыбранноеЗначение.Штрихкод,Объект.ТипЦен, ВыбранноеЗначение.Цена);
			//Сообщить("Товар додано");
		КонецЕсли;
		
	КонецЕсли;
	
	ЗаписатьПриИзменении(); //intrata_wald_02072021

КонецПроцедуры



