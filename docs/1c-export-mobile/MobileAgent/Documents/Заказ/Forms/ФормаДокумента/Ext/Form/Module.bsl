&НаКлиенте
Процедура ДобавитьШКБыстро(Команда)
	ДобавитьШКБыстроКод = Формат(ДобавитьШКБыстро,"ЧДЦ=; ЧГ=0");
	СтруктураТовара = Общий.ПолучитьДанныеТовараПоШК(Строка(ДобавитьШКБыстроКод));
	Если СтруктураТовара = "" Тогда 
		Сообщить("Не найден товар "+ДобавитьШКБыстроКод);
		Возврат;
	КонецЕсли;
	
	УжеВТаблице = 0;
	СтрокиТовара = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура,ХарактеристикаНоменклатуры,ЕдиницаИзмерения",СтруктураТовара.Номенклатура,СтруктураТовара.Характеристика,СтруктураТовара.ЕдиницаИзмерения));
	Для Каждого Строка Из СтрокиТовара Цикл
		УжеВТаблице = УжеВТаблице + Строка.Количество;
	КонецЦикла;
	СтруктураТовара.Вставить("УжеВТаблице",УжеВТаблице);

	
	ФормаПодтверждения = ПолучитьФорму("Документ.Заказ.Форма.ФормаПодтверждения",СтруктураТовара,ЭтаФорма);	
	ФормаПодтверждения.Открыть();
	//ДобавитьТовар(СтруктураТовара.Номенклатура,СтруктураТовара.Характеристика,СтруктураТовара.ЕдиницаИзмерения,1,ДобавитьШКБыстроКод);
	ДобавитьШКБыстро = 0;
	ЗаписатьПриИзменении(); //intrata_wald_02072021
	ПересчитатьИтогЕвро(); //intrata_wald_02072021
КонецПроцедуры

&НаКлиенте
Процедура ДобавитьТовар(Номенклатура,ХарактеристикаНоменклатуры,ЕдиницаИзмерения,Количество,Штрихкод,ТипЦен,Знач Цена = 0)
	СтрокиТовара = Объект.Товары.НайтиСтроки(Новый Структура("Номенклатура,ХарактеристикаНоменклатуры,ЕдиницаИзмерения",Номенклатура,ХарактеристикаНоменклатуры,ЕдиницаИзмерения,Цена));
	НовСтр = Неопределено;
	Если СтрокиТовара.Количество() Тогда 
		НовСтр = СтрокиТовара[0];
		НовСтр.Количество = НовСтр.Количество + Количество;
		НовСтр.Сума = НовСтр.Количество * НовСтр.Цена;
	Иначе
		НовСтр = Объект.Товары.Добавить();
		НовСтр.Номенклатура = Номенклатура;
		НовСтр.ХарактеристикаНоменклатуры = ХарактеристикаНоменклатуры;
		НовСтр.ЕдиницаИзмерения = ЕдиницаИзмерения;
		Вага = 20;
		Попытка
			Вага = Число(Строка(ХарактеристикаНоменклатуры));
		Исключение
		КонецПопытки;
		Если Вага > 900 Тогда 
			Вага = 20;
		КонецЕсли;
		
		НовСтр.Количество = Количество;
		НовСтр.Штрихкод = Штрихкод;
		Если Цена > 0 Тогда 
			НовСтр.ЦенаПродажиВес = Цена;
			НовСтр.Цена = Цена * Вага;
		Иначе
			НовСтр.ЦенаПродажиВес = Общий.ПолучитьЦенуНоменклатуры(Номенклатура,ХарактеристикаНоменклатуры,ТипЦен);
			
			НовСтр.Цена = НовСтр.ЦенаПродажиВес * Вага;
		КонецЕсли;
		НовСтр.Сума = Количество * НовСтр.Цена;
	КонецЕсли;
	
КонецПроцедуры

