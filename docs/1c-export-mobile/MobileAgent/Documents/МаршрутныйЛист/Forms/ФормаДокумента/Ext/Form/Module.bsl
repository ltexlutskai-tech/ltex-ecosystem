&НаКлиенте
Процедура ОтправитьКонтрагенту(Команда)
	ТекущиеДанные = Элементы.Реализации.ТекущиеДанные;
	НомераТелефонов = ТелефонКонтрагента(ТекущиеДанные.Контрагент);
	Если НомераТелефонов.Количество() > 1 Тогда 
		ВыбрЗнач = НомераТелефонов.ВыбратьЭлемент("Номер телефона клієнта");
		Если ВыбрЗнач = Неопределено Тогда 
			Возврат;
		КонецЕсли;
		Телефон = ВыбрЗнач.Значение;
	ИначеЕсли  НомераТелефонов.Количество() = 1 Тогда 
		Телефон = НомераТелефонов[0].Значение;
	КонецЕсли;
	
	НовВз 				= Новый ЗапускПриложенияМобильногоУстройства();
	НовВз.Действие 		= "android.intent.action.SEND";
	НовВз.Приложение 	= "com.viber.voip"; 
	НовВз.ИмяКласса 	= "com.viber.voip.WelcomeShareActivity"; 
	НовВз.Тип 			= "text/plain";
	НовВз.ДополнительныеДанные.Добавить("android.intent.extra.TEXT", Общий.ПолучитьТекстСообщенияВайбер(Элементы.Реализации.ТекущиеДанные.Реализация, Истина, Телефон));
	
	НовВз.Запустить(Истина);
	
КонецПроцедуры



