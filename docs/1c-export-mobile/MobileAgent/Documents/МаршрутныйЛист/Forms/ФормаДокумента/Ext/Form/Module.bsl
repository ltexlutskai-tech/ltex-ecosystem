&НаКлиенте
Функция ОпределитьСуммуКОплате(Сумма, Реализация)
	
	СуммаКОплате = Сумма;
	
	Для Каждого СтрОплата Из Объект.Оплаты Цикл
		Если СтрОплата.Реализация = Реализация Тогда 
			СуммаКОплате = СуммаКОплате - СтрОплата.Сумма;
		КонецЕсли;	
	КонецЦикла;	
	
	Возврат СуммаКОплате;
	
КонецФункции	

&НаСервереБезКонтекста
Функция СуммаОрдера(ЭлементМассива)
	
	Результат = 0;
	Если ЭлементМассива.ВидДвиженияДенежныхСредств = Перечисления.ВидДвиженияДенежныхСредств.Приход Тогда 
		Результат = ЭлементМассива.СуммаДокумента;
	Иначе 	
		Результат = ЭлементМассива.СуммаДокумента * (-1) ;
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции	

