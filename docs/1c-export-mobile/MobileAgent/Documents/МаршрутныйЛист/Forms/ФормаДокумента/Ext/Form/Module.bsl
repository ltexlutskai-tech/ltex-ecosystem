&НаСервере
Функция ОплатаРеализации(Реализация)
	
	ДокументОплаты = Документы.КассовыйОрдер.ПустаяСсылка();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	КассовыйОрдер.Ссылка КАК Ссылка
	|ИЗ
	|	Документ.КассовыйОрдер КАК КассовыйОрдер
	|ГДЕ
	|	КассовыйОрдер.Основание = &Основание
	|	И КассовыйОрдер.Проведен";
	Запрос.УстановитьПараметр("Основание", Реализация);
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ДокументОплаты = Выборка.Ссылка;
	КонецЕсли;	
	
	Возврат ДокументОплаты;
	
КонецФункции

