&НаКлиенте
Процедура ОбработкаСканирования(Штрихкод, Результат, Сообщение, ДополнительныеПараметры) Экспорт
	Перем ТекстСообщения;
	
	#Если МобильноеПриложениеКлиент Тогда
		СредстваМультимедиа.ЗакрытьСканированиеШтрихКодов();
	#КонецЕсли

	ТипЦен = ПолучитьТипЦен();
	СтруктураТовара = Общий.ПолучитьДанныеТовараПоШК(СокрЛП(Штрихкод), ТипЦен);
	Если СтруктураТовара = "" Тогда 
		Сообщить("Не найден товар " + Штрихкод);
		Возврат;
	КонецЕсли;
	
	Если АктивнаБроньМішка(СтруктураТовара.Характеристика,  ТекстСообщения) Тогда 
		Сообщить(ТекстСообщения);
		Возврат;
	КонецЕсли;
	
	ДобавитьТовар(СтруктураТовара.Номенклатура, СтруктураТовара.Характеристика, СтруктураТовара.ЕдиницаИзмерения, 1, СокрЛП(Штрихкод), ТипЦен);

КонецПроцедуры

&НаСервере
Функция АктивнаБроньМішка(Мішок, Текст)
	Если ПустаяСтрока(Мішок.ВерсияДанных) Тогда 
		Возврат Ложь;
	КонецЕсли;
	
	Текст = "Активна бронь мішка до " + Формат(Мішок.ПериодБрони,  "ДФ=dd.MM.yyyy /")  + Мішок.Бронь; 
	Возврат Мішок.ПериодБрони > ТекущаяДата() И Не Мішок.МояБронь 
	
КонецФункции
	
&НаКлиенте
Процедура ДобавитьТовар(Номенклатура, ХарактеристикаНоменклатуры, ЕдиницаИзмерения, Количество, Штрихкод, ТипЦен, Знач Цена = 0)
	
	СтрокиТовара 	= Объект.ЗагрузкаМашины.НайтиСтроки(Новый Структура("Номенклатура, ХарактеристикаНоменклатуры", Номенклатура, ХарактеристикаНоменклатуры));
	НовСтр 			= Неопределено;
	Если СтрокиТовара.Количество() Тогда 
		Сообщить("Товар уже добавлен!");
		Возврат;
	Иначе
		НовСтр 								= Объект.ЗагрузкаМашины.Добавить();
		НовСтр.Номенклатура 				= Номенклатура;
		НовСтр.ХарактеристикаНоменклатуры 	= ХарактеристикаНоменклатуры;
		НовСтр.ЕдиницаИзмерения 			= ЕдиницаИзмерения;
		Вес 								= 20;
		Попытка
			Вес 							= Число(Строка(ХарактеристикаНоменклатуры));
		Исключение
		КонецПопытки;
		НовСтр.Количество 					= Количество;
		НовСтр.Вес 							= Вес;
		НовСтр.Штрихкод 					= Штрихкод;
		Если Цена > 0 Тогда 
			НовСтр.ЦенаПродажиВес 			= Цена;
			НовСтр.Цена 					= Цена * Вес;
		Иначе
			НовСтр.ЦенаПродажиВес 			= Общий.ПолучитьЦенуНоменклатуры(Номенклатура, ХарактеристикаНоменклатуры, ТипЦен);
			НовСтр.Цена 					= НовСтр.ЦенаПродажиВес * Вес;
		КонецЕсли;
		НовСтр.Сумма 						= Количество * НовСтр.Цена;
		СтрокиВЗаказах 	= Объект.ТоварыЗаказов.НайтиСтроки(Новый Структура("Номенклатура, ХарактеристикаНоменклатуры", Номенклатура, ХарактеристикаНоменклатуры));
		Если СтрокиВЗаказах.Количество() Тогда 
			НовСтр.ЗаказПокупателя 			= СтрокиВЗаказах[0].ЗаказПокупателя;	
			НовСтр.Контрагент 				= СтрокиВЗаказах[0].Контрагент;	
		КонецЕсли;			
	КонецЕсли;
	
КонецПроцедуры

