&НаКлиенте
Процедура УдалитьТоварЗаказа(ТекущийЗаказ)
	
	// Товары
	МассивНаУдаление = Новый Массив;
	Для Каждого СтрТЧ Из Объект.ТоварыЗаказов Цикл 
		Если СтрТЧ.ЗаказПокупателя = ТекущийЗаказ Тогда 
			МассивНаУдаление.Добавить(СтрТЧ);
		КонецЕсли;	
	КонецЦикла;	
	Для Каждого ЭлементМассива Из МассивНаУдаление Цикл 
		Объект.ТоварыЗаказов.Удалить(ЭлементМассива);
	КонецЦикла;		
	
	// Реализации
	МассивНаУдаление = Новый Массив;
	Для Каждого СтрТЧ Из Объект.Реализации Цикл 
		Если СтрТЧ.ЗаказПокупателя = ТекущийЗаказ Тогда 
			МассивНаУдаление.Добавить(СтрТЧ);
		КонецЕсли;	
	КонецЦикла;	
	Для Каждого ЭлементМассива Из МассивНаУдаление Цикл 
		Объект.Реализации.Удалить(ЭлементМассива);
	КонецЦикла;			
	
	// Продажи
	МассивНаУдаление = Новый Массив;
	Для Каждого СтрТЧ Из Объект.Продажи Цикл 
		Если СтрТЧ.ЗаказПокупателя = ТекущийЗаказ Тогда 
			МассивНаУдаление.Добавить(СтрТЧ);
		КонецЕсли;	
	КонецЦикла;	
	Для Каждого ЭлементМассива Из МассивНаУдаление Цикл 
		Объект.Продажи.Удалить(ЭлементМассива);
	КонецЦикла;				
	
	// Оплаты
	МассивНаУдаление = Новый Массив;
	Для Каждого СтрТЧ Из Объект.Оплаты Цикл 
		Если СтрТЧ.ЗаказПокупателя = ТекущийЗаказ Тогда 
			МассивНаУдаление.Добавить(СтрТЧ);
		КонецЕсли;	
	КонецЦикла;	
	Для Каждого ЭлементМассива Из МассивНаУдаление Цикл 
		Объект.Оплаты.Удалить(ЭлементМассива);
	КонецЦикла;					
	
	ЗаписатьПриИзменении();	
	
КонецПроцедуры	

&НаКлиенте
Процедура УдалитьДанныеРеализации(ТекущийДокумент, Оплаты = Неопределено)
	
	// Продажи
	МассивНаУдаление = Новый Массив;
	Для Каждого СтрТЧ Из Объект.Продажи Цикл 
		Если СтрТЧ.Реализация = ТекущийДокумент Тогда 
			МассивНаУдаление.Добавить(СтрТЧ);
		КонецЕсли;	
	КонецЦикла;	
	Для Каждого ЭлементМассива Из МассивНаУдаление Цикл 
		Объект.Продажи.Удалить(ЭлементМассива);
	КонецЦикла;				
	
	// Оплаты  
	Оплаты = Новый Массив;
	МассивНаУдаление = Новый Массив;
	Для Каждого СтрТЧ Из Объект.Оплаты Цикл 
		Если СтрТЧ.Реализация = ТекущийДокумент Тогда 
			
			МассивНаУдаление.Добавить(СтрТЧ);
		КонецЕсли;	
	КонецЦикла;	
	Для Каждого ЭлементМассива Из МассивНаУдаление Цикл 
		Объект.Оплаты.Удалить(ЭлементМассива);
	КонецЦикла;					
	
КонецПроцедуры	

&НаСервере
Процедура ТоварыЗаказа(Заказ, Контрагент)
	
	ТЗТовары = Заказ.Товары.Выгрузить();
	Для Каждого СтрТЗ Из ТЗТовары Цикл 
		НоваяСтрока 					= Объект.ТоварыЗаказов.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрТЗ);
		НоваяСтрока.ЗаказПокупателя 	= Заказ;
		НоваяСтрока.Контрагент 			= Контрагент;
		НоваяСтрока.Сумма 				= СтрТЗ.Сума;
	КонецЦикла;		

КонецПроцедуры

&НаКлиенте
Процедура ОбновитьДеревоТоваров() 
	
	ОбновитьДеревоТоваровНаСервере();
	РазвернутьДерево()
	
КонецПроцедуры	

&НаСервере
Процедура ОбновитьДеревоТоваровНаСервере() 
	
	ТЗТовары = Объект.ТоварыЗаказов.Выгрузить();
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Товары.ЗаказПокупателя КАК ЗаказПокупателя,
	|	Товары.Контрагент КАК Контрагент,
	|	Товары.Номенклатура КАК Номенклатура,
	|	Товары.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	|	Товары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	Товары.Количество КАК Количество,
	|	Товары.Цена КАК Цена,
	|	Товары.Сумма КАК Сумма
	|ПОМЕСТИТЬ ВТТовары
	|ИЗ
	|	&Товары КАК Товары
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТТовары.ЗаказПокупателя КАК ЗаказПокупателя,
	|	ВТТовары.Контрагент КАК Контрагент,
	|	ВТТовары.Номенклатура КАК Номенклатура,
	|	ВТТовары.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	|	ВТТовары.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	|	ВТТовары.Количество КАК Количество,
	|	ВТТовары.Цена КАК Цена,
	|	ВТТовары.Сумма КАК Сумма
	|ИЗ
	|	ВТТовары КАК ВТТовары
	|ИТОГИ
	|	СУММА(Количество),
	|	СУММА(Сумма)
	|ПО
	|	ЗаказПокупателя";
	Запрос.УстановитьПараметр("Товары", ТЗТовары);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		Дерево = РезультатЗапроса.Выгрузить(ОбходРезультатаЗапроса.ПоГруппировкам);
		ЗначениеВРеквизитФормы(Дерево, "ДеревоТоваров");
	КонецЕсли;	
	
КонецПроцедуры	

