	ТоварыЗаказа(ТекущийЗаказ, ТекущийКонтрагент);
	
	ОбновитьДеревоТоваров();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбработатьСозданиеЗаказа(РезультатЗакрытия, ДополнительныеПараметры) Экспорт 
	Если ЗначениеЗаполнено(РезультатЗакрытия) Тогда 
		
		НоваяСтрока = Объект.Заказы.Добавить();
		НоваяСтрока.ЗаказПокупателя = РезультатЗакрытия;
		НоваяСтрока.Город = ПолучитьГородКонтрагента(РезультатЗакрытия);
		НоваяСтрока.Контрагент = КонтрагентЗаказа(РезультатЗакрытия);
		Элементы.Заказы.ТекущаяСтрока = НоваяСтрока.НомерСтроки - 1; 

		ЗаказыЗаказПокупателяПриИзменении(НоваяСтрока);
		ЗаписатьПриИзменении();
	КонецЕсли;
	
КонецПроцедуры

