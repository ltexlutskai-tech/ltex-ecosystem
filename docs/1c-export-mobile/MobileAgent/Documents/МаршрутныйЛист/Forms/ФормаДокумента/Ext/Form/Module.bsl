	ИначеЕсли  НомераТелефонов.Количество() = 1 Тогда 
		Телефон = НомераТелефонов[0].Значение;
	КонецЕсли;
	
	Общий.ОбновитьСумаОплатиНаложкою(Элементы.Реализации.ТекущиеДанные.Реализация);

	Сообщить(Общий.ПолучитьТекстСообщенияВайбер(Элементы.Реализации.ТекущиеДанные.Реализация, Истина, Телефон));
	

