&НаКлиенте
Процедура ОбработатьСозданиеРеализации(ДокументСоздан, Параметры) Экспорт 
	
	
	
	//ТекущийЭлемент 						= Элементы.Реализации;
	НоваяСтрока 						= Объект.Реализации.Добавить();
	НоваяСтрока.ЗаказПокупателя			= ПолучитьРеквизитОбъекта(ДокументСоздан, "Сделка");
	НоваяСтрока.Реализация = ДокументСоздан;
	НоваяСтрока.Контрагент 				= КонтрагентЗаказа(ДокументСоздан);
			
	
	Если КонтрагентЗаказа(НоваяСтрока.Реализация) <> КонтрагентЗаказа(НоваяСтрока.ЗаказПокупателя) Тогда 
		НоваяСтрока.ЗаказПокупателя = ПолучитьПустойЗаказ();
	КонецЕсли;
	
	
	ПроданныеТовары(НоваяСтрока.Реализация, НоваяСтрока.ЗаказПокупателя, НоваяСтрока.Контрагент);
	ТекущийЭлемент.ТекущаяСтрока 		= Объект.Реализации.Количество() - 1;

	Элементы.Реализации.Обновить();

	ЗаписатьПриИзменении();
	
КонецПроцедуры

