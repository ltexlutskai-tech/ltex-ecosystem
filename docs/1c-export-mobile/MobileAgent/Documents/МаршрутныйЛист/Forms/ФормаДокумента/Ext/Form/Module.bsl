Процедура РеализацииПередУдалением(Элемент, Отказ)
	Перем Ответ;
	ОбъектыНаУдаление = Новый Массив;
	
	КодОтвета = Вопрос("При видаленні Реалізації з маршрутника, документ видаляється фізично. Також видаляться оплати повязані з ним. Ви скинули всі документи по обміну? Видалити документи фізично?", РежимДиалогаВопрос.ДаНет);
	Если Не КодОтвета = КодВозвратаДиалога.Да Тогда 
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	
	ТекущийДокумент = Элементы.Реализации.ТекущиеДанные.Реализация;
	Если ЗначениеЗаполнено(ТекущийДокумент) И Лев(ТекущийДокумент, 3) <> "<Об" Тогда  
		Строки = Объект.Оплаты.НайтиСтроки(Новый Структура("Реализация", ТекущийДокумент)); 
		ОбъектыНаУдаление.Добавить(ТекущийДокумент);
		Для Каждого мЭлемент Из  Строки Цикл 
			ОбъектыНаУдаление.Добавить(мЭлемент.Оплата);
		КонецЦикла;
		
		
		УдалитьНепосредственно(ОбъектыНаУдаление, Ответ);
		
		Если Ответ.Отказ Тогда
			ПоказатьПредупреждение(,Ответ.Сообщение);
			Отказ = Истина;
			Возврат;
		КонецЕсли;
	КонецЕсли;

	УдалитьДанныеРеализации(ТекущийДокумент);
	
КонецПроцедуры

