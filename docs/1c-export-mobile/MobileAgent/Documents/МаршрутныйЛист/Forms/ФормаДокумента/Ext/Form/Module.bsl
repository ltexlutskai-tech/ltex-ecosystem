&НаКлиенте
Процедура СтраницыПриСменеСтраницы(Элемент, ТекущаяСтраница)
	
	Если ТекущаяСтраница.Имя = "ГруппаТоварыЗаказов" Тогда 
		ИдентификаторТекСтроки 					= Элементы.ДеревоТоваров.ТекущаяСтрока;
		Элементы.ДеревоТоваров.ТекущаяСтрока 	= Неопределено;
		КоллекцияЭлементовДерева 				= ДеревоТоваров.ПолучитьЭлементы();
		Для Каждого Строка Из КоллекцияЭлементовДерева Цикл
			ИдентификаторСтроки 				= Строка.ПолучитьИдентификатор();
			Элементы.ДеревоТоваров.Развернуть(ИдентификаторСтроки, Истина);
		КонецЦикла;
		Элементы.ДеревоТоваров.ТекущаяСтрока 	= ИдентификаторТекСтроки;
	КонецЕсли;	
	
КонецПроцедуры

