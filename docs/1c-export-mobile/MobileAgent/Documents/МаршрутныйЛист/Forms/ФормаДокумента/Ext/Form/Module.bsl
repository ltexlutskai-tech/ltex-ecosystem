&НаСервереБезКонтекста
Функция КонтрольРеализации(Параметры)
	 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.Сделка = &Сделка
		|	И РеализацияТоваровУслуг.МаршрутныйЛист = &МаршрутныйЛист";
	
	Запрос.УстановитьПараметр("МаршрутныйЛист", Параметры.МаршрутныйЛист);   
	Запрос.УстановитьПараметр("Сделка", Параметры.Сделка);
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат Выборка.Следующий();	
	
КонецФункции

&НаСервереБезКонтекста
Функция КонтрольОплати(Данные)
	
	
	Если Не ЗначениеЗаполнено(Данные.ЗаказПокупателя) 
		И Не  ЗначениеЗаполнено(Данные.Основание) Тогда 
		Возврат Ложь;
	КонецЕсли;

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КассовыйОрдер.Ссылка КАК Ссылка
		|ИЗ
		|	Документ.КассовыйОрдер КАК КассовыйОрдер
		|ГДЕ
		|	КассовыйОрдер.ЗаказПокупателя = &ЗаказПокупателя
		|	И КассовыйОрдер.Основание = &Основание";
	
	Запрос.УстановитьПараметр("ЗаказПокупателя", Данные.ЗаказПокупателя);
	Запрос.УстановитьПараметр("Основание", Данные.Основание);
	Выборка = Запрос.Выполнить().Выбрать();
	Возврат Выборка.Следующий();

КонецФункции

&НаСервереБезКонтекста
Процедура УдалитьНепосредственно(МассивОбъектов, Ответ)
	Ответ = Новый Структура("Отказ", Ложь);
	НачатьТранзакцию();
	Для Каждого ОбъектСсылка Из МассивОбъектов Цикл
		
		Если Не ЗначениеЗаполнено(ОбъектСсылка) Тогда 
			Продолжить;
		КонецЕсли;
		
		
		Если ОбъектСсылка.Архив Или ОбъектСсылка.В_1с Тогда 
			Ответ.Вставить("Отказ", Истина);
			Ответ.Вставить("Сообщение", "Документ " + ОбъектСсылка + " синхронізований з 1С!");
			ОтменитьТранзакцию();
			Возврат;
		КонецЕсли;
		Попытка
			ОбъектСсылка.ПолучитьОбъект().Удалить();
		Исключение
			Ответ.вставить("Отказ", Истина);
			Ответ.Вставить("Сообщение", ОписаниеОшибки());
			ОтменитьТранзакцию();
			Возврат;
		КонецПопытки;
	КонецЦикла;
	
	ЗафиксироватьТранзакцию();
КонецПроцедуры

&НаКлиенте
Процедура ОплатыПередУдалением(Элемент, Отказ)
	Перем Ответ;
	ОбъектыНаУдаление = Новый Массив;
	
	КодОтвета = Вопрос("Видалити документ фізично?", РежимДиалогаВопрос.ДаНет);
	Если Не КодОтвета = КодВозвратаДиалога.Да Тогда 
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	ОбъектыНаУдаление.Добавить(Элемент.ТекущиеДанные.Оплата);
	УдалитьНепосредственно(ОбъектыНаУдаление, Ответ);
	
	Если Ответ.Отказ Тогда
		ПоказатьПредупреждение(,Ответ.Сообщение);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	

КонецПроцедуры

