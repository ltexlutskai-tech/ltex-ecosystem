&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(Объект.Основание)  Тогда
		Если НЕ ЗначениеЗаполнено(Объект.КурсEUR) Тогда 
			Объект.КурсEUR = Константы.КурсEUR.Получить();
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(Объект.КурсUSD) Тогда
			Объект.КурсUSD = Константы.КурсUSD.Получить();
		КонецЕсли;
		
		Если Не (ЗначениеЗаполнено(Объект.КурсEUR) 
			И ЗначениеЗаполнено(Объект.КурсUSD)) Тогда  
			Сообщить("Виконайте обмін, не заповнені курси валют");
			Отказ = Истина;
		КонецЕсли;
	КонецЕсли;

	Если Параметры.Свойство("МаршрутныйЛист") Тогда
		Объект.Основание 		= Параметры.Основание;
		Объект.Контрагент 		= Параметры.Контрагент;
		Объект.МаршрутныйЛист 	= Параметры.МаршрутныйЛист;
		Объект.ЗаказПокупателя 	= Параметры.ЗаказПокупателя;
	КонецЕсли;	
	
	Если Объект.ВидДвиженияДенежныхСредств = Перечисления.ВидДвиженияДенежныхСредств.Приход Тогда
		Элементы.СтатьяДвиженияДенежныхСредств.Видимость = Ложь;
		Элементы.Контрагент.Видимость = Истина; 
	Иначе	
		Элементы.СтатьяДвиженияДенежныхСредств.Видимость = Истина;
		Элементы.Контрагент.Видимость = Ложь; 
	КонецЕсли;	
	
КонецПроцедуры

&НаСервере
Процедура РекомендацииПоОплате()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(ВложенныйЗапрос.СуммаОборот, 0) КАК СуммаОборот
		|ИЗ
		|	(ВЫБРАТЬ
		|		СУММА(ДенежныеСредстваОбороты.СуммаОборот) КАК СуммаОборот
		|	ИЗ
		|		Документ.КассовыйОрдер КАК КассовыйОрдер
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ДенежныеСредства.Обороты(, , Регистратор, ) КАК ДенежныеСредстваОбороты
		|			ПО КассовыйОрдер.Ссылка = ДенежныеСредстваОбороты.Регистратор
		|	ГДЕ
		|		КассовыйОрдер.Основание = &Основание
		|		И КассовыйОрдер.Ссылка <> &Ссылка) КАК ВложенныйЗапрос";
	
	Запрос.УстановитьПараметр("Основание", Объект.Основание);
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);

	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда 	
		ОплаченаСума = Выборка.СуммаОборот;
	КонецЕсли;	
	
	СумаUAHПриИзмененииНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Если ВладелецФормы = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	Попытка
		Если ВладелецФормы.Имя = "ОплатыОплата" Тогда 
			ВладелецФормы.Родитель.ТекущиеДанные.Оплата 			= Объект.Ссылка;
			ВладелецФормы.Родитель.ТекущиеДанные.Сумма 				= Объект.СуммаДокумента;
		ИначеЕсли ВладелецФормы.Имя = "ОплатыСумма" Тогда 	
			ВладелецФормы.Родитель.ТекущиеДанные.Сумма 				= Объект.СуммаДокумента;
		КонецЕсли;	
	Исключение
	КонецПопытки;
	
КонецПроцедуры

