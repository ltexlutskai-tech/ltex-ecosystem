Функция  ТелефонКонтрагента() 
	СЗ = Новый СписокЗначений();
	НомерТелефона = Объект.Контрагент.НомерТелефона;
	Если Не ПустаяСтрока(НомерТелефона) Тогда 
		Для Н=1 по СтрЧислоСтрок(НомерТелефона) Цикл
			СЗ.Добавить(СтрПолучитьСтроку(НомерТелефона, Н));
		КонецЦикла;
	КонецЕсли;
	
	Возврат СЗ;	
