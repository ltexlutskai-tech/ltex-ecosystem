	если не  ДозволитиЗакритяФорми тогда 
		отказ = истина;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатиНаСервере()
Запис = РегистрыСведений.Кілометраж.СоздатьМенеджерЗаписи();
запис.Кілометраж = Кілометри;
Запис.Период = Период;
запис.СтатусДня = СтатусДня;
Запис.Записать();
ДозволитиЗакритяФорми = Истина;
КонецПроцедуры

&НаКлиенте
Процедура Записати(Команда)
	Если Не Кілометри Тогда 
		Возврат;
	КонецЕсли;
	Если Не ЕстьПароль() Тогда 
		Предупреждение("Введіть пароль та зробіть обмін");
		Возврат;
	КонецЕсли;
	
	
	ЗаписатиНаСервере();
	Закрыть();
КонецПроцедуры

