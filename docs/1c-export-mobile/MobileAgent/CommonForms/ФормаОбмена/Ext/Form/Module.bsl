
&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если УспешноеНачалоОбмена Тогда 
		Возврат;
	КонецЕсли;
	
	Обмен_УправлениеОбменом.Лог("СбросЛога",1);
	Обмен_УправлениеОбменом.Лог("Форма. ВыполнитьОбмен","A");
	Попытка
		//ПодключитьОбработчикОжидания("ОбновитьПрогрес",3,Ложь);
		Обмен_УправлениеОбменом.Лог("Форма. ВыполнитьОбмен1","F");
		ВыполнитьОбмен();
		Обмен_УправлениеОбменом.Лог("Форма. ВыполнитьОбмен2","G");
	Исключение
		Обмен_УправлениеОбменом.Лог("Форма. ВыполнитьОбмен3","H");
		ПоказатьПредупреждение(Новый ОписаниеОповещения("ЗакрытьФорму",ЭтаФорма), ОписаниеОшибки(),0,"Выполнение обмена");
	КонецПопытки;
	Обмен_УправлениеОбменом.Лог("Форма. ВыполнитьОбмен4","I");
	//Ошибка = Обмен_УправлениеОбменом.ВыполнитьОбменДанными();
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОбмен(СбрасыватьОбмен = Истина)
	
	Если Общий.АвтообмінВключений() Тогда
		
		Возврат;
	КонецЕсли;
	
	
	Если СбрасыватьОбмен Тогда 
		УспешноеНачалоОбмена = Ложь;
		ОтключитьЗапускОбменаПриСтарте();
	КонецЕсли;
	 УстановитьКонстантыНоль();
	//Константы.ОшибкаОбмена.Установить("");
	//ФЗ = ФоновыеЗадания.Выполнить("Обмен_УправлениеОбменом.ВыполнитьОбменДанными");
	//ФЗУИД = ФЗ.УникальныйИдентификатор;
	//Обмен_УправлениеОбменом.ВыполнитьОбменДанными();
	ПодключитьОбработчикОжидания("ВыполнитьОбменНапрямую",1,Истина);
КонецПроцедуры

&НаКлиенте
Процедура ВыполнитьОбменНапрямую()
	Если РежимВыполненияОбмена = 1 Тогда   // Частковий обмін
		Обмен_УправлениеОбменом.ВыполнитьОбменДанными();	
	ИначеЕсли  РежимВыполненияОбмена = 2 Тогда  // Повний обмін 	
		Обмен_УправлениеОбменом.ВыполнитьОбменДаннымиВыгрузкаЗаказов();
		Обмен_УправлениеОбменом.ВыполнитьОбменДанными(Ложь);
		Обмен_УправлениеОбменом.ОновитиЗалишкиТаЦіни();
	ИначеЕсли  РежимВыполненияОбмена = 3 Тогда  // Оновити ціни
		Обмен_УправлениеОбменом.ОновитиЗалишкиТаЦіни(); // Обмен_УправлениеОбменом.ОновитиЗалишкиТаЦіни(Истина); 
	ИначеЕсли  РежимВыполненияОбмена = 4 Тогда  // Вивантажити документи
		Обмен_УправлениеОбменом.ВыполнитьОбменДаннымиВыгрузкаЗаказов(); 
		Обмен_УправлениеОбменом.ВыполнитьОбменДаннымиВыгрузкаЗаказов();  
	ИначеЕсли  РежимВыполненияОбмена = 5 Тогда  // Завантажити товари
		Обмен_УправлениеОбменом.ВыполнитьОбменДаннымиЗагрузкаТоварів();
	ИначеЕсли  РежимВыполненияОбмена = 6 Тогда  // Завантажити контрагентів
		Обмен_УправлениеОбменом.ВыполнитьОбменДаннымиЗагрузкаКонтрагентів();
	ИначеЕсли  РежимВыполненияОбмена = 7 Тогда  // Завантажити документи
		Обмен_УправлениеОбменом.ВыполнитьОбменДаннымиЗагрузкаДокументів();
	ИначеЕсли  РежимВыполненияОбмена = 8 Тогда  // Завантажити документи
		Обмен_УправлениеОбменом.ЗавантажитиКурсиВалют();

	КонецЕсли;
	ОбновитьПрогрес();
	УстановитьЗаголовокПриложения("Обмін: "+ТекущаяДата());
КонецПроцедуры


