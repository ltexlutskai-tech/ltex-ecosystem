			Оповестить("СобытиеОбновленДолг");
			//МассивОшибок = СтруктураСостоянияОбмена.МассивОшибок;
			//Для Каждого Элемент Из МассивОшибок Цикл
			//	
			//	Ошибка = Ошибка + " " + Элемент;
			//	
			//КонецЦикла;
			//УстановитьОшибку(Ошибка);
			
			УстановитьКонстантыНоль();
			Если ЗначениеЗаполнено(Ошибка) Тогда 
				//ПоказатьПредупреждение(Новый ОписаниеОповещения("ЗакрытьФорму",ЭтаФорма), Ошибка + "После закрытия окна сообщения обмен будет продолжен.",20,"Выполнение обмена");
