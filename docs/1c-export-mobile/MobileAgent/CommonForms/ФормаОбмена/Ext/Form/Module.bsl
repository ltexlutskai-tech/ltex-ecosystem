&НаСервере
Функция ПолучитьСостоянеОбмена()
	ФЗ = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ФЗУИД);
	НовСтруктура = Новый Структура;
	Если ФЗ = Неопределено Тогда 
		НовСтруктура.Вставить("Активен", Ложь);
		НовСтруктура.Вставить("МассивОшибок", Новый Массив);
	Иначе	
		НовСтруктура.Вставить("Активен", ФЗ.Состояние = СостояниеФоновогоЗадания.Активно);
		НовСтруктура.Вставить("МассивОшибок", ФЗ.ПолучитьСообщенияПользователю());
	КонецЕсли;
	Возврат НовСтруктура;
КонецФункции


&НаКлиенте
Процедура ЗакрытьФорму(Параметр) Экспорт
	Обмен_УправлениеОбменом.Лог("Форма. Закрыть Форму","Z");
	ОтключитьОбработчикОжидания("ОбновитьПрогрес");
	ОтключитьЗапускОбменаПриСтарте();
	Прогрес = 100;
	Закрыть();
КонецПроцедуры

&НаКлиенте
Процедура ПродолжитьОбмен(Параметр) Экспорт
	Элементы.ДекорацияОбмен.Заголовок = "Продовження обміну...";
	ВыполнитьОбмен(Ложь);
	Обмен_УправлениеОбменом.Лог("Форма. Подключения обработчика Обновления","A");
	//ПодключитьОбработчикОжидания("ОбновитьПрогрес",3,Ложь);
КонецПроцедуры



&НаСервереБезКонтекста
Процедура УстановитьКонстантыНоль()
	Константы.ПроцентОбмена.Установить(0);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОтключитьЗапускОбменаПриСтарте()
	Константы.ОбменВыполняется.Установить(Ложь);
	
КонецПроцедуры


&НаСервереБезКонтекста
Процедура УстановитьЧастичныйОбмен()	
	Константы.ЭтоНеПервыйОбмен.Установить(Истина);
КонецПроцедуры


&НаСервереБезКонтекста
Функция ПолучитьТекущийПрогрес()
	Возврат Константы.ПроцентОбмена.Получить();
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьОшибку()
	Возврат Константы.ОшибкаОбмена.Получить();
КонецФункции

&НаСервереБезКонтекста
Функция УстановитьОшибку(Ошибка)
	Константы.ОшибкаОбмена.Установить(Ошибка);
КонецФункции


&НаСервереБезКонтекста
Функция ПолучитьОбменВыполняется()
	Возврат Константы.ОбменВыполняется.Получить();
КонецФункции


&НаКлиенте
Процедура ПередЗакрытием(Отказ, СтандартнаяОбработка)
	Если Прогрес < 100 Тогда 
		Отказ = Истина;
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	РежимВыполненияОбмена = Параметры.РежимВыполненияОбмена;
КонецПроцедуры




