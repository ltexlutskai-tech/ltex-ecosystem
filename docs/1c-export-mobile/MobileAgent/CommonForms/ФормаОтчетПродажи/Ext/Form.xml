				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ПродажиОбороты.Период КАК Дата,
	ПродажиОбороты.Регистратор.Номер КАК Номер,
	СУММА(ПродажиОбороты.ЦенаПартнераОборот * ПродажиОбороты.КоличествоОборот) КАК СуммаПартнера,
	СУММА(ПродажиОбороты.ЦенаОборот * ПродажиОбороты.КоличествоОборот) КАК СуммаПродажи,
	СУММА(ПродажиОбороты.ЦенаОборот * ПродажиОбороты.КоличествоОборот - ПродажиОбороты.ЦенаПартнераОборот * ПродажиОбороты.КоличествоОборот) КАК Прибыль
ИЗ
	РегистрНакопления.Продажи.Обороты(, , Запись, ) КАК ПродажиОбороты
ГДЕ
	ПродажиОбороты.Период МЕЖДУ &amp;ДатаНачала И &amp;ДатаКонец

СГРУППИРОВАТЬ ПО
	ПродажиОбороты.Период,
	ПродажиОбороты.Регистратор.Номер</QueryText>
