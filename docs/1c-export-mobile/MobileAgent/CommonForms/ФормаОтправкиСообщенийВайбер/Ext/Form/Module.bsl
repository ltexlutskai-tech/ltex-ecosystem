
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Параметры.Свойство("Контрагенты")Тогда
		Для Каждого Стр из Параметры.Контрагенты Цикл
			Нстр = СписокКонтрагентов.Добавить();
			Нстр.Контрагент = Стр;
		КонецЦикла;
	КонецЕсли;	
	
КонецПроцедуры

&НаКлиенте
Процедура ОтправитьВайбер(Команда)
	
	Если НЕ ЗначениеЗаполнено(НовоеСообщение) И Не ЗначениеЗаполнено(ВыбратьФайл) Тогда
		 #Если МобильноеПриложениеКлиент Тогда
			 Текст = "Вкажіть файл або введіть текст";  
			 СредстваМультимедиа.ВоспроизвестиТекст(Текст,,,,,Истина);
		 #Иначе
			 Текст = "Вкажіть файл або введіть текст";
			 Сообщить(Текст);
		 #КонецЕсли
	Иначе	 
		
		СписокПолучателей = ПолучитьСписокКлиентов();
		ViberОбновлениеКлиент.ОтправитьСообщенияСКлиента(СписокПолучателей, НовоеСообщение, ВыбратьФайл);			
	КонецЕсли;
	
	Закрыть();
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСписокКлиентов()
	
	МассивКонтрагентов = Новый Массив;
	
	Для Каждого Строка из СписокКонтрагентов Цикл
		МассивКонтрагентов.Добавить(Строка.Контрагент);		
    КонецЦикла;
	
	Возврат МассивКонтрагентов;
	
КонецФункции	

&НаКлиенте
Процедура ВыбратьФайлНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	
	Если Диалог.Выбрать() Тогда
    	ВыбратьФайл = Диалог.ПолноеИмяФайла;
	КонецЕсли; 	
	
КонецПроцедуры

