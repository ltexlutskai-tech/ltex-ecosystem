	<Attributes>
		<Attribute name="Остатки" id="1">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Остатки</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>false</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	ОстаткиТоваровОстатки.Номенклатура,
	ОстаткиТоваровОстатки.ХарактеристикаНоменклатуры,
	ОстаткиТоваровОстатки.ЕдиницаИзмерения,
	ОстаткиТоваровОстатки.КоличествоОстаток,
	Штрихкоды.Штрихкод,
	ВЫБОР
		КОГДА ЕСТЬNULL(ОтметкиНаличия.Штрихкод, 0) = 0
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК Пометка
ИЗ
	РегистрНакопления.ОстаткиТоваров.Остатки КАК ОстаткиТоваровОстатки
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Штрихкоды КАК Штрихкоды
			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ОтметкиНаличия КАК ОтметкиНаличия
			ПО Штрихкоды.Штрихкод = ОтметкиНаличия.Штрихкод
		ПО ОстаткиТоваровОстатки.Номенклатура = Штрихкоды.Владелец
			И ОстаткиТоваровОстатки.ХарактеристикаНоменклатуры = Штрихкоды.ХарактеристикаНоменклатуры
			И ОстаткиТоваровОстатки.ЕдиницаИзмерения = Штрихкоды.ЕдиницаИзмерения</QueryText>
				<MainTable>AccumulationRegister.ОстаткиТоваров.Balance</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
					</dcsset:order>
					<dcsset:conditionalAppearance>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>b75fecce-942b-4aed-abc9-e6a02e460fb3</dcsset:userSettingID>
					</dcsset:conditionalAppearance>
					<dcsset:itemsViewMode>Normal</dcsset:itemsViewMode>
					<dcsset:itemsUserSettingID>911b6018-f537-43e8-a417-da56b22f9aec</dcsset:itemsUserSettingID>
				</ListSettings>
			</Settings>
