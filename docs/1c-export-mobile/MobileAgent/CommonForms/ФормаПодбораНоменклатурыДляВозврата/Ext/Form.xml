			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	Штрихкоды.Штрихкод,
	Штрихкоды.Владелец КАК Номенклатура,
	Штрихкоды.ХарактеристикаНоменклатуры КАК Характеристика,
	Штрихкоды.ЕдиницаИзмерения,
	ОстаткиТоваровОстатки.КоличествоОстаток КАК Остаток,
	ЦеныНоменклатуры.Цена
ИЗ
	РегистрСведений.Штрихкоды КАК Штрихкоды
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ОстаткиТоваров.Остатки КАК ОстаткиТоваровОстатки
		ПО Штрихкоды.Владелец = ОстаткиТоваровОстатки.Номенклатура
			И Штрихкоды.ХарактеристикаНоменклатуры = ОстаткиТоваровОстатки.ХарактеристикаНоменклатуры
			И Штрихкоды.ЕдиницаИзмерения = ОстаткиТоваровОстатки.ЕдиницаИзмерения
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
		ПО Штрихкоды.Владелец = ЦеныНоменклатуры.Номенклатура
			И Штрихкоды.ЕдиницаИзмерения = ЦеныНоменклатуры.ЕдиницаИзмерения
			И Штрихкоды.ХарактеристикаНоменклатуры = ЦеныНоменклатуры.ХарактеристикаНоменклатуры
ГДЕ
	НЕ ЦеныНоменклатуры.ТипЦен.ЭтоЦенаПартнера</QueryText>
				<MainTable>InformationRegister.Штрихкоды</MainTable>
				<ListSettings>
					<dcsset:filter>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>dfcece9d-5077-440b-b6b3-45a5cb4538eb</dcsset:userSettingID>
					</dcsset:filter>
					<dcsset:order>
						<dcsset:viewMode>Normal</dcsset:viewMode>
						<dcsset:userSettingID>88619765-ccb3-46c6-ac52-38e9c992ebd4</dcsset:userSettingID>
