				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	СправочникНагадування.Ссылка КАК Ссылка,
	СправочникНагадування.ПометкаУдаления КАК ПометкаУдаления,
	СправочникНагадування.Код КАК Код,
	СправочникНагадування.Наименование КАК Наименование,
	СправочникНагадування.Нагадування КАК Нагадування,
	СправочникНагадування.Періодичність КАК Періодичність,
	НЕ СправочникНагадування.Активне КАК Виконано,
	СправочникНагадування.ДеньНедели КАК ДеньНедели,
	//СправочникНагадування.ДатаНапоминания КАК ДатаНапоминания,
	СправочникНагадування.Контрагент КАК Контрагент,
	СправочникНагадування.НагадатиПроТовар КАК НагадатиПроТовар,
	СправочникНагадування.Предопределенный КАК Предопределенный,
	СправочникНагадування.ИмяПредопределенныхДанных КАК ИмяПредопределенныхДанных,
	ВложенныйЗапрос.ДатаУведомления КАК ДатаНагадування,
	СправочникНагадування.ЗаказВидео КАК ЗаказВидео
	ИЗ
	Справочник.Нагадування КАК СправочникНагадування
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ЗапланированыеУведомления.ОбъектУведомления КАК ОбъектУведомления,
			МИНИМУМ(ЗапланированыеУведомления.ДатаУведомления) КАК ДатаУведомления
		ИЗ
			РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
		ГДЕ
			НЕ ЗапланированыеУведомления.Выполнено
		
		СГРУППИРОВАТЬ ПО
			ЗапланированыеУведомления.ОбъектУведомления) КАК ВложенныйЗапрос
		ПО СправочникНагадування.Ссылка = ВложенныйЗапрос.ОбъектУведомления</QueryText>
				<MainTable>Catalog.Нагадування</MainTable>
