Процедура АвтоОбновлениеАвтоматичнийОбмінБоргиТаЦіниНаСервере() Экспорт 
	Если Не Константы.АвтоматичнийОбмінБоргиТаЦіни.Получить() Тогда 
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(КлючФЗБоргиТаЦіни) Тогда 
		ФоновоеЗадания = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(КлючФЗБоргиТаЦіни);
		Если ФоновоеЗадания = Неопределено Тогда
			Возврат; // вероятно уже вытеснено из памяти
		КонецЕсли;

		Если ФоновоеЗадания.Состояние = СостояниеФоновогоЗадания.Активно Тогда 
			Возврат;
		КонецЕсли;
	КонецЕсли;	
	
	ФоновоеЗадания = ФоновыеЗадания.Выполнить("Обмен_УправлениеОбменом.ОбмінБоргиТаЦіни",,"ОбмінБоргиТаЦіни"); 
	КлючФЗБоргиТаЦіни = ФоновоеЗадания.УникальныйИдентификатор;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьНеПросмотренныеНапоминания() Экспорт 
	
	Напоминания = Общий.ПолучитьНеПросмотренныеНапоминания();
	
	Если Напоминания.Количество() Тогда 
		Если УникальностьФормыУведомлений = Неопределено Тогда 
			УникальностьФормыУведомлений = Новый УникальныйИдентификатор;
		КонецЕсли;
		Форма = ПолучитьФорму("Обработка.Нагадування.Форма.ФормаОтриманихНагадувань",,,УникальностьФормыУведомлений);
		ОткрытьФорму(Форма);
		
	КонецЕсли;
	
	Возврат;
	Для Каждого ПараметрыФормы Из Напоминания Цикл 
	
		Форма = ПолучитьФорму("Обработка.Нагадування.Форма.ФормаПерегляду", ПараметрыФормы,,ПараметрыФормы.Ключ);
		Если Не (Форма = Неопределено Или Форма.Открыта()) Тогда 
			
			Если Не МассивОткрытыхОконНапоминаний.Найти(ПараметрыФормы.УИД_Уведомления) = Неопределено Тогда
		        Продолжить;
			КонецЕсли;			
			МассивОткрытыхОконНапоминаний.Добавить(ПараметрыФормы.УИД_Уведомления);
				
			
			//ОткрытьФормуМодально(Форма);
			ОткрытьФорму(Форма);
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры



Функция _ПолучитьНеПросмотренныеНапоминания()
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаУведомления", ТекущаяДата());
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗапланированыеУведомления.УИД_Уведомления КАК УИД_Уведомления
	|ИЗ
	|	РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗапланированыеУведомления.ДатаУведомления КАК ДатаУведомления,
	|			ЗапланированыеУведомления.ОбъектУведомления КАК ОбъектУведомления
	|		ИЗ
	|			РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
	|		ГДЕ
	|			НЕ ЗапланированыеУведомления.Выполнено
	|			И НЕ ЗапланированыеУведомления.ОбъектУведомления.НагадатиПроТовар
	|			И ЗапланированыеУведомления.ДатаУведомления < &ДатаУведомления) КАК ВложенныйЗапрос
	|		ПО ЗапланированыеУведомления.ОбъектУведомления = ВложенныйЗапрос.ОбъектУведомления
	|			И ЗапланированыеУведомления.ДатаУведомления < ВложенныйЗапрос.ДатаУведомления
	|			И (НЕ ЗапланированыеУведомления.Выполнено)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Массив = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Набор = РегистрыСведений.ЗапланированыеУведомления.СоздатьНаборЗаписей();
		Набор.Отбор.УИД_Уведомления.Установить(ВыборкаДетальныеЗаписи.УИД_Уведомления);
		Набор.Записать();
	КонецЦикла;
	
	
	
	Запрос.Текст = 	"ВЫБРАТЬ
	|	ЗапланированыеУведомления.УИД_Уведомления КАК УИД_Уведомления,
	|	ЗапланированыеУведомления.ДанныеУведомления КАК ДанныеУведомления
	|ИЗ
	|	РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
	|ГДЕ
	|	НЕ ЗапланированыеУведомления.Выполнено
	|	И ЗапланированыеУведомления.ДатаУведомления < &ДатаУведомления
	|";
	
	
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Массив = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Уведомление = ВыборкаДетальныеЗаписи.ДанныеУведомления.Получить();
		ДанныеУведомления = Уведомление.Данные;
		ПараметрыФормы = Новый Структура("ТекстНагадування",  Уведомление.Текст);
		ПараметрыФормы.Вставить("ДатаНагадування",  ДанныеУведомления["Дата"]);
		ПараметрыФормы.Вставить("УИД_Уведомления",  ДанныеУведомления["УИД_Уведомления"]);
		ПараметрыФормы.Вставить("УИД_Напоминание", ДанныеУведомления["УИД_Напоминание"]); 
		ПараметрыФормы.Вставить("Ключ", ДанныеУведомления["УИД_Напоминание"]); 
		Если ДанныеУведомления["НапоминаниеОТоваре"] = "1" Тогда
			
			ПараметрыФормы.Вставить("УИД_Номенклатура", ДанныеУведомления["УИД_Номенклатуры"]);
			
		КонецЕсли;
		
		Массив.Добавить(ПараметрыФормы);
		
	КонецЦикла;

	Возврат Массив;
КонецФункции


