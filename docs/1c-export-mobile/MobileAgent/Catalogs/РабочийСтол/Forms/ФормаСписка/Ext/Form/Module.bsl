&НаСервере
Процедура ПриОткрытииНаСервере()
	//ОбновитьЗаголвок();	
	Общий.ПроверитьЗаполненостьДаннихКонтрагентов();
	
	ПослДата = Константы.ПоследняяДатаВхода.Получить();
	Если Не ЗначениеЗаполнено(ПослДата) ИЛИ ПослДата < НачалоДня(ТекущаяДата()) Тогда
		Константы.ЭтоНеПервыйОбмен.Установить(Ложь);
		Константы.ПоследняяДатаВхода.Установить(НачалоДня(ТекущаяДата()));
	КонецЕсли;
	
	Если Константы.ВідображатиВсіхКлієнтів.Получить() Тогда 
		юзер = ПользователиИнформационнойБазы.НайтиПоИмени("Пользователь");
		юзер.Роли.Добавить(Метаданные.Роли.ВидимістьВсіхКлієнтів);
		юзер.Записать();
	Иначе
		юзер = ПользователиИнформационнойБазы.НайтиПоИмени("Пользователь");
		юзер.Роли.Удалить(Метаданные.Роли.ВидимістьВсіхКлієнтів);
		юзер.Записать();
	КонецЕсли;
	

КонецПроцедуры

