&НаКлиенте
Процедура НайтиИОткрытьХарактеристику(Штрихкод, Результат, Сообщение, ДополнительныеПараметры) Экспорт
	Перем ТекстСообщения;
	
	#Если МобильноеПриложениеКлиент Тогда
		СредстваМультимедиа.ЗакрытьСканированиеШтрихКодов();
	#КонецЕсли
	
	СтруктураТовара = Общий.ПолучитьДанныеТовараПоШК(СокрЛП(Штрихкод), );
	Если ТипЗнч(СтруктураТовара) = Тип("Структура") Тогда 
		
		ОткрытьЗначение(СтруктураТовара.Характеристика);
	Иначе
		
		Сообщить("Не найден товар " + Штрихкод);

	КонецЕсли;
	
	
	
КонецПроцедуры

