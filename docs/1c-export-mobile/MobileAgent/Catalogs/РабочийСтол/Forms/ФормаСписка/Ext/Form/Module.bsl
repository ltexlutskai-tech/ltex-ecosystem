&НаСервере
Процедура ПроверкаФоновогоОбменаНаСервере(Сообщение)
	
	ДатаОбновления = Константы.ДатаПоследнегоФоновогоОбновления.Получить();
	
	Если ДатаОбновления + 600 < ТекущаяДата()  Тогда 
		
		Сообщение = "Перезайдіть в додаток! Останнє оновлення відбулося " + Цел((ТекущаяДата() - ДатаОбновления)/60) + " хвилин тому";
	КонецЕсли;
	
	
	ФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(Новый Структура("Ключ", "ФоновыйОбмен"))[0];
	Сообщения = ФЗ.ПолучитьСообщенияПользователю(Истина);

	МассивОшибок = Новый Массив;
	Для Каждого Элемент Из Сообщения Цикл 
		Если МассивОшибок.Найти(Элемент.Текст) = Неопределено Тогда 
			МассивОшибок.Добавить(Элемент.Текст);
			Элемент.Сообщить();
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры


