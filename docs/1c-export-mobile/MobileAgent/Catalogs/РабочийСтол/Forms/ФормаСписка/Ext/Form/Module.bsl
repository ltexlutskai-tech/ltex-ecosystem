	//ПодключитьОбработчикОжидания("АвтоОбновлениеИнформацииОБрони", 1);
	//
	//ПодключитьОбработчикОжидания("АвтоОбновлениеАвтоматичнийОбмінБоргиТаЦіни", 1);
	//Обмен_УправлениеОбменом.ФоновыйОбмен();
	
	ЗапуститьФоновыйОбмен();
	
	ОбновитьИдентификатор();
	
	ОбновитьНапоминания();
	
	//ПодключитьОбработчикОжидания("ЗагрузитьОчередьНапоминанийСДействием", 60);
	//ЗагрузитьОчередьНапоминанийСДействием();
	
