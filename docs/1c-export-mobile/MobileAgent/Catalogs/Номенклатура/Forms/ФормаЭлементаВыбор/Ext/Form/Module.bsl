	//Запрос.УстановитьПараметр("Номенклатура", Объект.Ссылка);
	//Запрос.УстановитьПараметр("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	//Выборка = Запрос.Выполнить().Выбрать();
	//
	//Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда
	//	СсылкаНаКартинку = ПолучитьНавигационнуюСсылку(Выборка.Ссылка, "Хранилище");
	//	//Элементы.ПолеКартинки.Картинка = Выборка.Ссылка.Хранилище.Получить();
	//КонецЕсли;
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	Штрихкоды.Штрихкод КАК Штрихкод
	          |ИЗ
	          |	РегистрСведений.Штрихкоды КАК Штрихкоды
	          |ГДЕ
	          |	Штрихкоды.Владелец = &Владелец";
	з.УстановитьПараметр("Владелец",Объект.Ссылка);
	Выборка = з.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Штрихкод = Выборка.Штрихкод;
	КонецЕсли;
	
	//з.УстановитьПараметр("ЕдиницаИзмерения");
	
	СсылкаНаКартинку = ПолучитьКартинку(Объект.Ссылка,Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	
	
з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	          |	ЦеныНоменклатуры.Цена КАК Цена,
	          |	ЦеныНоменклатуры.ЕдиницаИзмерения КАК ЕдиницаИзмерения
	          |ИЗ
	          |	РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
	          |ГДЕ
	          |	НЕ ЦеныНоменклатуры.ТипЦен.ЭтоЦенаПартнера
	          |	И ЦеныНоменклатуры.Номенклатура = &Номенклатура
	          |	И ЦеныНоменклатуры.ХарактеристикаНоменклатуры = &ПустаяХарактеристика";
			  з.УстановитьПараметр("Номенклатура",Объект.Ссылка);
			  з.УстановитьПараметр("ПустаяХарактеристика",Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	Выборка = з.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Цена = Формат(Выборка.Цена,"ЧДЦ=2") + " EUR.";
		ЕдиницаИзмерения = Выборка.ЕдиницаИзмерения;
	КонецЕсли;
	
	
	//з.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	//          |	НормыЗапасов.Количество
	//          |ИЗ
	//          |	РегистрСведений.НормыЗапасов КАК НормыЗапасов
	//          |ГДЕ
	//          |	НормыЗапасов.Номенклатура = &Номенклатура
