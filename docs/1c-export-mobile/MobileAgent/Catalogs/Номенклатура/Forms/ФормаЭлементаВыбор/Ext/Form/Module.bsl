	//КонецЕсли;
	ТипЦен = Параметры.ТипЦен;
	УИД = Параметры.УИД;
	
	
	ВремКарт = ПоместитьВоВременноеХранилище(БиблиотекаКартинок.NoImage,ЭтаФорма.УникальныйИдентификатор);	

	 СсылкаНаКартинку = ВремКарт;     
	 Элементы.СсылкаНаКартинку.РазмерКартинки = РазмерКартинки.АвтоРазмер;	
	
	СоздатьЭлементыХарактеристик();
	 	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ХарактеристикиНоменклатуры.Ссылка) КАК Ссылка
		|ИЗ
		|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
		|ГДЕ
		|	ХарактеристикиНоменклатуры.Владелец = &Владелец
		|	И ХарактеристикиНоменклатуры.ПериодБрони > &ПериодБрони
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(Резервы.Количество) КАК Количество
		|ИЗ
		|	РегистрСведений.Резервы КАК Резервы
		|ГДЕ
		|	Резервы.Номенклатура = &Владелец";
	
	Запрос.УстановитьПараметр("Владелец", Объект.Ссылка);
	Запрос.УстановитьПараметр("ПериодБрони", НачалоДня(ТекущаяДата()));
	
	Результат = Запрос.ВыполнитьПакет();
	Выборка = Результат[0].Выбрать();
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Ссылка) Тогда 
		Элементы.ИнфоБронь.Заголовок = "Заброньовано мішків: " + Выборка.Ссылка;
		Элементы.ИнфоБронь.Видимость = Истина;
	КонецЕсли;
	
	Выборка = Результат[1].Выбрать();
	
	Если Выборка.Следующий() И ЗначениеЗаполнено(Выборка.Количество) Тогда 
		Элементы.ИнфоРезерв.Заголовок = "Мішків у резерві: " + Выборка.Количество;
		Элементы.ИнфоРезерв.Видимость = Истина;
	КонецЕсли;


КонецПроцедуры


&НаСервере
Процедура СоздатьЭлементыХарактеристик()     
	//ИспользоватьПачки = Константы.ПідбірВПачкахШтуках.Получить();
	//Если ИспользоватьПачки Тогда 
	//	Элементы.Декорация2.Заголовок = "Замовити:";
	//КонецЕсли;
	
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	|	Товари.Характеристика КАК Характеристика,
	|	МАКСИМУМ(Товари.ЦенаОбщая) КАК ЦенаОбщая,
	|	СУММА(Товари.Остаток) КАК Остаток
	|ИЗ
	|	(ВЫБРАТЬ
	|		ХарактеристикиНоменклатуры.Ссылка.Вага КАК Характеристика,
	|		ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) КАК Цена,
	|		ЕСТЬNULL(ЦеныНоменклатурыБезХарактеристик.Цена, 0) КАК ЦенаОбщая,
	|		ХарактеристикиНоменклатуры.Залишок КАК Остаток,
	|		0 КАК Штрихкод,
	|		""міш."" КАК ЕдиницаИзмерения
	|	ИЗ
	|		(ВЫБРАТЬ
	|			ХарактеристикиНоменклатуры.Ссылка КАК Ссылка,
	|			ХарактеристикиНоменклатуры.Владелец КАК Владелец,
	|			ХарактеристикиНоменклатуры.Залишок КАК Залишок
	|		ИЗ
	|			Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|		ГДЕ
	|			ХарактеристикиНоменклатуры.Владелец = &Владелец) КАК ХарактеристикиНоменклатуры
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
	|			ПО (ЦеныНоменклатуры.ХарактеристикаНоменклатуры = ХарактеристикиНоменклатуры.Ссылка)
	|				И (ЦеныНоменклатуры.ТипЦен = &ТипЦен)
	|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатурыБезХарактеристик
	|			ПО ХарактеристикиНоменклатуры.Владелец = ЦеныНоменклатурыБезХарактеристик.Номенклатура
	|				И (ЦеныНоменклатурыБезХарактеристик.ТипЦен = &ТипЦен)
	|				И (ЦеныНоменклатурыБезХарактеристик.ХарактеристикаНоменклатуры = &ПустаяХарактеристика)) КАК Товари
	|ГДЕ
	|	Товари.Остаток > 0
	|
	|СГРУППИРОВАТЬ ПО
	|	Товари.Характеристика";
	з.УстановитьПараметр("Владелец",Объект.Ссылка);
	з.УстановитьПараметр("ТипЦен",ТипЦен);
	з.УстановитьПараметр("ПустаяХарактеристика",Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	
	Выборка = з.Выполнить().Выбрать();
	НомерЭлементаГруппы = 1;  
	Стр = "";
	
	Если ОтображатьХарактеристики Тогда 
		Элементы.ИнформацияОХарактеристиках.Видимость = Ложь;
	КонецЕсли;
	
	Пока Выборка.Следующий() Цикл
		Если Цена = 0 Тогда
			Цена =  Выборка.ЦенаОбщая;
		КонецЕсли;
		
		Если НЕ ОтображатьХарактеристики Тогда
			
			НовСтр = ИнформацияОХарактеристиках.Добавить();
			НовСтр.Вага = Выборка.Характеристика;
			НовСтр.Залишок = Выборка.Остаток;
		Иначе 	
			// СТВОРЕННЯ ЕЛЕМЕНТІВ УПРАВЛІННЯ
			
			МассивДобавляемыхРеквизитов = Новый Массив;
			МассивУдаляемыхРеквизитов = Новый Массив;
			
			//ЭлементСтраницы = Элементы["Характеристика"+НомерЭлементаГруппы];	
			
			ТипСтрока = Новый ОписаниеТипов("Строка");
			ТипЧисло = Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(10,0));
			ТипЦена = Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15,2));
			
			ТипХарактеристика = Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры");
			ТипЕдИзм = Новый ОписаниеТипов("СправочникСсылка.ЕдиницыИзмерения");
			
			ЭлементСтраницы = Элементы.Добавить("Характеристика"+НомерЭлементаГруппы, Тип("ГруппаФормы"), Элементы.ГруппаХарактеристик);
			ЭлементСтраницы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			//ш = Новый Шрифт(,,Истина);
			//ЭлементСтраницы.Уст = ш;
			ЭлементСтраницы.Заголовок = "Мішок вагою: " + Выборка.Характеристика;
			//ЭлементСтраницы.Поведение = ПоведениеОбычнойГруппы.Свертываемая;
			ЭлементСтраницы.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная;
			//	ЭлементСтраницы.Свернута = Истина;
			ЭлементСтраницы.ЗаголовокСвернутогоОтображения = Выборка.Характеристика;
			/////////////////////////////////////////////////////////////////////////СТВОРЕННЯ РЕКВІЗИТІВ
			
			
			
			Картинка = Новый РеквизитФормы("Картинка"+НомерЭлементаГруппы, ТипСтрока, "", "Картинка");
			МассивДобавляемыхРеквизитов.Добавить(Картинка);
			ШК = Новый РеквизитФормы("Штрихкод"+НомерЭлементаГруппы, ТипХарактеристика, "", "Штрихкод");
			МассивДобавляемыхРеквизитов.Добавить(ШК);
			ЕдИзм = Новый РеквизитФормы("ЕдиницаИзмерения"+НомерЭлементаГруппы, ТипЕдИзм, "", "Од. вим.");
			МассивДобавляемыхРеквизитов.Добавить(ЕдИзм);
			Характ = Новый РеквизитФормы("Характеристика"+НомерЭлементаГруппы, ТипХарактеристика, "", "Характеристика");
			МассивДобавляемыхРеквизитов.Добавить(Характ);
			ЦенаТов = Новый РеквизитФормы("Цена"+НомерЭлементаГруппы, ТипЦена, "", "Ціна");	
			МассивДобавляемыхРеквизитов.Добавить(ЦенаТов);
			НормаЗапасов = Новый РеквизитФормы("Остаток"+НомерЭлементаГруппы, ТипСтрока, "", "Залишок");		
			МассивДобавляемыхРеквизитов.Добавить(НормаЗапасов);	
			НормаЗапасов = Новый РеквизитФормы("Заказать"+НомерЭлементаГруппы, ТипЧисло, "", "Замовити");		
			МассивДобавляемыхРеквизитов.Добавить(НормаЗапасов);		
			НоваяКоманда = Команды.Добавить("Добавить"+НомерЭлементаГруппы);
			НоваяКоманда.Действие   = "Добавить";	
			
			
			///////////////////////////////////////////////////////////////////////////////////////////////////////////////
			
			
			
			//
			
			//////////////////////////////////////////////////////////////////////////////////////////СТВОРЕННЯ ЕЛЕМЕНТІВ
			
			
			///////////////////////////////////////////////////////////////////////////////// КАРТИНКА
			//ЭлементКартинка = Элементы.Добавить("Картинка"+НомерЭлементаГруппы, Тип("ПолеФормы"), ЭлементСтраницы);
			//ЭлементКартинка.Вид = ВидПоляФормы.ПолеКартинки;
			//ЭлементКартинка.ПутьКДанным = "Картинка"+НомерЭлементаГруппы;
			//ЭлементКартинка.Ширина = 9;
			//ЭлементКартинка.Высота = 4;
			//ЭлементКартинка.РастягиватьПоГоризонтали = Ложь;
			//ЭлементКартинка.Видимость = Истина;
			//ЭлементКартинка.РастягиватьПоВертикали = Ложь;
			//ЭлементКартинка.РазмерКартинки = РазмерКартинки.Пропорционально;
			//ЭлементКартинка.Гиперссылка = Истина;
			//ЭлементКартинка.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
			//ЭлементКартинка.Рамка = Новый Рамка(ТипРамкиЭлементаУправления.БезРамки,0);
			
			//ЭтаФорма["Картинка"+НомерЭлементаГруппы] =  ПолучитьКартинку(Объект.Ссылка,Выборка.Характеристика);
			//ЭлементКартинка.УстановитьДействие("Нажатие","СсылкаНаКартинкуНажатие");
			/////////////////////////////////////////////////////////////////////////////////
			
			ЭлементПодгруппа = Элементы.Добавить("ЭлементПодгруппа"+НомерЭлементаГруппы,Тип("ГруппаФормы"),ЭлементСтраницы);
			ЭлементПодгруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
			ЭлементПодгруппа.Отображение = ОтображениеОбычнойГруппы.Нет;
			ЭлементПодгруппа.РастягиватьПоГоризонтали = Истина;
			ЭлементПодгруппа.РастягиватьПоВертикали = Ложь;
			//ЭлементПодгруппа.ВертикальноеПоложение = ВертикальноеПоложение.Верх;
			ЭлементПодгруппа.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Верх;
			ЭлементПодгруппа.ОтображатьЗаголовок = Ложь;
			//ЭлементПодгруппа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
			ИзменитьРеквизиты(МассивДобавляемыхРеквизитов, МассивУдаляемыхРеквизитов);
			ЭлементШтрихкод = Элементы.Добавить("ЭлементШК"+НомерЭлементаГруппы,Тип("ПолеФормы"),ЭлементПодгруппа);
			ЭлементШтрихкод.ПутьКДанным = "Штрихкод"+НомерЭлементаГруппы;
			ЭлементШтрихкод.Заголовок = "Вага";
			ЭлементШтрихкод.Вид = ВидПоляФормы.ПолеНадписи;
			ЭлементШтрихкод.Видимость = Ложь;
			ЭтаФорма["Штрихкод"+НомерЭлементаГруппы] = Выборка.Штрихкод; 
			
			
			ЭтаФорма["Характеристика"+НомерЭлементаГруппы] = Выборка.Характеристика;
			
			ЭлементЦена = Элементы.Добавить("ЭлементЦена"+НомерЭлементаГруппы,Тип("ПолеФормы"),ЭлементПодгруппа);
			ЭлементЦена.ПутьКДанным = "Цена"+НомерЭлементаГруппы;
			ЭлементЦена.Вид = ВидПоляФормы.ПолеВвода;
			Если ЗначениеЗаполнено(Выборка.Цена) Тогда 
				
				ЭтаФорма["Цена"+НомерЭлементаГруппы] = Формат(Выборка.Цена,"ЧДЦ=2");
			ИначеЕсли ЗначениеЗаполнено(Выборка.ЦенаОбщая) Тогда 
				
				ЭтаФорма["Цена"+НомерЭлементаГруппы] = Формат(Выборка.ЦенаОбщая,"ЧДЦ=2");
				
			КонецЕсли;
			
