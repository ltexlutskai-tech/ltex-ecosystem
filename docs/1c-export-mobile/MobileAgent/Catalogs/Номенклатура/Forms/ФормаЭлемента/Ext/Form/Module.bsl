		/////////////////////////////////////////////////////////////////////////СТВОРЕННЯ РЕКВІЗИТІВ
		
		
		
		Картинка = Новый РеквизитФормы("Картинка"+НомерЭлементаГруппы, ТипСтрока, "", "Картинка");
		МассивДобавляемыхРеквизитов.Добавить(Картинка);
		ШК = Новый РеквизитФормы("Штрихкод"+НомерЭлементаГруппы, ТипСтрока, "", "Штрихкод");
		МассивДобавляемыхРеквизитов.Добавить(ШК);
		ЕдИзм = Новый РеквизитФормы("ЕдиницаИзмерения"+НомерЭлементаГруппы, ТипЕдИзм, "", "Ед. изм.");
		МассивДобавляемыхРеквизитов.Добавить(ЕдИзм);
		Характ = Новый РеквизитФормы("Характеристика"+НомерЭлементаГруппы, ТипХарактеристика, "", "Характеристика");
		МассивДобавляемыхРеквизитов.Добавить(Характ);
		ЦенаТов = Новый РеквизитФормы("Цена"+НомерЭлементаГруппы, ТипСтрока, "", "Цена");	
		МассивДобавляемыхРеквизитов.Добавить(ЦенаТов);
		НормаЗапасов = Новый РеквизитФормы("НормаЗапаса"+НомерЭлементаГруппы, ТипЧисло, "", "Норма запаса");		
		МассивДобавляемыхРеквизитов.Добавить(НормаЗапасов);

		
		
		
		///////////////////////////////////////////////////////////////////////////////////////////////////////////////

		
		МассивУдаляемыхРеквизитов = Новый Массив;
		//
		ИзменитьРеквизиты(МассивДобавляемыхРеквизитов, МассивУдаляемыхРеквизитов);
		//////////////////////////////////////////////////////////////////////////////////////////СТВОРЕННЯ ЕЛЕМЕНТІВ
		
		
		
		ЭлементКартинка = Элементы.Добавить("Картинка"+НомерЭлементаГруппы, Тип("ПолеФормы"), ЭлементСтраницы);
		ЭлементКартинка.Вид = ВидПоляФормы.ПолеКартинки;
		ЭлементКартинка.ПутьКДанным = "Картинка"+НомерЭлементаГруппы;
		ЭлементКартинка.Ширина = 11;
		ЭлементКартинка.Высота = 4;
		ЭлементКартинка.РастягиватьПоГоризонтали = Ложь;
		ЭлементКартинка.РастягиватьПоВертикали = Ложь;
		ЭлементКартинка.РазмерКартинки = РазмерКартинки.Пропорционально;
		ЭлементКартинка.Гиперссылка = Истина;
		ЭлементКартинка.ПоложениеЗаголовка = ПоложениеЗаголовкаЭлементаФормы.Нет;
		ЭлементКартинка.Рамка = Новый Рамка(ТипРамкиЭлементаУправления.БезРамки,0);

		ЭтаФорма["Картинка"+НомерЭлементаГруппы] =  ПолучитьКартинку(Объект.Ссылка,Выборка.Характеристика);
		ЭлементКартинка.УстановитьДействие("Нажатие","СсылкаНаКартинкуНажатие");
		/////////
		
		ЭлементПодгруппа = Элементы.Добавить("ЭлементПодгруппа"+НомерЭлементаГруппы,Тип("ГруппаФормы"),ЭлементСтраницы);
		ЭлементПодгруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		ЭлементПодгруппа.Отображение = ОтображениеОбычнойГруппы.Нет;
		ЭлементПодгруппа.РастягиватьПоГоризонтали = Истина;
		ЭлементПодгруппа.РастягиватьПоВертикали = Ложь;
		//ЭлементПодгруппа.ВертикальноеПоложение = ВертикальноеПоложение.Верх;
		ЭлементПодгруппа.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Верх;
		ЭлементПодгруппа.ОтображатьЗаголовок = Ложь;
		//ЭлементПодгруппа.Отображение = ОтображениеОбычнойГруппы.СильноеВыделение;
		
		ЭлементШтрихкод = Элементы.Добавить("ЭлементШК"+НомерЭлементаГруппы,Тип("ПолеФормы"),ЭлементПодгруппа);
		ЭлементШтрихкод.ПутьКДанным = "Штрихкод"+НомерЭлементаГруппы;
		ЭлементШтрихкод.Заголовок = "Код товара";
		ЭлементШтрихкод.Вид = ВидПоляФормы.ПолеНадписи;
		ЭтаФорма["Штрихкод"+НомерЭлементаГруппы] = Выборка.Штрихкод; 
		
		ЭлементЕдИзм = Элементы.Добавить("ЭлементЕдИзм"+НомерЭлементаГруппы,Тип("ПолеФормы"),ЭлементПодгруппа);
		ЭлементЕдИзм.ПутьКДанным = "ЕдиницаИзмерения"+НомерЭлементаГруппы;
		ЭлементЕдИзм.Вид = ВидПоляФормы.ПолеНадписи;
		ЭтаФорма["ЕдиницаИзмерения"+НомерЭлементаГруппы] = Выборка.ЕдиницаИзмерения;
		
		ЭтаФорма["Характеристика"+НомерЭлементаГруппы] = Выборка.Характеристика;
		
		ЭлементЦена = Элементы.Добавить("ЭлементЦена"+НомерЭлементаГруппы,Тип("ПолеФормы"),ЭлементПодгруппа);
		ЭлементЦена.ПутьКДанным = "Цена"+НомерЭлементаГруппы;
