&НаСервере
Процедура ВилучитиБроньНаСервере(Характеристика)
	
	Если Не (Характеристика.МояБронь И Характеристика.ПериодБрони >= КонецДня(ТекущаяДата())) тогда 

		Возврат;
	КонецЕсли;
	
	
	Прокси = СоединениеСБазой.ПолучитьПрокси();
	Пароль = Константы.ПарольВхода.Получить();
	Данные = Новый Структура;
	Данные.Вставить("Команда", "ВилучитиБронь");
	Данные.Вставить("Характеристика", Характеристика.УникальныйИдентификатор());
	Ответ = Прокси.ЗабронюватиНоменклатуру(Пароль, Обмен_УправлениеОбменом.Сериализовать(Данные));
	Ответ = Ответ.Получить();
	
	Если Ответ.Успешно Тогда 
		ВагаОбъект = Характеристика.ПолучитьОбъект();
		ВагаОбъект.Бронь = Неопределено;
		ВагаОбъект.ПериодБрони = Неопределено;
		ВагаОбъект.МояБронь = Ложь;
		ВагаОбъект.Записать();
	Иначе
		Сообщить(Ответ.Ошибка);
	КонецЕсли; 	
	
КонецПроцедуры

