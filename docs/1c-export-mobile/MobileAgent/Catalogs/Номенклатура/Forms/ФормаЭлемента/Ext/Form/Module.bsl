&НаСервере
Процедура СоздатьЭлементыХарактеристик()
	
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	ХарактеристикиНоменклатуры.Ссылка КАК Характеристика,
	          |	Штрихкоды.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
	          |	ЦеныНоменклатуры.Цена КАК Цена,
	          |	Штрихкоды.Штрихкод КАК Штрихкод,
	          |	НормыЗапасов.Количество КАК НормаЗапасов,
	          |	ЦеныНоменклатурыБезХарактеристик.Цена КАК ЦенаОбщая
	          |ИЗ
	          |	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	          |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Штрихкоды КАК Штрихкоды
	          |		ПО (Штрихкоды.ХарактеристикаНоменклатуры = ХарактеристикиНоменклатуры.Ссылка)
	          |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
	          |		ПО (ЦеныНоменклатуры.ХарактеристикаНоменклатуры = ХарактеристикиНоменклатуры.Ссылка)
	          |			И (НЕ ЦеныНоменклатуры.ТипЦен.ЭтоЦенаПартнера)
	          |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НормыЗапасов КАК НормыЗапасов
	          |		ПО ХарактеристикиНоменклатуры.Владелец = НормыЗапасов.Номенклатура
	          |			И ХарактеристикиНоменклатуры.Ссылка = НормыЗапасов.ХарактеристикаНоменклатуры
	          |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатурыБезХарактеристик
	          |		ПО ХарактеристикиНоменклатуры.Владелец = ЦеныНоменклатурыБезХарактеристик.Номенклатура
	          |			И (НЕ ЦеныНоменклатурыБезХарактеристик.ТипЦен.ЭтоЦенаПартнера)
	          |			И (ЦеныНоменклатурыБезХарактеристик.ХарактеристикаНоменклатуры = &ПустаяХарактеристика)
	          |ГДЕ
	          |	ХарактеристикиНоменклатуры.Владелец = &Владелец";
			  з.УстановитьПараметр("Владелец",Объект.Ссылка);
			  з.УстановитьПараметр("ПустаяХарактеристика",Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());

	Выборка = з.Выполнить().Выбрать();
	НомерЭлементаГруппы = 1;
	Пока Выборка.Следующий() Цикл
		МассивДобавляемыхРеквизитов = Новый Массив;
		//ЭлементСтраницы = Элементы["Характеристика"+НомерЭлементаГруппы];	
		
		ТипСтрока = Новый ОписаниеТипов("Строка");
		ТипЧисло = Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(10,0));
		ТипХарактеристика = Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры");
		ТипЕдИзм = Новый ОписаниеТипов("СправочникСсылка.ЕдиницыИзмерения");
		
		ЭлементСтраницы = Элементы.Добавить("Характеристика"+НомерЭлементаГруппы, Тип("ГруппаФормы"), ЭтаФорма);
		ЭлементСтраницы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
		ЭлементСтраницы.Заголовок = Выборка.Характеристика;
