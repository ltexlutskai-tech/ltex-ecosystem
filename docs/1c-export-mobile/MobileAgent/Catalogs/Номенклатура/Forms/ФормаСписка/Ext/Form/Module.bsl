КонецФункции


Функция ПолучитьРодителейНоменклатуры(ТзНоменклатура,СписокГрупп)
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	Номенклатура.Родитель.Ссылка КАК Ссылка,
	|	Номенклатура.Родитель.Наименование КАК Наименование,
	|	Номенклатура.Родитель.ЭтоГруппа КАК ЭтоГруппа,
	|	Номенклатура.Родитель.Родитель КАК Родитель
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В(&СписокРодителей)
	|	И НЕ Номенклатура.Родитель.ПометкаУдаления
	|	И НЕ Номенклатура.Родитель.Ссылка В (&СписокГрупп)
	|
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура.Родитель.Ссылка,
	|	Номенклатура.Родитель.Наименование,
	|	Номенклатура.Родитель.ЭтоГруппа,
	|	Номенклатура.Родитель.Родитель";
	
	Запрос.УстановитьПараметр("СписокРодителей",ТзНоменклатура.ВыгрузитьКолонку("Ссылка"));
	Запрос.УстановитьПараметр("СписокГрупп",СписокГрупп);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

&НаКлиенте
Процедура СписокВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если ЭтоГруппа(ВыбраннаяСтрока) Тогда 
		Возврат;
	КонецЕсли;
	

	Попытка
		Если ЭтаФорма.ВладелецФормы.Имя = "Напоминание_Товары_Номенклатура" Тогда 
			СтандартнаяОбработка = Ложь;
			ОповеститьОВыборе(ВыбраннаяСтрока);
			ОбработкаОповещения("ДоданоТовар", ВыбраннаяСтрока, ЭтаФорма);
			Возврат;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
		
	Если РежимВыбора Тогда 
		СтандартнаяОбработка = Ложь;
		ФормаНоменклатуры = ПолучитьФорму("Справочник.Номенклатура.Форма.ФормаЭлементаВыбор",Новый Структура("Ключ, ТипЦен, УИД",ВыбраннаяСтрока,ТипЦен, УИД),ЭтаФорма);
		ФормаНоменклатуры.Открыть();
	КонецЕсли;
	
КонецПроцедуры

