&НаКлиенте
Процедура кмСкинутиНоменклатуруУВайбер(Команда)
	ТекущаяСтрока = Элементы.Список.ТекущаяСтрока;
	Если ТекущаяСтрока = Неопределено Тогда 
		Возврат;
	КонецЕсли;


	ТекстСообщения =  Общий.ПолучитьТекстОписанияНоменклатуры(ТекущаяСтрока);
	
	#Если МобильноеПриложениеКлиент Тогда
		
		НовВз = Новый ЗапускПриложенияМобильногоУстройства();
		
		НовВз.Действие = "android.intent.action.SEND";
		НовВз.Приложение = "com.viber.voip"; 
		НовВз.ИмяКласса = "com.viber.voip.WelcomeShareActivity"; 
		НовВз.Тип = "text/plain";
		НовВз.ДополнительныеДанные.Добавить("android.intent.extra.TEXT", СокрЛП(ТекстСообщения));
		
		НовВз.Запустить(Истина);
	#Иначе 
		Сообщить(ТекстСообщения);
	#КонецЕсли

	
КонецПроцедуры


&НаКлиенте
Процедура ДобавитьВГруповуюОтправку(Команда)
	ТекущиеДанные = Элементы.Список.ТекущаяСтрока;
	Если ТекущиеДанные = Неопределено Тогда 
		Возврат;
	КонецЕсли;

	Данные = Новый Структура("Номенклатура", ТекущиеДанные);

	ДобавитьВГруповуюОтправкуНаСервере(Данные);
	
КонецПроцедуры

&НаСервере
Процедура ДобавитьВГруповуюОтправкуНаСервере(Данные)
	Перем СтрокаРассылки;
	Элементы.Рассылка.Видимость = истина;
	элементы.ОтправитьРассылку.Видимость = Истина;
	
	Если Данные.Свойство("Характеристика") Тогда 
		Отбор = Новый Структура("Номенклатура, Характеристика", Данные.Номенклатура, Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
		Строки = ТоварыДляРассылки.НайтиСтроки(Отбор);
		Если Строки.Количество() Тогда 
