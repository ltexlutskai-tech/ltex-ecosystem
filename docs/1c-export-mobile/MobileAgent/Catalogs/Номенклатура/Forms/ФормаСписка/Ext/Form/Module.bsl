&НаКлиенте
Процедура ЗдійснитиПошук()
	ОтключитьОбработчикОжидания("ЗдійснитиПошук");
	
	
	
	
	МассивПоиска = СтрРазделить(глТекстПошуку, " ", Ложь);
	Если НЕ МассивПоиска.Количество() Тогда 
		Список.Параметры.УстановитьЗначениеПараметра("КоличествоВМасиве", 0);
		Список.Параметры.УстановитьЗначениеПараметра("МасивПоиска", ПолучитьПустуюСсылкуНоменклатуры());
		Возврат;
	КонецЕсли;
	
	ТаблицаРезультатов = ПолучитьРезультати(МассивПоиска[0]);
	

	
	МасивРезультатов = Новый Массив;
	
	Для Каждого Стр Из ТаблицаРезультатов Цикл
		РезультатПоАртикулу = Истина;
		РезультатПоНаименованию = Истина;

		Для ИтМас = 1 По МассивПоиска.Количество() -1 Цикл
			Если Найти(нрег(Стр.Артикул), нрег(МассивПоиска[ИтМас])) = 0 Тогда 
				РезультатПоАртикулу = Ложь;
			КонецЕсли;
			
			Если Найти(нрег(Стр.Наименование), нрег(МассивПоиска[ИтМас])) = 0 Тогда 
				РезультатПоНаименованию = Ложь;
			КонецЕсли;			
		КонецЦикла;
		Если РезультатПоАртикулу ИЛИ РезультатПоНаименованию Тогда 
			МасивРезультатов.Добавить(Стр.Ссылка);
		КонецЕсли;		
	КонецЦикла;
	
	Список.Параметры.УстановитьЗначениеПараметра("МасивПоиска", МасивРезультатов);
	Список.Параметры.УстановитьЗначениеПараметра("КоличествоВМасиве", 1);
	
	
	//Список.Параметры.УстановитьЗначениеПараметра("СтрокаПоиска", СтрЗаменить(ПошукПоЧастиніРядка," ","%"));

	
	
	
	//Список.Параметры.УстановитьЗначениеПараметра("СтрокаПоиска", СтрЗаменить(глТекстПошуку," ","%"));	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьРезультати(СтрокаПоиска)
		з = новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	Номенклатура.Ссылка КАК Ссылка,
	          |	Номенклатура.Наименование КАК Наименование,
	          |	Номенклатура.Артикул КАК Артикул
	          |ИЗ
	          |	Справочник.Номенклатура КАК Номенклатура
	          |ГДЕ
	          |	(Номенклатура.Наименование ПОДОБНО &Наименование
	          |			ИЛИ Номенклатура.Артикул ПОДОБНО &Наименование)";
	з.УстановитьПараметр("Наименование", "%" + СтрокаПоиска + "%");
	МассивРезультатов = Новый Массив;
	Выборка =  з.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		МассивРезультатов.Добавить(Новый Структура("Ссылка, Наименование, Артикул", Выборка.Ссылка, Выборка.Наименование, Выборка.Артикул));
	КонецЦикла;
	Возврат МассивРезультатов;

КонецФункции



