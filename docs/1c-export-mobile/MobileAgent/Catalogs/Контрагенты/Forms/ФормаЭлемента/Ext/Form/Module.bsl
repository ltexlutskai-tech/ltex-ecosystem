

&НаКлиенте
Перем мСообщение; 

&НаСервере
Процедура ПередЗаписьюНаСервере(Отказ, ТекущийОбъект, ПараметрыЗаписи)
	
	Если Элементы.Страници.ТекущаяСтраница = Элементы.СтраницаИстория
		И ЭтаФорма.ТекущийЭлемент.Имя = "ТекстИстории"
		И Не ПустаяСтрока(ТекстИстории) Тогда 
		 Отказ = Истина;
		 Если ЗначениеЗаполнено(УИД_РедагуванняЗапису) Тогда 
			 ИсторияРаботиСКлиентом_РедагуванняЗапису();
			 Элементы.СкасуватиРедагування.Видимость = Ложь;	
		 Иначе
			 ИсторияРаботиСКлиентом_ЗаписатьИсторию();
		 КонецЕсли;

		 Возврат;
	КонецЕсли;

	
	ПоискДублейНомеровТелефона(, Отказ);
	
	
КонецПроцедуры

&НаСервере
Процедура  ПоискДублейНомеровТелефона(НомерТелефона = "", Отказ)
	
	
	Если  ЗначениеЗаполнено(НомерТелефона) Тогда 
		Условие = " И Контрагенты.НомерТелефона ПОДОБНО ""%" + Прав(НомерТелефона, 10)+ "%""";
	Иначе 
		Условие = "И (";
		Для Каждого Телефон Из Объект.Телефоны Цикл
			Если ЗначениеЗаполнено(Телефон.НомерТелефона) Тогда 
				Условие = Условие + "Контрагенты.НомерТелефона ПОДОБНО ""%" + Прав(Телефон.НомерТелефона, 10) + "%""" + " Или ";   
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ СтрДлина(Условие) > 4 Тогда 
			Условие = "";
			Возврат;
		Иначе 
			Условие = Условие + "Ложь)";
		КонецЕсли;

	КонецЕсли;
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.Ссылка <> &Ссылка
		|	" + Условие;
	
	Запрос.УстановитьПараметр("Ссылка", Объект.Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если  Выборка.Следующий() Тогда 
		Отказ = истина;
		Сообщить("Контрагент " + Выборка.Ссылка + " має співпадіння по номеру телефону"); 
	КонецЕсли;	
	
	
	Если Отказ = истина 
		Или НомерТелефона = "" Тогда 
		Возврат;
	КонецЕсли;
	
	Ответ = Общий.ПоискДублейНомеровТелефона_НаСервере1С(Прав(НомерТелефона, 10), Объект.Ссылка);
	Если Ответ.Успешно Тогда 
		Если Ответ.Данные.ЕстьДубли Тогда 
			Отказ = истина;
			Сообщить(Ответ.Данные.ТекстОшибки);
		КонецЕсли;
		
		
		Возврат; 
	Иначе
		Сообщить("Контроль унікальності контрагента виконано лише в додатку. Не має підключення до 1С!");
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	КонтрагентОбъект = РеквизитФормыВЗначение("Объект");
	КонтрагентОбъект.Заблокировать();
	ЗначениеВРеквизитФормы(КонтрагентОбъект, "Объект");

	
	ИсторияРаботиСКлиентом();
	
КонецПроцедуры

&НаКлиенте
Процедура ДобавлениеНовогоНомераТелефона(Команда)
	Месенджеры = ПолучитьМесенджеры();
	СЗМесенджер = Новый СписокЗначений;
	СЗМесенджер.Добавить(ПредопределенноеЗначение("Перечисление.ВидыМесендеров.Telegram"), "Telegram",,Месенджеры[0]); 
	СЗМесенджер.Добавить(ПредопределенноеЗначение("Перечисление.ВидыМесендеров.Viber"), "Viber",,Месенджеры[1]);
	НовыйТелефон = "";
	ВвестиСтроку(НовыйТелефон, "Номер телефону");
	мМесенджер = Вопрос("Месенджер для зв'язку", СЗМесенджер);
	Если ЗначениеЗаполнено(НовыйТелефон) Тогда 
		ЕстьДубли =Ложь;
		ПоискДублейНомеровТелефона(НовыйТелефон, ЕстьДубли);
		Если ЕстьДубли Тогда 
			Возврат
		КонецЕсли;
		
		ДобавитьТелефон(НовыйТелефон, мМесенджер);
		Если ПустаяСтрока(СокрЛП(Объект.НомерТелефона)) Тогда 
			Объект.НомерТелефона = НовыйТелефон;
		Иначе
			Объект.НомерТелефона = СокрЛП(Объект.НомерТелефона)+ Символы.ПС + НовыйТелефон;
		КонецЕсли;
		ДобавлениеЭлементаНомераТелефонаНаФорму(СтрЧислоСтрок(Объект.НомерТелефона), НовыйТелефон, Месенджеры);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ДобавлениеЭлементаНомераТелефонаНаФорму(Индекс, НомерТелефона, Месенджеры);
	ТипСтрока = Новый ОписаниеТипов("Строка");
	МассивДобавляемыхРеквизитов = Новый Массив;
	ЭлементСтраницы = Элементы.Добавить("НомерТелефона"+Индекс, Тип("ГруппаФормы"), Элементы.ГруппаДопТелефонны);
	ЭлементСтраницы.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	//ЭлементСтраницы.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяЕслиВозможно;
	//
	//ЭлементПодгруппа = Элементы.Добавить("ЭлементПодгруппа"+ Индекс, Тип("ГруппаФормы"), ЭлементСтраницы);
	//ЭлементПодгруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	//ЭлементПодгруппа.Отображение = ОтображениеОбычнойГруппы.Нет;
	//ЭлементПодгруппа.РастягиватьПоГоризонтали = Истина;
	//ЭлементПодгруппа.РастягиватьПоВертикали = Ложь;
	
	НомерТелефону = Новый РеквизитФормы("НомерТелефона"+Индекс, ТипСтрока, "", "Номер телефону");		
	МассивДобавляемыхРеквизитов.Добавить(НомерТелефону);
	
	МассивУдаляемыхРеквизитов = Новый Массив;
	ИзменитьРеквизиты(МассивДобавляемыхРеквизитов, МассивУдаляемыхРеквизитов);
	
		ТЗТелефоны = Объект.Телефоны.Выгрузить();
	Строка = ТЗТелефоны.Найти(НомерТелефона);	
	Если Строка <> Неопределено  
		И Месенджеры.Получить(Строка.Месенджер) <> Неопределено Тогда 
		ЭлементФорми = Элементы.Добавить("ИзображениеНТ"+Индекс,Тип("ДекорацияФормы"), ЭлементСтраницы);
		ЭлементФорми.Вид = ВидДекорацииФормы.Картинка;
		ЭлементФорми.РазмерКартинки = РазмерКартинки.Пропорционально;
		ЭлементФорми.Высота = 1;
		ЭлементФорми.Ширина = 2;
		
		ЭлементФорми.Картинка =  Месенджеры.Получить(Строка.Месенджер);
	КонецЕсли;

	
	ЭлементФорми = Элементы.Добавить("ЭлементНТ"+Индекс,Тип("ПолеФормы"), ЭлементСтраницы);
	ЭлементФорми.ПутьКДанным = "НомерТелефона"+ Индекс;
	ЭлементФорми.Заголовок = "";
	ЭлементФорми.Вид = ВидПоляФормы.ПолеНадписи;
	ЭлементФорми.Гиперссылка = Истина;
	ЭлементФорми.УстановитьДействие("Нажатие", "НабратьНомер");
	ЭтаФорма["НомерТелефона" + Индекс] = НомерТелефона; 


КонецПроцедуры

&НаКлиенте
Процедура НабратьНомер(Элемент, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	СЗ = Новый СписокЗначений;
	СЗ.Добавить(1, "Зателефонувати");
	СЗ.Добавить(2, "Змінити");
	Сз.Добавить(3, "Вилучити");
	Сз.Добавить(4, "Скасувати");
	Сз.Добавить(5, "Viber");

	Действие = СЗ.ВыбратьЭлемент();
	Номер = ПолучитьДанныеТелефона(Элемент.Имя);

	Если Действие = Неопределено 
		Или Действие.Значение = 4 Тогда 
		Возврат;
		
	ИначеЕсли  Действие.Значение = 1 Тогда 
		#Если МобильноеПриложениеКлиент Тогда 
			Если СредстваТелефонии.ПоддерживаетсяНаборНомера() Тогда
				СредстваТелефонии.НабратьНомер(Номер, Ложь);
			КонецЕсли;
		#КонецЕсли
	ИначеЕсли Действие.Значение = 2 Тогда 
		мНовыйНомер = Номер;
		ВвестиСтроку(мНовыйНомер, "Номер телефону");
		Если ПустаяСтрока(мНовыйНомер) Тогда 
			Возврат;
		КонецЕсли;
		
		Объект.НомерТелефона = СтрЗаменить(Объект.НомерТелефона, Номер, мНовыйНомер);
		ИзменитьНомерТелефону(Номер, мНовыйНомер, Ложь);
		
		Индекс = ПолучитьИндекс(Элемент.Имя);
		ЭтаФорма["НомерТелефона" + Индекс] = мНовыйНомер;
	ИначеЕсли  Действие.Значение = 3 Тогда  
		ИзменитьНомерТелефону(Номер, , Истина);
		Объект.НомерТелефона = СтрЗаменить(Объект.НомерТелефона, Номер, "");
		Объект.НомерТелефона = СтрЗаменить(Объект.НомерТелефона, Символы.ПС + Символы.ПС, Символы.ПС);


		Индекс = ПолучитьИндекс(Элемент.Имя);
		ЭтаФорма["НомерТелефона" + Индекс] = "";
	ИначеЕсли  Действие.Значение = 5 Тогда	
		ОбработатьПереходКВайберу(Номер);
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ОбработатьПереходКВайберу(Номер)
	
	ЗапуститьПриложение("viber://chat?number=" + Номер);	
	
КонецПроцедуры	

&НаСервере
Функция ПолучитьДанныеТелефона(ИмяЭлемента)
	Возврат ЭтаФорма[Элементы[ИмяЭлемента].ПутьКДанным];
КонецФункции

&НаСервере
Процедура ИсторияРаботиСКлиентом()
	Перем мДата;
	
	ИсторияЗаписи.Очистить();
	Для Каждого стрСписокСозданыхЭлементов Из СписокСозданыхЭлементов Цикл
		ИмяЭлемента = стрСписокСозданыхЭлементов.Значение;
		Элемент = Элементы.Найти(ИмяЭлемента);
		Если Элемент <> Неопределено Тогда 
			Элементы.Удалить(Элемент);
		КонецЕсли; 		
	КонецЦикла;	
	СписокСозданыхЭлементов.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ " + (ИсторияЗаписи.Количество() + 50) + "
		|	РаботаСКлиентом.Период КАК Период,
		|	РаботаСКлиентом.Запись КАК Запись,
		|	РаботаСКлиентом.УИД_Записи КАК УИД_Записи
		|ПОМЕСТИТЬ ПакетИстория
		|ИЗ
		|	РегистрСведений.РаботаСКлиентом КАК РаботаСКлиентом
		|ГДЕ
		|	РаботаСКлиентом.Клиент = &Клиент
		|" + ?(ЗначениеЗаполнено(ТекстПоиска), " И РаботаСКлиентом.Запись ПОДОБНО &ТекстПоиска ", "") + " 
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период УБЫВ
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 50
		|	ПакетИстория.Период КАК Период,
		|	ПакетИстория.Запись КАК Запись,
		|	ПакетИстория.УИД_Записи КАК УИД_Записи
		|ИЗ
		|	ПакетИстория КАК ПакетИстория
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период УБЫВ";
	Запрос.УстановитьПараметр("Клиент", Объект.Ссылка);
	Запрос.УстановитьПараметр("ТекстПоиска", "%" + ТекстПоиска + "%");
	Выборка = Запрос.Выполнить().Выбрать();
	
	НомерПоПорядку = 1;
	
	Пока Выборка.Следующий() Цикл
		
		Если мДата <> НачалоДня(Выборка.Период) Тогда 
		    ИсторияРаботиСКлиентом_ДобавитьДатуНаФорму(Выборка.Период);
			мДата = НачалоДня(Выборка.Период);
		КонецЕсли;
		
		ИсторияРаботиСКлиентом_ДобавитьЗаписьНаФорму(Выборка, ,НомерПоПорядку);
		
		НомерПоПорядку =  НомерПоПорядку + 1;
		
		ИсторияЗаписи.Добавить().УИД =  Выборка.УИД_Записи
		
	КонецЦикла;
	ТЗ_История = ИсторияЗаписи.Выгрузить();
	ТЗ_История.Свернуть("УИД");
	ЗначениеВДанныеФормы(ТЗ_История, ИсторияЗаписи);
КонецПроцедуры

&НаСервере
Процедура ИсторияРаботиСКлиентом_ДобавитьЗаписьНаФорму(Данные, ПередЭлементомФормы = Неопределено, НомерПоПорядку = 1)
	перем ПередЭлементом;
	
	
	
	
	Имя = ПолучитьИмяЭлементаФормы("История", Данные.УИД_Записи);
	
	Если Не Элементы.Найти(Имя) = Неопределено Тогда 
		Возврат;
	КонецЕсли;
		
	Если ЗначениеЗаполнено(ПередЭлементомФормы) Тогда
		ПередЭлементом = Элементы.Найти(ПолучитьИмяЭлементаФормы("История", ПередЭлементомФормы));
	КонецЕсли;

	
	
	Группа = Элементы.Вставить(Имя, Тип("ГруппаФормы"), Элементы.СторінкаІсторія, ПередЭлементом);
	Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	
	Группа.РастягиватьПоВертикали			= Ложь;
	Группа.ОтображатьЗаголовок 				= Ложь;
	Группа.ГоризонтальноеПоложениеВГруппе 	= ГоризонтальноеПоложениеЭлемента.Лево;
	Если НомерПоПорядку%2 = 0 Тогда
		Группа.ЦветФона = Новый Цвет(240,255,255);
	Иначе		
		Группа.ЦветФона = Новый Цвет(255,255,240);
	КонецЕсли;	
	Группа.РастягиватьПоГоризонтали 		= Истина;
	
	СписокСозданыхЭлементов.Добавить(Группа.Имя);
	
	Элемент = Элементы.Добавить(Имя + "Отступ", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид 	= ВидДекорацииФормы.Надпись;
	Элемент.Ширина 	= 1;
	
	СписокСозданыхЭлементов.Добавить(Элемент.Имя);
	
	
	//мГруппа = Элементы.Добавить(Имя + "ТелоСообщенияГоризонт", Тип("ГруппаФормы"), Группа);
	//мГруппа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	//мГруппа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	
	//мГруппа.ОтображатьЗаголовок = Ложь;

	
	//Группа = Элементы.Добавить(Имя + "ТелоСообщения", Тип("ГруппаФормы"), Группа);
	//Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	//Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;	
	//Группа.ОтображатьЗаголовок = Ложь;
	//
	//Группа = Элементы.Добавить(Имя + "ТекстСообщения", Тип("ГруппаФормы"), Группа);
	//Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	//Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.ГоризонтальнаяВсегда;	
	//Группа.ОтображатьЗаголовок = Ложь;

	Элемент = Элементы.Добавить(Имя + "Текст", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид 					= ВидДекорацииФормы.Надпись;
	Элемент.Заголовок	 			= СокрЛП(Данные.Запись);
	Элемент.АвтоМаксимальнаяШирина 	= Ложь;
	//Элемент.МаксимальнаяШирина 		= 32;
	Элемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Лево;
	
	СписокСозданыхЭлементов.Добавить(Элемент.Имя);
	
	Группа = Элементы.Вставить(Имя + "ДопМеню", Тип("ГруппаФормы"), Группа);
	Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	Группа.Группировка = ГруппировкаПодчиненныхЭлементовФормы.Вертикальная;
	Группа.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
	Группа.ОтображатьЗаголовок = Ложь;
	Группа.РастягиватьПоВертикали  = Истина;
	Группа.РастягиватьПоГоризонтали  = Истина;
	//Группа.ЦветФона = Новый Цвет(255,255,255);
	Если НомерПоПорядку%2 = 0 Тогда
		Группа.ЦветФона = Новый Цвет(240,255,255);
	Иначе		
		Группа.ЦветФона = Новый Цвет(255,255,240);
	КонецЕсли;	
	
	СписокСозданыхЭлементов.Добавить(Группа.Имя);
	
	Элемент = Элементы.Добавить(Имя + "Меню", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид = ВидДекорацииФормы.Картинка;
	Элемент.Ширина = 1;
	Элемент.Высота = 1;
	Элемент.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Право;
	Элемент.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Верх;
	Элемент.Картинка = БиблиотекаКартинок.Меню;
	Элемент.Гиперссылка = Истина;
	Элемент.УстановитьДействие("Нажатие", "МенюСообщенияНажатие");
	Элемент.Подсказка = Данные.УИД_Записи; 
	Элемент.РазмерКартинки = РазмерКартинки.АвтоРазмер;
	
	СписокСозданыхЭлементов.Добавить(Элемент.Имя);

	Элемент = Элементы.Добавить(Имя + "Время", Тип("ДекорацияФормы"), Группа);
	Элемент.Вид = ВидДекорацииФормы.Надпись;
	Элемент.Заголовок = Формат(Данные.Период, "ДФ=ЧЧ:мм");;
	Элемент.Шрифт = Новый Шрифт(,5);
	Элемент.ГоризонтальноеПоложениеВГруппе  = ГоризонтальноеПоложениеЭлемента.Право;
	Элемент.ВертикальноеПоложениеВГруппе = ВертикальноеПоложениеЭлемента.Низ;
	
	СписокСозданыхЭлементов.Добавить(Элемент.Имя);
	
	Создано = Истина;
КонецПроцедуры

&НаСервере
Процедура ИсторияРаботиСКлиентом_ДобавитьДатуНаФорму(Дата, ПередЭлементомФормы = Неопределено)
	
	ИмяЭлемента = "_" + Формат(Дата, "ДФ=ddMMyy");
	
	Элемент = Элементы.Найти(ИмяЭлемента);
	Если Элемент <> Неопределено Тогда 
		Элементы.Удалить(Элемент);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ПередЭлементомФормы) Тогда
		ПередЭлементом = Элементы.Найти(ПолучитьИмяЭлементаФормы("ВходящееСообщение", ПередЭлементомФормы));
		Если ПередЭлементом = Неопределено Тогда 	
			ПередЭлементом = Элементы.Найти(ПолучитьИмяЭлементаФормы("ИсходящееСообщение", ПередЭлементомФормы));
		КонецЕсли;
	КонецЕсли;

	
	Элемент = Элементы.Вставить(ИмяЭлемента, Тип("ДекорацияФормы"), Элементы.СторінкаІсторія, ПередЭлементом);
	Элемент.Вид = ВидДекорацииФормы.Надпись;
	Элемент.Заголовок = Формат(Дата, "ДФ='dd MMMM'");
	Элемент.ГоризонтальноеПоложениеВГруппе = ГоризонтальноеПоложениеЭлемента.Центр;
	Элемент.РастягиватьПоГоризонтали = Истина;
	Элемент.ГоризонтальноеПоложение = ГоризонтальноеПоложениеЭлемента.Центр;
	Элемент.ЦветФона = Новый Цвет(240,240,235);


	СписокСозданыхЭлементов.Добавить(Элемент.Имя);
КонецПроцедуры

