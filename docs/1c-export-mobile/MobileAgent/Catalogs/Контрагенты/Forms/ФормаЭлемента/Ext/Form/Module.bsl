&НаСервере
Процедура РедагуавтиЗаписІсторії(УИД_Запису)
	
	    	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Данный фрагмент построен конструктором.
	// При повторном использовании конструктора, внесенные вручную изменения будут утеряны!!!
	УИД = Новый УникальныйИдентификатор(УИД_Запису);	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РаботаСКлиентом.Запись КАК Запись,
		|	РаботаСКлиентом.УИД_Записи КАК УИД_Записи
		|ИЗ
		|	РегистрСведений.РаботаСКлиентом КАК РаботаСКлиентом
		|ГДЕ
		|	РаботаСКлиентом.УИД_Записи = &УИД_Записи";
	
	Запрос.УстановитьПараметр("УИД_Записи", УИД);
	
	
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда 
		ТекстИстории = Выборка.Запись;
		УИД_РедагуванняЗапису = УИД;
