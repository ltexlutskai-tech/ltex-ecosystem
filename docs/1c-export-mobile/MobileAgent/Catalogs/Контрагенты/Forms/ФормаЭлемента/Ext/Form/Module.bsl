&НаКлиенте
Процедура ЗаписатьИсториюНажатие(Элемент)
	
	Записать();
	
	Если мСообщение = "" Тогда 
		Возврат;
	КонецЕсли;
	
	ТекстИстории = мСообщение;
	
	Если ЗначениеЗаполнено(УИД_РедагуванняЗапису) Тогда 
		ИсторияРаботиСКлиентом_РедагуванняЗапису();
		Элементы.СкасуватиРедагування.Видимость = Ложь;	
	Иначе
		ИсторияРаботиСКлиентом_ЗаписатьИсторию();
	КонецЕсли;
	мСообщение = "";
	Прочитать();
	
	
КонецПроцедуры

