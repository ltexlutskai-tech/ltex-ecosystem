		И Объект.КонтактВайбер.Новый Тогда
		
		Запись = РегистрыСведений.РегистрацияОбмена.СоздатьМенеджерЗаписи();
		ЗАпись.Объект = Объект.Ссылка;
		Запись.ид = Новый УникальныйИдентификатор;
		Запись.Записать();
		
		
		Спр = Объект.КонтактВайбер.ПолучитьОбъект();
		Спр.Новый = Ложь;
		Спр.Контрагент = Объект.Ссылка;
		Спр.Наименование = Объект.Наименование;

		Спр.Записать();
		
		
		ViberОбновлениеСервер.ОтправитьКонтрагентаНаСервере(Объект.КонтактВайбер, Объект.Ссылка);
		
	КонецЕсли;	
	
	
