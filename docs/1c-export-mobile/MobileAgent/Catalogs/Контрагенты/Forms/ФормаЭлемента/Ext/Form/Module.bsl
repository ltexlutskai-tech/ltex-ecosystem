&НаСервере
Процедура ОновитиПрезентаціїНаСервере(Ответ)
	Ответ = Новый Структура;
	Ответ.Вставить("Успех", Истина);
	
	Пароль = Константы.ПарольВхода.Получить();
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Контрагент", Объект.Ссылка.УникальныйИдентификатор());
	ПараметрыКоманды.Вставить("НачалоПериодаПродаж", НачалоПериодаПрезентаций);
	ПараметрыКоманды.Вставить("КонецПериодаПродаж", КонецДня(КонецПериодаПрезентаций));
	
	
	Данные = Новый Структура;
	Данные.Вставить("Команда", "ПолучитьОтчетПрезентацииПоКонтрагенту");
	Данные.Вставить("Параметры", ПараметрыКоманды);
	
	Попытка 
		Прокси = СоединениеСБазой.ПолучитьПрокси();
		СтруктураОтветаПоОтчету = Прокси.ВыполнитьКоманду(Пароль, Обмен_УправлениеОбменом.Сериализовать(Данные)).Получить();
	Исключение
		СтруктураОтветаПоОтчету = Новый Структура;
		СтруктураОтветаПоОтчету.Вставить("Успешно", Ложь);
		СтруктураОтветаПоОтчету.Вставить("Ошибка", ОписаниеОшибки());
	КонецПопытки;

	Если Не СтруктураОтветаПоОтчету.Успешно Тогда
		Ответ.Вставить("Успешно",Ложь);
		Ответ.Вставить("Ошибка", СтруктураОтветаПоОтчету.Ошибка);
		Возврат;
	КонецЕсли;
	
	ТЗОтчетПоПрезентациям = СтруктураОтветаПоОтчету.Данные;	
	
	ТЗОтчетПоПрезентациям.Колонки.Добавить("Контрагент");
	ТЗОтчетПоПрезентациям.Колонки.Добавить("Номенклатура");
	
	Для Каждого стрОтчета Из ТЗОтчетПоПрезентациям Цикл
		стрОтчета.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(стрОтчета.УИДКонтрагент);
		стрОтчета.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(стрОтчета.УИДНоменклатура);
	КонецЦикла;	
	
	//ОтчетПоПродажам.Очистить(); 
	
	ТЗОтчетПоПрезентациямПоМесяцам = ТЗОтчетПоПрезентациям.Скопировать();
	ТЗОтчетПоПрезентациямПоМесяцам.Свернуть("ПериодНачалоМесяца", "Количество");

	ОтчетПоПрезентациямДеревоЗначение = РеквизитФормыВЗначение("ОтчетПоПрезентациямДерево");
	ОтчетПоПрезентациямДеревоЗначение.Строки.Очистить();
		
	
	Для Каждого стрОтчетаЗаМесяц Из ТЗОтчетПоПрезентациямПоМесяцам Цикл
		НоваяСтрокаРодитель = ОтчетПоПрезентациямДеревоЗначение.Строки.Добавить();	
		НоваяСтрокаРодитель.Период = стрОтчетаЗаМесяц.ПериодНачалоМесяца;
		НоваяСтрокаРодитель.Количество = стрОтчетаЗаМесяц.Количество;
		Для Каждого стрОтчета Из ТЗОтчетПоПрезентациям Цикл
			Если Не НачалоМесяца(стрОтчета.Период) = стрОтчетаЗаМесяц.ПериодНачалоМесяца Тогда
				Продолжить;
			КонецЕсли;	
			НоваяСтрока = НоваяСтрокаРодитель.Строки.Добавить();
	        НоваяСтрока.Период = стрОтчета.Период;
			НоваяСтрока.Артикул = стрОтчета.Номенклатура.Артикул;
			НоваяСтрока.Номенклатура = стрОтчета.Номенклатура;
			НоваяСтрока.Коментар = стрОтчета.Коментар;
			НоваяСтрока.КоментарМенеджера = стрОтчета.КоментарМенеджера;
			НоваяСтрока.Количество = стрОтчета.Количество;
		КонецЦикла;	
	КонецЦикла;   	
	
	ЗначениеВРеквизитФормы(ОтчетПоПрезентациямДеревоЗначение, "ОтчетПоПрезентациямДерево");	
	Элементы.ОтчетПоПрезентациямДеревоКоличество.ТекстПодвала = ТЗОтчетПоПрезентациямПоМесяцам.Итог("Количество")	

КонецПроцедуры

&НаКлиенте
Процедура ОновитиПрезентації(Команда)
	
	Перем ДанныеПроверки; 
	
	ОновитиПрезентаціїНаСервере(ДанныеПроверки);
	 
	Если ДанныеПроверки.Свойство("Ошибка") Тогда 
		Предупреждение(ДанныеПроверки.Ошибка);
	КонецЕсли;

КонецПроцедуры

