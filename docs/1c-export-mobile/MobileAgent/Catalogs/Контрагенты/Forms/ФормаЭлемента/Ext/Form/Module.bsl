	Для Каждого стрОтчета Из ТЗОтчетПоПродажам Цикл
		стрОтчета.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(стрОтчета.УИДКонтрагент);
		стрОтчета.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(стрОтчета.УИДНоменклатура);
	КонецЦикла;	
	
	//ОтчетПоПродажам.Очистить(); 
	
	ТЗОтчетПоПродажамПоМесяцам = ТЗОтчетПоПродажам.Скопировать();
	ТЗОтчетПоПродажамПоМесяцам.Свернуть("Период", "Количество");
	
	//Для Каждого стрОтчетаЗаМесяц Из ТЗОтчетПоПродажамПоМесяцам Цикл
	//	НоваяСтрока = ОтчетПоПродажам.Добавить();	
	//	НоваяСтрока.Период = стрОтчетаЗаМесяц.Период;
	//	НоваяСтрока.Количество = стрОтчетаЗаМесяц.Количество;
	//	Для Каждого стрОтчета Из ТЗОтчетПоПродажам Цикл
	//		Если Не стрОтчета.Период = стрОтчетаЗаМесяц.Период Тогда
	//			Продолжить;
	//		КонецЕсли;	
	//		НоваяСтрока = ОтчетПоПродажам.Добавить();
	//        НоваяСтрока.Период = стрОтчета.Период;
	//		НоваяСтрока.Артикул = стрОтчета.Номенклатура.Артикул;
	//		НоваяСтрока.Номенклатура = стрОтчета.Номенклатура;
	//		НоваяСтрока.Количество = стрОтчета.Количество;
	//	КонецЦикла;	
	//КонецЦикла;   	
	//
	//Элементы.ОтчетПоПродажамКоличество.ТекстПодвала = ТЗОтчетПоПродажам.Итог("Количество");

	ОтчетПоПродажамДеревоЗначение = РеквизитФормыВЗначение("ОтчетПоПродажамДерево");
	ОтчетПоПродажамДеревоЗначение.Строки.Очистить();
		
	
	Для Каждого стрОтчетаЗаМесяц Из ТЗОтчетПоПродажамПоМесяцам Цикл
		НоваяСтрокаРодитель = ОтчетПоПродажамДеревоЗначение.Строки.Добавить();	
		НоваяСтрокаРодитель.Период = стрОтчетаЗаМесяц.Период;
		НоваяСтрокаРодитель.Количество = стрОтчетаЗаМесяц.Количество;
		Для Каждого стрОтчета Из ТЗОтчетПоПродажам Цикл
			Если Не стрОтчета.Период = стрОтчетаЗаМесяц.Период Тогда
				Продолжить;
			КонецЕсли;	
			НоваяСтрока = НоваяСтрокаРодитель.Строки.Добавить();
	        //НоваяСтрока.Период = стрОтчета.Период;
			НоваяСтрока.Артикул = стрОтчета.Номенклатура.Артикул;
			НоваяСтрока.Номенклатура = стрОтчета.Номенклатура;
			НоваяСтрока.Количество = стрОтчета.Количество;
		КонецЦикла;	
	КонецЦикла;   	
	
	ЗначениеВРеквизитФормы(ОтчетПоПродажамДеревоЗначение, "ОтчетПоПродажамДерево");	
	Элементы.ОтчетПоПродажамДеревоКоличество.ТекстПодвала = ТЗОтчетПоПродажам.Итог("Количество")	
	
