Процедура ОновитиПродажіНаСервере(Ответ)
	Ответ = Новый Структура;
	Ответ.Вставить("Успех", Истина);
	
	Пароль = Константы.ПарольВхода.Получить();
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("Контрагент", Объект.Ссылка.УникальныйИдентификатор());
	ПараметрыКоманды.Вставить("НачалоПериодаПродаж", НачалоПериодаПродаж);
	ПараметрыКоманды.Вставить("КонецПериодаПродаж", КонецДня(КонецПериодаПродаж));
	
	
