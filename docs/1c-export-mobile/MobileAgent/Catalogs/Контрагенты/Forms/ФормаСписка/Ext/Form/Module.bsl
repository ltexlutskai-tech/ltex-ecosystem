&НаКлиенте
Процедура ФільтрТорговыйАгентПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(ФільтрТорговыйАгент) Тогда 
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[8].Использование = Ложь;
	Иначе  
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[8].Использование 	= Истина;
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[8].ВидСравнения 	= ВидСравненияКомпоновкиДанных.Равно;
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[8].ПравоеЗначение	= ФільтрТорговыйАгент;		
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПолучитьСписокСылокКонтрагентовДляОтбораПоИтории(ФільтрИстория)
	СписокДляОтбора = Новый СписокЗначений;
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РаботаСКлиентом.Клиент КАК Клиент,
		|	РаботаСКлиентом.Запись КАК Запись
		|ИЗ
		|	РегистрСведений.РаботаСКлиентом КАК РаботаСКлиентом
		|ГДЕ
		|	РаботаСКлиентом.Запись ПОДОБНО &Запись";
	
	Запрос.УстановитьПараметр("Запись", "%" + ФільтрИстория + "%");
	
	ТЗРезультатЗапроса = Запрос.Выполнить().Выгрузить();
	СписокДляОтбора.ЗагрузитьЗначения(ТЗРезультатЗапроса.ВыгрузитьКолонку("Клиент"));
	
	Возврат СписокДляОтбора;	
КонецФункции

&НаКлиенте
Процедура ФільтрИсторияПриИзменении(Элемент)
	Если Не ЗначениеЗаполнено(ФільтрИстория) Тогда 
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[3].Использование = Ложь;
	Иначе  
		СписокКонтрагентовДляФильтра = ПолучитьСписокСылокКонтрагентовДляОтбораПоИтории(ФільтрИстория);
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[3].Использование 	= Истина;
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[3].ВидСравнения 	= ВидСравненияКомпоновкиДанных.ВСписке;
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[3].ПравоеЗначение	= СписокКонтрагентовДляФильтра;		
	КонецЕсли;


КонецПроцедуры

&НаКлиенте
Процедура ОтборазитьКнопкуНовыеУведомления()Экспорт
	
	СписокНовых = ПолучитьСписокНовыхУведомлений();
	Если СписокНовых > 0 Тогда
		Элементы.НовыеУведомления.Заголовок = "Нові повідомлення (" + СписокНовых + ")";
		Если НЕ ФильтрТолькоНовые Тогда
			Элементы.НовыеУведомления.ЦветФона  = Новый Цвет(191, 255, 194);
		Иначе
			Элементы.НовыеУведомления.ЦветФона  = Новый Цвет(255, 99, 125);
		КонецЕсли;	
	Иначе
		Элементы.НовыеУведомления.Заголовок = "Нові повідомлення";
		Элементы.НовыеУведомления.ЦветФона  = Новый Цвет();
	КонецЕсли;	
	
		
КонецПроцедуры

