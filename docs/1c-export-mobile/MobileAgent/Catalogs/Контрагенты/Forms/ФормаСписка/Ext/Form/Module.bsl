&НаКлиенте
Процедура НовыеУведомления(Команда)
	
	Если НЕ ФильтрТолькоНовые Тогда
		ФильтрТолькоНовые = Истина;
	Иначе
		ФильтрТолькоНовые = Ложь;
	КонецЕсли;	
	
	Если НЕ ФильтрТолькоНовые Тогда 
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[8].Использование = Ложь;
		Элементы.НовыеУведомления.ЦветФона  = Новый Цвет();
	Иначе 
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[8].Использование 	= Истина;
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[8].ВидСравнения 	= ВидСравненияКомпоновкиДанных.Равно;
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[8].ПравоеЗначение	= Истина;
		Элементы.НовыеУведомления.ЦветФона  = Новый Цвет(255, 99, 125);
	КонецЕсли; 
	
	
	
КонецПроцедуры

&НаКлиенте
Процедура ФільтрКлючовіСловаАбоПриИзменении(Элемент)
	
	Отбор = Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[10];
	Отбор.ПравоеЗначение = ФільтрКлючовіСлова.Количество();
	Отбор.Использование = ФільтрКлючовіСлова100;

КонецПроцедуры

&НаСервере
Процедура ПошукПоТелефонуНаСервере(Телефон)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Ссылка,
	|	Контрагенты.ТорговыйАгент КАК ТорговыйАгент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.НомерТелефона ПОДОБНО &Телефон";
	
	Запрос.УстановитьПараметр("Телефон", "%" + Прав(Телефон, 10) + "%");
	
		
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если  Выборка.Следующий() Тогда 
		Отказ = истина;
		Сообщить("" + Выборка.Ссылка + " відповідальний "  + Выборка.ТорговыйАгент); 
	КонецЕсли;	
	
	
	Если Отказ = истина 
		Или Телефон = "" Тогда 
		Возврат;
	КонецЕсли;
	
	Ответ = Общий.ПоискДублейНомеровТелефона_НаСервере1С(Прав(Телефон, 10), Справочники.Контрагенты.ПустаяСсылка(), Истина);
	
	Если Ответ.Успешно Тогда 
		Если Ответ.Данные.ЕстьДубли Тогда 
			Отказ = истина;
			Сообщить(Ответ.Данные.ТекстОшибки);
		КонецЕсли;
		
		
		Возврат; 
	Иначе
		Сообщить("Контроль унікальності контрагента виконано лише в додатку. Не має підключення до 1С!");
	КонецЕсли;
	

КонецПроцедуры

&НаКлиенте
Процедура ПошукПоТелефону(Команда)
	Телефон = "";
	Если Не ВвестиСтроку(Телефон, "Номер телефону") Тогда 
		Возврат;
	КонецЕсли;
	
	ПошукПоТелефонуНаСервере(Телефон);
КонецПроцедуры

