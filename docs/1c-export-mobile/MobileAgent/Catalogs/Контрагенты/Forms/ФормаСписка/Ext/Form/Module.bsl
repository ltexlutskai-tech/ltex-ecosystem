&НаКлиенте
Процедура ФільтрКлючовіСловаПриИзменении(Элемент)
	
	
	ОтборУсловие = Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[9];
	ОтборУсловие.Элементы.Очистить();
ОтборУсловие.Использование = Истина;
	
	Если Не ЗначениеЗаполнено(ФільтрКлючовіСлова) Тогда 
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[7].Использование = Ложь;
		ОтборУсловие.Использование = Ложь;

	Иначе  
		
		Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[7].Использование = Истина;
		ОтборУсловие.Использование = Истина;
		
		Для Каждого Элемент Из ФільтрКлючовіСлова Цикл 
			Отбор = ОтборУсловие.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
			Отбор.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("КлючовіСлова");
			Отбор.ПравоеЗначение = Элемент.Значение;
			Отбор.ВидСравнения = ВидСравненияКомпоновкиДанных.Содержит;
			Отбор.Использование = Истина;
		КонецЦикла;
	КонецЕсли;

	Отбор = Список.КомпоновщикНастроек.Настройки.Отбор.Элементы[10];
	Отбор.ПравоеЗначение = ФільтрКлючовіСлова.Количество();
	Отбор.Использование = ФільтрКлючовіСлова100;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьАнализКлиентскойБазыНаСервере()
	ТабДокумент = Новый ТабличныйДокумент;
	
	ТаблицаСписка = СписокВКоллекциюЗначений();
	
	МассивКлиентов = ТаблицаСписка.ВыгрузитьКолонку("Ссылка");
	
	СписокКонтрагентов = Новый СписокЗначений;
	СписокКонтрагентов.ЗагрузитьЗначения(МассивКлиентов);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка
		|ПОМЕСТИТЬ ТабКОнрагентв
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.Ссылка В(&Ссылка)
		|
		|СГРУППИРОВАТЬ ПО
		|	Контрагенты.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РаботаСКлиентом.Клиент КАК Клиент,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РаботаСКлиентом.УИД_Записи) КАК КоличествоЗаписейПоКонтрагенту
		|ПОМЕСТИТЬ ТабРботкКлиентов
		|ИЗ
		|	РегистрСведений.РаботаСКлиентом КАК РаботаСКлиентом
		|ГДЕ
		|	РаботаСКлиентом.Период >= &НачалоНедели
		|	И РаботаСКлиентом.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	РаботаСКлиентом.Клиент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РаботаСКлиентом.Клиент КАК Клиент,
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РаботаСКлиентом.УИД_Записи) КАК КоличествоЗаписейПоКонтрагентуСНачалаДня
		|ПОМЕСТИТЬ ТабРботкКлиентовСНачалаДня
		|ИЗ
		|	РегистрСведений.РаботаСКлиентом КАК РаботаСКлиентом
		|ГДЕ
		|	РаботаСКлиентом.Период >= &НачалоДня
		|	И РаботаСКлиентом.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом = ЛОЖЬ
		|
		|СГРУППИРОВАТЬ ПО
		|	РаботаСКлиентом.Клиент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТабКОнрагентв.Ссылка КАК Контрагент,
		|	1 КАК КлиентскаяБаза,
		|	ЕСТЬNULL(ТабРботкКлиентов.КоличествоЗаписейПоКонтрагенту, 0) КАК ОбработаноКонтрагентов,
		|	1 КАК ОсталосьОбработать,
		|	ЕСТЬNULL(ТабРботкКлиентовСНачалаДня.КоличествоЗаписейПоКонтрагентуСНачалаДня, 0) КАК ОбработаноКонтрагентовСНачалаДня
		|ИЗ
		|	ТабКОнрагентв КАК ТабКОнрагентв
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТабРботкКлиентов КАК ТабРботкКлиентов
		|		ПО ТабКОнрагентв.Ссылка = ТабРботкКлиентов.Клиент
		|		ЛЕВОЕ СОЕДИНЕНИЕ ТабРботкКлиентовСНачалаДня КАК ТабРботкКлиентовСНачалаДня
		|		ПО ТабКОнрагентв.Ссылка = ТабРботкКлиентовСНачалаДня.Клиент";
	
	Запрос.УстановитьПараметр("НачалоНедели", НачалоНедели(ТекущаяДата()));
	Запрос.УстановитьПараметр("НачалоДня", НачалоДня(ТекущаяДата()));
	Запрос.УстановитьПараметр("Ссылка", СписокКонтрагентов);
	
	ТЗКонтрагентов = Запрос.Выполнить().Выгрузить();
	
	ТЗКонтрагентов.Колонки.Добавить("УИДКонтрагент");
	
	Для Каждого стрКонтрагент ИЗ ТЗКонтрагентов Цикл
		стрКонтрагент.УИДКонтрагент = стрКонтрагент.Контрагент.УникальныйИдентификатор();		
		Если стрКонтрагент.ОбработаноКонтрагентов > 0 Тогда
			стрКонтрагент.ОбработаноКонтрагентов = 1;
			стрКонтрагент.ОсталосьОбработать = 0;
		КонецЕсли; 	
		Если стрКонтрагент.ОбработаноКонтрагентовСНачалаДня > 0 Тогда
			стрКонтрагент.ОбработаноКонтрагентовСНачалаДня = 1;
		КонецЕсли;		
	КонецЦикла;	                                                                         
	
	ТЗКонтрагентов.Колонки.Удалить("Контрагент");
	
	Ответ = Новый Структура;
	Ответ.Вставить("Успех", Истина);
	
	Пароль = Константы.ПарольВхода.Получить();
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("ТЗКонтрагентов", ТЗКонтрагентов);

	Данные = Новый Структура;
	Данные.Вставить("Команда", "ПолучитьАнализКлиентскойБазы");
	Данные.Вставить("Параметры", ПараметрыКоманды);
	
	Попытка 
		Прокси = СоединениеСБазой.ПолучитьПрокси();
		СтруктураОтветаАнализуКилентскойБазы = Прокси.ВыполнитьКоманду(Пароль, Обмен_УправлениеОбменом.Сериализовать(Данные)).Получить();
	Исключение
		СтруктураОтветаАнализуКилентскойБазы = Новый Структура;
		СтруктураОтветаАнализуКилентскойБазы.Вставить("Успешно", Ложь);
		СтруктураОтветаАнализуКилентскойБазы.Вставить("Ошибка", ОписаниеОшибки());
	КонецПопытки;

	Если Не СтруктураОтветаАнализуКилентскойБазы.Успешно Тогда
		Сообщить("Полика запиту до сервера");
		Сообщить(СтруктураОтветаАнализуКилентскойБазы.Ошибка);
		Возврат Неопределено;
	Иначе
		ТабДокумент = СтруктураОтветаАнализуКилентскойБазы.Данные;		
	КонецЕсли;

	Возврат ТабДокумент;
КонецФункции

&НаКлиенте
Процедура АнализКлиентскойБазы(Команда)
	ТабДокумент = ПолучитьАнализКлиентскойБазыНаСервере();
	Если Не ТабДокумент = Неопределено Тогда
		ТабДокумент.Показать("Аналіз клієнтської бази");
	КонецЕсли;	
КонецПроцедуры


&НаСервере
Функция СписокВКоллекциюЗначений()
	
	//Получаем схема компановки данных (здесь хранится текст запроса)
	Схема = Элементы.Список.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	
	//Получаем настройки пользователя (отборы, сортировки и т.п.)
	Настройки = Элементы.Список.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	
	//Выводим динамический список в таблицу значений
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных();
	МакетКомпоновки = КомпоновщикМакета.Выполнить(Схема, Настройки, , ,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	Результат = ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	//Возвращаем полученную таблицу значений
	Возврат  Результат;
	
КонецФункции


