
Процедура  ИнфоБорг(Объект, ЭлементБоргу) Экспорт
	БоргиКлієнта = Общий.ОтриматиБоргиКлієнта(Объект.Контрагент);
	Текст = "";
	//если Не Объект.ПершаФорма  тогда
		Борг = БоргиКлієнта.Борг;
		ПростроченийБорг = БоргиКлієнта.ПросроченийБорг; 
	//иначе
	//	Борг = БоргиКлієнта.БоргТзОВ;
	//	ПростроченийБорг = БоргиКлієнта.ПросроченийБоргТзОВ;
	//КонецЕсли;
	
	если Борг > 0 Тогда 
		ЭлементБоргу.ЦветТекста = WebЦвета.Красный;
		Попытка
			Текст = ?(Объект.Наложка, "Наложка: ", "Борг: ") +Борг+" EUR";
		Исключение
			Текст = "Борг: " +Борг+" EUR";
		КонецПопытки;
	иначеЕсли Борг < 0 Тогда 
		ЭлементБоргу.ЦветТекста = WebЦвета.Зеленый;
		Текст = "Переплата: " + (-Борг) + " EUR";
	КонецЕсли;
	если ПростроченийБорг > 0 И Борг > 0 Тогда
		если текст = "" тогда 
			ТекстПР =  "Прострочений борг: " + ПростроченийБорг+" EUR."; 
		иначе		
			ТекстПР =  ", прострочений борг: " + ПростроченийБорг+" EUR.";
		КонецЕсли;
	иначе 
		текстПр= "";
	КонецЕсли;
	ЭлементБоргу.Заголовок = Текст +ТекстПР;
КонецПроцедуры

