//////////// проверяем не идет ли шяс обновление ///////////////////////////////
Функция ИдетОбмен() Экспорт
	
	ТекстОшибки = "";
	Возврат ИдентификаторФоновогоЗадания <> Неопределено
		И НЕ ViberОбновлениеСервер.ОбменДаннымиЗакончен(ИдентификаторФоновогоЗадания, ТекстОшибки);
		
КонецФункции

///////////формируем запись новых сообщений ///////////////////////////////////
Процедура ПолучитьСписокНовыхОповещений()Экспорт
	
	//////// получаем список новых сообщений //////////////////
	Ответ = ViberОбновлениеСервер.ОбновитьСписокИсторииСообщений();
	Если Ответ <> Неопределено Тогда
		Если Ответ.Свойство("МассивСообщений") Тогда
			ViberОбновлениеСервер.ЗаписатьИсториюСообщенийВайбер(Ответ.МассивСообщений);		
		КонецЕсли;
		
		Если Ответ.Свойство("Шаблоны") Тогда
			ViberОбновлениеСервер.ОбновитьШаблоныВайбер(Ответ.Шаблоны);				
		КонецЕсли;	
	Иначе
		 #Если МобильноеПриложениеКлиент Тогда
			 Текст = "Помилка оновлення вайбер";  
			 СредстваМультимедиа.ВоспроизвестиТекст(Текст,,,,,Истина);
		 #Иначе
			 Текст = "Помилка оновлення вайбер";
			 Сообщить(Текст);
		 #КонецЕсли
	КонецЕсли;	
	

	
	
КонецПроцедуры	

//////////Делаем отправку сообщения н клиенте //////////////////////////////////
