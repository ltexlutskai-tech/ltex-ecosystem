Функция ОтправитьИзменения(Данные = Неопределено) Экспорт
	
	ИгнорироватьПерейти 	= Истина;
	з 						= Новый Запрос;
	СтруктураВозврата 		= Новый Структура;

	//~Контрагенты:

	Если Не Данные = Неопределено Тогда 
		ИгнорироватьПерейти = Ложь;
		Значение = Неопределено;
		Если  Данные.Свойство("Контрагенты", Значение) 
			И Значение = Истина Тогда
			
			Если Данные.Свойство("ОтборКонтрагент", Значение) Тогда 
				Отбор = Новый Структура;
				Отбор.Вставить("КонтрагентСсылка", Значение);
			КонецЕсли;
			
			Перейти ~Контрагенты;
		КонецЕсли;
		
		
		Перейти ~Возврат;

	КонецЕсли;
	
	
	
	
	//ПКО
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РегистрацияОбмена.Объект КАК Объект,
		|	РегистрацияОбмена.ИД КАК ИД,
		|	КассовыйОрдер.Дата КАК Дата,
		|	КассовыйОрдер.Проведен КАК Проведен,
		|	КассовыйОрдер.СумаUAH КАК СумаUAH,
		|	КассовыйОрдер.СумаUAH_Безнал КАК СумаUAH_Безнал,
		|	КассовыйОрдер.СумаEUR КАК СумаEUR,
		|	КассовыйОрдер.СумаUSD КАК СумаUSD,
		|	КассовыйОрдер.Основание КАК Основание,
		|	КассовыйОрдер.ПометкаУдаления КАК ПометкаУдаления,
		|	КассовыйОрдер.Контрагент КАК Контрагент,
		|	КассовыйОрдер.МаршрутныйЛист КАК МаршрутныйЛист,
		|	КассовыйОрдер.ЗаказПокупателя КАК ЗаказПокупателя,
		|	КассовыйОрдер.КурсUSD КАК КурсUSD,
		|	КассовыйОрдер.КурсEUR КАК КурсEUR,
		|	КассовыйОрдер.Номер КАК Номер,
		|	ВЫБОР
		|		КОГДА КассовыйОрдер.ВидДвиженияДенежныхСредств = ЗНАЧЕНИЕ(Перечисление.ВидДвиженияДенежныхСредств.Расход)
		|			ТОГДА ""Расход""
		|		ИНАЧЕ ""Приход""
		|	КОНЕЦ КАК ВидДвижения,
		|	КассовыйОрдер.УИДUSD КАК УИДUSD,
		|	КассовыйОрдер.УИДГРН КАК УИДГРН,
		|	КассовыйОрдер.КоректировкаДолга КАК КоректировкаДолга,
		|	КассовыйОрдер.БанковскийСчет КАК БанковскийСчет,
		|	КассовыйОрдер.СтатьяДвиженияДенежныхСредств КАК СтатьяДвиженияДенежныхСредств,
		|	ВЫБОР
		|		КОГДА КассовыйОрдер.СдачаДокумента = ЗНАЧЕНИЕ(Документ.КассовыйОрдер.ПустаяСсылка)
		|			ТОГДА ЛОЖЬ
		|		ИНАЧЕ ИСТИНА
		|	КОНЕЦ КАК Сдача,
		|	КассовыйОрдер.УИДКоректировки КАК УИДКоректировки
		|ИЗ
		|	РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.КассовыйОрдер КАК КассовыйОрдер
		|		ПО РегистрацияОбмена.Объект = КассовыйОрдер.Ссылка
		|ГДЕ
		|	КассовыйОрдер.Проведен
		|	И (КассовыйОрдер.Основание = ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)
		|			ИЛИ КассовыйОрдер.Основание.Архив
		|			ИЛИ КассовыйОрдер.Основание В
		|				(ВЫБРАТЬ
		|					РеализацияТоваровУслуг.Ссылка КАК Ссылка
		|				ИЗ
		|					РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
		|						ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|						ПО
		|							РегистрацияОбмена.Объект = РеализацияТоваровУслуг.Ссылка))";                  // ВивантажуватиВ1С
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	МассивПКО = Новый Массив;
	Пока Выборка.Следующий() Цикл 
		ПКО = Новый Структура("ИД, Дата, Номер, Проведен, СумаUAH, СумаUAH_Безнал, СумаEUR, СумаUSD, ПометкаУдаления, КурсEUR, КурсUSD, УИДUSD, УИДГРН, ВидДвижения, КоректировкаДолга, Сдача, УИДКоректировки");
		ЗаполнитьЗначенияСвойств(ПКО, Выборка);
		ПКО.Вставить("ПКО_УИД", 							Выборка.Объект.УникальныйИдентификатор()); 
		ПКО.Вставить("Реализация_УИД", 						Выборка.Основание.УникальныйИдентификатор());
		ПКО.Вставить("Контрагент_УИД", 						Выборка.Контрагент.УникальныйИдентификатор());
		ПКО.Вставить("МаршрутныйЛист_УИД", 					Выборка.МаршрутныйЛист.УникальныйИдентификатор());
		ПКО.Вставить("ЗаказПокупателя_УИД",					Выборка.ЗаказПокупателя.УникальныйИдентификатор());
		ПКО.Вставить("БанковскийСчет_УИД",  				Выборка.БанковскийСчет.УникальныйИдентификатор());
		ПКО.Вставить("СтатьяДвиженияДенежныхСредств_УИД",   Выборка.СтатьяДвиженияДенежныхСредств.УникальныйИдентификатор());
		
		МассивПКО.Добавить(ПКО);
	КонецЦикла;
	
	СтруктураВозврата.Вставить("ПКО", МассивПКО);
		
		//////////////// Продажи
	//з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	ЗаказТовары.Ссылка КАК СсылкаСсылка,
	          |	ЗаказТовары.Ссылка.Номер КАК Номер,
	          |	ЗаказТовары.Ссылка.Дата КАК Дата,
	          |	ЗаказТовары.Ссылка.Проведен КАК Проведен,
	          |	ЗаказТовары.Номенклатура КАК НоменклатураСсылка,
	          |	ЗаказТовары.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатурыСсылка,
	          |	ЗаказТовары.ЕдиницаИзмерения КАК ЕдиницаИзмеренияСсылка,
	          |	ЗаказТовары.Количество КАК Количество,
	          |	РегистрацияОбмена.ИД КАК ИД,
	          |	ЗаказТовары.Ссылка.Коментар КАК Комментарий,
	          |	ЗаказТовары.Цена КАК Цена,
	          |	ЗаказТовары.Ссылка.Контрагент КАК КонтрагентСсылка,
	          |	ЗаказТовары.Ссылка.ТипЦен КАК ТипЦенСсылка,
	          |	ЗаказТовары.Ссылка.ПершаФорма КАК ПершаФорма,
	          |	ЗаказТовары.Ссылка.СкладКонтрагента КАК СкладКонтрагентаСсылка,
	          |	ЗаказТовары.Ссылка.Широта КАК Широта,
	          |	ЗаказТовары.Ссылка.Долгота КАК Долгота,
	          |	ЗаказТовары.ЦенаПродажиВес КАК ЦенаПродажиВес,
	          |	ЗаказТовары.Ссылка.ПометкаУдаления КАК ПометкаУдаления,
	          |	ЗаказТовары.Ссылка.Наложка КАК Наложка,
	          |	ЗаказТовары.Ссылка.ПризначитиПродажТорговомуКонтрагента КАК ПризначитиПродажТорговомуКонтрагента
	          |ИЗ
	          |	РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
	          |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Заказ.Товары КАК ЗаказТовары
	          |		ПО РегистрацияОбмена.Объект = ЗаказТовары.Ссылка";
	ТаблицаПродаж = з.Выполнить().Выгрузить();
	
	ТаблицаПродаж.Колонки.Добавить("Ссылка");
	ТаблицаПродаж.Колонки.Добавить("Номенклатура");
	ТаблицаПродаж.Колонки.Добавить("ХарактеристикаНоменклатуры");
	ТаблицаПродаж.Колонки.Добавить("ЕдиницаИзмерения");
	ТаблицаПродаж.Колонки.Добавить("Контрагент");
	ТаблицаПродаж.Колонки.Добавить("ТипЦен");
	ТаблицаПродаж.Колонки.Добавить("СкладКонтрагента");
	ТаблицаПродаж.Колонки.Добавить("Оплата");
	ТаблицаПродаж.Колонки.Добавить("Доставка");
	Для Каждого Строка Из ТаблицаПродаж Цикл
		
		Строка.Ссылка = Строка.СсылкаСсылка.УникальныйИдентификатор();
		Строка.Номенклатура = Строка.НоменклатураСсылка.УникальныйИдентификатор();
		Строка.ХарактеристикаНоменклатуры = Строка.ХарактеристикаНоменклатурыСсылка.УникальныйИдентификатор();
		Строка.ЕдиницаИзмерения = Строка.ЕдиницаИзмеренияСсылка.УникальныйИдентификатор();
		Строка.Контрагент = Строка.КонтрагентСсылка.УникальныйИдентификатор();

		Строка.Оплата = Строка(Строка.СсылкаСсылка.Оплата); 
		Строка.Доставка = Строка(Строка.СсылкаСсылка.Доставка); 

		Строка.ТипЦен = Строка.ТипЦенСсылка.УникальныйИдентификатор();
		Строка.СкладКонтрагента = Строка.СкладКонтрагентаСсылка.УникальныйИдентификатор();

		
	КонецЦикла;
	ТаблицаПродаж.Колонки.Удалить("СсылкаСсылка");
	ТаблицаПродаж.Колонки.Удалить("НоменклатураСсылка");
	ТаблицаПродаж.Колонки.Удалить("ХарактеристикаНоменклатурыСсылка");
	ТаблицаПродаж.Колонки.Удалить("ЕдиницаИзмеренияСсылка");
	ТаблицаПродаж.Колонки.Удалить("СкладКонтрагентаСсылка");
	СтруктураВозврата.Вставить("Заказы",ТаблицаПродаж);

	
	//////////////// Реализации
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	Реализация.Ссылка КАК СсылкаСсылка,
	          |	Реализация.Ссылка.Номер КАК Номер,
	          |	Реализация.Ссылка.Дата КАК Дата,
