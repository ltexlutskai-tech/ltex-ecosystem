Функция СформироватьПакетДанныхИсторияРаботыСКлиентом(ДатаОбновления)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	РаботаСКлиентом.Период КАК Период,
		|	РаботаСКлиентом.Клиент КАК Клиент,
		|	РаботаСКлиентом.Запись КАК Запись,
		|	РаботаСКлиентом.УИД_Записи КАК УИД_Записи,
		|	РаботаСКлиентом.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом КАК АвтоматичнийЗаписБезВзаємодіїЗКлієнтом
		|ИЗ
		|	РегистрСведений.РаботаСКлиентом КАК РаботаСКлиентом
		|ГДЕ
		|	РаботаСКлиентом.Период > &ДатаОбновления";
	
	Запрос.УстановитьПараметр("ДатаОбновления", ДатаОбновления);
	
	История = Запрос.Выполнить().Выгрузить();
	История.Колонки.Добавить("КлиентУИД");
	Для Каждого Элемент Из История Цикл 
		Элемент.КлиентУИД = Элемент.Клиент.УникальныйИдентификатор();
	КонецЦикла;
	Возврат История;
КонецФункции
