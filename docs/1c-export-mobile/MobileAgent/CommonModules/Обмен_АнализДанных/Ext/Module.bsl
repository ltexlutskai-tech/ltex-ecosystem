				НоваяСтрока.ХарактеристикаНоменклатуры  = ХарактеристикаНоменклатуры;
				НоваяСтрока.ЕдиницаИзмерения            = Справочники.ЕдиницыИзмерения.ПолучитьСсылку(Элемент.ЕдиницаИзмерения);
				НоваяСтрока.Количество                  = Элемент.Количество;
				НоваяСтрока.Цена                       	= Элемент.Цена;
				НоваяСтрока.Сумма                       = Элемент.Сумма;
				НоваяСтрока.Штрихкод                    = Элемент.Штрихкод;
				Попытка
					НоваяСтрока.Вес                  		= ХарактеристикаНоменклатуры.Вага;
				Исключение
				КонецПопытки;
				НоваяСтрока.ЦенаПродажиВес              = Элемент.ЦенаПродажиВес;
			КонецЦикла;			
			НовыйОбъект.Заказы.Свернуть("ЗаказПокупателя, Город, Контрагент");
			
			НовыйОбъект.НеХватает.Очистить();
			Если НЕ НеХватает = Неопределено Тогда 
				
				Для Каждого Элемент Из НеХватает Цикл 
					СтрокаНеХватает = НовыйОбъект.НеХватает.Добавить();
					СтрокаНеХватает.ЗаказПокупателя = Документы.Заказ.ПолучитьСсылку(Элемент.Заказ);
					СтрокаНеХватает.Номенклатура 	= Справочники.Номенклатура.ПолучитьСсылку(Элемент.Номенклатура);
					СтрокаНеХватает.Количество 		= Элемент.НеХватает;
				КонецЦикла;
				
				
			КонецЕсли;
			
			
			НовыйОбъект.Записать(РежимЗаписиДокумента.Проведение);
			НовСтр = ТаблицаИД.Добавить();
			НовСтр.ИД = СтрокаДанныеЭлемента.ИД;
			МассивДокументов.Добавить(НовыйОбъект.Ссылка)
		КонецЦикла;	
	КонецЕсли;
	
	Для Каждого ДокСсылка Из МассивДокументов Цикл
		ДокОб = ДокСсылка.ПолучитьОбъект();
		Если ДокСсылка.ПометкаУдаления Тогда 
			Продолжить;
		КонецЕсли;

		Попытка
			ДокОб.мЭтоОбмен = Истина;
		Исключение
		КонецПопытки;
		
		Попытка
		ДокОб.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		Исключение
		КонецПопытки;

	КонецЦикла;
	
	Для Каждого ДокСсылка Из МассивДокументов Цикл
		Если ДокСсылка.Проведен Или ДокСсылка.ПометкаУдаления Тогда 
			Продолжить;
		КонецЕсли;
		
			
		ДокОб = ДокСсылка.ПолучитьОбъект();
		Попытка
			ДокОб.мЭтоОбмен = Истина;
		Исключение
		КонецПопытки;
		
		Попытка
		ДокОб.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		Исключение
		КонецПопытки;

	КонецЦикла;

	
КонецПроцедуры


#КонецОбласти

#Область Месенджер_в_1с

Процедура ПринятьПакетДляМесенджера(Данные, дата)  Экспорт 
	//	Ответ.Вставить("Групы", тзЧаты); 
	//Ответ.Вставить("Учасники", тзУчасники);
	//Ответ.Вставить("ВходящиеСообщения", тзВходящиеСообщения);
	//Ответ.Вставить("ИсходящиеСообщения", тзИсходящиеСообщения);	
	Если Данные.Свойство("Групы") Тогда 
		СоздатьЭлементыСправочника("ГруппыЧата", Данные.Групы,);
	КонецЕсли;
	
	Если Данные.Свойство("Учасники") Тогда 
		СоздатьЭлементыСправочника("УчасникиЧата", Данные.Учасники,);
	КонецЕсли;
	
	Если Данные.Свойство("ВходящиеСообщения") Тогда 
		ЗаписатьВходящиеСообщения(Данные.ВходящиеСообщения);
	КонецЕсли;
	
	Если Данные.Свойство("ИсходящиеСообщения") Тогда 
		ЗаписатьИсходящиеСообщения(Данные.ИсходящиеСообщения);
	КонецЕсли;
	
	Если Данные.Свойство("НепрочитаныеСообщения") Тогда 
		ЗаписатьНепрочитанныеСообщения(Данные.НепрочитаныеСообщения);
	КонецЕсли;
	
	Если Данные.Свойство("УдаленныеСообщения") Тогда 
		ЗаписатьУдаленныеСообщения(Данные.УдаленныеСообщения);
	КонецЕсли;
	
	Если Данные.Свойство("Реакции") Тогда 
		ЗаписатьРеакцииНаСообщений(Данные.Реакции);
	КонецЕсли;

	Если Данные.Свойство("Уведомления") Тогда 
		ЗаписатьЗапланированыеУведомления(Данные.Уведомления)
	КонецЕсли;
	
	Если Данные.Свойство("ИсторияКлиента") Тогда 
		ЗаписатьИсториюКлиента(Данные.ИсторияКлиента)
	КонецЕсли;
	
	//мдата = ТекущаяДата();
	Если Данные.Свойство("Резервы") Тогда 
		ЗаписатьРезервы(Данные.Резервы);	
	КонецЕсли;
	//мдата = ТекущаяДата() - мдата;

	Если Данные.Свойство("АктуальныеЗаказы") Тогда 
		ЗаписатьИнфуОАктуальнихЗаказах(Данные.АктуальныеЗаказы)
	КонецЕсли;
	
	
	Константы.ДатаОбновлениеСообщений.Установить(ТекущаяДата() - 600);
	
КонецПроцедуры

Процедура ЗаписатьВходящиеСообщения(Данные)
	Набор = РегистрыСведений.ВходящиеСообщения.СоздатьНаборЗаписей();	
	
	Для Каждого Элемент Из Данные Цикл 
		
		Набор.Очистить();
		Набор.Отбор.Уид_Сообщения.Установить(Элемент.Уид_Сообщения);
		
		Запись = Набор.Добавить();
		Запись.Дата = Элемент.Период;
		Запись.Відправник = Справочники.УчасникиЧата.ПолучитьСсылку(Элемент.УИДВідправник);
		Запись.ГруппаЧата = ?( Элемент.ПолучательГруппа,Справочники.ГруппыЧата.ПолучитьСсылку(Элемент.УИДОдержувач),  Справочники.ГруппыЧата.ПустаяСсылка());
		Запись.Уид_Сообщения = Элемент.Уид_Сообщения;
		Запись.Повідомлення = Элемент.Повідомлення;
		
		Набор.Записать();
		
	КонецЦикла;
КонецПроцедуры

Процедура ЗаписатьИсходящиеСообщения(Данные)
	Набор = РегистрыСведений.ИсходящиеСообщения.СоздатьНаборЗаписей();	
	
	Для Каждого Элемент Из Данные Цикл 
		
		Набор.Очистить();
		Набор.Отбор.Уид_Сообщения.Установить(Элемент.Уид_Сообщения);
		
		Запись = Набор.Добавить();
		Запись.Дата = Элемент.Период;
		
		Если Элемент.ПолучательГруппа Тогда 
			Запись.Получатель = Справочники.ГруппыЧата.ПолучитьСсылку(Элемент.УИДОдержувач);
		Иначе
			Запись.Получатель = Справочники.УчасникиЧата.ПолучитьСсылку(Элемент.УИДОдержувач);	
		КонецЕсли;
		
		Запись.Уид_Сообщения = Элемент.Уид_Сообщения;
		Запись.Повідомлення = Элемент.Повідомлення;
		
		Набор.Записать();
		
	КонецЦикла;
КонецПроцедуры

Функция  ПолучитьИсходящиеСообщения(Дата) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ИсходящиеСообщения.Дата КАК Дата,
	|	ИсходящиеСообщения.Получатель КАК Получатель,
	|	ИсходящиеСообщения.Уид_Сообщения КАК Уид_Сообщения,
	|	ИсходящиеСообщения.Повідомлення КАК Повідомлення,
	|	ВЫБОР
	|		КОГДА ИсходящиеСообщения.Получатель ССЫЛКА Справочник.ГруппыЧата
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК ПолучательГруппа
	|ИЗ
	|	РегистрСведений.ИсходящиеСообщения КАК ИсходящиеСообщения
	|ГДЕ
	|	ИсходящиеСообщения.Дата > &Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НепрочитаныеСообщения.Отправитель КАК Отправитель,
	|	МАКСИМУМ(НепрочитаныеСообщения.Период) КАК Период,
	|	НепрочитаныеСообщения.Отправитель ССЫЛКА Справочник.ГруппыЧата КАК ГруппаЧата
	|ИЗ
	|	РегистрСведений.НепрочитаныеСообщения КАК НепрочитаныеСообщения
	|ГДЕ
	|	НепрочитаныеСообщения.кол = 0
	|
	|СГРУППИРОВАТЬ ПО
	|	НепрочитаныеСообщения.Отправитель
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	УдаленныеСообщения.УИД_Сообщения КАК УИД_Сообщения
	|ИЗ
	|	РегистрСведений.УдаленныеСообщения КАК УдаленныеСообщения
	|ГДЕ
	|	УдаленныеСообщения.Дата > &Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РекацииНаСобщения.УИД_Сообщения КАК УИД_Сообщения,
	|	РекацииНаСобщения.УчастникЧата КАК УчастникЧата,
	|	РекацииНаСобщения.Реакция КАК Реакция
	|ИЗ
	|	РегистрСведений.РекацииНаСобщения КАК РекацииНаСобщения
	|ГДЕ
	|	РекацииНаСобщения.Дата > &Дата
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	РегистрацияОбмена.ИД КАК ИД
	|ИЗ
	|	РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
	|ГДЕ
	|	РегистрацияОбмена.Уведомление
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	Справочник.Ссылка КАК Ссылка,
	|	Справочник.Наименование КАК Наименование,
	|	Справочник.Нагадування КАК ОписаниеНапоминания,
	|	Справочник.Періодичність.Порядок КАК Периодичность,
	|	Справочник.Активне КАК Активно,
	|	Справочник.ДеньНедели КАК ДеньНедели,
	|	Справочник.ДатаНапоминания КАК ДатаНапоминания,
	|	Справочник.Контрагент КАК Контрагент,
	|	Справочник.НагадатиПроТовар КАК НапоминаниеОТоваре,
	|	Справочник.ДатаСоздания КАК ДатаСоздания,
	|	Справочник.ИзЗаказа КАК ИзЗаказа, 	
	|	Справочник.Товары.(
	|		Номенклатура КАК Номенклатура,
	|		Виконано КАК Выполнено,
	|		Кількість КАК Количество
	|	) КАК Товары,
	|	РегистрацияОбмена.ИД КАК ИД
	|ИЗ
	|	РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Нагадування КАК Справочник
	|		ПО РегистрацияОбмена.Объект = Справочник.Ссылка";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	Результат  = Запрос.ВыполнитьПакет();
	тзСообщения = Результат[0].Выгрузить();
	тзПрочитано = Результат[1].Выгрузить();
	тзУдалено = Результат[2].Выгрузить();
	тзРеакции = Результат[3].Выгрузить();
	тзУведомления = Результат[4].Выгрузить();
	тзСправчникУведомления = Результат[5].Выгрузить();
	
	
	тзСообщения.Колонки.Добавить("УИД_Получатель");
	тзПрочитано.Колонки.Добавить("УИД_Отправитель");
	тзРеакции.Колонки.Добавить("УИД_УчастникЧата");

	Для Каждого Элемент Из тзСообщения Цикл 
		
		Элемент.Уид_Получатель = Элемент.Получатель.УникальныйИдентификатор();
		
	КонецЦикла;
	
	Для Каждого Элемент Из тзПрочитано Цикл 
		
		Элемент.УИД_Отправитель = Элемент.Отправитель.УникальныйИдентификатор();
		
	КонецЦикла;
	
	Для Каждого Элемент Из тзРеакции Цикл 
		
		Элемент.УИД_УчастникЧата = Элемент.УчастникЧата.УникальныйИдентификатор();
		
	КонецЦикла;

	Уведомления = Новый Массив;
	Для Каждого Напоминания Из тзСправчникУведомления Цикл 

		Элемент = Новый Структура;
		Элемент.Вставить("ИД", Напоминания.ИД);
		Элемент.Вставить("УИДСсылка", Напоминания.Ссылка.УникальныйИдентификатор());
		Элемент.Вставить("Наименование", Напоминания.Наименование);
		Элемент.Вставить("ОписаниеНапоминания", Напоминания.ОписаниеНапоминания);
		Элемент.Вставить("Активно", Напоминания.Активно);
		Элемент.Вставить("НапоминаниеОТоваре", Напоминания.НапоминаниеОТоваре);
		Элемент.Вставить("ДатаСоздания", Напоминания.ДатаСоздания);
		Элемент.Вставить("ИзЗаказа", Напоминания.ИзЗаказа);		
		Если Напоминания.НапоминаниеОТоваре Тогда 
			
			Элемент.Вставить("Контрагент", Напоминания.Контрагент.УникальныйИдентификатор());
			Элемент.Вставить("Товары", Новый Массив);
			//Артикул = Напоминания.Товары.Выбрать();
			Для Каждого  Артикул Из Напоминания.Товары Цикл 
				СтруктураАртикул = Новый Структура();
				СтруктураАртикул.Вставить("Номенклатура", Артикул.Номенклатура.УникальныйИдентификатор());
				СтруктураАртикул.Вставить("Выполнено", Артикул.Выполнено);
				СтруктураАртикул.Вставить("Количество", Артикул.Количество);

				Элемент.Товары.Добавить(СтруктураАртикул);
			КонецЦикла;
			
		Иначе
			
			Элемент.Вставить("ДеньНедели", Напоминания.ДеньНедели);
			Элемент.Вставить("ДатаНапоминания", Напоминания.ДатаНапоминания);
			Элемент.Вставить("Периодичность", Напоминания.Периодичность);
			
		КонецЕсли;
		Уведомления.Добавить(Элемент);
		
	КонецЦикла;
	

	
	
	тзСообщения.Колонки.Удалить("Получатель");
	тзПрочитано.Колонки.Удалить("Отправитель");
	тзРеакции.Колонки.Удалить("УчастникЧата");

	Параметры = Новый Структура;
	Параметры.Вставить("Сообщения", тзСообщения);
	Параметры.Вставить("Прочытаные", тзПрочитано);
	Параметры.Вставить("Удаленные", тзУдалено);
	Параметры.Вставить("Реакции", тзРеакции);
	

	
	Параметры.Вставить("Дата", дата);
	Параметры.Вставить("РаботаСКлиентом", СформироватьПакетДанныхИсторияРаботыСКлиентом(дата));   
	Параметры.Вставить("Уведомления", тзУведомления);
	Параметры.Вставить("СправочникУведомления", Уведомления); 
	Возврат Параметры;	
	
КонецФункции

Процедура ЗаписатьНепрочитанныеСообщения(Данные)
	
	Для Каждого Элемент Из Данные Цикл 
		
		Отправитель = ?(Элемент.ОтГруппы, 
		Справочники.ГруппыЧата.ПолучитьСсылку(Элемент.УИДВідправник),  
		Справочники.УчасникиЧата.ПолучитьСсылку(Элемент.УИДВідправник));
		
		НаборЗаписей = РегистрыСведений.НепрочитаныеСообщения.СоздатьНаборЗаписей();
		НаборЗаписей.Отбор.Отправитель.установить(Отправитель);
		Менеджер			 = НаборЗаписей.Добавить();
		Менеджер.Период 	 = ТекущаяДата();
		Менеджер.Отправитель = Отправитель;
		Менеджер.кол 		 =  Элемент.Кол;
		НаборЗаписей.Записать();
		
	КонецЦикла;
	
	
КонецПроцедуры

Процедура ЗаписатьУдаленныеСообщения(Данные);
	
	Для Каждого Элемент Из Данные Цикл
		Менеджер = РегистрыСведений.УдаленныеСообщения.СоздатьМенеджерЗаписи();
		Менеджер.УИД_Сообщения = Элемент.УИД_Сообщения;
		Менеджер.Дата = Элемент.Дата-20;
		Менеджер.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьРеакцииНаСообщений(Данные)
	 Для Каждого Элемент Из Данные Цикл
		Менеджер = РегистрыСведений.РекацииНаСобщения.СоздатьМенеджерЗаписи();
		Менеджер.УИД_Сообщения = Элемент.УИД_Сообщения;
		Менеджер.УчастникЧата = Справочники.УчасникиЧата.ПолучитьСсылку(Элемент.УИДУчастникЧата);
		Менеджер.Реакция = Элемент.Реакция;
		Менеджер.Дата = Элемент.Дата-20;
		Менеджер.Записать(Истина);
	КонецЦикла;

КонецПроцедуры

Процедура ЗаписатьЗапланированыеУведомления(Данные);
	
	Для Каждого Элемент Из Данные.Новые Цикл
		
		 Набор = РегистрыСведений.ЗапланированыеУведомления.СоздатьНаборЗаписей();
		 Набор.Отбор.УИД_Уведомления.Установить(Элемент.УИД_Уведомления);
		 Набор.Прочитать();
		 
		 Если Не Набор.Количество() Тогда  
			 
			СсылкаНагадування = Справочники.Нагадування.ПолучитьСсылку(Элемент.Объект); 
			Если НЕ ЗначениеЗаполнено(СсылкаНагадування.ВерсияДанных) Тогда 
				Продолжить;
			КонецЕсли;
			
			Запись = Набор.Добавить();
			Запись.УИД_Уведомления = Элемент.УИД_Уведомления;
			Запись.ДатаУведомления = ТекущаяДата();
			Запись.ДанныеУведомления = Элемент.ДанныеУведомления;
			Запись.ОбъектУведомления = СсылкаНагадування;
		 КонецЕсли;
		 
		 Набор.Записать();
		 
		 Менеджер = РегистрыСведений.РегистрацияОбмена.СоздатьМенеджерЗаписи();
		 Менеджер.ИД = Элемент.УИД_Уведомления;
		 Менеджер.Уведомление = Истина;
		 Менеджер.Записать();
		 
	 КонецЦикла;
	 
	 ДЛя Каждого Элемент Из Данные.Синхронизированые Цикл
		 Набор  = РегистрыСведений.РегистрацияОбмена.СоздатьНаборЗаписей();
		 Набор.Отбор.ИД.Установить(Элемент);
		 Набор.Записать();
	 КонецЦикла;
	 
	
	
КонецПроцедуры

Процедура ЗаписатьИсториюКлиента(Данные)
	 Запрос = Новый Запрос;
	 Запрос.Текст = "ВЫБРАТЬ
	                |	ТЗ.УИДКлиент КАК УИДКлиент,
	                |	ТЗ.Период КАК Период,
	                |	ТЗ.Запись КАК Запись,
	                |	ТЗ.УИД_Записи КАК УИД_Записи,
					|	ТЗ.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом КАК АвтоматичнийЗаписБезВзаємодіїЗКлієнтом
	                |ПОМЕСТИТЬ ВТ
	                |ИЗ
	                |	&ТЗ КАК ТЗ
	                |;
	                |
	                |////////////////////////////////////////////////////////////////////////////////
	                |ВЫБРАТЬ
	                |	ВТ.УИДКлиент КАК УИДКлиент,
	                |	ВТ.Период КАК Период,
	                |	ВТ.Запись КАК Запись,
	                |	ВТ.УИД_Записи КАК УИД_Записи,
					|	ВТ.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом КАК АвтоматичнийЗаписБезВзаємодіїЗКлієнтом					
	                |ИЗ
	                |	ВТ КАК ВТ
	                |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.РаботаСКлиентом КАК РаботаСКлиентом
	                |		ПО ВТ.УИД_Записи = РаботаСКлиентом.УИД_Записи
	                |ГДЕ
	                |	РаботаСКлиентом.Период ЕСТЬ NULL";
	 Запрос.УстановитьПараметр("ТЗ", Данные); 
	 Выборка = Запрос.Выполнить().Выбрать();
	 
	 РаботаСКлиентом = РегистрыСведений.РаботаСКлиентом;
	 Пока Выборка.Следующий() Цикл 
		 ЗаписьРегистра = РаботаСКлиентом.СоздатьМенеджерЗаписи();
		 ЗаписьРегистра.Клиент = Справочники.Контрагенты.ПолучитьСсылку(Выборка.УИДКлиент);
		 ЗаписьРегистра.УИД_Записи = Выборка.УИД_Записи;
		 ЗаписьРегистра.Период = Выборка.Период;
		 ЗаписьРегистра.Запись = Выборка.Запись;
		 ЗаписьРегистра.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом =  Выборка.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом;
		 ЗаписьРегистра.Записать();
		 Общий.ОбновитьПоследнююРаботуСКлиентом(ЗаписьРегистра.Клиент);
	 КонецЦикла; 
КонецПроцедуры

Процедура ЗаписатьИнфуОАктуальнихЗаказах(Данные)

	НаборЗаписей = РегистрыСведений.КонтрагентыСАктуальнымиЗаказами.СоздатьНаборЗаписей();

	//НужноЗаписывать = Ложь;
	Для Каждого Элемент из Данные Цикл
		
		Если Не Общий.ОбъектБДСуществует(Справочники.Контрагенты.ПолучитьСсылку(Элемент.УИДКонтрагент)) Тогда
			Продолжить;
		КонецЕсли;			
		           
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	КонтрагентыСАктуальнымиЗаказами.ЕстьПростроченыеАктуальныеЗаказы КАК ЕстьПростроченыеАктуальныеЗаказы
		|ИЗ
		|	РегистрСведений.КонтрагентыСАктуальнымиЗаказами КАК КонтрагентыСАктуальнымиЗаказами
		|ГДЕ
		|	КонтрагентыСАктуальнымиЗаказами.Контрагент = &Контрагент";
		
		Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПолучитьСсылку(Элемент.УИДКонтрагент));
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Если ВыборкаДетальныеЗаписи.Следующий() Тогда
			Если Не Элемент.ЕстьПростроченыеАктуальныеЗаказы = ВыборкаДетальныеЗаписи.ЕстьПростроченыеАктуальныеЗаказы Тогда
				Если Элемент.ЕстьПростроченыеАктуальныеЗаказы И Не Элемент.ЗаказВключенВМаршрутныйЛист Тогда
					Данные = Новый Структура;
					Данные.Вставить("Контрагент", Справочники.Контрагенты.ПолучитьСсылку(Элемент.УИДКонтрагент)); 
					Общий.СоздатьНапоминаниеСДействием(Перечисления.ТипыДействийПриНапоминании.ЗакрытиеСтарыхЗаказов, Данные);			 	 	
				КонецЕсли;
			КонецЕсли;	
		Иначе
			Если Элемент.ЕстьПростроченыеАктуальныеЗаказы И Не Элемент.ЗаказВключенВМаршрутныйЛист Тогда
				Данные = Новый Структура;
				Данные.Вставить("Контрагент", Справочники.Контрагенты.ПолучитьСсылку(Элемент.УИДКонтрагент)); 
				Общий.СоздатьНапоминаниеСДействием(Перечисления.ТипыДействийПриНапоминании.ЗакрытиеСтарыхЗаказов, Данные);			 	 	
			КонецЕсли;
		КонецЕсли;

		Запись = НаборЗаписей.Добавить();
		Запись.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Элемент.УИДКонтрагент);  
		Запись.ЕстьПростроченыеАктуальныеЗаказы = Элемент.ЕстьПростроченыеАктуальныеЗаказы;					
		Запись.ЗаказВключенВМаршрутныйЛист = Элемент.ЗаказВключенВМаршрутныйЛист;
	КонецЦикла;

	НаборЗаписей.Записать();
	
	
КонецПроцедуры	
#КонецОбласти

Процедура ЗаписатьРезервы(Данные)
	
	Набор = РегистрыСведений.Резервы.СоздатьНаборЗаписей();
	
	Для Каждого Элемент Из Данные Цикл 
		
			Строка = Набор.Добавить();
			Строка.УИД_Троговый = Элемент.УИДТорговий;
			Строка.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Элемент.УИДНоменклатура);
			Строка.Количество = Элемент.Количество;
			Строка.ТорговийИмя = Элемент.ТорговийАгентПредставление;
			
	КонецЦикла;
	Набор.Записать();

КонецПроцедуры


