#Область УДАЛЕНИЕ_ДАННЫХ

Процедура УдалитьВсеДанные(УдалитьВсе = Ложь) Экспорт
	
	ОчиститьРегистры();
	ОчиститьДокументы();
	ОчиститьСправочники();	
КонецПроцедуры

Процедура ОчиститьСправочники() Экспорт 
	
	Для каждого Справочник Из Метаданные.Справочники Цикл
		
		ИмяСправочника = Справочник.Имя;
		Если ИмяСправочника = "Нагадування" 
			ИЛИ ИмяСправочника = "Номенклатура" 
			ИЛИ ИмяСправочника = "Контрагенты"  
			ИЛИ ИмяСправочника = "СкладыКонтрагентов" 
			Тогда 
			Продолжить;
		КонецЕсли;
		
		
		Если Метаданные.Справочники[ИмяСправочника].Иерархический Тогда 
			Данные = Справочники[ИмяСправочника].ВыбратьИерархически();
		Иначе 
			Данные = Справочники[ИмяСправочника].Выбрать();
		КонецЕсли;	
		
		Пока Данные.Следующий() Цикл 
			Попытка
				Данные.ПолучитьОбъект().Удалить();
			Исключение
			КонецПопытки;
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОчиститьДокументы() Экспорт
	Для каждого Док Из Метаданные.Документы Цикл
		
		ИмяДока = Док.Имя;
		
		Данные = Документы[ИмяДока].Выбрать();
		
		Пока Данные.Следующий() Цикл 
			Если ИмяДока = "Заказ" ИЛИ ИмяДока = "РеализацияТоваровУслуг" ИЛИ ИмяДока = "МаршрутныйЛист" ИЛИ ИмяДока = "КассовыйОрдер"  ИЛИ ИмяДока = "ВозвратОтПокупателя" Тогда 
				//Если Данные.Дата > ТекущаяДата() - 1209600 Тогда 
				Если Данные.Дата > ДобавитьМесяц(ТекущаяДата(), -6) Тогда 
					Продолжить;
				КонецЕсли;
			КонецЕсли;
				
			об = Данные.ПолучитьОбъект();
			Попытка
				об.мЭтоОбмен = Истина;
			Исключение
			КонецПопытки;

			
			//Попытка
				об.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			//Исключение
			//КонецПопытки;
			
			//Попытка
			
			об.Удалить();
			//Исключение
				//Предупреждение(ОписаниеОшибки());
				//Возврат;
			//КонецПопытки;
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОчиститьРегистры() Экспорт
	Для каждого Рег Из Метаданные.РегистрыСведений Цикл	
		ИмяРег = Рег.Имя;
		Если ИмяРег = "РегистрацияОбмена" 
			Или ИмяРег = "РаботаСКлиентом" 
			Или СтрНайти(Рег,"сообщения")
			Или ИмяРег = "ЗапланированыеУведомления"
			Или ИмяРег = "Лог" Тогда 
			//Передати маэм закази
			Продолжить;
		КонецЕсли;
		
		Если ИмяРег = "Кілометраж" Тогда 
			
			з = Новый Запрос;
			з.Текст = "ВЫБРАТЬ
			          |	КілометражРегистр.Период
			          |ИЗ
			          |	РегистрСведений.Кілометраж КАК КілометражРегистр
					  |ГДЕ
			          |	КілометражРегистр.Период < &Дата";
			з.УстановитьПараметр("Дата",ТекущаяДата() - 345600);
			НЗ = РегистрыСведений[ИмяРег].СоздатьНаборЗаписей();
			Выборка = з.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НЗ.Отбор.Период.Установить(Выборка.Период);
				НЗ.Записать();
			КонецЦикла;

				
			
			Продолжить;
		КонецЕсли;
		
		Если ИмяРег = "РегистрацияКоординат" Тогда 
			з = Новый Запрос;
			з.Текст = "ВЫБРАТЬ
			          |	РегистрацияКоординат.Дата
			          |ИЗ
			          |	РегистрСведений.РегистрацияКоординат КАК РегистрацияКоординат
			          |ГДЕ
			          |	РегистрацияКоординат.Дата < &Дата";
			з.УстановитьПараметр("Дата",ТекущаяДата() - 345600);
			НЗ = РегистрыСведений[ИмяРег].СоздатьНаборЗаписей();
			Выборка = з.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				НЗ.Отбор.Дата.Установить(Выборка.Дата);
				НЗ.Записать();
			КонецЦикла;
				
			
			Продолжить;
		КонецЕсли;

		
		НЗ = РегистрыСведений[ИмяРег].СоздатьНаборЗаписей();
		НЗ.Записать();	                             
	КонецЦикла;
КонецПроцедуры

Процедура ОчиститьКонтрагентов(Контрагенты, ТаблицаИД)
	
	Для Каждого Элемент Из Контрагенты Цикл 
		
		Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Элемент.Ссылка);
		НовСтр = ТаблицаИД.Добавить();
		НовСтр.ИД = Элемент.ИД;

		Если ПустаяСтрока(Контрагент.ВерсияДанных) Тогда 
			Продолжить;
		КонецЕсли;
		
		Контрагент.ПолучитьОбъект().Удалить();
		
	КонецЦикла;
	
		
КонецПроцедуры

#КонецОбласти


Процедура ПрочитатьПакетДанных(ДанныеОбменаСтруктура,ТаблицаИД)Экспорт
	
	ПринятьПакетКонстант(ДанныеОбменаСтруктура.Константы,ТаблицаИД);
	ПринятьПакетСправочников(ДанныеОбменаСтруктура.Справочники,ТаблицаИД);
	ПринятьПакетРегистровСведений(ДанныеОбменаСтруктура.РегистрСведений);
	ПринятьПакетДокументов(ДанныеОбменаСтруктура.Документы,ТаблицаИД);
КонецПроцедуры


#Область ЗАПОЛНЕНИЕ_СПРАВОЧНИКОВ

Процедура ПринятьПакетКонстант(СтруктураКонстант,ТаблицаИД)
	Перем Значение;
	Если СтруктураКонстант = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если СтруктураКонстант.Свойство("ТипЦенПродаж", Значение) Тогда 
		Константы.ТипЦенПродаж.Установить(Справочники.ТипыЦенНоменклатуры.ПолучитьСсылку(Значение));
		СтруктураКонстант.Удалить("ТипЦенПродаж");
	КонецЕсли;
	
	Если СтруктураКонстант.Свойство("Пользователь1с", Значение) Тогда 
		Константы.Пользователь1с.Установить(Справочники.УчасникиЧата.ПолучитьСсылку(Значение));
		СтруктураКонстант.Удалить("Пользователь1с");
	КонецЕсли;

	Для  Каждого Константа Из  СтруктураКонстант Цикл 
		Константы[Константа.Ключ].Установить(Константа.Значение);
	КонецЦикла;
КонецПроцедуры


Процедура ПринятьПакетСправочников(СтруктураСправочники,ТаблицаИД)
	Если СтруктураСправочники = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Если СтруктураСправочники.Свойство("Удалить_Контрагенты") Тогда 
		ОчиститьКонтрагентов(СтруктураСправочники.Удалить_Контрагенты, ТаблицаИД);
		СтруктураСправочники.Удалить("Удалить_Контрагенты")
	КонецЕсли;
	
		
	Для  Каждого Справочник Из  СтруктураСправочники Цикл 
		
		Если Справочник.Ключ = "Номенклатура" ИЛИ Справочник.Ключ = "КлассификаторЕдиницИзмерения" Тогда 
			ИмяСправочника = Справочник.Ключ;
			ЗначенияСправочника = Справочник.Значение;
			СоздатьЭлементыСправочника(ИмяСправочника, ЗначенияСправочника,ТаблицаИД);
		КонецЕсли;
		
	КонецЦикла;
	
	Для  Каждого Справочник Из  СтруктураСправочники Цикл 
		Если Справочник.Ключ <> "Номенклатура" И Справочник.Ключ <> "КлассификаторЕдиницИзмерения" Тогда
			ИмяСправочника = Справочник.Ключ;
			ЗначенияСправочника = Справочник.Значение;
			СоздатьЭлементыСправочника(ИмяСправочника, ЗначенияСправочника,ТаблицаИД);
		КонецЕсли;
	КонецЦикла;
	
	
	
КонецПроцедуры

Процедура ПринятьПакетРегистровСведений(СтруктураРегистровСведений)
	
	Если СтруктураРегистровСведений = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	Для Каждого Регистр Из  СтруктураРегистровСведений Цикл 
		
		ИмяРегистра = Регистр.Ключ;
		ЗначенияРегистра = Регистр.Значение;
		СоздатьЭлементыРегистраСведений(ИмяРегистра, ЗначенияРегистра);
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ПринятьПакетДокументов(СтруктураДокументов,ТаблицаИД)
	Если СтруктураДокументов = Неопределено Тогда 
		Возврат;
	КонецЕсли;
	
	
	Для Каждого Док Из  СтруктураДокументов Цикл 	
		ИмяДокумента = Док.Ключ;
		ЗначенияДокумента = Док.Значение;
		СоздатьЭлементыДокумента(ИмяДокумента, ЗначенияДокумента,ТаблицаИД);	
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьЭлементыСправочника(ИмяСправочника, ЗначенияСправочника,ТаблицаИД) Экспорт 
	
	Иерархический = Метаданные.Справочники[ИмяСправочника].Иерархический;
	
	Для Каждого СтрокаДанныеЭлемента Из ЗначенияСправочника Цикл 
		Если Не ЗначениеЗаполнено(СтрокаДанныеЭлемента.УИДСсылка) Тогда 
			Продолжить;
		КонецЕсли;
		
		НовыйОбъект = Справочники[ИмяСправочника].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСсылка).ПолучитьОбъект();
		
		Если НовыйОбъект = Неопределено Тогда 
			Если Иерархический И СтрокаДанныеЭлемента.ЭтоГруппа Тогда 
				НовыйОбъект = Справочники[ИмяСправочника].СоздатьГруппу(); 
			Иначе 
				НовыйОбъект = Справочники[ИмяСправочника].СоздатьЭлемент();
			КонецЕсли;	
			НовыйОбъект.УстановитьСсылкуНового(Справочники[ИмяСправочника].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСсылка));
		КонецЕсли;	
		Попытка
			НовыйОбъект.мЭтоОбмен = Истина;
		Исключение
		КонецПопытки;
		Если Иерархический И СтрокаДанныеЭлемента.ЭтоГруппа Тогда 
			ЗаполнитьЗначенияСвойств(НовыйОбъект, СтрокаДанныеЭлемента,"Наименование", "Ссылка");
			Для Каждого Реквизит Из НовыйОбъект.Метаданные().СтандартныеРеквизиты Цикл
				Если Реквизит.Имя = "Родитель" Тогда 
					НовыйОбъект.Родитель = Справочники[НовыйОбъект.Родитель.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДРодитель);
				КонецЕсли;
			КонецЦикла;
			
		Иначе 
			Попытка                                         
				ЗаполнитьЗначенияСвойств(НовыйОбъект, СтрокаДанныеЭлемента,,"Ссылка");
			Исключение
				ЗаполнитьЗначенияСвойств(НовыйОбъект, СтрокаДанныеЭлемента);
			КонецПопытки;
			Для Каждого Реквизит Из НовыйОбъект.Метаданные().СтандартныеРеквизиты Цикл
				Если Реквизит.Имя = "Владелец" Тогда 
					НовыйОбъект.Владелец = Справочники[НовыйОбъект.Владелец.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДВладелец);
				КонецЕсли;
				Если Реквизит.Имя = "Родитель" Тогда 
					НовыйОбъект.Родитель = Справочники[НовыйОбъект.Родитель.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДРодитель);
				КонецЕсли;
				Если Реквизит.Имя = "Наименование" И ТипЗнч(НовыйОбъект) = Тип("СправочникОбъект.Номенклатура") Тогда 
					Если Лев(НовыйОбъект.Наименование,1) = "я" Тогда 
						НовыйОбъект.Наименование = "z"+НовыйОбъект.Наименование;
					КонецЕсли;
				КонецЕсли;
 
				
			КонецЦикла;
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("ЕдиницаПоКлассификатору") <> Неопределено Тогда
				НовыйОбъект.ЕдиницаПоКлассификатору = Справочники[НовыйОбъект.ЕдиницаПоКлассификатору.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДЕдиницаПоКлассификатору);
			КонецЕсли;
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("Хранилище") <> Неопределено Тогда
				НовКартинка = Новый Картинка(XMLЗначение(Тип("ДвоичныеДанные"),СтрокаДанныеЭлемента.Хранилище));
				Сжатие = Новый СжатиеДанных(9);
				НовыйОбъект.Хранилище = Новый ХранилищеЗначения(НовКартинка,Сжатие);
			КонецЕсли;
			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("Номенклатура") <> Неопределено Тогда
				НовыйОбъект.Номенклатура = Справочники[НовыйОбъект.Номенклатура.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДНоменклатура);
			КонецЕсли;
			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("ТипЦен") <> Неопределено Тогда
				НовыйОбъект.ТипЦен = Справочники[НовыйОбъект.ТипЦен.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДТипЦен);
			КонецЕсли;

			Если НовыйОбъект.Метаданные().Реквизиты.Найти("Контрагент") <> Неопределено Тогда
				НовыйОбъект.Контрагент = Справочники[НовыйОбъект.Контрагент.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКонтрагент);
			КонецЕсли;
			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("Характеристика") <> Неопределено Тогда
				НовыйОбъект.Характеристика = Справочники[НовыйОбъект.Характеристика.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДХарактеристика);
			КонецЕсли;
			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("Город") <> Неопределено Тогда
				НовыйОбъект.Город = Справочники[НовыйОбъект.Город.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДГород);
			КонецЕсли;

			Если НовыйОбъект.Метаданные().Реквизиты.Найти("Область") <> Неопределено Тогда
				НовыйОбъект.Область = Справочники[НовыйОбъект.Область.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДОбласть);
			КонецЕсли;
			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("СтатусКонтрагента") <> Неопределено Тогда
				НовыйОбъект.СтатусКонтрагента = Справочники.СтатусыКонтрагентов.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСтатусКонтрагента);
			КонецЕсли;
			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("ОперативныйСтатусКонтрагента") <> Неопределено Тогда
				НовыйОбъект.ОперативныйСтатусКонтрагента = Справочники.СтатусыКонтрагентов.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДОперативныйСтатусКонтрагента);
			КонецЕсли;			
			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("ТорговыйАгент") <> Неопределено Тогда
				НовыйОбъект.ТорговыйАгент = Справочники.ТорговыеАгенты.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДТорговыйАгент);
			КонецЕсли;
			
			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("Маршрут") <> Неопределено Тогда
				НовыйОбъект.Маршрут = Справочники.Маршруты.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДМаршрут);
			КонецЕсли;

			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("КатегорияТТ") <> Неопределено Тогда
				НовыйОбъект.КатегорияТТ = Справочники.КатегорииТТ.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКатегорияТТ);
			КонецЕсли;

			
			Если НовыйОбъект.Метаданные().Реквизиты.Найти("СпособДоставки") <> Неопределено Тогда
				НовыйОбъект.СпособДоставки = Справочники.СпособыДоставки.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСпособДоставки);
			КонецЕсли;

			Если НовыйОбъект.Метаданные().Реквизиты.Найти("КаналПошуку") <> Неопределено Тогда
				НовыйОбъект.КаналПошуку = Справочники.КаналиПошуку.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКаналПошуку);
			КонецЕсли;

			Если НовыйОбъект.Метаданные().Реквизиты.Найти("КодАсортимета") <> Неопределено 
				И ТипЗнч(СтрокаДанныеЭлемента.КодАсортимета) = Тип("Число") Тогда
				НовыйОбъект.КодАсортимета = Перечисления.КодыАсортимета.Получить(СтрокаДанныеЭлемента.КодАсортимета);
			КонецЕсли;
			
			
			Если ИмяСправочника = "Контрагенты" Тогда
				НовыйОбъект.Телефоны.Очистить();
				Для Каждого Элемент Из СтрокаДанныеЭлемента.ТелефоныТЗ Цикл 
					Строка = НовыйОбъект.Телефоны.ДОбавить();
					Строка.НомерТелефона = Элемент.Номер;
					Если ТипЗнч(Элемент.ВидМесенджера) = Тип("Число") Тогда
						Строка.Месенджер = Перечисления.ВидыМесендеров.Получить(Элемент.ВидМесенджера);
					КонецЕсли;
				КонецЦикла;
				
				НовыйОбъект.Маршруты.Очистить();
				Для Каждого Элемент Из СтрокаДанныеЭлемента.Маршруты Цикл 
					Строка = НовыйОбъект.Маршруты.ДОбавить();
					Строка.Маршрут = Справочники.Маршруты.ПолучитьСсылку(Элемент.УИД_Маршрут);
				КонецЦикла;

				НовыйОбъект.БанковскиеСчета.Очистить();
				Для Каждого Элемент Из СтрокаДанныеЭлемента.БанковскиеСчетаДляОплаты Цикл 
					Строка = НовыйОбъект.БанковскиеСчета.ДОбавить();
					Строка.БанковскийСчет = Справочники.БанковскиеСчета.ПолучитьСсылку(Элемент.УИДБанковскийСчет);
				КонецЦикла; 				
				
				НовыйОбъект.Асортимент.Очистить();
				Для Каждого Элемент Из СтрокаДанныеЭлемента.Асортимент Цикл 
					Строка = НовыйОбъект.Асортимент.ДОбавить();
					Строка.Артикул = Элемент.Артикул;
					Строка.НеРучнаяЗапись = Не Элемент.РучнаяЗапись;
				КонецЦикла;    
				
				НовыйОбъект.АсортиментПрезентацій.Очистить();
				Для Каждого Элемент Из СтрокаДанныеЭлемента.АсортиментПрезентацій Цикл 
					Строка = НовыйОбъект.АсортиментПрезентацій.ДОбавить();
					Строка.Артикул = Элемент.Артикул;
					Строка.НеРучнаяЗапись = Не Элемент.РучнаяЗапись;
				КонецЦикла;
				
				Попытка
					НовыйОбъект.СоцМережі.Очистить();
					Для Каждого Элемент Из СтрокаДанныеЭлемента.СоцМережі Цикл 
						Строка = НовыйОбъект.СоцМережі.ДОбавить();
						Строка.Коментар = Элемент.Коментар;
						Строка.Посилання = Элемент.Посилання;
						Строка.Мережа = Элемент.Мережа;
					КонецЦикла;
				Исключение
				КонецПопытки;
				
			КонецЕсли;



			// Если НовыйОбъект.Метаданные().Реквизиты.Найти("ДатаСозданияЭлемента") <> Неопределено Тогда
			//	НовыйОбъект.Область = Справочники[НовыйОбъект.Область.Метаданные().Имя].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДОбласть);
			//КонецЕсли;

		КонецЕсли;
		
		Попытка  
			НовыйОбъект.Записать();
			
			Если ЗначенияСправочника.Колонки.Найти("ИД") <> Неопределено И ЗначениеЗаполнено(СтрокаДанныеЭлемента.ИД) Тогда 
				НовСтр = ТаблицаИД.Добавить();
				НовСтр.ИД = СтрокаДанныеЭлемента.ИД;
			КонецЕсли;
		Исключение
			
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьЭлементыРегистраСведений(ИмяРегистра, ЗначенияРегистра)
	//Иерархический = Метаданные.Справочники[ИмяСправочника].Иерархический И Не ЗначенияСправочника.Колонки.Найти("ЭтоГруппа") = Неопределено;
	
	Для Каждого СтрокаДанныеЭлемента Из ЗначенияРегистра Цикл 
		Если ИмяРегистра = "Штрихкоды" Тогда 
			нз = РегистрыСведений.Штрихкоды.СоздатьНаборЗаписей();
			//нз.Отбор.Штрихкод.Использование = Истина;
			нз.Отбор.Владелец.Использование = Истина;
			нз.Отбор.ЕдиницаИзмерения.Использование = Истина;
			нз.Отбор.ХарактеристикаНоменклатуры.Использование = Истина;
			
			//нз.Отбор.Штрихкод.Значение = СтрокаДанныеЭлемента.Штрихкод;
			нз.Отбор.Владелец.Значение = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДВладелец);
			нз.Отбор.ЕдиницаИзмерения.Значение = Справочники.ЕдиницыИзмерения.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДЕдиницаИзмерения);
			нз.Отбор.ХарактеристикаНоменклатуры.Значение = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДХарактеристикаНоменклатуры);
			
			з = нз.Добавить();
			з.Штрихкод = СокрЛП(СтрокаДанныеЭлемента.Штрихкод);
			з.Владелец = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДВладелец);
			з.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДЕдиницаИзмерения);
			з.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДХарактеристикаНоменклатуры);
			
			нз.Записать();	
		ИначеЕсли ИмяРегистра = "ОтгруженныеЗаказы" Тогда
			нз = РегистрыСведений.ОтгруженныеЗаказы.СоздатьНаборЗаписей();
			нз.Отбор.Ссылка.Использование = Истина;

			нз.Отбор.Ссылка.Значение = Документы.Заказ.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСсылка);
			
			з = нз.Добавить();
			з.Ссылка = Документы.Заказ.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСсылка);
			нз.Записать();				
		ИначеЕсли  ИмяРегистра = "ЦеныНоменклатуры" Тогда
			нз = РегистрыСведений.ЦеныНоменклатуры.СоздатьНаборЗаписей();
			нз.Отбор.ТипЦен.Использование = Истина;
			нз.Отбор.Номенклатура.Использование = Истина;
			нз.Отбор.ХарактеристикаНоменклатуры.Использование = Истина;
			
			
			нз.Отбор.ТипЦен.Значение = Справочники.ТипыЦенНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДТипЦен);
			нз.Отбор.Номенклатура.Значение = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДНоменклатура);
			нз.Отбор.ХарактеристикаНоменклатуры.Значение = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДХарактеристикаНоменклатуры);
			
			з = нз.Добавить();
			
			з.ТипЦен = Справочники.ТипыЦенНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДТипЦен);
			з.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДНоменклатура);
			з.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДХарактеристикаНоменклатуры);
			з.Цена = СтрокаДанныеЭлемента.Цена;
			з.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДЕдиницаИзмерения);
			нз.Записать();	
			
		ИначеЕсли  ИмяРегистра = "НормыЗапасов" Тогда
			ТекНом = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДНоменклатура);
			ТекХар = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДХарактеристикаНоменклатуры);
			ТекЕдИзм = Справочники.ЕдиницыИзмерения.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДЕдиницаИзмерения);
			
			Запрос = Новый Запрос;
			Запрос.Текст="ВЫБРАТЬ
			             |	НормыЗапасов.Количество,
			             |	НормыЗапасов.Дата
			             |ИЗ
			             |	РегистрСведений.НормыЗапасов КАК НормыЗапасов
			             |ГДЕ
			             |	НормыЗапасов.Номенклатура = &Номенклатура
			             |	И НормыЗапасов.ХарактеристикаНоменклатуры = &ХарактеристикаНоменклатуры
			             |	И НормыЗапасов.ЕдиницаИзмерения = &ЕдиницаИзмерения";
			Запрос.УстановитьПараметр("Номенклатура",ТекНом);
			Запрос.УстановитьПараметр("ХарактеристикаНоменклатуры",ТекХар);
			Запрос.УстановитьПараметр("ЕдиницаИзмерения",ТекЕдИзм);
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() И Выборка.Дата > СтрокаДанныеЭлемента.Дата Тогда 
				
			Иначе 
				нз = РегистрыСведений.НормыЗапасов.СоздатьНаборЗаписей();
				нз.Отбор.ЕдиницаИзмерения.Использование = Истина;
				нз.Отбор.Номенклатура.Использование = Истина;
				нз.Отбор.ХарактеристикаНоменклатуры.Использование = Истина;
				
				
				нз.Отбор.ЕдиницаИзмерения.Значение = ТекЕдИзм;
				нз.Отбор.Номенклатура.Значение = ТекНом;
				нз.Отбор.ХарактеристикаНоменклатуры.Значение = ТекХар;
				
				з = нз.Добавить();
				
				з.Номенклатура = ТекНом;
				з.ХарактеристикаНоменклатуры = ТекХар;
				з.Количество = СтрокаДанныеЭлемента.Количество;
				з.Дата = СтрокаДанныеЭлемента.Дата;
				з.ЕдиницаИзмерения = ТекЕдИзм;
				нз.Записать();	
			КонецЕсли;
			
		//intrata_wald_08092021 ↓
		ИначеЕсли  ИмяРегистра = "КатегорииОбъектов" Тогда
			Объект = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДОбъект);
			Категория = Справочники.КатегорииОбъектов.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКатегория);
			МЗ = РегистрыСведений.КатегорииОбъектов.СоздатьМенеджерЗаписи();
			МЗ.Объект = Объект;
			МЗ.Категория = Категория;
			МЗ.Записать(Истина);
			//intrata_wald_08092021 ↑
			
		ИначеЕсли  ИмяРегистра = "ИсторияРаботыСКлиентом" Тогда 		
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	РаботаСКлиентом.Период КАК Период
			|ИЗ
			|	РегистрСведений.РаботаСКлиентом КАК РаботаСКлиентом
			|ГДЕ
			|	РаботаСКлиентом.УИД_Записи = &УИД_Записи";
			
			Запрос.УстановитьПараметр("УИД_Записи", СтрокаДанныеЭлемента.УИД_Записи);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Если ВыборкаДетальныеЗаписи.Количество() = 0 Тогда 
				
				Контрагент = Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКлиент);
				Если ЗначениеЗаполнено(Контрагент.ВерсияДанных) Тогда
					
					МЗ = РегистрыСведений.РаботаСКлиентом.СоздатьМенеджерЗаписи();
					МЗ.Период = СтрокаДанныеЭлемента.Период;
					МЗ.Клиент = Контрагент;
					МЗ.Запись = СтрокаДанныеЭлемента.Запись;
					МЗ.УИД_Записи = СтрокаДанныеЭлемента.УИД_Записи;
					МЗ.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом = СтрокаДанныеЭлемента.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом;
				    МЗ.Записать(Истина);
					Общий.ОбновитьПоследнююРаботуСКлиентом(Контрагент);
				КонецЕсли;
			КонецЕсли;   	
			
		КонецЕсли;
		
	КонецЦикла;
КонецПроцедуры

Процедура СоздатьЭлементыДокумента(ИмяДокумента, ЗначенияДокумента, ТаблицаИД)
	МассивДокументов = Новый Массив;      

	Если ИмяДокумента = "Перемещение" Тогда 
		НовыйОбъект = Документы.Приход.СоздатьДокумент();
		НовыйОбъект.Дата = НачалоДня(ТекущаяДата());
		ТекущаяСсылка = "";
		Для Каждого СтрокаДанныеЭлемента Из ЗначенияДокумента Цикл
			
			ИмяДок = "Приход";
			//Если СтрокаДанныеЭлемента.ЭтоВозврат Тогда 
			//	ИмяДок = "Возврат";
			//КонецЕсли;
			
			//НовыйОбъект = Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСсылка).ПолучитьОбъект();
			//Если НовыйОбъект = Неопределено Тогда 
			//	НовыйОбъект = Документы[ИмяДок].СоздатьДокумент();	
			//	НовыйОбъект.УстановитьСсылкуНового(Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСсылка));
			//Иначе
				НовыйОбъект.Записать(РежимЗаписиДокумента.Запись);
			//КонецЕсли;
			
			//Если ТекущаяСсылка <> СтрокаДанныеЭлемента.Ссылка Тогда 
			//	НовыйОбъект.Товары.Очистить();
			//	ТекущаяСсылка = СтрокаДанныеЭлемента.Ссылка;
			//	Попытка
			//		Если ЗначениеЗаполнено(СтрокаДанныеЭлемента.ИД) Тогда 
						НовСтр = ТаблицаИД.Добавить();
						НовСтр.ИД = СтрокаДанныеЭлемента.ИД;
			//		КонецЕсли;
			//	Исключение
			//	КонецПопытки;
			//КонецЕсли;
			
			СтрокаТоваров = НовыйОбъект.Товары.Добавить();
			ЗаполнитьЗначенияСвойств(НовыйОбъект,СтрокаДанныеЭлемента);
			ЗаполнитьЗначенияСвойств(СтрокаТоваров,СтрокаДанныеЭлемента);
			//Если ЗначениеЗаполнено(СтрокаДанныеЭлемента.Префикс) Тогда 
			//	НовыйОбъект.Номер = СтрокаДанныеЭлемента.Префикс + Сред(НовыйОбъект.Номер,2);
			//КонецЕсли;
			                   
			СтрокаТоваров.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДНоменклатура);
			СтрокаТоваров.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДХарактеристикаНоменклатуры);
			СтрокаТоваров.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДЕдиницаИзмерения);
			Попытка
				СтрокаТоваров.Штрихкод = Общий.ПолучитьШтрихкодТовара(СтрокаТоваров.Номенклатура,СтрокаТоваров.ХарактеристикаНоменклатуры,СтрокаТоваров.ЕдиницаИзмерения);
			Исключение
				ы=1;
			КонецПопытки;
			НовыйОбъект.Записать();
			Если МассивДокументов.Найти(НовыйОбъект.Ссылка) = Неопределено Тогда 
				МассивДокументов.Добавить(НовыйОбъект.Ссылка);
			КонецЕсли;
		КонецЦикла;
	ИначеЕсли ИмяДокумента = "Реализация" Тогда
		ТекущаяСсылка = "";
		Для Каждого СтрокаДанныеЭлемента Из ЗначенияДокумента Цикл
			
			ИмяДок = "РеализацияТоваровУслуг";
			
			НовыйОбъект = Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСсылка).ПолучитьОбъект();
			
			Если НовыйОбъект = Неопределено Тогда 
				НовыйОбъект = Документы[ИмяДок].СоздатьДокумент();	
				НовыйОбъект.УстановитьСсылкуНового(Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСсылка));
			Иначе
				НовыйОбъект.мЭтоОбмен = Истина;
				НовыйОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
			КонецЕсли;
			
			ЗаполнитьЗначенияСвойств(НовыйОбъект,СтрокаДанныеЭлемента);
			
			Если ТекущаяСсылка <> НовыйОбъект.Ссылка Тогда 
				НовыйОбъект.Товары.Очистить();
				НовыйОбъект.Контрагент 		= Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКонтрагент);
				НовыйОбъект.МаршрутныйЛист 	= Документы.МаршрутныйЛист.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДМаршрутныйЛист);
				НовыйОбъект.Сделка 			= Документы.Заказ.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСделка);
				НовыйОбъект.ТипЦен 			= Справочники.ТипыЦенНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДТипЦен);
				НовыйОбъект.Наложка			= СтрокаДанныеЭлемента.Наложка; //+wald_intrata_19112021
				Попытка
