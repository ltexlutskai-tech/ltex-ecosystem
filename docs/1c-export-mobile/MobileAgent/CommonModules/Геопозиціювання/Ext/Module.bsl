
Процедура ЗаписатьКоординаты(Широта, Долгота) Экспорт
		нз = РегистрыСведений.РегистрацияКоординат.СоздатьНаборЗаписей();
		ТекДата = ТекущаяДата();
		нз.Отбор.Дата.Установить(ТекДата);
		з = нз.Добавить();
		з.Дата = ТекДата;
		з.Широта = Широта; 
		з.Долгота = Долгота;
		нз.Записать();
