////// форматируем дату /////////////////////
Функция ПолучитьДатуИзСтроки(Дата)
	
	ДатаСтрокой = Лев(Дата, 2) + "." + Сред(Дата, 3,2) + "." + Сред(Дата, 5, 4) + " " + Сред(Дата, 9, 2) + ":" + Сред(Дата, 11, 2) + ":" + Сред(Дата, 13, 2);
	
	Возврат Дата(ДатаСтрокой);	
	
КонецФункции

////// форматируем контакта /////////////////
Функция ПолучитьКонтакт(СтруктураКонтакт, НовоеСообщение, Подписан)
	
	Если НЕ ЗначениеЗаполнено(СтруктураКонтакт) Тогда
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли;	
	
	//// поиск по ИД /////////////////////
	Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(СтруктураКонтакт.ИД));
	Если СсылкаСуществует(Контрагент) Тогда
		Если ЗначениеЗаполнено(Контрагент) Тогда
			Если НовоеСообщение Тогда
				Запись = РегистрыСведений.НовоеСообщение.СоздатьМенеджерЗаписи();
				Запись.Контакт = Контрагент;
				Запись.Прочитать();
				Если Запись.Выбран() Тогда
					Запись.Новое = Истина;
					Запись.Записать();
				Иначе
					Запись = РегистрыСведений.НовоеСообщение.СоздатьМенеджерЗаписи();
					Запись.Контакт = Контрагент;
					Запись.Новое = Истина;
					Запись.Записать();
				КонецЕсли;			
			КонецЕсли;
			
			Если НЕ Контрагент.ПодписанийВВайбере Тогда
				Спр = Контрагент.ПолучитьОбъект();
				Спр.ПодписанийВВайбере = Истина;
				Спр.мЭтоОбмен = Истина;
				Спр.Записать();
			КонецЕсли;	
			
			Возврат Контрагент;
		КонецЕсли;
	КонецЕсли;	
		
	 
	
	////// поиск по телефону ////////////
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.Телефон В(&Телефон)";
	
	Запрос.УстановитьПараметр("Телефон", СтруктураКонтакт.Телефон);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Спр = ВыборкаДетальныеЗаписи[0].Ссылка.ПолучитьОбъект();
		Спр.НовоеСообщение = НовоеСообщение;
		Спр.ПодписанийВВайбере = Подписан;
		Спр.мЭтоОбмен = Истина;
		Спр.Записать();
		
		Возврат ВыборкаДетальныеЗаписи[0].Ссылка;
	Иначе
		Возврат Справочники.Контрагенты.ПустаяСсылка();
	КонецЕсли; 
	
	
КонецФункции


