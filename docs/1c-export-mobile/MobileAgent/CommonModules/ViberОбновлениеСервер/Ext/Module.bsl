#Область Отправить_Запрос

Функция ОтправитьЗапросНаПолучениеИнформации(СтруктураЗапроса)
	
	СтрокаJSON = КодироватьСтроку(СтрокаJSON, СпособКодированияСтроки.КодировкаURL);
	
	URL = "ltex1c.com.ua/ltexbot/hs/bots/exchange";
	
	SSL =  Новый ЗащищенноеСоединениеOpenSSL; 
	ХТТПСоединение = Новый HTTPСоединение(СокрЛП(URL),,,,,, SSL);
		

		
	ЗаписьJSON = Новый ЗаписьJSON; 
	ЗаписьJSON.УстановитьСтроку(); 
	ЗаписатьJSON(ЗаписьJSON, СтруктураЗапроса); 
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Content-Type", ТипКонтентаJSON());
	ХТТПЗапрос = Новый HTTPЗапрос("",Заголовки);
	ХТТПЗапрос.УстановитьТелоИзСтроки(ЗаписьJSON.Закрыть(), КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать); 
	ХТТПЗапрос.Заголовки = Заголовки;
	
	Ответ = ХТТПСоединение.ОтправитьДляОбработки(ХТТПЗапрос);
	ТекстОтвета = Ответ.ПолучитьТелоКакСтроку();
	Если Ответ.КодСостояния = 200 Тогда
		Чтение = Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(ТекстОтвета);
		ДеревоОтвета =  ПрочитатьJSON(Чтение,Ложь);
		Возврат ДеревоОтвета;
	Иначе
		Сообщить("Ошибка: " + Ответ.КодСостояния);
		Возврат Ответ;
	КонецЕсли; 

	
КонецФункции

Функция ТипКонтентаJSON()
	
	 Возврат "application/json";
	
 КонецФункции
 
Функция СоздатьСтрокуBase64(Строка) Экспорт

 ВременныйФайл = ПолучитьИмяВременногоФайла();
 
 ЗаписьТекста = Новый ЗаписьТекста(ВременныйФайл, "CESU-8");
 ЗаписьТекста.Записать(Строка);
 ЗаписьТекста.Закрыть();
 
 ДД_Файла = Новый ДвоичныеДанные(ВременныйФайл);
 СтрокаBase64 = Base64Строка(ДД_Файла);
 
 УдалитьФайлы(ВременныйФайл);
 
 Возврат СтрокаBase64;

КонецФункции
#КонецОбласти

#Область Запросы_В_Базу

Функция ОбновитьСписокИсторииСообщений()Экспорт
	
	СтруктураЗапроса = Новый Структура;
	СтруктураЗапроса.Вставить("method", "vibermobile");
	СтруктураЗапроса.Вставить("IDdesktop", Строка(Константы.ПарольВхода.Получить()));
	
	ПоследняяДатаОбновления = Константы.ДатаПоследнегоОбновленияВайбер.Получить();
	Если НЕ ЗначениеЗаполнено(ПоследняяДатаОбновления) Тогда
		ПоследняяДатаОбновления = "0";
	КонецЕсли;
	
	Дата = СтрЗаменить(Строка(ПоследняяДатаОбновления), ".", "");
	Дата = СтрЗаменить(Дата, " ", "");
	Дата = СтрЗаменить(Дата, ":", "");
	
	СтруктураЗапроса.Вставить("Дата", Дата);
	
	Ответ = ОтправитьЗапросНаПолучениеИнформации(СтруктураЗапроса); 
	
	Возврат Ответ; 

	
	
КонецФункции

Функция ОтправитьСообщение(СписокКонтактов, НовоеСообщение, СтруктуруФайла)Экспорт
	
	МассивИДКонтрагентов = Новый Массив;
	Для Каждого Стр из СписокКонтактов Цикл
		МассивИДКонтрагентов.Добавить(Строка(Стр.УникальныйИдентификатор()));
		Если ТипЗнч(Стр) = Тип("СправочникСсылка.Контрагенты") Тогда
			КонтактСсылка = Истина;
		Иначе
			КонтактСсылка = Ложь;
		КонецЕсли;	
	КонецЦикла;
		
	СтруктураЗапроса = Новый Структура;
	СтруктураЗапроса.Вставить("method", "SendMessage");
	СтруктураЗапроса.Вставить("Контакты", МассивИДКонтрагентов);
	СтруктураЗапроса.Вставить("КонтрагентСсылка", КонтактСсылка);
	СтруктураЗапроса.Вставить("НовоеСообщение", НовоеСообщение);
	
	Если СтруктуруФайла <> Неопределено Тогда
		СтруктураЗапроса.Вставить("СтруктуруФайла", СтруктуруФайла);
	КонецЕсли;	

	Ответ = ОтправитьЗапросНаПолучениеИнформации(СтруктураЗапроса); 
	
	Возврат Ответ;	
	
	
КонецФункции	

#КонецОбласти


#Область Процедуры_И_Функции_Приложения_Сервер

//////Обновляем регистр сообщений///////
Процедура ЗаписатьИсториюСообщенийВайбер(МассивСообщений)Экспорт
	
	Для Каждого Стр из МассивСообщений Цикл
		ВыполнитьОбновлениеЗаписи(Стр); 
	КонецЦикла;	
	
КонецПроцедуры

/////Поиск и обновление записи регистра/////////////////////////
Процедура ВыполнитьОбновлениеЗаписи(Стр)
	
	ТокенСообщения = СтрЗаменить(Стр.ТокенСообщния, Символ(160), "");
	 
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ViberИсторииСообщений.Контакт КАК Контакт,
		|	ViberИсторииСообщений.Дата КАК Дата,
		|	ViberИсторииСообщений.Направление КАК Направление,
		|	ViberИсторииСообщений.ЧатID КАК ЧатID,
		|	ViberИсторииСообщений.ТокенСообщния КАК ТокенСообщния,
		|	ViberИсторииСообщений.ИсточникПривличения КАК ИсточникПривличения,
		|	ViberИсторииСообщений.Картинка КАК Картинка,
		|	ViberИсторииСообщений.Файл КАК Файл,
		|	ViberИсторииСообщений.Видео КАК Видео,
		|	ViberИсторииСообщений.Текст КАК Текст,
		|	ViberИсторииСообщений.ПутьКФайлу КАК ПутьКФайлу,
		|	ViberИсторииСообщений.Размер КАК Размер,
		|	ViberИсторииСообщений.Наименование КАК Наименование,
		|	ViberИсторииСообщений.ФайлВБазе КАК ФайлВБазе,
		|	ViberИсторииСообщений.Доставлено КАК Доставлено,
		|	ViberИсторииСообщений.Прочтено КАК Прочтено,
		|	ViberИсторииСообщений.Менеджер КАК Менеджер,
		|	ViberИсторииСообщений.Отправитель КАК Отправитель
		|ИЗ
		|	РегистрСведений.ViberИсторииСообщений КАК ViberИсторииСообщений
		|ГДЕ
		|	ViberИсторииСообщений.ТокенСообщния ПОДОБНО &ТокенСообщния";
	
	Запрос.УстановитьПараметр("ТокенСообщния", ТокенСообщения);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Количество() > 0 Тогда 
		Пока Выборка.Следующий() Цикл
			Запись = РегистрыСведений.ViberИсторииСообщений.СоздатьМенеджерЗаписи();
			ЗаполнитьЗначенияСвойств(Запись, Выборка);
			Запись.Прочитать();
			Если Запись.Выбран() Тогда
				ЗаполнитьЗначенияСвойств(Запись, Стр);
				Запись.Дата    = ПолучитьДатуИзСтроки(Стр.Дата);
				Запись.Контакт = ПолучитьКонтакт(Стр.Контрагент, Стр.НовоеСообщение, Стр.Подписан);
				Запись.ТокенСообщния   = ТокенСообщения;
			Если ЗначениеЗаполнено(Стр.Менеджер) Тогда
				Запись.Менеджер = Справочники.УчасникиЧата.ПолучитьСсылку(Новый УникальныйИдентификатор(Стр.Менеджер));
			КонецЕсли;
			
			Запись.Направление = Перечисления.Viber_Направление[Стр.Напрвление];
			
			УИДКлиента = Новый УникальныйИдентификатор(Стр.КлиентВайбер);
			СправочникКонтрагент = Справочники.КонтактыViber.ПолучитьСсылку(УИДКлиента);
			Если СсылкаСуществует(СправочникКонтрагент) Тогда
				Запись.КлиентВайбер = СправочникКонтрагент.Ссылка;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Стр.Менеджер) Тогда
				Запись.Отправитель = Справочники.УчасникиЧата.ПолучитьСсылку(Новый УникальныйИдентификатор(Стр.Менеджер));
			КонецЕсли;	
			    Запись.Записать();
			КонецЕсли;			
		КонецЦикла;
	Иначе
		Запись = РегистрыСведений.ViberИсторииСообщений.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(Запись, Стр);
		Запись.Дата     = ПолучитьДатуИзСтроки(Стр.Дата);
		Запись.Контакт  = ПолучитьКонтакт(Стр.Контрагент, Стр.НовоеСообщение, Стр.Подписан);
		Запись.ТокенСообщния   = ТокенСообщения;
		Если ЗначениеЗаполнено(Стр.Менеджер) Тогда
			Запись.Менеджер = Справочники.УчасникиЧата.ПолучитьСсылку(Новый УникальныйИдентификатор(Стр.Менеджер));
		КонецЕсли;
		
		Запись.Направление = Перечисления.Viber_Направление[Стр.Напрвление];
		
		Если ЗначениеЗаполнено(Стр.Менеджер) Тогда
			Запись.Отправитель = Справочники.УчасникиЧата.ПолучитьСсылку(Новый УникальныйИдентификатор(Стр.Менеджер));
		КонецЕсли;	
		
		УИДКлиента = Новый УникальныйИдентификатор(Стр.КлиентВайбер);
		СправочникКонтрагент = Справочники.КонтактыViber.ПолучитьСсылку(УИДКлиента);
		Если СсылкаСуществует(СправочникКонтрагент) Тогда
			Запись.КлиентВайбер = СправочникКонтрагент.Ссылка;
			Если НЕ ЗначениеЗаполнено(Запись.Контакт) Тогда
				ЗаписьС = РегистрыСведений.НовоеСообщение.СоздатьМенеджерЗаписи();
				ЗаписьС.Контакт = СправочникКонтрагент.Ссылка;
				ЗаписьС.Прочитать();
				Если ЗаписьС.Выбран() Тогда
					ЗаписьС.Новое = Стр.НовоеСообщение;
					ЗаписьС.Записать();
				ИНаче
					ЗаписьС.Контакт = СправочникКонтрагент.Ссылка;
					ЗаписьС.Новое = Стр.НовоеСообщение;
					ЗаписьС.Записать();
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;
		Запись.Записать();
	КонецЕсли;	
		
						
			
	
	
	
КонецПроцедуры

/////запись шаблонов сообщений /////////////////////////////////
Процедура ОбновитьШаблоныВайбер(СписокШаблонов)Экспорт
	
	Для Каждого Ст из СписокШАблонов Цикл
		Спр = Справочники.ШаблоныСообщений.НайтиПоКоду(Ст.Код);
		Если Спр <> Справочники.ШаблоныСообщений.ПустаяСсылка() Тогда
			Если Спр.Текст <> Ст.Текст Тогда
				Нспр = Спр.ПолучитьОбъект();
				Нспр.Текст = Ст.Текст;
				Нспр.Записать();
			КонецЕсли;
		Иначе
			Нспр = Справочники.ШаблоныСообщений.СоздатьЭлемент();
			Нспр.Код          = Ст.Код;
			Нспр.Текст        = Ст.Текст;
			Нспр.Наименование = Ст.Наименование;
			Нспр.Записать();
		КонецЕсли;		
		
	КонецЦикла;	

КонецПроцедуры

//// записываем новые контакты /////////////////////////////////
Процедура ОбновитьСписокКонтактов(НовыеКонтакты)Экспорт
	
	Для Каждого Ст из НовыеКонтакты Цикл
		
		УИД = Новый УникальныйИдентификатор(Ст.ИДКонтакта);
		СправочникСсылка = Справочники.КонтактыViber.ПолучитьСсылку(УИД);
		Если НЕ СсылкаСуществует(СправочникСсылка) Тогда
        	Спр = Справочники.КонтактыViber.СоздатьЭлемент();
			
			Спр.ОбменДанными.Загрузка = Истина;
			Спр.УстановитьСсылкуНового(СправочникСсылка);
			
			Спр.Наименование = Ст.Наименование;
			Спр.Телефон      = Ст.Телефон;
			Спр.ДатаПодписки = Ст.Дата;
			Спр.Новый        = Истина;
			
			Спр.Записать();		
		
		КонецЕсли;
	КонецЦикла
	
КонецПроцедуры

//// записываем новые контакты /////////////////////////////////
Процедура ОбновитьСписокНовых(НовыеКонтакты)Экспорт
	
	Для Каждого Ст из НовыеКонтакты Цикл
		
		УИД = Новый УникальныйИдентификатор(Ст.ИДКонтакта);
		СправочникСсылка = Справочники.КонтактыViber.ПолучитьСсылку(УИД);
		Если ЗначениеЗаполнено(СправочникСсылка) Тогда
			Если ЗначениеЗАполнено(СправочникСсылка.Контрагент.ВерсияДанных) Тогда
				Если НЕ СправочникСсылка.Контрагент.ПодписанийВВайбере Тогда
					Спр = СправочникСсылка.Контрагент.ПолучитьОбъект();
					Спр.ПодписанийВВайбере = Истина;
					Если Ст.Статус = "Разрешон" Тогда
						Спр.СтатусДиалога = Истина;
					Иначе
						Спр.СтатусДиалога = Ложь;
					КонецЕсли;
					Спр.ОстатокСесия = Ст.Сесия;
					Спр.мЭтоОбмен = Истина;
					Спр.Записать();
				КонецЕсли;
			Иначе
				УИДКон = Новый УникальныйИдентификатор(Ст.ИДКонтрагента);
				СправочникСсылкаКон = Справочники.Контрагенты.ПолучитьСсылку(УИДКон);
				Если ЗначениеЗаполнено(СправочникСсылкаКон.Телефон) И (НЕ СправочникСсылкаКон.ПодписанийВВайбере ИЛИ СправочникСсылка.Контрагент <> СправочникСсылкаКон.Ссылка ) Тогда
					СпрК = СправочникСсылкаКон.ПолучитьОбъект();
					СпрК.ПодписанийВВайбере = Истина;
					Если Ст.Статус = "Разрешон" Тогда
						СпрК.СтатусДиалога = Истина;
					Иначе
						СпрК.СтатусДиалога = Ложь;
					КонецЕсли;
					СпрК.ОстатокСесия = Ст.Сесия;
					//Если СпрК.ПодписанийВВайбере = Спрк.Ссылка.ПодписанийВВайбере И Спрк.СтатусДиалога = СпрК.Ссылка.СтатусДиалога Тогда 
					СпрК.мЭтоОбмен = Истина;
					//КонецЕсли;

					СпрК.Записать();
					
					Спр = СправочникСсылка.ПолучитьОбъект();
					Спр.Контрагент = СпрК.Ссылка;
					Если Ст.Статус = "Разрешон" Тогда
						Спр.СтатусДиалога = Истина;
					Иначе
						Спр.СтатусДиалога = Ложь;
					КонецЕсли;
					
					Спр.Записать();
					
				КонецЕсли;
				
			КонецЕсли;
			
			
		Иначе
			Спр = Справочники.КонтактыViber.СоздатьЭлемент();
			
			Спр.ОбменДанными.Загрузка = Истина;
			Спр.УстановитьСсылкуНового(СправочникСсылка);
			
			Спр.Наименование = Ст.Наименование;
			Спр.Телефон      = Ст.Телефон;
			Спр.ДатаПодписки = Ст.Дата;
			Если Ст.Статус = "Разрешон" Тогда
				Спр.СтатусДиалога = Истина;
			Иначе
				Спр.СтатусДиалога = Ложь;
			КонецЕсли;
			
			Если ЗначениеЗаполнено(Ст.ИДКонтрагента) Тогда
				УИДКон = Новый УникальныйИдентификатор(Ст.ИДКонтрагента);
				СправочникСсылкаКон = Справочники.Контрагенты.ПолучитьСсылку(УИДКон);
				Если СсылкаСуществует(СправочникСсылкаКон) Тогда
					Спр.Контрагент = СправочникСсылкаКон; 
				КонецЕсли;
			КонецЕсли;	
			
			Попытка
				Спр.Записать();
				
				
				Если ЗначениеЗаполнено(Спр.Контрагент) Тогда
					СпрК = Спр.Контрагент.ПолучитьОбъект();				
					СпрК.ПодписанийВВайбере = Истина;
					Если Ст.Статус = "Разрешон" Тогда
						СпрК.СтатусДиалога = Истина;
					Иначе
						СпрК.СтатусДиалога = Ложь;
					КонецЕсли;   				
					СпрК.ОстатокСесия = Ст.Сесия;
					//Если СпрК.ПодписанийВВайбере = Спрк.Ссылка.ПодписанийВВайбере И Спрк.СтатусДиалога = СпрК.Ссылка.СтатусДиалога Тогда 
					СпрК.мЭтоОбмен = Истина;
					//КонецЕсли;
					
					СпрК.Записать();
				КонецЕсли;	
			Исключение
			КонецПопытки;
			
		КонецЕсли;
		
		УИДКон = Новый УникальныйИдентификатор(Ст.ИДКонтрагента);
		СправочникСсылкаКон = Справочники.Контрагенты.ПолучитьСсылку(УИДКон);
		Если  ЗначениеЗаполнено(СправочникСсылкаКон.Телефон) Тогда
			Если Ст.Статус = "Разрешон" Тогда
				СтатусДиалога = Истина;
			Иначе
				СтатусДиалога = Ложь;
			КонецЕсли;
			
			ОстатокСесия = Ст.Сесия;
			Если НЕ ЗначениеЗаполнено(ОстатокСесия) Тогда
				ОстатокСесия = 0;
			КонецЕсли;	
			
			Если СправочникСсылкаКон.СтатусДиалога <> СтатусДиалога ИЛИ СправочникСсылкаКон.ОстатокСесия <> Число(ОстатокСесия) Тогда 
				СпрК = СправочникСсылкаКон.ПолучитьОбъект();
				Если Ст.Статус = "Разрешон" Тогда
					СпрК.СтатусДиалога = Истина;
				Иначе
					СпрК.СтатусДиалога = Ложь;
				КонецЕсли;   				
