///// получаем список сообщений через сервер ////////////////////////////
Функция ВыполнитьЗагрузкуНовыхСообщений()Экспорт
	ДатаОбмена = ТекущаяДата() - 3 * 24 * 3600;
	
	Ответ = ViberОбновлениеСервер.ОбновитьСписокИсторииСообщений();
	Если Ответ <> Неопределено Тогда
		Если Ответ.Свойство("МассивСообщений") Тогда
			ViberОбновлениеСервер.ЗаписатьИсториюСообщенийВайбер(Ответ.МассивСообщений);		
		КонецЕсли;
		
		Если Ответ.Свойство("Шаблоны") Тогда
			ViberОбновлениеСервер.ОбновитьШаблоныВайбер(Ответ.Шаблоны);				
		КонецЕсли;
		
		Если Ответ.Свойство("НовыеКонтакты") Тогда
			ViberОбновлениеСервер.ОбновитьСписокКонтактов(Ответ.НовыеКонтакты);				
		КонецЕсли;
		
		Если Ответ.Свойство("МассивКонтактыВайбер") Тогда
			ViberОбновлениеСервер.ОбновитьСписокНовых(Ответ.МассивКонтактыВайбер);				
		КонецЕсли;
 
		
		//Константы.ДатаОбновлениеСообщений.Установить(ТекущаяДата());
		  Константы.ДатаПоследнегоОбновленияВайбер.Установить(ДатаОбмена);
	КонецЕсли;
	
КонецФункции	

