/////// отправить контак вайбер //////////////////////////////
Процедура ОтправитьКонтрагентаНаСервере(Контакт, Контрагент)Экспорт
	
	
	Данные = Новый Структура("Контрагенты", Истина);
	Данные.Вставить("ОтборКонтрагент", Контрагент);
	ДанныеКонтрагента = Обмен_АнализДанных.ОтправитьИзменения(Данные);
	
	СтруктураЗапроса = Новый Структура();
	СтруктураЗапроса.Вставить("method", "svias");
	СтруктураЗапроса.Вставить("Контрагент", Строка(Контрагент.УникальныйИдентификатор()));
	СтруктураЗапроса.Вставить("Наименование", Строка(Контрагент.Наименование));
	СтруктураЗапроса.Вставить("Телефон", Строка(Контрагент.Телефон));
	СтруктураЗапроса.Вставить("Контакт", Строка(Контакт.УникальныйИдентификатор()));
	СтруктураЗапроса.Вставить("ДанныеКонтрагента", XMLСтрока(Новый ХранилищеЗначения(ДанныеКонтрагента)));
	СтруктураЗапроса.Вставить("Пароль", Константы.ПарольВхода.Получить());



	Ответ = ОтправитьЗапросНаПолучениеИнформации(СтруктураЗапроса);
	
	Если ТипЗнч(Ответ) = Тип("Структура") Тогда
		Если Ответ.Result = "Ok" Тогда 
	    	ПерезаписываемСообщенияВайбер(Ответ.СписокСообщений);
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры	

