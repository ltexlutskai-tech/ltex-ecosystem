		|	ViberИсторииСообщений.ТокенСообщния КАК ТокенСообщния,
		|	ViberИсторииСообщений.ИсточникПривличения КАК ИсточникПривличения,
		|	ViberИсторииСообщений.Картинка КАК Картинка,
		|	ViberИсторииСообщений.Файл КАК Файл,
		|	ViberИсторииСообщений.Видео КАК Видео,
		|	ViberИсторииСообщений.Текст КАК Текст,
		|	ViberИсторииСообщений.ПутьКФайлу КАК ПутьКФайлу,
		|	ViberИсторииСообщений.Размер КАК Размер,
		|	ViberИсторииСообщений.Наименование КАК Наименование,
		|	ViberИсторииСообщений.ФайлВБазе КАК ФайлВБазе,
		|	ViberИсторииСообщений.Доставлено КАК Доставлено,
		|	ViberИсторииСообщений.Прочтено КАК Прочтено,
		|	ViberИсторииСообщений.Менеджер КАК Менеджер,
		|	ViberИсторииСообщений.Отправитель КАК Отправитель
		|ИЗ
		|	РегистрСведений.ViberИсторииСообщений КАК ViberИсторииСообщений
		|ГДЕ
		|	ViberИсторииСообщений.Контакт = &Контакт";
	
	Запрос.УстановитьПараметр("Контакт", Контакт);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	HTML_Схема = ПолучитьСхемуHTML();
	
	Для Каждого Сообщения из РезультатЗапроса Цикл
		Если Сообщения.Направление = Перечисления.Viber_Направление.Входящее Тогда
			Если Сообщения.Доставлено Тогда 
				Класс = "newin";
			Иначе
				Класс = "in";
			КонецЕсли;	
		Иначе
			Класс = "out";
		КонецЕсли;
		
		Если НЕ Сообщения.Картинка И НЕ Сообщения.Файл И НЕ Сообщения.Видео Тогда
			Текст = Сообщения.Текст;
		Иначе
			Текст = Сообщения.Наименование;
		КонецЕсли;
		
		Время = ?(Сообщения.Дата < НачалоДня(ТекущаяДата()), Формат(Сообщения.Дата, "ДФ='дд.ММ.гг ЧЧ:мм'"), Формат(Сообщения.Дата, "ДФ=ЧЧ:мм"));
		
		Если НЕ Сообщения.Картинка И НЕ Сообщения.Файл И НЕ Сообщения.Видео Тогда   
			
			HTML_Схема = HTML_Схема + Символы.ПС + "		<div class=""" + Класс + """>" + Текст + " <font color=""#666666""><sub>" + Время + "</sub></font></div><br clear=""all"">";
			
		ИначеЕсли Сообщения.Картинка Тогда
			
			HTML_Схема = HTML_Схема + Символы.ПС + "		<div class=""" + Класс + """ style=""text-align: right;""><img height=""200"" src=""" + Сообщения.ПутьКФайлу + """ ><br><font color=""#666666""><sub>" + Время + "</sub></font></div><br clear=""all"">";

		Иначе
			
			HTML_Схема = HTML_Схема + Символы.ПС + "		<div class=""" + Класс + """> <a href=""" + Текст + """><b><i>" + Сообщения.ПутьКФайлу + "</i></b></a> <font color=""#666666""><sub>" + Время + "</sub></font></div><br clear=""all"">";
			
    	КонецЕсли;	
		
	КонецЦикла;	
	
	HTML_Схема = HTML_Схема + Символы.ПС +
	
	
	"	</body>
	|</html>";

	Возврат Новый Структура("Переписка", HTML_Схема);
	
	
КонецФункции

