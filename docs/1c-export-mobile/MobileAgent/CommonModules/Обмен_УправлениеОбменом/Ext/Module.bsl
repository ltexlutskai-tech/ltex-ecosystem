		КонецЕсли;		
		
		ВыборкаХарактеристика = ВыборкаНоменклатура.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		ВстановленаЦена = Ложь;
		Пока ВыборкаХарактеристика.Следующий() Цикл 
			Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(ВыборкаХарактеристика.УИДХарактеристикаНоменклатуры);
			Если ЗначениеЗаполнено(Характеристика) Тогда 
				Если НЕ ПустаяСтрока(Характеристика.ВерсияДанных) И ВыборкаХарактеристика.Остаток  Тогда 
					
					Если Характеристика.Залишок <> ВыборкаХарактеристика.Остаток
						Или Характеристика.Целевой  <> ВыборкаХарактеристика.Целевой
						Или Характеристика.СсылкаНаYouTube  <> ВыборкаХарактеристика.СсылкаНаYouTube 
						Или Характеристика.Описание  <> ВыборкаХарактеристика.Описание 
						Или Характеристика.Бронь  <> ВыборкаХарактеристика.Бронь 
						Или Характеристика.ПериодБрони  <> ВыборкаХарактеристика.ПериодБрони Тогда 
						
						Характ = Характеристика.ПолучитьОбъект();
						Характ.Залишок 				= ВыборкаХарактеристика.Остаток;
						Характ.Целевой 				= ВыборкаХарактеристика.Целевой;
						Характ.СсылкаНаYouTube 		= ВыборкаХарактеристика.СсылкаНаYouTube;
						Характ.Описание 			= ВыборкаХарактеристика.Описание;
						Характ.Бронь  				= ВыборкаХарактеристика.Бронь; 
						Характ.ПериодБрони 			= ВыборкаХарактеристика.ПериодБрони;
						Характ.МояБронь 			= ВыборкаХарактеристика.МояБронь;
						Характ.Контрагент 			= Справочники.Контрагенты.ПолучитьСсылку(ВыборкаХарактеристика.УИДКонтрагент);


						Характ.Записать();
					КонецЕсли;
				Иначе 
					НоваяХарактеристика = Справочники.ХарактеристикиНоменклатуры.СоздатьЭлемент();
					НоваяХарактеристика.УстановитьСсылкуНового(Характеристика);
					НоваяХарактеристика.Владелец 		= Номенклатура;
					НоваяХарактеристика.Наименование 	= ВыборкаХарактеристика.НаименованиеХарактеристики;
					НоваяХарактеристика.Вага 			= ВыборкаХарактеристика.Вага;
					НоваяХарактеристика.Залишок 		= ВыборкаХарактеристика.Остаток;
					НоваяХарактеристика.Целевой 		= ВыборкаХарактеристика.Целевой;
					НоваяХарактеристика.СсылкаНаYouTube = ВыборкаХарактеристика.СсылкаНаYouTube;
					НоваяХарактеристика.Описание 		= ВыборкаХарактеристика.Описание;
					НоваяХарактеристика.Бронь  			= ВыборкаХарактеристика.Бронь; 
					НоваяХарактеристика.ПериодБрони 	= ВыборкаХарактеристика.ПериодБрони;
					НоваяХарактеристика.МояБронь 		= ВыборкаХарактеристика.МояБронь;
					НоваяХарактеристика.Контрагент 		= Справочники.Контрагенты.ПолучитьСсылку(ВыборкаХарактеристика.УИДКонтрагент);

					НоваяХарактеристика.Записать();
					Характеристика = НоваяХарактеристика.Ссылка;
				КонецЕсли;	
				Строка = ТЗ_ПрийнятыхОстатков.Добавить();
				Строка.ХарактеристикиНоменклатуры = Характеристика; 
			КонецЕсли;
			
			ВыборкаЦена = ВыборкаХарактеристика.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаЦена.Следующий() Цикл 
				
				Если не ЗначениеЗаполнено(ВыборкаЦена.УИДТипЦен) Тогда 
					Продолжить;                            
				КонецЕсли;
				
				ТипЦен = Справочники.ТипыЦенНоменклатуры.ПолучитьСсылку(ВыборкаЦена.УИДТипЦен);
				Если ПустаяСтрока(ТипЦен.ВерсияДанных)Тогда 
					Продолжить;
				КонецЕсли;
				отбор = Новый Структура("Номенклатура, ТипЦен", Номенклатура, ТипЦен);
				Если  ТЗ_Цены.НайтиСтроки(отбор).Количество() Тогда 
					Продолжить;
				КонецЕсли;

				
				Запись = НаборЗаписейЦен.Добавить();
				Запись.Номенклатура = Номенклатура;
				Запись.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
				Запись.Период = ТекущаяДата();
				Запись.Цена = ВыборкаЦена.Цена;
				Запись.ТипЦен = ТипЦен;
				Запись.ЦенаАкция = ВыборкаЦена.ЦенаАкция;
				//Запись.КонецАкции = ВыборкаЦена.КонецАкции;
				
				ЗаполнитьЗначенияСвойств(ТЗ_Цены.Добавить(), Запись); 
				
			КонецЦикла;                   
		КонецЦикла;	
	КонецЦикла;
	
	
	ЗанультьОстатки(ТЗ_ПрийнятыхОстатков);
	//Приход.Записать(РежимЗаписиДокумента.Проведение);
	НаборЗаписейЦен.Записать();
	
	Если Данные.Свойство("ЦеныПоставщиков") Тогда 
		ЗаписатьЦеныПоставщиков(Данные.ЦеныПоставщиков);
	КонецЕсли;
	
	
КонецФункции


Процедура ЗанультьОстатки(Характеристики)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ТЗ.ХарактеристикиНоменклатуры КАК Характеристика
	|ПОМЕСТИТЬ ХН
	|ИЗ
	|	&ТЗ КАК ТЗ
	|
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ХарактеристикиНоменклатуры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ ХН КАК ХН
	|		ПО (ХН.Характеристика = ХарактеристикиНоменклатуры.Ссылка)
	|ГДЕ
	|	ХН.Характеристика ЕСТЬ NULL
	|	И ХарактеристикиНоменклатуры.Залишок <> 0";
	Запрос.УстановитьПараметр("ТЗ", Характеристики);
	Выборка = Запрос.Выполнить().Выбрать(); 
	Пока Выборка.Следующий() Цикл 
		Объект = Выборка.Ссылка.ПолучитьОбъект();
		Объект.Залишок = 0;
		Объект.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьЦеныПоставщиков(Данные)  
	Набор = РегистрыСведений.ЦеныПоставщиков.СоздатьНаборЗаписей();
	Выборка = Данные.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока Выборка.Следующий() Цикл
		Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(Выборка.УИДНоменклатуры));
		Если Не ЗначениеЗаполнено(Номенклатура.ВерсияДанных) Тогда 
			Продолжить;
		КонецЕсли;
		
		ВыборкаДетали = Выборка.Выбрать();
		Пока ВыборкаДетали.Следующий() Цикл 
			Запись = Набор.Добавить();
			Запись.Номенклатура = Номенклатура;
			Запись.Постачальник = ВыборкаДетали.Поставщик;
			Запись.Цена = ВыборкаДетали.ЦенаЗакупкиВес;
		КонецЦикла;
	КонецЦикла;;
	
	Набор.Записать();
КонецПроцедуры



