Функция ОбновлениеИнфоОБрониМешков() Экспорт;
	Попытка
		Прокси = СоединениеСБазой.ПолучитьПрокси();
		Пароль = Константы.ПарольВхода.Получить();
		
		Данные = Новый Структура;
		Данные.Вставить("Команда", "ЗапросНаОбновлениеИнформацииОБрони");
		Ответ = Прокси.ЗабронюватиНоменклатуру(Пароль, Сериализовать(Данные));
		Ответ = Ответ.Получить();
		Массив = Новый Массив;
		Если Ответ.Успешно Тогда 
			Для Каждого Элемент из Ответ.ИнфоОБрони Цикл 
				Массив.Добавить(Элемент.УИД);
				
				Вага =  Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Элемент.УИДХарактеристики);
				Если ПустаяСтрока(Вага.ВерсияДанных) Тогда 
					Продолжить;
				КонецЕсли;
				
				ВагаОбъект = Вага.ПолучитьОбъект();
				ВагаОбъект.Бронь = Элемент.Бронь;
				ВагаОбъект.ПериодБрони 		= Элемент.ПериодБрони;
				ВагаОбъект.МояБронь 		= Элемент.МояБронь;
				ВагаОбъект.Контрагент 		= Справочники.Контрагенты.ПолучитьСсылку(Элемент.УИДКонтрагент);
				ВагаОбъект.Открыт 			= Элемент.Открыт;
				ВагаОбъект.СекторНаСкладі 	= Элемент.СекторНаСкладі;
				ВагаОбъект.Коментар 		= Элемент.Коментар;

				ВагаОбъект.Записать();
			КонецЦикла;
			
		Иначе
			Сообщить(Ответ.Ошибка);
		КонецЕсли; 
		
		
		Данные.Вставить("Команда", "ОтветНаОбновлениеИнформацииОБрони");
		Данные.Вставить("МассивИД", Массив);
		Ответ = Прокси.ЗабронюватиНоменклатуру(Пароль, Сериализовать(Данные));
		
	Исключение 
		Текст = ИнформацияОбОшибке();
	КонецПопытки;
	
	
	
	
КонецФункции

Процедура ОбновитьИдентификаторПолучателя() Экспорт
	
	Прокси = СоединениеСБазой.ПолучитьПрокси();
