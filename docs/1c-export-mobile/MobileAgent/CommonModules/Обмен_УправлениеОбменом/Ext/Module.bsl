Функция ПорахуватиКількістьДанихВПакеті(СтруктураДаних)
	КількістьДаних = 0;
	Для Каждого ЭлементСтр Из СтруктураДаних.Документы.Заказы Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.Документы.МаршрутныйЛист Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.Документы.Реализация Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.РегистрСведений.КатегорииОбъектов Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.РегистрСведений.ЦеныНоменклатуры Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.РегистрСведений.Штрихкоды Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.Справочники.ЕдиницыИзмерения Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.Справочники.Контрагенты Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	//Для Каждого ЭлементСтр Из СтруктураДаних.Справочники.Маршруты Цикл
	//	КількістьДаних = КількістьДаних + 1;
	//КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.Справочники.Нагадування Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.Справочники.Номенклатура Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Для Каждого ЭлементСтр Из СтруктураДаних.Справочники.ХарактеристикиНоменклатуры Цикл
		КількістьДаних = КількістьДаних + 1;
	КонецЦикла;
	Возврат КількістьДаних;
КонецФункции


