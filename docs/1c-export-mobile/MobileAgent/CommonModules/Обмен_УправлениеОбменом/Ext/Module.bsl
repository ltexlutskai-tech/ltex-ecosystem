Функция ВыполнитьОбменДанными(ЭтоНеПервыйОбмен = Истина) Экспорт
	
	//Тест();
	//Возврат 1;
	
	Попытка
		Константы.ЭтоНеПервыйОбмен.Установить(ЭтоНеПервыйОбмен);
		Если Не ЭтоНеПервыйОбмен Тогда 
			Константы.ДатаОбновлениеСообщений.Установить(ТекущаяДата() - 60 *24 * 3600);
		КонецЕсли;
		
		Лог("Начало обмена",2);
		Попытка
			//Константы.ПроцентОбмена.Установить(0.01);
			Константы.ОшибкаОбмена.Установить("");
			
			
		Исключение
			Возврат ЗавершитьОбмен("Ошибка доступа к константам");
			
		КонецПопытки;
		//Константы.ПроцентОбмена.Установить(0.02);
		Лог("Підключаємось",3);
		Попытка
			Прокси = СоединениеСБазой.ПолучитьПрокси();
		Исключение
			Возврат ЗавершитьОбмен("Не вдалось підключитись до сервера: "+ОписаниеОшибки());
		КонецПопытки;
		//Константы.ПроцентОбмена.Установить(0.03);
		Лог("Готуємо дані для входа на сервер",4);
		Попытка
			СисИнфо = Новый СистемнаяИнформация;
			КодМобильногоКомпьютера = Строка(СисИнфо.ИдентификаторКлиента);
			
			ПарольВхода = СокрЛП(Константы.ПарольВхода.Получить());
			
			Если Не ЗначениеЗаполнено(ПарольВхода) Тогда 
				Возврат ЗавершитьОбмен("Не заповнено пароль для обміну");
			КонецЕсли;	
			
		Исключение
			Возврат ЗавершитьОбмен("Ошибка доступа к данным клиента");
			
		КонецПопытки;
		
		ЭтоНеПервыйОбмен = Константы.ЭтоНеПервыйОбмен.Получить();
		Если НЕ ЭтоНеПервыйОбмен Тогда 
			Лог("Очистка мобільного додатку",7);
			
			Обмен_АнализДанных.УдалитьВсеДанные();    
			Константы.ЭтоНеПервыйОбмен.Установить(Истина);
		КонецЕсли;
		//Константы.ПроцентОбмена.Установить(0.04);
		Лог("Починаємо обмін",5);
		Попытка
			Ошибка = Прокси.НачатьОбмен(СокрЛП(Метаданные.Версия), КодМобильногоКомпьютера, ПарольВхода, ЭтоНеПервыйОбмен); 
		Исключение
			Возврат ЗавершитьОбмен("Не вдалось розпочати обмін. "+ОписаниеОшибки());
		КонецПопытки;
		//Константы.ПроцентОбмена.Установить(0.05);
		
		Лог("Аналіз відповіді початку",6);
		Попытка
			Если Лев(Ошибка,1) <> "*" Тогда
				
				//Если ЗначениеЗаполнено(Ошибка) Тогда 
				Возврат ЗавершитьОбмен(Ошибка);
			КонецЕсли;
			Константы.ОбменВыполняется.Установить(Истина);
			  
			
			
			
			КоличествоПакетов = Число(Сред(Ошибка,2));
			Лог("Всього записів: "+КоличествоПакетов,8);
			
			ТекПакетов = 0;
			Ошибка = "";
			КоличествоДанныхВПакете = 100;
		Исключение
			Возврат ЗавершитьОбмен("Ошибка начала обмена: "+ ОписаниеОшибки());
			
		КонецПопытки;
		//Константы.ПроцентОбмена.Установить(0.06);
		Перший = Истина;
		Пока КоличествоДанныхВПакете > 0 Цикл
			Лог("Запит на пакет даних з сервера",9);
			Попытка
				ДанныеОбмена = Прокси.СформироватьПакетДанных(КодМобильногоКомпьютера, ПарольВхода);
			Исключение
				Возврат ЗавершитьОбмен("Не вдалось сформувати пакет данних для смартфона"+ОписаниеОшибки());
			КонецПопытки;                                     	
			
			Попытка
				ТаблицаИД = Новый ТаблицаЗначений;
				ТаблицаИД.Колонки.Добавить("ИД");
				

				ДанныеОбменаСтруктура = Десериализовать(ДанныеОбмена);
				
				КоличествоДанныхВПакете = ДанныеОбменаСтруктура.КоличествоЗаписейОбмена;
				
				
			    Если КоличествоДанныхВПакете = 0 Тогда  // Перерахуєм дані може не вірно рахуються
					КоличествоДанныхВПакете = ПорахуватиКількістьДанихВПакеті(ДанныеОбменаСтруктура); //Рахуєм кількість даних в пакеті
				КонецЕсли;
				
				
				
				Лог("Кількість даних в пакеті: "+КоличествоДанныхВПакете,"А");
				//Если НЕ ДанныеОбменаСтруктура.Справочники.Номенклатура.Количество()
				//	И НЕ ДанныеОбменаСтруктура.Документы.
				//	Тогда 
				//	Прервать;
				//КонецЕсли;
				Если КоличествоДанныхВПакете <= 0 Тогда 
					Прервать;
					//Константы.ПроцентОбмена.Установить(100);
				КонецЕсли;
				
				
				
				Если ДанныеОбменаСтруктура.ЭтоПолнаяВыгрузка Тогда 
					Лог("Удаляєм всі дані мобільного додатку","Б");
					Обмен_АнализДанных.УдалитьВсеДанные();
				КонецЕсли;   
				
				
				
				 // Перший И ДанныеОбменаСтруктура.Справочники.Контрагенты.Количество() = 0;
				
				//Если НЕ ЭтоНеПервыйОбмен Тогда     // Тут зависає якщо цпосилка
					Лог("Читаєм отримані дані...","В");
				
					Обмен_АнализДанных.ПрочитатьПакетДанных(ДанныеОбменаСтруктура,ТаблицаИД);  /////////////////////////////////////////// Читаєм дані
					Лог("...Закінчили читати дані","Г");
					Лог("Контрагенты в додатку: " + Справочники.Контрагенты.ПолучитьДанныеВыбора(Новый Структура).Количество(), "0!");
					Лог("Контрагенты в отримано: " + ДанныеОбменаСтруктура.Справочники.Контрагенты.Количество(), "1!");
Перший = Ложь;
				//КонецЕсли;
				//Если ДанныеОбменаСтруктура.ЭтоПолнаяВыгрузка Тогда 
				//	Прокси.ВключитьЧастичныйОбмен(ПарольВхода);
				//Иначе
				Если ТаблицаИД.Количество() Тогда 
					Лог("Видаляємо регістрацію... Кол. записів: "+ТаблицаИД.Количество(),"Д");
					Прокси.УдалитьРегистрацию(Сериализовать(ТаблицаИД),ПарольВхода);
								Лог("Видалили регістрацію","Е");
				КонецЕсли;
				ТекПакетов = ТекПакетов + КоличествоДанныхВПакете;
				Лог("Всього записів: "+ТекПакетов+" з "+КоличествоПакетов,"Ж");
				НовПроцент = ТекПакетов * 100 / КоличествоПакетов;
				Если НовПроцент > 100 Тогда 
					НовПроцент = 99;
				КонецЕсли;
				Константы.ПроцентОбмена.Установить(НовПроцент);
				
				//КонецЕсли;
			Исключение
				Лог("Ошибка обмена: "+ОписаниеОшибки(),"З");
				
				
				Ошибка = Ошибка + " Не вдалось обробити отримані дані "+ ОписаниеОшибки();				
				Если НЕ Найти(Ошибка,"Unexpected end of stream on Connection") И НЕ Найти(Ошибка,"unexpected end of stream on Connection") Тогда 
					Возврат ЗавершитьОбмен(Ошибка);
				КонецЕсли;
			КонецПопытки;	
		КонецЦикла;
		
		/////// Відправка змін на сервер  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		//Лог("Відправка даних на сервер","І");	
		//Попытка
		//	СтруктураОтправки = Обмен_АнализДанных.ОтправитьИзменения();
		//	//Если СтруктураОтправки.Продажи.Количество() ИЛИ СтруктураОтправки.Возвраты.Количество() ИЛИ СтруктураОтправки.НормыЗапасов.Количество()  ИЛИ СтруктураОтправки.Заказы.Количество() Тогда 
		//	//Если  СтруктураОтправки.Заказы.Количество() Тогда 
		//		Рез = Прокси.ОбработатьПакетДанных(ПарольВхода,Сериализовать(Обмен_АнализДанных.ОтправитьИзменения()));     //Відправляємо дані
		//		Если ТипЗнч(Рез) <> Тип("Строка") Тогда 
		//			ОшибкаУдаленияРегистрации = УдалитьРегистрацию(Десериализовать(Рез));
		//		Иначе 
		//			ОшибкаУдаленияРегистрации = Рез;
		//		КонецЕсли;
		//		
		//			
		//		Если ЗначениеЗаполнено(ОшибкаУдаленияРегистрации) Тогда 
		//			Ошибка = Ошибка + " Не вдалось зчитати дані на сервері "+ ОшибкаУдаленияРегистрации;
		//		КонецЕсли;
		//		
		//	//КонецЕсли;               
		//Исключение
		//	Ошибка = Ошибка + " Не вдалось вивантажити дані "+ ОписаниеОшибки();
		//КонецПопытки;
		//Лог("Закінчили відправку на сервер","К");
		
		/////////////////////////////// Читаэм долг партнера
		//Попытка
		//	Константы.ДолгПартнера.Установить(Прокси.ПолучитьДолгПартнера(ПарольВхода));
		//Исключение
		//	Возврат ЗавершитьОбмен("Не вдалось отримати борг партера "+ОписаниеОшибки());
		//КонецПопытки;   	
		
		////////////////////////////////////////////
		
		Константы.ОшибкаОбмена.Установить(Ошибка);
		Константы.ПроцентОбмена.Установить(100);
		НовПроцент = 100;
		Константы.ОбменВыполняется.Установить(Ложь);
		Константы.ДатаОстанньогоОбміну.Установить(ТекущаяДата());
		Возврат Ошибка;
	Исключение
		Возврат ЗавершитьОбмен("Помилка при виконанні обміну "+ ОписаниеОшибки());		
	КонецПопытки;
	
КонецФункции

Функция ВыполнитьОбменДаннымиВыгрузкаЗаказов() Экспорт
	//ЭтоНеПервыйОбмен = Истина;
	Попытка
		
		Лог("Начало обмена",2);
		Попытка
			//Константы.ПроцентОбмена.Установить(0.01);
			Константы.ОшибкаОбмена.Установить("");
			
			
		Исключение
			Возврат ЗавершитьОбмен("Ошибка доступа к константам");
			
		КонецПопытки;
		//Константы.ПроцентОбмена.Установить(0.02);
		Лог("Підключаємось",3);
		Попытка
			Прокси = СоединениеСБазой.ПолучитьПрокси();
		Исключение
			Возврат ЗавершитьОбмен("Не вдалось підключитись до сервера: "+ОписаниеОшибки());
		КонецПопытки;
		//Константы.ПроцентОбмена.Установить(0.03);
		Лог("Готуємо дані для входа на сервер",4);
		Попытка
			СисИнфо = Новый СистемнаяИнформация;
			КодМобильногоКомпьютера = Строка(СисИнфо.ИдентификаторКлиента);
			
			ПарольВхода = СокрЛП(Константы.ПарольВхода.Получить());
			
			Если Не ЗначениеЗаполнено(ПарольВхода) Тогда 
				Возврат ЗавершитьОбмен("Не заповнено пароль для обміну");
			КонецЕсли;	
			
		Исключение
			Возврат ЗавершитьОбмен("Ошибка доступа к данным клиента");
			
		КонецПопытки;
		//Константы.ПроцентОбмена.Установить(0.04);
		Лог("Починаємо обмін",5);
		Попытка
			Ошибка = Прокси.НачатьОбмен(СокрЛП(Метаданные.Версия), КодМобильногоКомпьютера, ПарольВхода,Истина); 
		Исключение
			Возврат ЗавершитьОбмен("Не вдалось розпочати обмін. "+ОписаниеОшибки());
		КонецПопытки;
		//Константы.ПроцентОбмена.Установить(0.05);
		
		Лог("Аналіз відповіді початку",6);
		Попытка
			Если Лев(Ошибка,1) <> "*" Тогда
				
				//Если ЗначениеЗаполнено(Ошибка) Тогда 
				Возврат ЗавершитьОбмен(Ошибка);
			КонецЕсли;
			Константы.ОбменВыполняется.Установить(Истина);
			//ЭтоНеПервыйОбмен = Истина;
			//Если НЕ ЭтоНеПервыйОбмен Тогда 
			//	Лог("Очистка мобільного додатку",7);
			//	
			//	Обмен_АнализДанных.УдалитьВсеДанные();    
			//	Константы.ЭтоНеПервыйОбмен.Установить(Истина);
			//КонецЕсли;  
			
			
			
			КоличествоПакетов = Число(Сред(Ошибка,2));
			Лог("Всього записів: "+КоличествоПакетов,8);
			
			ТекПакетов = 0;
			Ошибка = "";
			КоличествоДанныхВПакете = 100;
		Исключение
			
			Возврат ЗавершитьОбмен("Ошибка начала обмена: "+ ОписаниеОшибки());
			
		КонецПопытки;
		 // Читання змін нема
		///// Відправка змін на сервер  /////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		Лог("Відправка даних на сервер","І");	
		Попытка
			СтруктураОтправки = Обмен_АнализДанных.ОтправитьИзменения();
			//Если СтруктураОтправки.Продажи.Количество() ИЛИ СтруктураОтправки.Возвраты.Количество() ИЛИ СтруктураОтправки.НормыЗапасов.Количество()  ИЛИ СтруктураОтправки.Заказы.Количество() Тогда 
			//Если  СтруктураОтправки.Заказы.Количество() Тогда 
			Рез = Прокси.ОбработатьПакетДанных(ПарольВхода,Сериализовать(СтруктураОтправки));     //Відправляємо дані
			РезРаспакованный = Десериализовать(Рез);
			Если ТипЗнч(РезРаспакованный) = Тип("Строка") Тогда 
				Ошибка = Ошибка + " Не вдалось вигрузити дані на сервер "+ РезРаспакованный;
			Иначе 
				Если РезРаспакованный.Свойство("ИнфоМаршруты") Тогда 
					
					Для Каждого Элемент Из РезРаспакованный.ИнфоМаршруты Цикл 
						
						МаршрутныйЛист = Документы.МаршрутныйЛист.ПолучитьСсылку(Элемент.Маршрут);
						Если ПустаяСтрока(МаршрутныйЛист.ВерсияДанных) Тогда 
							Продолжить;
						КонецЕсли;
						

						Объект = МаршрутныйЛист.ПолучитьОбъект();
						Объект.мЭтоОбмен = Истина;
						Объект.НеХватает.Очистить();

						Для Каждого Элемент Из Элемент.НеХватает Цикл 
							СтрокаНеХватает = Объект.НеХватает.Добавить();
							СтрокаНеХватает.ЗаказПокупателя = Документы.Заказ.ПолучитьСсылку(Элемент.Заказ);
							СтрокаНеХватает.Номенклатура 	= Справочники.Номенклатура.ПолучитьСсылку(Элемент.Номенклатура);
							СтрокаНеХватает.Количество 		= Элемент.НеХватает;
						
						КонецЦикла;
						Объект.Записать();
						//++
						Общий.ЗаписатьИсториюРеализацийИзМаршрутного(Объект.Ссылка)
						//++
					КонецЦикла;
				КонецЕсли;
				
				Общий.ЗанестиВИсториюКлиентовСообщиеняПоДокументамПриОбмене(РезРаспакованный.ТаблицаИД);
				
				ОшибкаУдаленияРегистрации = УдалитьРегистрацию(РезРаспакованный.ТаблицаИД);	
				
				
				
				
				Если ЗначениеЗаполнено(ОшибкаУдаленияРегистрации) Тогда 
					Ошибка = Ошибка + " Не вдалось зчитати дані на сервері "+ ОшибкаУдаленияРегистрации;
				КонецЕсли;
				Для Каждого  Сообщение Из РезРаспакованный.МассивОшибок Цикл 
					Ошибка = Ошибка + Сообщение + Символы.ПС;
				КонецЦикла;
				

				
			КонецЕсли;
			
			//КонецЕсли;               
		Исключение
			Ошибка = Ошибка + " Не вдалось вивантажити дані "+ ОписаниеОшибки();
		КонецПопытки;
		Лог("Закінчили відправку на сервер","К");
		
		/////////////////////////////// Читаэм долг партнера
		//Попытка
