Процедура Лог(Текст,Порядок)Экспорт 
	Возврат;
	
	нз = РегистрыСведений.Лог.СоздатьНаборЗаписей();
	Если Текст = "СбросЛога" Тогда 
		//нз.Записать();
		Возврат;
	КонецЕсли;
	ТекДата = Формат(ТекущаяДата(),"ДЛФ=T") + " "+Строка(Порядок);
	нз.Отбор.Дата.Установить(ТекДата);
	з = нз.Добавить();
	з.Дата = ТекДата;
	з.Лог = Текст;
	нз.Записать();	
