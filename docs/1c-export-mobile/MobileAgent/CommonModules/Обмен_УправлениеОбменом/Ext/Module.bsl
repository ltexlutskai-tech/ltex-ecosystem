	Если Частково Тогда 
		Рез = Прокси.ОновитьОстаткиТаЦеныЧастково(ПарольВхода);
	Иначе 
		Рез = Прокси.ОновитьОстаткиТаЦены(ПарольВхода);
	КонецЕсли;
	Данные = Десериализовать(Рез);
	
