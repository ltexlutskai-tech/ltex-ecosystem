Функция ОбновлениеСтатусовЗаказов() Экспорт 
	
	Попытка
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	Заказ.Контрагент КАК Контрагент
		|ИЗ
		|	Документ.Заказ КАК Заказ
		|
		|СГРУППИРОВАТЬ ПО
		|	Заказ.Контрагент";
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			КонтрагентОбъект = ВыборкаДетальныеЗаписи.Контрагент.ПолучитьОбъект();
			Ответ = Неопределено;
			КонтрагентОбъект.ОновитиСтатусиЗакаів(Ответ);
		КонецЦикла;
		
	Исключение 
		Текст = ИнформацияОбОшибке();
	КонецПопытки;	
	
		
КонецФункции	

Процедура ОбменХарактеристикНоменклатуры();
	
	ПарольВхода = СокрЛП(Константы.ПарольВхода.Получить());		
	Попытка
		Прокси = СоединениеСБазой.ПолучитьПрокси();
	Исключение
		Возврат;
	КонецПопытки; 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ХарактеристикиНоменклатуры.Ссылка КАК Ссылка,
		|	ХарактеристикиНоменклатуры.СекторНаСкладі КАК СекторНаСкладі,
		|	ХарактеристикиНоменклатуры.Коментар КАК Коментар,
		|	РегистрацияОбмена.ИД КАК ИД,
		|	ХарактеристикиНоменклатуры.Открыт КАК Открыт
		|ИЗ
		|	РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
		|		ПО РегистрацияОбмена.Объект = ХарактеристикиНоменклатуры.Ссылка";
	
	Данные = Запрос.Выполнить().Выгрузить();
	Данные.Колонки.Добавить("УИД_Ссылка");
	Для Каждого Элемент Из Данные Цикл 
		
		Элемент.УИД_Ссылка = Элемент.Ссылка.УникальныйИдентификатор();
		
	КонецЦикла;
	
	Параметры = Новый Структура;
	Параметры.Вставить("Команда", "ИзмененияХарактеристик");
	Параметры.Вставить("Параметры", Данные);
	
	Попытка
		Ответ = Прокси.ВыполнитьКоманду(ПарольВхода, Сериализовать(Параметры));  
	    ДанныеОтвет = Ответ.Получить();
		Для Каждого Элемент Из ДанныеОтвет.Данные Цикл 
			Запись = РегистрыСведений.РегистрацияОбмена.СоздатьМенеджерЗаписи();
			Запись.Объект = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Элемент.УИД);
			Запись.ИД = Элемент.ИД;
			Запись.Удалить();
		КонецЦикла;
	Исключение
		
	КонецПопытки;
	
	
	
КонецПроцедуры


Процедура ФоновыйОбмен() Экспорт
	
	Дата_АвтоОбновлениеЧата1с 			= ТекущаяДата();
	Дата_ОбновлениеБрони 				= ТекущаяДата();
	Дата_БоргиТаЦіни 					= ТекущаяДата();
	Дата_АвтоОбновлениеСтатусовЗаказов 	= ТекущаяДата();
	Дата_ОбменНапоминаний				= ТекущаяДата();
	Дата_ОбменХарактеристик				= ТекущаяДата();
	//Дата_ИзмененияДанных				= ТекущаяДата();

	
	Пока Истина Цикл 
		Константы.ДатаПоследнегоФоновогоОбновления.Установить(ТекущаяДата());
		мДатаНачала = ТекущаяУниверсальнаяДатаВМиллисекундах();
		Если ТекущаяДата() > Дата_АвтоОбновлениеЧата1с + 2 Тогда 	
			Обмен_УправлениеОбменом.ОновитьЧат();
			Дата_АвтоОбновлениеЧата1с = ТекущаяДата();
		КонецЕсли;
		
		Если ТекущаяДата() > Дата_ОбновлениеБрони + 2 Тогда 	
			Обмен_УправлениеОбменом.ОбновлениеИнфоОБрониМешков();
			Дата_ОбновлениеБрони = ТекущаяДата();
		КонецЕсли;
		
		Если Константы.АвтоматичнийОбмінБоргиТаЦіни.Получить() 
			И ТекущаяДата() > Дата_БоргиТаЦіни + 5 Тогда 	
			Обмен_УправлениеОбменом.ОбмінБоргиТаЦіни();
			Дата_БоргиТаЦіни = ТекущаяДата();
		КонецЕсли;
		
		Если ТекущаяДата() > Дата_АвтоОбновлениеСтатусовЗаказов + 3600 Тогда 
			ОбновлениеСтатусовЗаказов();
			Дата_АвтоОбновлениеСтатусовЗаказов = ТекущаяДата();
		КонецЕсли;
		
		Если ТекущаяДата() >  Дата_ОбменНапоминаний + 120 Тогда 
			Общий.ЗагрузитьОчередьНапоминанийСДействием();
			Дата_ОбменНапоминаний = ТекущаяДата();
		КонецЕсли;
		
		Если ТекущаяДата() >  Дата_ОбменХарактеристик + 60 Тогда 
			ОбменХарактеристикНоменклатуры();
			Дата_ОбменХарактеристик = ТекущаяДата();
		КонецЕсли;
		
		//Если ТекущаяДата() >  Дата_ИзмененияДанных + 60 Тогда 
		//	ОбменХарактеристикНоменклатуры();
		//	Дата_ИзмененияДанных = ТекущаяДата();
		//КонецЕсли;

		
		
		Отбор = Новый Структура;
		Отбор.Вставить("Состояние", СостояниеФоновогоЗадания.Активно);
		Задания = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
		Для Каждого ФЗ Из Задания Цикл 
			
			Если ФЗ.Ключ = "ФоновыйОбмен" Тогда 
				Продолжить;
			КонецЕсли;
			
			ФЗ.Отменить();
			Попытка
				Выполнить ФЗ.ИмяМетода + "()";
			Исключение
				Сообщение = Новый СообщениеПользователю();
				Сообщение.Текст = ОписаниеОшибки();
				Сообщение.Сообщить();
			КонецПопытки;
		КонецЦикла;
		мДатаОкончания = ТекущаяУниверсальнаяДатаВМиллисекундах();
		ВремяОбмена = мДатаОкончания - мДатаНачала;
	КонецЦикла;
	
КонецПроцедуры
