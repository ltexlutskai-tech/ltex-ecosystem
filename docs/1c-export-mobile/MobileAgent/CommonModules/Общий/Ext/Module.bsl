	СимволЧерныйБольшойКвадрат = "◼";
	СимволЧерныйМалыйКвадрат = "◾";   
	СимволУказательныйПалецУказываетВниз = ПолучитьСимволПоЮникоду(128071); 
	СимволКрасныйКвдарт = ПолучитьСимволПоЮникоду(128997); 
	СимволТелефон		 = ПолучитьСимволПоЮникоду(128242);
	СимволСтрелкаУказываетВниз = ПолучитьСимволПоЮникоду(11015);
	
	
	
	
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл 
		НаименованиеТовара = СимволЗеленыйКруг + СимволЧерныйМалыйКвадрат + " " + Выборка.Наименование + " " + СимволЧерныйМалыйКвадрат + СимволЗеленыйКруг;	
		Текст = "*" + НаименованиеТовара + "*"
		+?(ЗначениеЗаполнено(Выборка.ЦенаАкция) И Выборка.Цена >  Выборка.ЦенаАкция, "
		|
		|*" + СимволКрасныйКвдарт + СимволЧерныйБольшойКвадрат +  " АКЦІЯ " + СимволЧерныйБольшойКвадрат + СимволКрасныйКвдарт + "*" , "" ) 
		+?(ЗначениеЗаполнено(Выборка.ЦенаАкция) И Выборка.Цена >  Выборка.ЦенаАкция, "
		|
		|*" + СимволЗеленыйКруг + СимволБелыйКруг +  " НОВИНКА " + СимволБелыйКруг + СимволЗеленыйКруг  + "*", "" ) + "			
		|
		|" + Выборка.Описание + " 
		|"
		+?(ЗначениеЗаполнено(Выборка.ЦенаАкция) И Выборка.Цена >  Выборка.ЦенаАкция, "
		|~*Ціна: " + Формат(Выборка.Цена, "ЧДЦ=2") + " €/" + ?(Выборка.ВідображатиВШтуках,"шт*~" , "кг*~"), "
		|*Ціна: " + Формат(Выборка.Цена, "ЧДЦ=2") + " €/" + ?(Выборка.ВідображатиВШтуках,"шт* " , "кг* ")) 
		+ ?(ЗначениеЗаполнено(Выборка.ЦенаАкция) И Выборка.Цена >  Выборка.ЦенаАкция, "  
		|_*Акційна: " + Формат(Выборка.ЦенаАкция, "ЧДЦ=2") + " €/" + ?(Выборка.ВідображатиВШтуках,"шт*_" , "кг*_"), "") + "
		|
		|Наші контакти : 
		|" + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + "
		|" + СимволТелефон + " *+380676710516*
		|" + СимволТелефон + " *+380993584992*		
		|
		|" + Выборка.YouTube;
	КонецЦикла;
	Возврат Текст;
	
КонецФункции

&НаСервере
Процедура ПолучитьДанныеУведомленийНаНеделю(Уведомления)Экспорт 
	Уведомления = Новый Массив;
	ДоНедели = ТекущаяДата() + 7 * 24 * 3600;
	ТекущееВремя = ТекущаяДата() - 60;  
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	мНагадування.Ссылка КАК Ссылка,
		|	мНагадування.Нагадування КАК Нагадування,
		|	мНагадування.Періодичність КАК Періодичність,
		|	мНагадування.ДеньНедели КАК ДеньНедели,
		|	мНагадування.ДатаНапоминания КАК ДатаНапоминания,
		|	мНагадування.Наименование КАК Наименование
		|ИЗ
		|	Справочник.Нагадування КАК мНагадування
		|ГДЕ
		|	мНагадування.Активне
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапланированыеУведомления.УИД_Уведомления КАК УИД_Уведомления
		|ИЗ
		|	РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
		|ГДЕ
		|	НЕ ЗапланированыеУведомления.Отложено
		|	И ЗапланированыеУведомления.ДатаУведомления > &ДатаУведомления
		|	И НЕ ЗапланированыеУведомления.ОбъектУведомления.Періодичність = ЗНАЧЕНИЕ(Перечисление.Періоди.НеПовторювати)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапланированыеУведомления.ДанныеУведомления КАК ДанныеУведомления
		|ИЗ
		|	РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
		|ГДЕ
		|	ЗапланированыеУведомления.Отложено
		|	И ЗапланированыеУведомления.ДатаУведомления > &ДатаУведомления";
	
	Запрос.УстановитьПараметр("ДатаУведомления", ТекущаяДата());
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[1].Выбрать();
	Набор = РегистрыСведений.ЗапланированыеУведомления.СоздатьНаборЗаписей();	

	Пока Выборка.Следующий() Цикл 
		Набор.Отбор.УИД_Уведомления.Установить(Выборка.УИД_Уведомления);
		Набор.Записать();
	КонецЦикла;
	

	Выборка = РезультатЗапроса[0].Выбрать();
	
	Пока Выборка.Следующий() Цикл
		МассивДат = Новый Массив;
		мДатаНапоминания = Выборка.ДатаНапоминания;
		Если Выборка.Періодичність = Перечисления.Періоди.Щодня Тогда 
			Пока мДатаНапоминания < ДоНедели Цикл 
				Если мДатаНапоминания > ТекущееВремя Тогда 
					
					МассивДат.Добавить(мДатаНапоминания);
					
				КонецЕсли;
				
				мДатаНапоминания = мДатаНапоминания + 24 * 3600;
				
			КонецЦикла;
			
		ИначеЕсли Выборка.Періодичність = Перечисления.Періоди.Щотижня Тогда 
			мДеньНедели = ДеньНедели(мДатаНапоминания);
			мДатаНапоминания = мДатаНапоминания + (Выборка.ДеньНедели -  мДеньНедели) * 24 * 3600;
			Пока мДатаНапоминания  < ДоНедели Цикл 
				Если мДатаНапоминания > ТекущееВремя Тогда 
					
					МассивДат.Добавить(мДатаНапоминания);
					
				КонецЕсли;
				
				мДатаНапоминания = мДатаНапоминания + 7 * 24 * 3600;
				
			КонецЦикла;
		ИначеЕсли Выборка.Періодичність = Перечисления.Періоди.Щомісяця Тогда 
			
			
			Пока мДатаНапоминания  < ДоНедели Цикл 
				Если мДатаНапоминания > ТекущееВремя Тогда 
					
					МассивДат.Добавить(мДатаНапоминания);
					
				КонецЕсли;
				
				мДатаНапоминания = ДобавитьМесяц(мДатаНапоминания, 1);
				
				
			КонецЦикла;
		ИначеЕсли Выборка.Періодичність = Перечисления.Періоди.Щороку Тогда 
			
			
			Пока мДатаНапоминания  < ДоНедели Цикл 
				Если мДатаНапоминания > ТекущееВремя Тогда 
					
					МассивДат.Добавить(мДатаНапоминания);
					
				КонецЕсли;
				
				мДатаНапоминания = ДобавитьМесяц(мДатаНапоминания, 12);
				
				
			КонецЦикла;

			
		КонецЕсли;
		
		
		Если МассивДат.Количество() Тогда 			
			
			Для Каждого Дата Из МассивДат Цикл 
				УИД = Новый УникальныйИдентификатор;
				ДанныеУведомления = Новый Структура;;
				ДанныеУведомления.Вставить("Заголовок", Выборка.Наименование);
				ДанныеУведомления.Вставить("Текст", Выборка.Нагадування);
				ДанныеУведомления.Вставить("Данные"); 

				ДанныеУведомления["Данные"] = Новый Соответствие;
				ДанныеУведомления["Данные"]["Действие"] = "Напоминание";
				ДанныеУведомления["Данные"]["Дата"] = Дата;
				ДанныеУведомления["Данные"]["УИД_Уведомления"] = Строка(УИД);
				ДанныеУведомления["Данные"]["УИД_Напоминание"] = Строка(Выборка.Ссылка.УникальныйИдентификатор());
				ЗапланироватьУведомление(ДанныеУведомления, Ложь, УИД, Дата, Выборка.Ссылка);
				Уведомления.Добавить(ДанныеУведомления);

			КонецЦикла;	
			
		КонецЕсли;
	КонецЦикла;
	
	
	
	Для Каждого Элемент ИЗ РезультатЗапроса[2].Выгрузить() Цикл 
		ДанныеУведомления = Элемент.ДанныеУведомления.Получить();			 
		
		Уведомления.Добавить(ДанныеУведомления);
		
	КонецЦикла;
	
	
	
	

	  
КонецПроцедуры

