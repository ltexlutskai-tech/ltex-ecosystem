&НаСервере
Процедура ОбновитьПоследнююРаботуСКлиентом(Контрагент) Экспорт 
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	РаботаСКлиентомСрезПоследних.Период КАК Период,
	          |	РаботаСКлиентомСрезПоследних.Запись КАК Запись
	          |ИЗ
	          |	РегистрСведений.РаботаСКлиентом.СрезПоследних(, Клиент = &Клиент) КАК РаботаСКлиентомСрезПоследних";
	з.УстановитьПараметр("Клиент", Контрагент);
	Виборка = з.Выполнить().Выбрать();
	
	контрОб = Контрагент.ПолучитьОбъект();
	ЕстьИзменения = Ложь;
	контрОб.мЭтоОбмен = Истина;
	
	Если Виборка.Следующий() Тогда 
		Если контрОб.РаботаСКлиентомПериод <>  Виборка.Период ИЛИ контрОб.РаботаСКлиентомЗапись <> Виборка.Запись Тогда 
			контрОб.РаботаСКлиентомПериод = Виборка.Период;
			контрОб.РаботаСКлиентомЗапись = Виборка.Запись;
			ЕстьИзменения = Истина;
		КонецЕсли;
	иначе
		Если контрОб.РаботаСКлиентомПериод <>  '00010101' ИЛИ контрОб.РаботаСКлиентомЗапись <> "" Тогда
			контрОб.РаботаСКлиентомПериод =  '00010101';
			контрОб.РаботаСКлиентомЗапись = "";
			ЕстьИзменения = Истина;
		КонецЕсли;
	КонецЕсли;
	Если ЕстьИзменения Тогда 
		контрОб.Записать();
	КонецЕсли;
	
	
КонецПроцедуры

&НаСервере
Процедура ПроверитьЗаполненостьДаннихКонтрагентов() Экспорт
		з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	Контрагенты.Ссылка КАК Ссылка
	          |ИЗ
	          |	Справочник.Контрагенты КАК Контрагенты
	          |ГДЕ
	          |	Контрагенты.РаботаСКлиентомПериод <> ДАТАВРЕМЯ(1, 1, 1)";
	
	Если з.Выполнить().Выбрать().Количество() = 0 Тогда 
		з.Текст = "ВЫБРАТЬ
		          |	Контрагенты.Ссылка КАК Ссылка
		          |ИЗ
		          |	Справочник.Контрагенты КАК Контрагенты";
		Виборка = з.Выполнить().Выбрать();
		Пока Виборка.Следующий() Цикл	
			ОбновитьПоследнююРаботуСКлиентом(Виборка.Ссылка);
		КонецЦикла;
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция  ПоискДублейНомеровТелефона_НаСервере1С(НомерТелефона, Контрагент, Пошук = Ложь) Экспорт
	
	ПараметрыКоманды = Новый Структура;
	ПараметрыКоманды.Вставить("НомерТелефона", НомерТелефона);
	ПараметрыКоманды.Вставить("Контрагент", Контрагент.УникальныйИдентификатор()); 
	ПараметрыКоманды.Вставить("Пошук", Пошук);  
	
	Данные = Новый Структура;
	Данные.Вставить("Команда", "ДублиКонтрагента");
	Данные.Вставить("Параметры", ПараметрыКоманды);
	Пароль = Константы.ПарольВхода.Получить();
	
	Попытка 
		Прокси = СоединениеСБазой.ПолучитьПрокси();
		Ответ = Прокси.ВыполнитьКоманду(Пароль, Обмен_УправлениеОбменом.Сериализовать(Данные)).Получить();
	Исключение
		Ответ = Новый Структура;
		Ответ.Вставить("Успешно", Ложь);
		Ответ.Вставить("Ошибка", ОписаниеОшибки());
	КонецПопытки;
	
	Возврат Ответ;	
	
КонецФункции

&НаСервере
Процедура ЗарегистрироватьИзмененияКонтрагента(Контрагент, НаименованиеСтар, НаименованиеНов, ДатаОновленняСтар, ДатаОновленняНов) Экспорт
	
	Если НаименованиеСтар = НаименованиеНов Тогда 
		Возврат
	КонецЕсли;
	
	
	
	нз = РегистрыСведений.РегистрацияИзмененияКонтрагента.СоздатьНаборЗаписей();
	нз.Отбор.Контрагент.Установить(Контрагент);
	ТекД = ТекущаяДата();
	нз.Отбор.Период.Установить(ТекД);
	з = нз.Добавить();
	з.Контрагент = Контрагент;
	з.Период =  ТекД;
	з.НаименованиеСтар = НаименованиеСтар;
	з.НаименованиеНов = НаименованиеНов;
	з.ДатаОновленняСтар = ДатаОновленняСтар;
	з.ДатаОновленняНов = ДатаОновленняНов;
	
	
	ПоследнееМестоВызова = "";
	Попытка
		Ошибка = 1 / 0;
	Исключение
		ПоследнееМестоВызова	= ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		//Отсекаем лишний текст
		ПоследнееМестоВызова	= СтрЗаменить(ПоследнееМестоВызова, "Деление на 0", "");
		ПоследнееМестоВызова	= СтрЗаменить(ПоследнееМестоВызова, "Ділення на 0", "");
		ПоследнееМестоВызова	= Сред(ПоследнееМестоВызова, Найти(ПоследнееМестоВызова, ")}:ДобавитьИнформациюСозданияЭлемента(Источник);"), СтрДлина(ПоследнееМестоВызова));		
		ПоследнееМестоВызова	= СокрЛП(СтрЗаменить(ПоследнееМестоВызова, ")}:ДобавитьИнформациюСозданияЭлемента(Источник);", ""));
		
	
		
	КонецПопытки;	
	
	з.Инфо = ПоследнееМестоВызова;
	
	
	
	нз.Записать();
	
КонецПроцедуры




