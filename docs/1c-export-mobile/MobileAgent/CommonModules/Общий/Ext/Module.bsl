Функция ПолучитьТекстОписанияНоменклатуры(Номенклатура) Экспорт
	
	//Сообщить("1: Передана Номенклатура - " + Номенклатура);
	//Сообщить("2: Продажна ціна - " + Константы.ТипЦенПродаж.Получить());

	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) КАК Цена,
	|	ЦеныНоменклатуры.ЦенаАкция КАК ЦенаАкция,
	|	ЦеныНоменклатуры.КонецАкции КАК КонецАкции,
	|	Товары.Наименование КАК Наименование,
	|	Товары.ДополнительноеОписаниеНоменклатуры КАК Описание,
	|	Товары.YouTube КАК YouTube,
	|	Товары.ВідображатиВШтуках КАК ВідображатиВШтуках
	|ИЗ
	|	РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК Товары
	|		ПО (ЦеныНоменклатуры.ТипЦен = &ТипЦен)
	|			И ЦеныНоменклатуры.Номенклатура = Товары.Ссылка
	|ГДЕ
	|	Товары.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("Ссылка", Номенклатура);
