&НаСервере
Процедура ЗарегистрироватьИзменения(Объект) Экспорт
	нз = РегистрыСведений.РегистрацияОбмена.СоздатьНаборЗаписей();
	нз.Отбор.Объект.Использование = Истина;
	нз.Отбор.Объект.Значение = Объект;
	Запись = нз.Добавить();
	Запись.Объект = Объект;                         
	Запись.ИД = Новый УникальныйИдентификатор();
	нз.Записать();
КонецПроцедуры

