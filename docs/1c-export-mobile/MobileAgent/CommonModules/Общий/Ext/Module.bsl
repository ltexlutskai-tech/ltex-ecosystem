Процедура ЗапланироватьУведомление(ДанныеУведомления, Отложено, УИД_Уведомления, ДатаУведомления, Напоминание) Экспорт 

	Запись = РегистрыСведений.ЗапланированыеУведомления.СоздатьМенеджерЗаписи();
	Запись.УИД_Уведомления = УИД_Уведомления;
	Запись.Отложено = Отложено;
	Запись.ДанныеУведомления = Новый ХранилищеЗначения(ДанныеУведомления);
	Запись.ДатаУведомления = ДатаУведомления;
	Запись.ОбъектУведомления = Напоминание;
	Запись.Записать();
	


КонецПроцедуры


&НаСервере
Функция ПолучитьУведомленияНаСервере(Дата) Экспорт 
	
	Массив = Новый Массив;	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВходящиеСообщения.Відправник КАК Відправник,
		|	ВходящиеСообщения.ГруппаЧата КАК ГруппаЧата,
		|	ВходящиеСообщения.Повідомлення КАК Текст,
		|	ВходящиеСообщения.ГруппаЧата.КартинкаГруппы КАК КартинкаГруппы
		|ИЗ
		|	РегистрСведений.ВходящиеСообщения КАК ВходящиеСообщения
		|ГДЕ
		|	ВходящиеСообщения.Дата >= &Дата";
	
	Запрос.УстановитьПараметр("Дата", Дата);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл 
		ДанныеСообщения = Новый Структура();
		ДанныеСообщения.Вставить("Текст", Выборка.Текст);
		ДанныеСообщения.Вставить("Відправник", Выборка.Відправник);
		ДанныеСообщения.Вставить("ГруппаЧата", Выборка.ГруппаЧата);
		ДанныеСообщения.Вставить("Картинка", Новый Картинка(Выборка.КартинкаГруппы.Получить()));

		Массив.Добавить(ДанныеСообщения);
	КонецЦикла;
	
	Возврат Массив;	

КонецФункции

&НаСервере
Функция СофрмроватьСообщениеНаВайберЗаказВидео(Номенклатура, Контрагент, КоличествоШтук) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	Номенклатура.Наименование КАК Наименование,
		|	Номенклатура.Артикул КАК Артикул
		|ИЗ
		|	Справочник.Номенклатура КАК Номенклатура
		|ГДЕ
		|	Номенклатура.Ссылка = &Ссылка";

	Запрос.УстановитьПараметр("Ссылка", Номенклатура);
		
	Выборка =  Запрос.Выполнить().Выбрать();
	Если Не Выборка.Следующий() Тогда 
		Возврат Ложь;
