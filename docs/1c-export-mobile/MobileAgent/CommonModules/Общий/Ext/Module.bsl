&НаСервере
Функция ОбъектБДСуществует(ТестоваяСсылка) Экспорт    
	МД = Метаданные.НайтиПоТипу(ТипЗнч(ТестоваяСсылка));     
	ИмяОбъекта = МД.Имя;      
	ПолноеИмяОбъекта = МД.ПолноеИмя();        
	Запрос = новый Запрос();      
	Запрос.Текст =      "ВЫБРАТЬ      
	|   " + ИмяОбъекта + ".Ссылка КАК СсылкаБД      
	|ИЗ      
	|   " + ПолноеИмяОбъекта + " КАК " + ИмяОбъекта + "      
	|ГДЕ      
	|   " + ИмяОбъекта + ".Ссылка = &Cсылка";      
	Запрос.УстановитьПараметр("Cсылка", ТестоваяСсылка);      
	РезультатЗапроса = Запрос.Выполнить();        
	Возврат Не РезультатЗапроса.Пустой();    
КонецФункции

&НаСервере
Процедура ЗагрузитьОчередьНапоминанийСДействием() Экспорт
	Ответ = Новый Структура;
	Ответ.Вставить("Успех", Истина);
	
	Пароль = Константы.ПарольВхода.Получить();
	ПараметрыКоманды = Новый Структура;
	
	Данные = Новый Структура;
	Данные.Вставить("Команда", "ПолучитьОчередьНапоминанийСДействием");
	Данные.Вставить("Параметры", ПараметрыКоманды);
	
	Попытка 
		Прокси = СоединениеСБазой.ПолучитьПрокси();
		СтруктураОтветаПоОтчету = Прокси.ВыполнитьКоманду(Пароль, Обмен_УправлениеОбменом.Сериализовать(Данные)).Получить();
	Исключение
		СтруктураОтветаПоОтчету = Новый Структура;
		СтруктураОтветаПоОтчету.Вставить("Успешно", Ложь);
		СтруктураОтветаПоОтчету.Вставить("Ошибка", ОписаниеОшибки());
	КонецПопытки;

	Если Не СтруктураОтветаПоОтчету.Успешно Тогда
		Ответ.Вставить("Успешно",Ложь);
		Ответ.Вставить("Ошибка", СтруктураОтветаПоОтчету.Ошибка);
		Возврат;
	КонецЕсли;
	
	//ТЗОчередьНапоминанийСДействием = СтруктураОтветаПоОтчету.Данные;		
	СтруктураОтвета = СтруктураОтветаПоОтчету.Данные;		
	ТЗОчередьНапоминанийСДействием = СтруктураОтвета.ТЗОчереди;
	ТЗХарактеристик = СтруктураОтвета.ТЗХарактеристик;
	
	Для Каждого стрТЗХарактеристик ИЗ ТЗХарактеристик Цикл
		Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(стрТЗХарактеристик.УИДСсылка);
		Если Общий.ОбъектБДСуществует(Характеристика) Тогда
			Если Характеристика.Залишок = стрТЗХарактеристик.Залишок 
				И Характеристика.Описание = стрТЗХарактеристик.Описание
				И Характеристика.ПериодБрони = стрТЗХарактеристик.ПериодБрони
				И Характеристика.СсылкаНаYouTube = стрТЗХарактеристик.СсылкаНаYouTube
				И Характеристика.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(стрТЗХарактеристик.УИДКонтрагент)
				Тогда
				Продолжить;
			КонецЕсли;
			ХарактеристикаОбъект = Характеристика.ПолучитьОбъект();
			ХарактеристикаОбъект.Залишок = стрТЗХарактеристик.Залишок;
			ХарактеристикаОбъект.Описание = стрТЗХарактеристик.Описание;
			ХарактеристикаОбъект.ПериодБрони = стрТЗХарактеристик.ПериодБрони;
			ХарактеристикаОбъект.СсылкаНаYouTube = стрТЗХарактеристик.СсылкаНаYouTube;
			ХарактеристикаОбъект.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(стрТЗХарактеристик.УИДКонтрагент);			
			ХарактеристикаОбъект.Записать();
		КонецЕсли;
	КонецЦикла;	
	
	Для Каждого стрОчереди Из ТЗОчередьНапоминанийСДействием Цикл
		Контрагент = Справочники.Контрагенты.ПолучитьСсылку(стрОчереди.УИДКонтрагентДляДействий);
		Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(стрОчереди.УИДХарактеристикаДляДействий);
		ТипДействия = Перечисления.ТипыДействийПриНапоминании[стрОчереди.ИмяТипДействяПриНапоминании];
		
		Если Общий.ОбъектБДСуществует(Характеристика) И Общий.ОбъектБДСуществует(Контрагент) Тогда
			Данные = Новый Структура;
			Данные.Вставить("Характеристика", Характеристика); 
			Данные.Вставить("Контрагент", Контрагент); 
			
			Если ТипДействия = Перечисления.ТипыДействийПриНапоминании.ОтправкаСообщенияВайберОВидео Тогда	
				
				Общий.СоздатьНапоминаниеСДействием(Перечисления.ТипыДействийПриНапоминании.ОтправкаСообщенияВайберОВидео, Данные);			 	 					
				
				
				Запрос = Новый Запрос;
				Запрос.Текст = 
				"ВЫБРАТЬ
				|	Напоминание.Ссылка КАК Напоминание
				|ИЗ
				|	Справочник.Нагадування КАК Напоминание
				|ГДЕ
				|	Напоминание.НоменклатураВидео = &Номенклатура
				|	И Напоминание.КонтрагентВидео = &Контрагент
				|	И Напоминание.ЗаказВидео = ИСТИНА
				|	И Напоминание.Активне = ИСТИНА";
				
				
				Запрос.УстановитьПараметр("Контрагент", Контрагент);
				Запрос.УстановитьПараметр("Номенклатура", Характеристика.Владелец);
				
				РезультатЗапроса = Запрос.Выполнить();
				
				ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
				
				Если ВыборкаДетальныеЗаписи.Следующий() Тогда
					Напоминание = ВыборкаДетальныеЗаписи.Напоминание;
					
					Запрос = Новый Запрос;
					Запрос.Текст = 
					"ВЫБРАТЬ
					|	ЗапланированыеУведомления.УИД_Уведомления КАК УИД_Уведомления
					|ИЗ
					|	РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
					|ГДЕ
					|	ЗапланированыеУведомления.ОбъектУведомления = &ОбъектУведомления
					|	И ЗапланированыеУведомления.Выполнено = ЛОЖЬ";
					
					Запрос.УстановитьПараметр("ОбъектУведомления", Напоминание);
					
					РезультатЗапроса = Запрос.Выполнить();
					
					ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
					
					Если ВыборкаДетальныеЗаписи.Следующий() Тогда
						Набор = РегистрыСведений.ЗапланированыеУведомления.СоздатьНаборЗаписей();
						Набор.Отбор.УИД_Уведомления.Установить(ВыборкаДетальныеЗаписи.УИД_Уведомления);
						Набор.Прочитать();
						
						Если Набор.Количество() Тогда 
							Набор[0].Выполнено = Истина;
							Набор.Записать();
						КонецЕсли;
						
					КонецЕсли;	
					
					Если Напоминание.Періодичність = Перечисления.Періоди.НеПовторювати Тогда 
						Об = Напоминание.ПолучитьОбъект();
						Об.Активне = Ложь;
						об.Записать();
					КонецЕсли; 					
					
				КонецЕсли;  				
			КонецЕсли;   
			
			Если ТипДействия = Перечисления.ТипыДействийПриНапоминании.ПродолжениеБрониТовара Тогда	
				Общий.СоздатьНапоминаниеСДействием(Перечисления.ТипыДействийПриНапоминании.ПродолжениеБрониТовара, Данные);			 	 					
			КонецЕсли;	

		КонецЕсли;
		
		Если Общий.ОбъектБДСуществует(Контрагент) Тогда
			Если ТипДействия = Перечисления.ТипыДействийПриНапоминании.ЗакрытиеСтарыхЗаказов Тогда	
				Данные = Новый Структура;
				Данные.Вставить("Характеристика", Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка()); 
				Данные.Вставить("Контрагент", Контрагент); 
				Данные.Вставить("АвтоматическоеЗакрытиеЗаказа", Истина); 
				Общий.СоздатьНапоминаниеСДействием(Перечисления.ТипыДействийПриНапоминании.ЗакрытиеСтарыхЗаказов, Данные);			 	 					
			КонецЕсли;	
		КонецЕсли;	
		
	КонецЦикла;	
КонецПроцедуры	


&НаСервере
Процедура ПоискАктуальныхЗаказов(Контрагент, Ответ) Экспорт 
	
	Ответ = Новый Структура;
	Ответ.Вставить("Успех", Истина);
	
	Пароль = Константы.ПарольВхода.Получить();
	Параметры = Новый Структура;
	Параметры.Вставить("Контрагент", Контрагент.УникальныйИдентификатор());
	
	
	Данные = Новый Структура;
	Данные.Вставить("Команда", "ПолучитьАктуальныеЗаказы");
	Данные.Вставить("Параметры", Параметры);
	
	Попытка 
		Прокси = СоединениеСБазой.ПолучитьПрокси();
		АктуальныеЗаказы = Прокси.ВыполнитьКоманду(Пароль, Обмен_УправлениеОбменом.Сериализовать(Данные)).Получить();
	Исключение
		АктуальныеЗаказы = Новый Структура;
		АктуальныеЗаказы.Вставить("Успешно", Ложь);
		АктуальныеЗаказы.Вставить("Ошибка", ОписаниеОшибки());
	КонецПопытки;

	Если Не АктуальныеЗаказы.Успешно Тогда
		Ответ.Вставить("Успешно",Ложь);
		Ответ.Вставить("Ошибка", АктуальныеЗаказы.Ошибка);
		Возврат;
	КонецЕсли;
	
	
	Если АктуальныеЗаказы.данные.Количество() Тогда
		Ответ.Вставить("Предупреждение", "У клієнта є актуальні замовлення");
		Заказ = Документы.Заказ.ПолучитьСсылку(АктуальныеЗаказы.Данные[0].УИДЗаказ);
		Если ПустаяСтрока(Заказ.ВерсияДанных) Тогда 
			Ответ.Вставить("ОткрытьЗакрытиеЗаказа", Истина);
		Иначе
			Ответ.Вставить("Заказ", Заказ);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

