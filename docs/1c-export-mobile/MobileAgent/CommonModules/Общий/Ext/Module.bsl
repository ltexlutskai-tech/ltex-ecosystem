&НаСервере
Процедура ОбновитьСумаОплатиНаложкою(Реализация) Экспорт
	ТекРеализация = Реализация.ПолучитьОбъект();
	Оплаты = ПолучитьДанныеПоОплате(Реализация);
	ТекРеализация.СумаОплатиНаложкою = Окр((Реализация.Сума - Оплаты.СуммаУчета) * Оплаты.Курс.EUR, 0);
	ТекРеализация.Записать(РежимЗАписиДокумента.Запись);
КонецПроцедуры


&НаСервере
Функция ПолучитьТекстСообщенияВайбер(Знач Объект, ДляКлиента, Телефон = "") Экспорт
	ЗРеализации =  ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг");	
	ДоставкаТекст = "";
	Сума = 0;
	Сообщение = "";
	Контрагент = Объект.Контрагент;
	// Доставка    ////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	
	Если ЗРеализации Тогда
		Сума = Объект.Товары.Итог("Сума");
		Если Объект.Доставка = Перечисления.НаявністьДоставки.Почта Тогда 
			ДоставкаТекст = "Відділення пошти № " + Объект.НомерВідділенняНП;
		ИначеЕсли Объект.Доставка = Перечисления.НаявністьДоставки.Самовывоз Тогда
			ДоставкаТекст = "Самовивіз";
		ИначеЕсли Объект.Доставка = Перечисления.НаявністьДоставки.Доставка Тогда
			ДоставкаТекст = "Адресна доставка
			|" + Объект.Контрагент.Адреса
			
		КонецЕсли;
	Иначе
		Сума = Объект.СуммаДокумента;
	КонецЕсли;
	
	//Если Не ДляКлиента Тогда 		
	
	Сообщение = Контрагент.Наименование +"
	
	|" + Контрагент.Область.Наименование + "
	|" + Контрагент.Город.Наименование +"
	|" + Телефон;
	
	//	КонецЕсли;
	Если ЗначениеЗаполнено(Сообщение) Или ЗначениеЗаполнено(ДоставкаТекст) Тогда 
		Сообщение = Сообщение + "
		|" + ДоставкаТекст +  "
		|";
	КонецЕсли;
	Если ЗРеализации Тогда
		/////////Перелік товарів//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////	
		Для Каждого Элемент Из Объект.Товары Цикл 
			Вес = Элемент.ХарактеристикаНоменклатуры.Вага;
			Если Вес = 0 Тогда 
				Попытка
					Вес = Число(Строка(Элемент.ХарактеристикаНоменклатуры));
				Исключение
					Вес = 20;
				КонецПопытки;
			КонецЕсли;
			
			Если ДляКлиента Тогда
				Сообщение  = Сообщение + "
				|[" + Элемент.Номенклатура.Наименование + "] " 
				+ Элемент.Количество * Вес + "х" + Элемент.ЦенаПродажиВес + " = " + Элемент.Сума;
			Иначе
				СекторНаСкладі = Элемент.ХарактеристикаНоменклатуры.СекторНаСкладі;
				Сообщение  = Сообщение + "
				|[" + Элемент.Номенклатура.Артикул + "] " + ?(Объект.Доставка = Перечисления.НаявністьДоставки.Почта," (" + Элемент.Штрихкод + ") ", "") +
				 ?(ЗначениеЗаполнено(СекторНаСкладі), "(" + СекторНаСкладі + ") ", " ") + (Элемент.Количество * Вес) + "х" + Элемент.ЦенаПродажиВес + " = " + Элемент.Сума;
				
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;

	//Суми////////////////////////////////////////////////////////////////////////////////////////////////////
	
	Оплаты = ПолучитьДанныеПоОплате(Объект);
	Если ЗначениеЗаполнено(Сообщение)  Тогда  
		Сообщение = Сообщение + "
		|";
	КонецЕсли;
	Если ЗРеализации Тогда
				Сообщение = Сообщение + "
				|Загальна сума: " + Формат(Объект.Сума, "ЧДЦ=2") + " €
				|Загальна сума: *" + Формат(Оплаты.Курс.EUR * Объект.Сума, "ЧДЦ=2") + " грн*"	;
	КонецЕсли;
	
	Если Оплаты.СуммаУчета > 0 Тогда
		ОплаченоСума = Оплаты.СуммаУчета;
		Если ОплаченоСума > Сума Тогда 
			ОплаченоСума = Сума;
		КонецЕсли;
		
		
		
		Сообщение = Сообщение +  "
		|Оплачено " +  Оплаты.СуммаУчета + " €" + "
		|Фактична оплата:"; 
		Для  Каждого СумаОплаты Из Оплаты.Суммы Цикл 
			Сообщение = Сообщение + ?(ЗначениеЗаполнено(СумаОплаты.Значение), " 
			|" + Формат(СумаОплаты.Значение, "ЧДЦ=2") + " " + СумаОплаты.Ключ, ""); 
			Если СумаОплаты.Ключ = "UAH_Безнал" Тогда				
				Сообщение = Сообщение + "
				|" + ПолучитьБанковскиеСчетаОплат(Объект);
			КонецЕсли;	
		КонецЦикла;
		
		Если Оплаты.Здача.EUR <> 0 ИЛИ Оплаты.Здача.UAH <> 0 ИЛИ Оплаты.Здача.USD <> 0 Тогда 
			СообщениеРешта = ""; 
			Для  Каждого СумаЗдача Из Оплаты.Здача Цикл 
				СообщениеРешта = СообщениеРешта + ?(ЗначениеЗаполнено(СумаЗдача.Значение), " 
				|" + Формат(СумаЗдача.Значение, "ЧДЦ=2") + " " + СумаЗдача.Ключ, "");  
			КонецЦикла;
			Если НЕ ПустаяСтрока(СообщениеРешта) Тогда 
				Сообщение = Сообщение +  "
				|Фактична решта: " + СообщениеРешта; 
			КонецЕсли;			
			
		КонецЕсли;
		
		
	КонецЕсли;
	
	//Курси////////////////////////////////////////////////////////////////////////////////////////////////
	Взаиморасчеты = Оплаты.Взаиморасчеты; 
	
	Сообщение = Сообщение + "
	|
	|Курс EUR " + Оплаты.Курс.EUR + "
	|Курс USD " + Оплаты.Курс.USD; 
	
	Если ЗРеализации Тогда   // Борг - Переплата
		//Если СообщениеРешта = "" И Взаиморасчеты.Статус = "Передплата" ИЛИ Взаиморасчеты.Статус <> "Передплата" Тогда 
		//	Сообщение = Сообщение + "
		//	|
		//	|" + Взаиморасчеты.Статус +  " "  + Взаиморасчеты.Сумма + " €";
		//КонецЕсли;
		//КонецЕсли;
		
		Если Объект.Сума - Оплаты.СуммаУчета > 0 Тогда  
			Сообщение = Сообщение + "	
			| Борг по документу " +  Формат(Объект.Сума - Оплаты.СуммаУчета, "ЧЦ=12; ЧДЦ=2;") + " €";
		ИначеЕсли Объект.Сума - Оплаты.СуммаУчета < 0 Тогда 
			Сообщение = Сообщение +  "
			| Передоплата по документу: " + Формат(Оплаты.СуммаУчета - Объект.Сума, "ЧЦ=12; ЧДЦ=2") + " €"; 		
		КонецЕсли;
		
		
		//Если ЗРеализации Тогда
		
		Если Объект.Наложка И Объект.Сума - Оплаты.СуммаУчета > 0 Тогда 
			Сообщение = Сообщение + "	
			| Наложений платіж " +  Формат(Объект.СумаОплатиНаложкою, "ЧДЦ=2") + " грн.";
		КонецЕсли;
		
		Если Не ДляКлиента Тогда 
			Сообщение = Сообщение + "	
			|Коментар: " + Объект.Коментар;
			
			Сообщение = Сообщение + "	
			|
			|" + Объект.Дата;

		КонецЕсли;
		
	Иначе 
		//мБорг = Контрагент.Борг - Оплаты.СуммаУчета ;
		//Сообщение = Сообщение + "
		//	|
		//    | " + ?(мБорг >=0, "Борг: ", "Переплата: ") + СтрЗаменить(Формат(мБорг , "ЧЦ=12; ЧДЦ=2;"), "-", "") + " €"
	КонецЕсли;
	
	
	Возврат Сообщение;

КонецФункции

&НаСервере
Функция ПолучитьТекстСообщенияВайберДляПрезентации(Знач Объект, ДляКлиента, Телефон = "") Экспорт

	ДоставкаТекст = "";
	Сума = 0;
	Сообщение = "";
	Контрагент = Объект.Контрагент;
			
	
	Сообщение = "Презентація / Завдання 
	|
	|" + Контрагент.Наименование + "
	
	|" + Контрагент.Область.Наименование + "
	|" + Контрагент.Город.Наименование + "
	|" + Телефон + "
	|";

	Если ЗначениеЗаполнено(Объект.Коментар) Тогда
		Сообщение  = Сообщение + "
		|" + Объект.Коментар;
	КонецЕсли;
	
	Сообщение  = Сообщение + "
	|";
	
	Для Каждого Элемент Из Объект.Товары Цикл 
			Сообщение  = Сообщение + "
			|[" + Элемент.Номенклатура.Артикул + "]  
			|"	+ Элемент.Коментар;
	КонецЦикла;


	
	Возврат Сообщение;

КонецФункции


Функция  ПолучитьДанныеПоОплате(Знач Объект) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КассовыйОрдер.СумаUAH КАК СумаUAH,
		//intrata_wald_24112021 ↓
		|	КассовыйОрдер.СумаUAH_Безнал КАК СумаUAH_Безнал,
		//intrata_wald_24112021 ↑
		|	КассовыйОрдер.СумаEUR КАК СумаEUR,
		|	КассовыйОрдер.СумаUSD КАК СумаUSD,
		|	КассовыйОрдер.КурсUSD КАК КурсUSD,
		|	КассовыйОрдер.КурсEUR КАК КурсEUR,
		|	ДенежныеСредства.Сумма КАК Сумма,
		|	КассовыйОрдер.ВидДвиженияДенежныхСредств КАК ВидДвиженияДенежныхСредств
		|ИЗ
		|	Документ.КассовыйОрдер КАК КассовыйОрдер
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ДенежныеСредства КАК ДенежныеСредства
		|		ПО КассовыйОрдер.Ссылка = ДенежныеСредства.Регистратор
		|ГДЕ " + ?(ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг")," 
		|	КассовыйОрдер.Основание = &Основание", " КассовыйОрдер.Ссылка = &Основание Или КассовыйОрдер.СдачаДокумента = &Основание") + "  
		|	И КассовыйОрдер.Проведен
		|
		|УПОРЯДОЧИТЬ ПО
		|	КассовыйОрдер.Дата";
	
	Запрос.УстановитьПараметр("Основание", Объект.Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Оплаты = Новый Структура("Курс, Суммы, Здача, Взаиморасчеты, СуммаУчета", 
	Новый Структура("EUR, USD", Объект.КурсEUR, Объект.КурсUSD),
	//intrata_wald_24112021 ↓
	//Новый Структура("EUR, USD, UAH", 0, 0, 0), 
	Новый Структура("EUR, USD, UAH, UAH_Безнал", 0, 0, 0, 0),
	//intrata_wald_24112021 ↑
	Новый Структура("EUR, USD, UAH", 0, 0, 0),
	Новый Структура("ВидРеализации, Статус, Сумма", "в борг", "Борг", 0), 
	0);
	Суммы = Оплаты.Суммы;
	Здача = Оплаты.Здача;
	ПерваяЗапись = Истина;
	Пока Выборка.Следующий() Цикл
		Если ПерваяЗапись Тогда 
			Оплаты.Курс.EUR = Выборка.КурсEUR;
			Оплаты.Курс.USD = Выборка.КурсUSD;
			ПерваяЗапись = Ложь;
		КонецЕсли;
		Если Выборка.ВидДвиженияДенежныхСредств = Перечисления.ВидДвиженияДенежныхСредств.Приход Тогда 
			Суммы.EUR = Суммы.EUR + Выборка.СумаEUR;
			Суммы.USD = Суммы.USD + Выборка.СумаUSD;
			Суммы.UAH = Суммы.UAH + Выборка.СумаUAH;
			Суммы.UAH_Безнал = Суммы.UAH_Безнал + Выборка.СумаUAH_Безнал; //intrata_wald_24112021
			Оплаты.СуммаУчета = Оплаты.СуммаУчета + Выборка.Сумма;
		Иначе
			Здача.EUR = Здача.EUR + Выборка.СумаEUR;
			Здача.USD = Здача.USD + Выборка.СумаUSD;
			Здача.UAH = Здача.UAH + Выборка.СумаUAH;
			Оплаты.СуммаУчета = Оплаты.СуммаУчета - Выборка.Сумма;
		КонецЕсли;
	КонецЦикла;
	Если ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда  
		Взаиморасчеты = Оплаты.Взаиморасчеты; 
		Взаиморасчеты.Сумма = Объект.Сума - Оплаты.СуммаУчета + Объект.Контрагент.Борг;
		Если Взаиморасчеты.Сумма < 0 Тогда 
			Взаиморасчеты.Сумма = -1 * Взаиморасчеты.Сумма;  
			Взаиморасчеты.ВидРеализации =  " по передплаті";
			Взаиморасчеты.Статус =  "Передплата";
		ИначеЕсли Объект.Наложка Тогда 
			Взаиморасчеты.ВидРеализации =  " по післяплаті";
			//Взаиморасчеты.Статус =  "Наложка";		
			
		КонецЕсли;
	КонецЕсли;
	Возврат Оплаты;
		
КонецФункции  

Функция  ПолучитьБанковскиеСчетаОплат(Знач Объект) Экспорт
	
	СтрокаПредставленияСчетов = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КассовыйОрдер.БанковскийСчет КАК БанковскийСчет
		|ИЗ
		|	Документ.КассовыйОрдер КАК КассовыйОрдер
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ДенежныеСредства КАК ДенежныеСредства
		|		ПО КассовыйОрдер.Ссылка = ДенежныеСредства.Регистратор
		|ГДЕ " + ?(ТипЗнч(Объект.Ссылка) = Тип("ДокументСсылка.РеализацияТоваровУслуг")," 
		|	КассовыйОрдер.Основание = &Основание", " КассовыйОрдер.Ссылка = &Основание Или КассовыйОрдер.СдачаДокумента = &Основание") + "  
		|	И КассовыйОрдер.Проведен
		|
		|УПОРЯДОЧИТЬ ПО
		|	КассовыйОрдер.Дата";
	
	Запрос.УстановитьПараметр("Основание", Объект.Ссылка);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если ЗначениеЗаполнено(Выборка.БанковскийСчет) Тогда
			СтрокаПредставленияСчетов = СтрокаПредставленияСчетов + Строка(Выборка.БанковскийСчет) + Символы.ПС;
		КонецЕсли;	
	КонецЦикла;	
	
	Возврат СтрокаПредставленияСчетов;
КонецФункции	


