	Запрос1.УстановитьПараметр("Характеристика", Характеристика);
	Вибірка = Запрос1.Выполнить().Выбрать();
	Если Вибірка.Следующий() Тогда
		
		ТекстСообщения = ТекстСообщения + "
		|
		//| *Курс EUR " + Курс + "*"; 
		| *Штрихкод " + Вибірка.Штрихкод + "*"; 
	КонецЕсли;
	ТекстСообщения = ТекстСообщения + "
		|
		| *Курс EUR " + Курс + "*"; 
	
	ТекстСообщения = ТекстСообщения + "
	|
	| Наші контакти : 
	| " + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + СимволУказательныйПалецУказываетВниз + СимволСтрелкаУказываетВниз + "
	| " + СимволТелефон + " *+380676710516*
	| " + СимволТелефон + " *+380993584992*";
	
	
	ТекстСообщения = ТекстСообщения + "
