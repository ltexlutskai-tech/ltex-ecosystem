// Преобразует таблицу значений в массив структур.
// Может использоваться для передачи на клиент данных в том случае, если таблица
// значений содержит только такие значения, которые могут
// быть переданы с сервера на клиент.
//
// Полученный массив содержит структуры, каждая из которых повторяет
// структуру колонок таблицы значений.
//
// Не рекомендуется использовать для преобразования таблиц значений
// с большим количеством строк.
//
// Параметры:
//  ТаблицаЗначений - ТаблицаЗначений - исходная таблица значений.
//
// Возвращаемое значение:
//  Массив - коллекция строк таблицы в виде структур.
//
Функция ТаблицаЗначенийВМассив(ТаблицаЗначений) Экспорт
	
	Массив = Новый Массив();
	СтруктураСтрокой = "";
	НужнаЗапятая = Ложь;
	Для Каждого Колонка Из ТаблицаЗначений.Колонки Цикл
		Если НужнаЗапятая Тогда
			СтруктураСтрокой = СтруктураСтрокой + ",";
		КонецЕсли;
		СтруктураСтрокой = СтруктураСтрокой + Колонка.Имя;
		НужнаЗапятая = Истина;
	КонецЦикла;
	Для Каждого Строка Из ТаблицаЗначений Цикл
		НоваяСтрока = Новый Структура(СтруктураСтрокой);
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Строка);
		Массив.Добавить(НоваяСтрока);
	КонецЦикла;
	Возврат Массив;

КонецФункции

Функция ОтправитьНоменклатуруУВайбер(Характеристика) Экспорт
	  
	//Сообщить("1: Передана характеристика -" + Характеристика);
	//Сообщить("2: Продажна ціна -" + Константы.ТипЦенПродаж.Получить());

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ХарактеристикиНоменклатуры.Владелец.Наименование КАК Наименование,
		|	ХарактеристикиНоменклатуры.Вага КАК Вага,
		|	ХарактеристикиНоменклатуры.Залишок КАК Залишок,
		|	ХарактеристикиНоменклатуры.СсылкаНаYouTube КАК СсылкаНаYouTube,
		|	ЕСТЬNULL(ЦеныНоменклатуры.Цена, 0) КАК Цена,
		|	ЦеныНоменклатуры.ЦенаАкция КАК ЦенаАкция,
		|	ЦеныНоменклатуры.КонецАкции КАК КонецАкции,
		|	ХарактеристикиНоменклатуры.Описание КАК Описание,
		|	ХарактеристикиНоменклатуры.Владелец.ВідображатиВШтуках КАК ВідображатиВШтуках,
		|	ХарактеристикиНоменклатуры.Владелец.ДатаСозданияЭлемента КАК ДатаСозданияНоменклатуры
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры КАК ЦеныНоменклатуры
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
		|		ПО ЦеныНоменклатуры.Номенклатура = ХарактеристикиНоменклатуры.Владелец
		|			И (ЦеныНоменклатуры.ТипЦен = &ТипЦен)
		|ГДЕ
		|	ХарактеристикиНоменклатуры.Ссылка = &Ссылка";
	Запрос.УстановитьПараметр("ТипЦен", Константы.ТипЦенПродаж.Получить());
	Запрос.УстановитьПараметр("Ссылка", Характеристика);
		
	Выборка =  Запрос.Выполнить().Выбрать();
	Если Не Выборка.Следующий() Тогда 
		Возврат Ложь;
	КонецЕсли;
	Курс = Константы.КурсEUR.Получить();	
	
	
	СимволБелыйКруг = ПолучитьСимволПоЮникоду(9898);
	СимволЗеленыйКруг = ПолучитьСимволПоЮникоду(128994); 
	СимволЧерныйБольшойКвадрат = "◼";
	СимволЧерныйМалыйКвадрат = "◾";   
	СимволУказательныйПалецУказываетВниз = ПолучитьСимволПоЮникоду(128071); 
	СимволКрасныйКвдарт = ПолучитьСимволПоЮникоду(128997); 
	СимволТелефон		 = ПолучитьСимволПоЮникоду(128242);
	СимволСтрелкаУказываетВниз = ПолучитьСимволПоЮникоду(11015);
	
	
	НаименованиеТовара = СимволЗеленыйКруг + СимволЧерныйМалыйКвадрат + " " + Выборка.Наименование + " " + СимволЧерныйМалыйКвадрат + СимволЗеленыйКруг;
	
	ТекстСообщения = "*" + НаименованиеТовара + "*";

	Если  ЗначениеЗаполнено(Выборка.ЦенаАкция) И Выборка.Цена >  Выборка.ЦенаАкция Тогда  		
		ТекстСообщения = ТекстСообщения + " 
		|
		|*" + СимволКрасныйКвдарт + СимволЧерныйБольшойКвадрат +  " АКЦІЯ " + СимволЧерныйБольшойКвадрат + СимволКрасныйКвдарт + "*";			
	КонецЕсли;

	Если  ЗначениеЗаполнено(Выборка.ДатаСозданияНоменклатуры) И Выборка.ДатаСозданияНоменклатуры >  ТекущаяДата() - 14 * 24 * 60 * 60 Тогда  		
		ТекстСообщения = ТекстСообщения + " 
		|
		|*" + СимволЗеленыйКруг + СимволБелыйКруг +  " НОВИНКА " + СимволБелыйКруг + СимволЗеленыйКруг + "*";			
	КонецЕсли;
	
	
			
	ТекстСообщения = ТекстСообщения + "
	|
	| " + СтрЗаменить(СокрЛП(ОбрізатиОпис(Выборка.Описание)), "¶", Символы.ПС)+ "
	| 
	| " + ?(Выборка.ВідображатиВШтуках,"*Кількість:","*Вага:    ") + Выборка.Вага + ?(Выборка.ВідображатиВШтуках," шт*"," кг*");
	                                   
	Если ЗначениеЗаполнено(Выборка.цена) Тогда 
		Если  ЗначениеЗаполнено(Выборка.ЦенаАкция) И Выборка.Цена >  Выборка.ЦенаАкция Тогда  		
			ТекстСообщения = ТекстСообщения + " 
			| ~*Ціна:    " + Формат(Выборка.Цена, "ЧДЦ=2") + " €/" + ?(Выборка.ВідображатиВШтуках,"шт*~" , "кг*~");			
		Иначе	
			ТекстСообщения = ТекстСообщения + " 
			| *Ціна:    " + Формат( Выборка.Цена, "ЧДЦ=2") + " €/" + ?(Выборка.ВідображатиВШтуках,"шт*" , "кг*");
		КонецЕсли;	
	КонецЕсли;
	
	Если  ЗначениеЗаполнено(Выборка.ЦенаАкция) И Выборка.Цена >  Выборка.ЦенаАкция Тогда  
		ТекстСообщения = ТекстСообщения + "
