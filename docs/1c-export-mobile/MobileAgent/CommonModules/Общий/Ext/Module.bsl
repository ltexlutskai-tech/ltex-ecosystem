&НаСервере
Функция ПолучитьСимволПоЮникоду(КодСимволаВДесятичномВиде) Экспорт
	
//	https://ru.wikipedia.org/wiki/UTF-16#%D0%9F%D1%80%D0%B8%D0%BD%D1%86%D0%B8%D0%BF_%D0%BA%D0%BE%D0%B4%D0%B8%D1%80%D0%BE%D0%B2%D0%B0%D0%BD%D0%B8%D1%8F

//В UTF-16 символы кодируются двухбайтовыми словами с использованием всех возможных диапазонов значений (от 0 до FFFF16). При этом можно кодировать символы Unicode в диапазонах 000016..D7FF16 и E00016..FFFF16. Исключенный отсюда диапазон D80016..DFFF16 используется как раз для кодирования так называемых суррогатных пар — символов, которые кодируются двумя 16-битными словами.

//Символы Unicode до FFFFh включительно (исключая диапазон для суррогатов) записываются как есть 16-битным словом.

//Символы же в диапазоне 10000h..10FFFFh (больше 16 бит) кодируются по следующей схеме:

//    Из кода символа вычитается 10000h. В результате получится значение от нуля до FFFFF16, которое помещается в разрядную сетку 20 бит.

//    Старшие 10 бит (число в диапазоне 0000h..03FFh) суммируются с D800h, и результат идёт в ведущее (первое) слово, которое входит в диапазон D800h..DBFFh.

//    Младшие 10 бит (тоже число в диапазоне 0000h..03FFh) суммируются с DC00h, и результат идёт в последующее (второе) слово, которое входит в диапазон DC00h..DFFFh.


//ПРИКЛАД
//Исходный код символа
//Зеленый круг
//1F7E2

//Сначала вычитаем из него 10000h
//Получим 
//0F7E2

//Закидываем это на 20-битную сетку, получаем: 
//0000.1111.0111.1110.0010

//Разбиваем на две чиселки по 10 бит
//0000.1111.01
//11.1110.0010

//Переводим в хекс
//3D
//3E2

//Прибавляем к ним константы D800h и DC00h

//Получаэм
//D83D
//DFE2

//Переводим в десятичный
//55357
//57314


//Сообщить(Символ (55357) + Символ (57314)); 

	Если КодСимволаВДесятичномВиде <= 65536 Тогда
		Возврат Символ(КодСимволаВДесятичномВиде);
	КонецЕсли;	

    //Отнимем 1000h
	Константа1000h_ВДесятичномВиде = 65536;
	КодСимволаВДесятичномВиде = КодСимволаВДесятичномВиде - Константа1000h_ВДесятичномВиде;
	
	КодСимволаВДвоичновмВиде = ДесятичноеВДвоичное(КодСимволаВДесятичномВиде);

	Если СтрДлина(КодСимволаВДвоичновмВиде) > 20 Тогда
		Возврат "";
	КонецЕсли;	 
	
	Пока СтрДлина(КодСимволаВДвоичновмВиде) < 20 Цикл
		КодСимволаВДвоичновмВиде = "0" + КодСимволаВДвоичновмВиде;	
	КонецЦикла;	
	
	КодСимволаВДвоичновмВиде_Часть1 = Лев(КодСимволаВДвоичновмВиде, 10);
	КодСимволаВДвоичновмВиде_Часть2 = Прав(КодСимволаВДвоичновмВиде, 10);
	
	Константа_D800h_ВДесятичномВиде = 55296;
	Константа_DC00h_ВДесятичномВиде = 56320;  
	
	КодСимволаВДесятичномВиде_Часть1 = ДвоичноеВДесятичное(КодСимволаВДвоичновмВиде_Часть1);	
	КодСимволаВДесятичномВиде_Часть2 = ДвоичноеВДесятичное(КодСимволаВДвоичновмВиде_Часть2);	
	
	КодСимволаВДесятичномВиде_Часть1 = КодСимволаВДесятичномВиде_Часть1 + Константа_D800h_ВДесятичномВиде;
	КодСимволаВДесятичномВиде_Часть2 = КодСимволаВДесятичномВиде_Часть2 + Константа_DC00h_ВДесятичномВиде;
	
	Возврат Символ(КодСимволаВДесятичномВиде_Часть1) + Символ(КодСимволаВДесятичномВиде_Часть2);
	

КонецФункции   

&НаСервере
Функция ДесятичноеВДвоичное(Знач ИсхЧисло) Экспорт
    
    ДвоичныйКод = "";
    Пока ИсхЧисло <> 0 Цикл
        ДвоичныйКод = "" + ИсхЧисло%2 + ДвоичныйКод ;
        ИсхЧисло = Цел(ИсхЧисло/2);
	КонецЦикла;
	
    Возврат ДвоичныйКод;
    
КонецФункции

&НаСервере
Функция ДвоичноеВДесятичное(Знач Стр2) Экспорт
	
	Стр = СокрЛП(Стр2);
	Рез=0;
	
	Для н=1 по СтрДлина(Стр) Цикл
		Рез=Рез*2+Число(Сред(Стр,н,1));
	КонецЦикла;
	
	Возврат Рез;
	
КонецФункции  

Функция ПолучитьНеПросмотренныеНапоминания() Экспорт
		
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("ДатаУведомления", ТекущаяДата());
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ЗапланированыеУведомления.УИД_Уведомления КАК УИД_Уведомления
	|ИЗ
	|	РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗапланированыеУведомления.ДатаУведомления КАК ДатаУведомления,
	|			ЗапланированыеУведомления.ОбъектУведомления КАК ОбъектУведомления
	|		ИЗ
	|			РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
	|		ГДЕ
	|			НЕ ЗапланированыеУведомления.Выполнено
	|			И НЕ ЗапланированыеУведомления.ОбъектУведомления.НагадатиПроТовар
	|			И ЗапланированыеУведомления.ДатаУведомления < &ДатаУведомления) КАК ВложенныйЗапрос
	|		ПО ЗапланированыеУведомления.ОбъектУведомления = ВложенныйЗапрос.ОбъектУведомления
	|			И ЗапланированыеУведомления.ДатаУведомления < ВложенныйЗапрос.ДатаУведомления
	|			И (НЕ ЗапланированыеУведомления.Выполнено)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Массив = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Набор = РегистрыСведений.ЗапланированыеУведомления.СоздатьНаборЗаписей();
		Набор.Отбор.УИД_Уведомления.Установить(ВыборкаДетальныеЗаписи.УИД_Уведомления);
		Набор.Записать();
	КонецЦикла;
	
	
	
	Запрос.Текст = 	"ВЫБРАТЬ
	|	ЗапланированыеУведомления.УИД_Уведомления КАК УИД_Уведомления,
	|	ЗапланированыеУведомления.ДанныеУведомления КАК ДанныеУведомления
	|ИЗ
	|	РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
	|ГДЕ
	|	НЕ ЗапланированыеУведомления.Выполнено
	|	И ЗапланированыеУведомления.ДатаУведомления < &ДатаУведомления
	|";
	
	
	
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Массив = Новый Массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Уведомление = ВыборкаДетальныеЗаписи.ДанныеУведомления.Получить();
		ДанныеУведомления = Уведомление.Данные;
		ПараметрыФормы = Новый Структура("ТекстНагадування",  Уведомление.Текст);
		ПараметрыФормы.Вставить("ДатаНагадування",  ДанныеУведомления["Дата"]);
		ПараметрыФормы.Вставить("УИД_Уведомления",  ДанныеУведомления["УИД_Уведомления"]);
		ПараметрыФормы.Вставить("УИД_Напоминание", ДанныеУведомления["УИД_Напоминание"]); 
		ПараметрыФормы.Вставить("Ключ", ДанныеУведомления["УИД_Напоминание"]); 
		Если ДанныеУведомления["НапоминаниеОТоваре"] = "1" Тогда
			
			ПараметрыФормы.Вставить("УИД_Номенклатура", ДанныеУведомления["УИД_Номенклатуры"]);
			
		КонецЕсли;
		
		Массив.Добавить(ПараметрыФормы);
		
	КонецЦикла;

	Возврат Массив;
КонецФункции

