Процедура ЗаписІсторіїЗміниХарактеристики(Характеристика, ПоточнийКористувач) Экспорт 
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Штрихкоды.Штрихкод
	|ИЗ
	|	РегистрСведений.Штрихкоды КАК Штрихкоды
	|ГДЕ
	|	Штрихкоды.Владелец = &Владелец
	|	И Штрихкоды.ХарактеристикаНоменклатуры = &Характеристика";
	Запрос.УстановитьПараметр("Владелец", Характеристика.Владелец);
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	Выборка = Запрос.Выполнить().Выбрать();
	ШК = "";
	Если Выборка.Следующий() Тогда
		ШК = Выборка.Штрихкод;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ІсторіяЗміниХарактеристикиСрезПоследних.Открыт,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.ЕстьВидео,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.Целевой,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.СсылкаНаYouTube,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.Описание,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.Бронь,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.ПериодБрони,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.Контрагент,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.Ефір,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.ЕфірНаДоставку,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.Коментар,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.СекторНаСкладі,
	|	ІсторіяЗміниХарактеристикиСрезПоследних.Відповідальний
	|ИЗ
	|	РегистрСведений.ІсторіяЗміниХарактеристики.СрезПоследних КАК ІсторіяЗміниХарактеристикиСрезПоследних
	|ГДЕ
	|	ІсторіяЗміниХарактеристикиСрезПоследних.ХарактеристикаНоменклатури = &Характеристика";
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	Вибірка = Запрос.Выполнить().Выбрать();
	Записувати = Ложь;
	Если Вибірка.Следующий() Тогда
		Если Вибірка.Бронь <> Характеристика.Бронь ИЛИ Вибірка.ЕстьВидео <> Характеристика.ЕстьВидео
			ИЛИ Вибірка.Ефір <> Характеристика.Ефір ИЛИ Вибірка.ЕфірНаДоставку <> Характеристика.ЕфірНаДоставку ИЛИ Вибірка.Коментар <> Характеристика.Коментар
			ИЛИ Вибірка.Контрагент <> Характеристика.Контрагент ИЛИ Вибірка.Описание <> Характеристика.Описание ИЛИ Вибірка.Открыт <> Характеристика.Открыт
			ИЛИ Вибірка.ПериодБрони <> Характеристика.ПериодБрони ИЛИ Вибірка.СекторНаСкладі <> Характеристика.СекторНаСкладі 
			ИЛИ Вибірка.СсылкаНаYouTube <> Характеристика.СсылкаНаYouTube ИЛИ Вибірка.Целевой <> Характеристика.Целевой Тогда
			Записувати = Истина;
		КонецЕсли;
	Иначе
		Записувати = Истина;
	КонецЕсли;	
	
	Если Записувати Тогда
		МенеджерЗапису = РегистрыСведений.ІсторіяЗміниХарактеристики.СоздатьМенеджерЗаписи();
		МенеджерЗапису.Бронь = Характеристика.Бронь;
		МенеджерЗапису.Відповідальний = ПоточнийКористувач;
		МенеджерЗапису.ЕстьВидео = Характеристика.ЕстьВидео;
		МенеджерЗапису.Ефір = Характеристика.Ефір;
		МенеджерЗапису.ЕфірНаДоставку = Характеристика.ЕфірНаДоставку;
		МенеджерЗапису.Коментар = Характеристика.Коментар;
		МенеджерЗапису.Контрагент = Характеристика.Контрагент;
		МенеджерЗапису.Описание = Характеристика.Описание;
		МенеджерЗапису.Открыт = Характеристика.Открыт;
		МенеджерЗапису.ПериодБрони = Характеристика.ПериодБрони;
		МенеджерЗапису.СекторНаСкладі = Характеристика.СекторНаСкладі;
		МенеджерЗапису.СсылкаНаYouTube = Характеристика.СсылкаНаYouTube;
		МенеджерЗапису.ХарактеристикаНоменклатури = Характеристика;
		МенеджерЗапису.Целевой = Характеристика.Целевой;
		МенеджерЗапису.Штрихкод = ШК;
		МенеджерЗапису.Период = ТекущаяДата();
		МенеджерЗапису.Активность = Истина;
		МенеджерЗапису.Користувач = ПараметрыСеанса.ТекущийПользователь;
		МенеджерЗапису.Записать();
	КонецЕсли;
	
КонецПроцедуры	

