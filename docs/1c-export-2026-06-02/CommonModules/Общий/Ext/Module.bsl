Функция ОкруглитьСуммуДоГривни(ТЧТовары) Экспорт
	  
    Если ТЧТовары.Количество() = 0 Тогда
        Возврат Истина;
    КонецЕсли;

    Итог = 0;
    Для каждого Стр Из ТЧТовары Цикл
        Стр.Сумма = Окр(Стр.Цена * Стр.Количество, 2);
        Итог = Итог + Стр.Сумма;
    КонецЦикла;

    ЦелеваяСумма = Окр(Итог, 0);
    ОсталосьКоп = ВКопейках(ЦелеваяСумма - Итог);
    Если ОсталосьКоп = 0 Тогда
        Возврат Истина;
    КонецЕсли;

    МассивСтрок = Новый Массив;
    Для каждого Стр Из ТЧТовары Цикл
        Если Стр.Количество = 0 Тогда
            Продолжить;
        КонецЕсли;
        Данные = Новый Структура("Строка,ДельтаЦенаКоп", Стр, 0);
        МассивСтрок.Добавить(Данные);
    КонецЦикла;

    // 1) Ряды з Количество = 1 (кожен крок 0.01 дає рівно 1 коп.)
    Направление = ЗнакЧисла(ОсталосьКоп);
    Для каждого Данные Из МассивСтрок Цикл
        Стр = Данные.Строка;
        Если Стр.Количество <> 1 Тогда
            Продолжить;
        КонецЕсли;

        Пока ОсталосьКоп <> 0 И АбсЧисло(Данные.ДельтаЦенаКоп) < 100 Цикл
            Стр.Цена = Окр(Стр.Цена + Направление / 100, 2);
            Данные.ДельтаЦенаКоп = Данные.ДельтаЦенаКоп + Направление;
            Стр.Сумма = Окр(Стр.Цена * Стр.Количество, 2);
            ОсталосьКоп = ОсталосьКоп - Направление;

            Если ОсталосьКоп = 0 Тогда
                Возврат Истина;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;

    // 2) Інші кількості: крок 0.01 і перевірка фактичної дельти
    Прогресс = Истина;
    Пока ОсталосьКоп <> 0 И Прогресс Цикл
        Прогресс = Ложь;
        Направление = ЗнакЧисла(ОсталосьКоп);

        Для каждого Данные Из МассивСтрок Цикл
            Стр = Данные.Строка;
            Если Стр.Количество = 1 Тогда
                Продолжить;
            КонецЕсли;

            Если АбсЧисло(Данные.ДельтаЦенаКоп) >= 100 Тогда
                Продолжить;
            КонецЕсли;

            Цена0 = Стр.Цена;
            Сумма0 = Окр(Цена0 * Стр.Количество, 2);
            Цена1 = Окр(Цена0 + Направление / 100, 2);
            Сумма1 = Окр(Цена1 * Стр.Количество, 2);
            ДельтаКоп = ВКопейках(Сумма1 - Сумма0);

            Если ДельтаКоп = 0 Тогда
                Продолжить;
            КонецЕсли;

            Если (ОсталосьКоп > 0 И ДельтаКоп > 0) Или (ОсталосьКоп < 0 И ДельтаКоп < 0) Тогда
                Если АбсЧисло(ДельтаКоп) <= АбсЧисло(ОсталосьКоп) Тогда
                    Стр.Цена = Цена1;
                    Стр.Сумма = Сумма1;
                    Данные.ДельтаЦенаКоп = Данные.ДельтаЦенаКоп + Направление;
                    ОсталосьКоп = ОсталосьКоп - ДельтаКоп;
                    Прогресс = Истина;

                    Если ОсталосьКоп = 0 Тогда
                        Возврат Истина;
                    КонецЕсли;
                КонецЕсли;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;

    Возврат (ОсталосьКоп = 0);
КонецФункции

Функция ВКопейках(Сумма) Экспорт
    Возврат Цел(Окр(Сумма * 100, 0));
КонецФункции

Функция АбсЧисло(Значение) Экспорт
    Если Значение < 0 Тогда
        Возврат -Значение;
    Иначе
        Возврат Значение;
    КонецЕсли;
КонецФункции

Функция ЗнакЧисла(Значение) Экспорт
    Если Значение > 0 Тогда
        Возврат 1;
    ИначеЕсли Значение < 0 Тогда
        Возврат -1;
    Иначе
        Возврат 0;
    КонецЕсли;
КонецФункции

Процедура ОчисткаПростроченоіБроні() Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ХарактеристикиНоменклатуры.Ссылка
	               |ИЗ
	               |	Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
	               |ГДЕ
	               |	ХарактеристикиНоменклатуры.Бронь <> ЗНАЧЕНИЕ(Справочник.ТорговыеАгенты.ПустаяСсылка)
	               |	И ХарактеристикиНоменклатуры.ПериодБрони < &ТекущаяДата";
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата() - 86420);
	Виборка = Запрос.Выполнить().Выбрать();
	Пока Виборка.Следующий() Цикл
		ХарОб = Виборка.Ссылка.ПолучитьОбъект();
		ХарОб.Бронь = Справочники.ТорговыеАгенты.ПустаяСсылка();
		ХарОб.ПериодБрони = '00010101';
		ХарОб.Контрагент = Справочники.Контрагенты.ПустаяСсылка();
		ХарОб.Записать();
	КонецЦикла;
	
КонецПроцедуры


