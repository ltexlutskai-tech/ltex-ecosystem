
Функция ПрошелКонтрольУникальностиСправочникаПоРеквизиту(ИмяОбъекта, СтрРеквизитов, ЗначениеСсылка) 
	
    Запрос = Новый Запрос;
    Запрос.Текст = 
    "ВЫБРАТЬ ПЕРВЫЕ 1
    |    Спр.Ссылка
    |ИЗ
    |    Справочник." + ИмяОбъекта + " КАК Спр
    |ГДЕ
    |    Спр.Ссылка <> &парЗначениеСсылка И НЕ Спр.Ссылка.ПометкаУдаления
    |";     
    Нум = 0;
	Для Каждого Знч Из СтрРеквизитов Цикл
		
        ИмяПараметраВЗапросе = " = &Пар" + Строка(Нум);
        Запрос.Текст = Запрос.Текст + " И Спр." + Знч.Ключ + ИмяПараметраВЗапросе; 
        Запрос.УстановитьПараметр("Пар" + Строка(Нум),    Знч.Значение);
        Нум = Нум + 1;
    КонецЦикла;    
    Запрос.УстановитьПараметр("парЗначениеСсылка",         ЗначениеСсылка);        
    РезультатЗапроса = Запрос.Выполнить();
        Возврат РезультатЗапроса.Пустой(); 
КонецФункции

Функция КонтрольУникальностиПоРеквизиту(ЭтотОбъект, ИмяРеквизита) Экспорт
    ИмяОбъекта = ЭтотОбъект.Метаданные().Имя;
    СтрРеквизитов = Новый Структура; //
    СтрРеквизитов.Вставить(ИмяРеквизита, ЭтотОбъект[ИмяРеквизита]);
	Если Не ПрошелКонтрольУникальностиСправочникаПоРеквизиту(ИмяОбъекта, СтрРеквизитов, ЭтотОбъект.Ссылка) Тогда
		#Если Клиент Тогда 
        Сообщить("Подобный элемент справочника /" + ЭтотОбъект[ИмяРеквизита] + "/ существует!
                |Модуль: Контроль уникальности элементов справочника." );
		#КонецЕсли
		Возврат Ложь;
	КонецЕсли;	
	Возврат Истина;
КонецФункции

Функция ТелефонКонтрагентаСтрокой(Контрагент) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Контрагенты.НомерТелефона,
	               |	Контрагенты.ДополнительныеНомераТелефонов.(
	               |		Номер
	               |	)
	               |ИЗ
	               |	Справочник.Контрагенты КАК Контрагенты
	               |ГДЕ
	               |	Контрагенты.Ссылка = &Контрагент";
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Рез = Запрос.Выполнить().Выгрузить();
	НомераСтрокой = "";
	Если Рез.Количество() > 0 Тогда
		Если Рез[0].ДополнительныеНомераТелефонов.Количество() > 0 Тогда
			Для Каждого Строка из Рез[0].ДополнительныеНомераТелефонов Цикл
				Если ЗначениеЗаполнено(НомераСтрокой) Тогда
					НомераСтрокой = НомераСтрокой + " ";
				КонецЕсли;
				
				НомераСтрокой = НомераСтрокой + СтрЗаменить(Строка.Номер, " ", ""); 	
			КонецЦикла;
		КонецЕсли;
		
		
		Если СтрДлина(Рез[0].НомерТелефона) > 7 Тогда
			Возврат Рез[0].НомерТелефона + " " + НомераСтрокой;
		Иначе
			Возврат НомераСтрокой;
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

Функция НеОтгруженныеТоварыСЗаказов(Товар, Заказ) Экспорт
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ТоварыНаСкладахОстатки.Номенклатура.Ссылка
	|ИЗ
	|	РегистрНакопления.ТоварыНаСкладах.Остатки(, Номенклатура.Ссылка = &Ссылка) КАК ТоварыНаСкладахОстатки
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ЗаказыПокупателей.Остатки(, ЗаказПокупателя = &Заказ) КАК ЗаказыПокупателейОстатки
	|		ПО ТоварыНаСкладахОстатки.Номенклатура = ЗаказыПокупателейОстатки.Номенклатура";
		
	Запрос.УстановитьПараметр("Ссылка", Товар);
	Запрос.УстановитьПараметр("Заказ", Заказ);
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	Если Выборка.Количество() > 0 Тогда
		Возврат Истина;
	Иначе 
		Возврат Ложь;
	КонецЕсли;
КонецФункции

Функция СоздатьЗаказ(ТекущийКонтрагент, ДатаДокумента) Экспорт 
	
	Если ТекущийКонтрагент 	= Справочники.Контрагенты.ПустаяСсылка() Тогда 
		Возврат Документы.ЗаказПокупателя.ПустаяСсылка();
	КонецЕсли;		
	
	ЗапросЗаказа = Новый Запрос;
	ЗапросЗаказа.Текст = 
	"ВЫБРАТЬ
	|	ЗаказПокупателя.Ссылка
	|ИЗ
	|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
	|ГДЕ
	|	ЗаказПокупателя.Контрагент = &Контрагент
	|	И ЗаказПокупателя.ДоговорКонтрагента = &ДоговорКонтрагента
	|	И НЕ ЗаказПокупателя.ПометкаУдаления";
	ЗапросЗаказа.УстановитьПараметр("Контрагент", ТекущийКонтрагент);		
	ЗапросЗаказа.УстановитьПараметр("ДоговорКонтрагента", ТекущийКонтрагент.ДоговорДляНеплановыхПродаж);
	
	РезультатЗапроса = ЗапросЗаказа.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		Выборка 		   = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ДокументЗаказ = Выборка.Ссылка.ПолучитьОбъект();
	Иначе 	
		ДокументЗаказ = Документы.ЗаказПокупателя.СоздатьДокумент();	
		ДокументЗаказ.Дата 								= ДатаДокумента - 1;
		мВалютаУправленческогоУчета 					= Константы.ВалютаУправленческогоУчета.Получить();
		мВалютаРегламентированногоУчета 				= Константы.ВалютаРегламентированногоУчета.Получить();
		ЗаполнениеДокументов.ЗаполнитьШапкуДокумента(ДокументЗаказ, глЗначениеПеременной("глТекущийПользователь"), мВалютаУправленческогоУчета, "Продажа");
		ДокументЗаказ.Контрагент 					= ТекущийКонтрагент;
		ДокументЗаказ.ДоговорКонтрагента 			= ТекущийКонтрагент.ДоговорДляНеплановыхПродаж;
		ДокументЗаказ.Комментарий 					= "Створено для заповнення маршрутних листів.";
	КонецЕсли;	
	
	ДокументЗаказ.Записать(РежимЗаписиДокумента.Запись);
	
	Возврат ДокументЗаказ.Ссылка;
	
КонецФункции

Процедура ЗаписатьВерсию(ДокументСсылка, ДокументОбъект) Экспорт
	
	НомерВерсии = 0;
	ЗапросНомераВерсии = Новый Запрос;
	ЗапросНомераВерсии.Текст = 
		"ВЫБРАТЬ
		|	ВерсииОбъектов.Документ,
	    |	МАКСИМУМ(ВерсииОбъектов.НомерВерсии) КАК НомерВерсии
	    |ИЗ
       	|	РегистрСведений.ВерсииОбъектов КАК ВерсииОбъектов
       	|ГДЕ
       	|	ВерсииОбъектов.Документ = &Документ
       	|
       	|СГРУППИРОВАТЬ ПО
       	|	ВерсииОбъектов.Документ";
	ЗапросНомераВерсии.УстановитьПараметр("Документ", ДокументСсылка);
	РезультатЗапроса = ЗапросНомераВерсии.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		НомерВерсии = Выборка.НомерВерсии + 1;	
	Иначе 
		НомерВерсии = 1;	
	КонецЕсли;	
	
	МетаданныеДокумента = ДокументОбъект.Метаданные();
	НаборЗаписей = РегистрыСведений.ВерсииОбъектов.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Документ.Установить(ДокументСсылка);
	НаборЗаписей.Отбор.НомерВерсии.Установить(НомерВерсии);
	НаборЗаписей.Прочитать();
	
	Для Каждого Реквизит Из МетаданныеДокумента.Реквизиты Цикл 	
		НоваяЗапись 					= НаборЗаписей.Добавить();
		НоваяЗапись.Документ 			= ДокументСсылка;
		НоваяЗапись.НомерВерсии 		= НомерВерсии;
		НоваяЗапись.ПериодВерсии   		= ТекущаяДата();
		НоваяЗапись.ИмяРеквизита 		= Реквизит.Имя;
		НоваяЗапись.ЗначениеРеквизита 	= ДокументОбъект[Реквизит.Имя];
	КонецЦикла;	

	Для Каждого ТабличнаяЧасть Из МетаданныеДокумента.ТабличныеЧасти Цикл 
		ТекущаяТЗ = ДокументОбъект[ТабличнаяЧасть.Имя].Выгрузить();
		НоваяЗапись 					= НаборЗаписей.Добавить();
		НоваяЗапись.Документ 			= ДокументСсылка;
		НоваяЗапись.НомерВерсии 		= НомерВерсии;
		НоваяЗапись.ПериодВерсии   		= ТекущаяДата();
		НоваяЗапись.ИмяРеквизита 		= ТабличнаяЧасть.Имя;
		НоваяЗапись.ЗначениеРеквизита 	= "ТабЧасть";
		НоваяЗапись.ХранилищеТЧ 		= Новый ХранилищеЗначения(ТекущаяТЗ);
	КонецЦикла;	
	
	НаборЗаписей.Записать();	
	
КонецПроцедуры	

Процедура ВосстановитьВерсию(НомерВерсии, ДокументИсточник, ДокументПриемникОбъект) Экспорт
	
	Если НомерВерсии = 0 Тогда 
		Возврат;
	КонецЕсли;
	
	ДокументИсточникОбъект = ДокументИсточник.Получитьобъект();
	Если ТипЗнч(ДокументПриемникОбъект) <> ТипЗнч(ДокументИсточникОбъект) Тогда 
		#Если Клиент Тогда
		Вопрос("Тип документа для восстановления не совпадает с типом документа.", РежимДиалогаВопрос.ОК);
		#КонецЕсли
		Возврат;
	КонецЕсли;	
	
	ЗапросДанных = Новый Запрос;
	ЗапросДанных.Текст = 
		"ВЫБРАТЬ
		|	ВерсииОбъектов.Документ,
		|	ВерсииОбъектов.НомерВерсии,
		|	ВерсииОбъектов.ПериодВерсии,
		|	ВерсииОбъектов.ИмяРеквизита,
		|	ВерсииОбъектов.ЗначениеРеквизита,
		|	ВерсииОбъектов.ХранилищеТЧ
		|ИЗ
		|	РегистрСведений.ВерсииОбъектов КАК ВерсииОбъектов
		|ГДЕ
		|	ВерсииОбъектов.Документ = &Документ
		|	И ВерсииОбъектов.НомерВерсии = &НомерВерсии";
	ЗапросДанных.УстановитьПараметр("Документ", ДокументИсточник);
	ЗапросДанных.УстановитьПараметр("НомерВерсии", НомерВерсии);
	РезультатЗапроса = ЗапросДанных.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда 
		#Если Клиент Тогда
		Вопрос("По данному документу нет сохраненных версий.", РежимДиалогаВопрос.ОК);
		#КонецЕсли
	Иначе 
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл 
			Если Выборка.ЗначениеРеквизита = "ТабЧасть" Тогда 
				ТаблицаДанныхТЧ = Выборка.ХранилищеТЧ.Получить();
				ДокументПриемникОбъект[Выборка.ИмяРеквизита].Загрузить(ТаблицаДанныхТЧ);
			Иначе
				ДокументПриемникОбъект[Выборка.ИмяРеквизита] = Выборка.ЗначениеРеквизита;
			КонецЕсли;	
		КонецЦикла;	
	КонецЕсли;	
	
КонецПроцедуры

Процедура УдалениеВерсий() Экспорт 
	
	ГраницаВерсий = 14; // дней хранятся версии в системе
	СекундВСутках = 60*60*24; 
	
	ЗапросВерсий = Новый Запрос;
	ЗапросВерсий.Текст = 
		"ВЫБРАТЬ
		|	ВерсииОбъектов.Документ,
		|	ВерсииОбъектов.НомерВерсии,
		|	ВерсииОбъектов.ПериодВерсии,
		|	ВерсииОбъектов.ИмяРеквизита,
		|	ВерсииОбъектов.ЗначениеРеквизита,
		|	ВерсииОбъектов.ХранилищеТЧ
		|ИЗ
		|	РегистрСведений.ВерсииОбъектов КАК ВерсииОбъектов
		|ГДЕ
		|	ВерсииОбъектов.ПериодВерсии <= &ПериодВерсии";
	ЗапросВерсий.УстановитьПараметр("ПериодВерсии", ТекущаяДата() - (ГраницаВерсий * СекундВСутках));
	РезультатЗапроса = ЗапросВерсий.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Пока Выборка.Следующий() Цикл 
			ЗаписьРегистра 						= РегистрыСведений.ВерсииОбъектов.СоздатьМенеджерЗаписи();
			ЗаписьРегистра.Документ 			= Выборка.Документ;
			ЗаписьРегистра.НомерВерсии 			= Выборка.НомерВерсии;
			ЗаписьРегистра.ПериодВерсии 		= Выборка.ПериодВерсии;
			ЗаписьРегистра.ИмяРеквизита 		= Выборка.ИмяРеквизита;
			ЗаписьРегистра.ЗначениеРеквизита 	= Выборка.ЗначениеРеквизита;
			ЗаписьРегистра.Прочитать();
			ЗаписьРегистра.Удалить();
		КонецЦикла;	
	КонецЕсли;		
	
КонецПроцедуры	

Функция ПолучитьШтрихкод(Номенклатура, Характеристика) Экспорт
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	Штрихкоды.Штрихкод
	          |ИЗ
	          |	РегистрСведений.Штрихкоды КАК Штрихкоды
	          |ГДЕ
	          |	Штрихкоды.Владелец = &Владелец
	          |	И Штрихкоды.ХарактеристикаНоменклатуры = &ХарактеристикаНоменклатуры";
	з.УстановитьПараметр("Владелец", Номенклатура);
	з.УстановитьПараметр("ХарактеристикаНоменклатуры", Характеристика);
	Выборка = з.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат	Выборка.Штрихкод;
	КонецЕсли;
	
	Возврат "";	
КонецФункции

Функция ПолучитьКурсОплаты(ДокументОплаты, Валюта) Экспорт
Попытка	
	Если Валюта.Код = "978" Тогда 
		Возврат ДокументОплаты.КурсEUR;
	ИначеЕсли Валюта.Код = "840" Тогда
		Возврат ДокументОплаты.КурсUSD;
	Иначе 
		Возврат 1;
	КонецЕсли;
Исключение
	Возврат 1;
	КонецПопытки;
		
КонецФункции

Процедура ЗаполнитьКурсПоМаршрутному(ТаблицаПлатежейУпр, ЭтотОбъект, ВалютаДокумента, МаршрутныйЛист, Контрагент, КурсДокумента) Экспорт
	Для Каждого СтрПлатежейУпр Из ТаблицаПлатежейУпр Цикл 
		
		КурсУпрУчетаОбм = ПолучитьКурсОплаты(ЭтотОбъект, СтрПлатежейУпр.ВалютаВзаиморасчетов);
		Если КурсУпрУчетаОбм > 0 Тогда
			СтрПлатежейУпр.КурсУпрУчета = КурсУпрУчетаОбм;
		КонецЕсли;
		КурсДокументаОбм = ПолучитьКурсОплаты(ЭтотОбъект, ВалютаДокумента);
		Если КурсДокументаОбм > 0 Тогда 
			СтрПлатежейУпр.КурсДокумента = КурсДокументаОбм;
		КонецЕсли;
		Если СтрПлатежейУпр.КурсУпрУчета = 0 Тогда 
			Если ЗначениеЗаполнено(МаршрутныйЛист) И Найти(СокрЛП(МаршрутныйЛист.Ссылка), "<") = Неопределено Тогда     //ЗаписьЖурналаРегистрации("ПКО_Обмен", УровеньЖурналаРегистрации.Информация, ,,СокрЛП(МаршрутныйЛист.Ссылка));
				МаршрутныйЛистОбъект = МаршрутныйЛист.ПолучитьОбъект();
				
				КурсРасчета 				= МаршрутныйЛистОбъект.ПолучитьКурсВалютыРасчета(Контрагент, СтрПлатежейУпр.ВалютаВзаиморасчетов);
				СтрПлатежейУпр.КурсУпрУчета = КурсРасчета.КурсУпр;
			КонецЕсли;
		КонецЕсли;
		СтрПлатежейУпр.СуммаУпр 	= МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(СтрПлатежейУпр.СуммаПлатежа, ВалютаДокумента, СтрПлатежейУпр.ВалютаВзаиморасчетов, КурсДокумента, СтрПлатежейУпр.КурсУпрУчета, 1, 1);
	КонецЦикла;	

КонецПроцедуры

Процедура ОтправитьИнформациюВЧат(Текст) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ГруппыЧатаУчасники.Ссылка КАК Ссылка,
	|	ГруппыЧатаУчасники.Пользователь
	|ИЗ
	|	Справочник.ГруппыЧата.Учасники КАК ГруппыЧатаУчасники
	|ГДЕ
	|	ГруппыЧатаУчасники.Ссылка.ПрисылатьИзменения
	|ИТОГИ ПО
	|	Ссылка";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСсылка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Организация = Справочники.Организации.НайтиПоКоду("000000001");
	
	Пока ВыборкаСсылка.Следующий() Цикл
		
		МенеджерЗаписи 					= РегистрыСведений.Чат1С.СоздатьМенеджерЗаписи();	
		МенеджерЗаписи.Уид_Сообщения 	= Новый УникальныйИдентификатор;
		МенеджерЗаписи.Організація 		= Организация;
		МенеджерЗаписи.Відправник  		= Справочники.Пользователи.ПустаяСсылка();
		
		МенеджерЗаписи.Одержувач  = ВыборкаСсылка.Ссылка;
		
		МенеджерЗаписи.Повідомлення 	= Текст;
		МенеджерЗаписи.Период       	= ТекущаяДата();
		МенеджерЗаписи.ДатаНаСервере 	= ТекущаяДата();
		МенеджерЗаписи.Записать();
		
		ВыборкаДетальныеЗаписи = ВыборкаСсылка.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			РегНепрочитані = РегистрыСведений.НепрочитаніПовідомлення.СоздатьМенеджерЗаписи();			
			РегНепрочитані.Одержувач = ВыборкаДетальныеЗаписи.Пользователь;
			РегНепрочитані.Відправник = ВыборкаСсылка.Ссылка;
			РегНепрочитані.ГруппаЧата = ВыборкаСсылка.Ссылка;
			РегНепрочитані.Кол = 1;
			РегНепрочитані.Период = ТекущаяДата();
			РегНепрочитані.Записать(); 		
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

Процедура СнятьАктуальностьСЗаказаСоСтатусомДоставкиПочтаСамовывоз(Реализация) Экспорт 
	
	Если (Реализация.Доставка = Перечисления.НаявністьДоставки.Почта 
		Или Реализация.Доставка = Перечисления.НаявністьДоставки.Самовывоз)
		И Не ЗначениеЗаполнено(Реализация.Сделка) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказПокупателя.Ссылка
		|ИЗ
		|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|ГДЕ
		|	ЗаказПокупателя.Дата <= &Дата
		|	И ЗаказПокупателя.Контрагент = &Контрагент
		|	И ЗаказПокупателя.Доставка = ЗаказПокупателя.Доставка
		|	И ЗаказПокупателя.СтатусЗамовлення = &СтатусЗамовлення
		|	И ЗаказПокупателя.ПометкаУдаления = ЛОЖЬ";
		
		Запрос.УстановитьПараметр("Дата", Реализация.Дата);
		Запрос.УстановитьПараметр("Доставка", Реализация.Доставка);
		Запрос.УстановитьПараметр("Контрагент", Реализация.Контрагент);
		Запрос.УстановитьПараметр("СтатусЗамовлення", Справочники.СтатусиЗамовлень.Новий);
		
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			
			ЗаказДляОбработки = ВыборкаДетальныеЗаписи.Ссылка;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	МаршрутныйЛистЗаказы.Ссылка
			|ИЗ
			|	Документ.МаршрутныйЛист.Заказы КАК МаршрутныйЛистЗаказы
			|ГДЕ
			|	МаршрутныйЛистЗаказы.ЗаказПокупателя = &ЗаказПокупателя
			|	И МаршрутныйЛистЗаказы.Ссылка.ПометкаУдаления = ЛОЖЬ";
			
			Запрос.УстановитьПараметр("ЗаказПокупателя", ЗаказДляОбработки);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Если ВыборкаДетальныеЗаписи.Следующий() Тогда
				Продолжить;
			КонецЕсли;
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ
			|	РеализацияТоваровУслуг.Ссылка
			|ИЗ
			|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
			|ГДЕ
			|	РеализацияТоваровУслуг.Сделка = &ЗаказПокупателя
			|	И РеализацияТоваровУслуг.ПометкаУдаления = ЛОЖЬ";
			
			Запрос.УстановитьПараметр("ЗаказПокупателя", ЗаказДляОбработки);
			
			РезультатЗапроса = Запрос.Выполнить();
			
			ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
			
			Если ВыборкаДетальныеЗаписи.Следующий() Тогда
				Продолжить;
			КонецЕсли;			
			
			ЗаказДляОбработкиОбъект = ЗаказДляОбработки.ПолучитьОбъект();
			ЗаказДляОбработкиОбъект.СтатусЗамовлення = Справочники.СтатусиЗамовлень.Неактуальний;
			ЗаказДляОбработкиОбъект.Записать();
			
			РеализацияОб = Реализация.ПолучитьОбъект();
			РеализацияОб.Сделка = ЗаказДляОбработки;
			РеализацияОб.Комментарий = РеализацияОб.Комментарий + " Привязали замовлення по способу доставки Пошта або Самовивіз " + Строка(ТекущаяДата());
			РеализацияОб.Записать();
			
			ЗаписьОчереди = РегистрыСведений.ОчередьНапоминанийСДействием.СоздатьМенеджерЗаписи();
			ЗаписьОчереди.ТорговыйАгент = РеализацияОб.Контрагент.ТорговыйАгент;
			ЗаписьОчереди.КонтрагентДляДействий	= РеализацияОб.Контрагент;
			ЗаписьОчереди.ХарактеристикаДляДействий = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
			ЗаписьОчереди.ТипДействяПриНапоминании = Перечисления.ТипыДействийПриНапоминании.ЗакрытиеСтарыхЗаказов;
			ЗаписьОчереди.ПериодДобавления = ТекущаяДата();
			ЗаписьОчереди.Записать(); 						
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры	

