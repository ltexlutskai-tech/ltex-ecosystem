
Процедура ЗарегистрироватьОбъектОбменАндроидДляПродавца(Объект, Продавец, ВыгружатьФайлы = Ложь) Экспорт
	нз = РегистрыСведений.РегистрацияОбмена.СоздатьНаборЗаписей();
	нз.Отбор.Объект.Использование = Истина;
	нз.Отбор.Продавец.Использование = Истина;
	нз.Отбор.Объект.Значение = Объект;
	нз.Отбор.Продавец.Значение = Продавец;
	
	нз.Прочитать();
	Если нз.Количество() Тогда 
		Если нз[0].ВыгружатьФайлы Тогда 
			Возврат;
		КонецЕсли;
	КонецЕсли;
	нз.Очистить();
	
	
	
	Запись = нз.Добавить();
	Запись.Объект = Объект;                         
	Запись.Продавец = Продавец;
	Запись.ИД = Новый УникальныйИдентификатор();
	Запись.ВыгружатьФайлы = ВыгружатьФайлы;
	нз.Записать();
КонецПроцедуры

Процедура УдалитьРегистрациюПоИД(МассивИД,ПарольВхода) Экспорт
	Продавец = ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
	Для Каждого Строка Из МассивИД Цикл
		нз = РегистрыСведений.РегистрацияОбмена.СоздатьНаборЗаписей();
		нз.Отбор.ИД.Использование = Истина;
		нз.Отбор.Продавец.Использование = Истина;
		нз.Отбор.ИД.Значение = Строка.ИД;
		нз.Отбор.Продавец.Значение = Продавец;
		нз.Записать();                            
	КонецЦикла;
	ВключитьЧастичныйОбмен(ПарольВхода);
КонецПроцедуры                                           

Процедура ЗарегистрироватьОбъектОбменАндроид(Объект,ВыгружатьФайлы = Ложь,ИсключатьПродавца = Ложь,Склад = Неопределено, ТорговийАгент = Неопределено) Экспорт
		
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	          |	СкладыПродавцыПартнера.Ссылка КАК Продавец,
	          |	СкладыПродавцыПартнера.Склад КАК Склад
	          |ИЗ
	          |	Справочник.ТорговыеАгенты КАК СкладыПродавцыПартнера
	          |ГДЕ
	          |	СкладыПродавцыПартнера.ПарольДоступаАндроід <> """"
	          |	И НЕ СкладыПродавцыПартнера.Ссылка.ПометкаУдаления";
	//з.УстановитьПараметр("Склад",Склад);
	//з.УстановитьПараметр("Торговий",ТорговийАгент);

	Выборка = з.Выполнить().Выбрать();
	тзРегистрации = Новый ТаблицаЗначений;
	тзРегистрации.Колонки.Добавить("Объект");
	тзРегистрации.Колонки.Добавить("Продавец");
	тзРегистрации.Колонки.Добавить("ВыгружатьФайлы");

	

	Пока Выборка.Следующий() Цикл
		Если Выборка.Продавец = ИсключатьПродавца ИЛИ (Выборка.Склад <> Склад И Склад <> Неопределено) Тогда 
			Продолжить;
		КонецЕсли;
		
		Если Объект.Метаданные().Имя = "Номенклатура" Тогда 
			ЗапНаСклад = Новый Запрос;
			ЗапНаСклад.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
			                   |	НоменклатураСпр.Ссылка
			                   |ИЗ
			                   |	РегистрСведений.ВыгружатьВАндроидПоСкладам КАК ВыгружатьВАндроидПоСкладам
			                   |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК НоменклатураСпр
			                   |		ПО (ВыгружатьВАндроидПоСкладам.Номенклатура = НоменклатураСпр.Ссылка
			                   |				ИЛИ НоменклатураСпр.Ссылка.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			                   |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			                   |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			                   |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			                   |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			                   |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			                   |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
							   |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			                   |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			                   |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура)
			                   |ГДЕ
			                   |	ВыгружатьВАндроидПоСкладам.ТорговийАгент = &ТорговийАгент
			                   |	И ВыгружатьВАндроидПоСкладам.Выгружать
			                   |	И НоменклатураСпр.Ссылка = &Номенклатура";
			ЗапНаСклад.УстановитьПараметр("ТорговийАгент",Выборка.Продавец);
			ЗапНаСклад.УстановитьПараметр("Номенклатура",Объект.Ссылка);
			ВыборкаСклад = ЗапНаСклад.Выполнить().Выбрать();
			НужноРегистрироватьДляОбмена = Ложь;
			
			Если ВыборкаСклад.Следующий() Тогда 
				НужноРегистрироватьДляОбмена = Истина;
				ВыгружатьФайлы = Ложь;
			КонецЕсли;
		ИначеЕсли Объект.Метаданные().Имя = "Контрагенты" Тогда	
			НужноРегистрироватьДляОбмена = Ложь;
			Если КонтрагентПривязан(Выборка.Продавец, Объект) Тогда 
				НужноРегистрироватьДляОбмена = Истина;
				ВыгружатьФайлы = Ложь;
			КонецЕсли;
		
		Иначе
			НужноРегистрироватьДляОбмена = Ложь;
			Для Каждого Реквизит Из Объект.Метаданные().Реквизиты Цикл 
				Если Реквизит.Имя = "Склад" И Объект.Склад = Выборка.Склад Тогда 
					НужноРегистрироватьДляОбмена = Истина;
				ИначеЕсли  Реквизит.Имя = "СкладОрдер" И Объект.СкладОрдер = Выборка.Склад Тогда 
					НужноРегистрироватьДляОбмена = Истина;
				ИначеЕсли  Реквизит.Имя = "СкладГруппа" И Объект.СкладГруппа = Выборка.Склад Тогда 
					НужноРегистрироватьДляОбмена = Истина;
				ИначеЕсли Реквизит.Имя = "СкладОтправитель" И Объект.СкладОтправитель = Выборка.Склад Тогда 
					НужноРегистрироватьДляОбмена = Истина;
				ИначеЕсли Реквизит.Имя = "СкладПолучатель" И Объект.СкладПолучатель = Выборка.Склад Тогда 
					НужноРегистрироватьДляОбмена = Истина; 	
				ИначеЕсли Реквизит.Имя = "Контрагент" Тогда
						Если КонтрагентПривязан(Выборка.Продавец, Объект.Контрагент) Тогда 
							НужноРегистрироватьДляОбмена = Истина;
							ВыгружатьФайлы = Ложь;
						КонецЕсли;
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		Если НужноРегистрироватьДляОбмена Тогда 
			СтрРег  = тзРегистрации.Добавить();
			СтрРег.Объект = Объект;
			СтрРег.Продавец = Выборка.Продавец;
			СтрРег.ВыгружатьФайлы = ВыгружатьФайлы;
		КонецЕсли;
	КонецЦикла;	
	
	тзРегистрации.Свернуть("Объект,Продавец","ВыгружатьФайлы");
	Для Каждого СтрРег Из тзРегистрации Цикл
		ЗарегистрироватьОбъектОбменАндроидДляПродавца(СтрРег.Объект, СтрРег.Продавец, СтрРег.ВыгружатьФайлы);
	КонецЦикла;
	
	
	
КонецПроцедуры

