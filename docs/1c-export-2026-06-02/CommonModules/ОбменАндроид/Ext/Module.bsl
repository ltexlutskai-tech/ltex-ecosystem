Функция ПолучитьПродавцаПоКодуПартнера(КодПартнера) Экспорт
			з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	СкладыПродавцыПартнера.Ссылка КАК Продавец
	          |ИЗ
	          |	Справочник.ТорговыеАгенты КАК СкладыПродавцыПартнера
	          |ГДЕ
	          |	СкладыПродавцыПартнера.ПарольДоступаАндроід = &КодПартнера";
	з.УстановитьПараметр("КодПартнера",КодПартнера);
	Выборка = з.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Продавец;
	Иначе 
		Возврат Неопределено;
	КонецЕсли;

КонецФункции

Функция ПолучитьСкладПартнера(ПарольВхода) Экспорт
		з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	ТорговіАгенти.ТорговыйАгент.Склад КАК Склад
	          |ИЗ
	          |	Справочник.Контрагенты КАК ТорговіАгенти
	          |ГДЕ
	          |	ТорговіАгенти.ТорговыйАгент.ПарольДоступаАндроід = &ПарольДоступаАндроід";
	з.УстановитьПараметр("ПарольДоступаАндроід",ПарольВхода);
	Выборка = з.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Склад;
	Иначе                        
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

Процедура ВключитьЧастичныйОбмен(КодПартнера) Экспорт
	
	Продавец = ПолучитьПродавцаПоКодуПартнера(КодПартнера);
	Если ЗначениеЗаполнено(Продавец) Тогда 
		НЗ = РегистрыСведений.ЧастичнаяВыгрузка.СоздатьНаборЗаписей();
		НЗ.Отбор.Продавец.Использование = Истина;
		НЗ.Отбор.Продавец.Значение = Продавец;
		Запись = НЗ.Добавить();
		Запись.Продавец = Продавец;
		НЗ.Записать();	
	КонецЕсли;
	
КонецПроцедуры

Процедура ВыключитьЧастичныйОбмен(КодПартнера) Экспорт
	
	Продавец = ПолучитьПродавцаПоКодуПартнера(КодПартнера);
	Если ЗначениеЗаполнено(Продавец) Тогда 
		НЗ = РегистрыСведений.ЧастичнаяВыгрузка.СоздатьНаборЗаписей();
		НЗ.Отбор.Продавец.Использование = Истина;
		НЗ.Отбор.Продавец.Значение = Продавец;
		НЗ.Записать();	
	КонецЕсли;
	
КонецПроцедуры

