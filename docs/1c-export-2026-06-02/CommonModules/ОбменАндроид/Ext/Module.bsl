Функция ПолучитьТорговыхЗаданнойНоменклатуры(Номенклатура) Экспорт
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ РАЗРЕШЕННЫЕ
	          |	ВыгружатьВАндроидПоСкладам.ТорговийАгент КАК ТорговийАгент
	          |ИЗ
	          |	РегистрСведений.ВыгружатьВАндроидПоСкладам КАК ВыгружатьВАндроидПоСкладам
	          |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	          |			НоменклатураСпр.Ссылка КАК Ссылка
	          |		ИЗ
	          |			Справочник.Номенклатура КАК НоменклатураСпр
	          |		ГДЕ
	          |			НоменклатураСпр.Ссылка = &Номенклатура) КАК НоменклатураСпр
	          |		ПО (ВыгружатьВАндроидПоСкладам.Номенклатура = НоменклатураСпр.Ссылка
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
	          |				ИЛИ НоменклатураСпр.Ссылка.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура)
	          |			И (ВыгружатьВАндроидПоСкладам.Выгружать)
	          |ГДЕ
	          |	ВыгружатьВАндроидПоСкладам.Выгружать
	          |	И ВыгружатьВАндроидПоСкладам.ТорговийАгент.ПарольДоступаАндроід <> """"
	          |	И НЕ НоменклатураСпр.Ссылка.ПометкаУдаления
	          |	И НЕ НоменклатураСпр.Ссылка.ЭтоГруппа
	          |	И НЕ ВыгружатьВАндроидПоСкладам.ТорговийАгент.ПометкаУдаления
	          |
	          |СГРУППИРОВАТЬ ПО
	          |	ВыгружатьВАндроидПоСкладам.ТорговийАгент";
	
	
	з.УстановитьПараметр("Номенклатура", Номенклатура);
	Возврат з.Выполнить().Выгрузить().ВыгрузитьКолонку("ТорговийАгент");
