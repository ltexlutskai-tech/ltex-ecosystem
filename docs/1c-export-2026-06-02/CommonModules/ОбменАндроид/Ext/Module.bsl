Функция ПолучитьДанныеВыгрузкиАндроид(Склад,Номенклатура) Экспорт
	Стр = Новый Структура;
	Стр.Вставить("ВыгружатьАндроид",Ложь);
	Стр.Вставить("Отображать",Ложь);
		з = Новый Запрос;
			з.Текст = "ВЫБРАТЬ
			          |	ВыгружатьВАндроидПоСкладам.Выгружать КАК Выгружать,
			          |	ВыгружатьВАндроидПоСкладам.ОтображатьВПоиске КАК ОтображатьВПоиске
			          |ИЗ
			          |	РегистрСведений.ВыгружатьВАндроидПоСкладам КАК ВыгружатьВАндроидПоСкладам
			          |ГДЕ
			          |	ВыгружатьВАндроидПоСкладам.ТорговийАгент = &ТорговийАгент
			          |	И ВыгружатьВАндроидПоСкладам.Номенклатура = &Номенклатура";
			з.УстановитьПараметр("ТорговийАгент",Склад);
			з.УстановитьПараметр("Номенклатура",Номенклатура);
			Выборка = з.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда 
				Стр.ВыгружатьАндроид = Выборка.Выгружать;
				Стр.Отображать = Выборка.ОтображатьВПоиске;
			КонецЕсли;
	Возврат Стр;
КонецФункции


Функция ЗаписатьДанныеВыгрузкиНаСайт(ВыгружатьАндроид,Отображать,Ссылка,ТекНом) Экспорт
	//Если ТекНом.ЭтоГруппа Тогда 
	//	Возврат Ложь;
	//КонецЕсли;
	//Склад = ПолучитьСкладПартнераПоТА(Ссылка);
	//Если НЕ ЗначениеЗаполнено(Склад) Тогда 
	//	Возврат Ложь;
	//КонецЕсли;
	ВыгружатьАндроид = НЕ ВыгружатьАндроид;
	
	нз = РегистрыСведений.ВыгружатьВАндроидПоСкладам.СоздатьНаборЗаписей();
	нз.Отбор.ТорговийАгент.Установить(Ссылка);
	нз.Отбор.Номенклатура.Установить(ТекНом);
	Результат = Ложь;
	нз.Прочитать();
	Если нз.Количество() Тогда 
		Для Каждого з Из нз Цикл
			Если з.Выгружать = ВыгружатьАндроид и з.ОтображатьВПоиске = Отображать Тогда
				Возврат Ложь;
			КонецЕсли;
			з.Выгружать = ВыгружатьАндроид;
			з.ОтображатьВПоиске = Отображать;
			Результат = Истина;
		КонецЦикла;	
	Иначе			
		з = нз.Добавить();
		з.Номенклатура = ТекНом;
		з.ТорговийАгент = Ссылка;
		з.Выгружать = ВыгружатьАндроид;
		з.ОтображатьВПоиске = Отображать;
		Результат = Истина;
	КонецЕсли;
	нз.Записать();
	Возврат Результат;
КонецФункции

