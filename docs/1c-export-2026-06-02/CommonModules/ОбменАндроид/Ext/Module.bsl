			Если з.Выгружать = ВыгружатьАндроид Тогда
				Возврат Ложь;
			КонецЕсли;
			з.Выгружать = ВыгружатьАндроид;
			Результат = Истина;
		КонецЦикла;	
	Иначе			
		з = нз.Добавить();
		з.ТипЦен = ТекНом;
		з.ТорговийАгент = Ссылка;
		з.Выгружать = ВыгружатьАндроид;

		Результат = Истина;
	КонецЕсли;
	нз.Записать();
	Возврат Результат;
КонецФункции

Функция ПолучитьСкладПартнераПоТА(ТорговыйАгент) Экспорт
		з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	ТорговіАгенти.Склад,
	          |	ТорговіАгенти.ТорговийАгент.Склад КАК ОсновнийСклад
	          |ИЗ
	          |	РегистрСведений.ТорговіАгенти КАК ТорговіАгенти
	          |ГДЕ
	          |	ТорговіАгенти.ТорговийАгент = &ТорговыйАгент";
	з.УстановитьПараметр("ТорговыйАгент",ТорговыйАгент);
	Выборка = з.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Если ЗначениеЗаполнено(Выборка.Склад) Тогда 
			Возврат Выборка.Склад;
		Иначе 
			Возврат Выборка.ОсновнийСклад;
		КонецЕсли;
	Иначе                        
		Возврат Неопределено;
	КонецЕсли;
	
КонецФункции

