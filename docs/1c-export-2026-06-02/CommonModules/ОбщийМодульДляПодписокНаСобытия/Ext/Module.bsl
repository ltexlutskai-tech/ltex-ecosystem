Процедура СоздатьСписаниеТоваров(Автомобиль, ИсточникСсылка, ИсточникОбъект)
	
	ЗапросСписания = Новый Запрос;
	ЗапросСписания.Текст = 
		"ВЫБРАТЬ
		|	СписаниеТоваров.Ссылка
		|ИЗ
		|	Документ.СписаниеТоваров КАК СписаниеТоваров
		|ГДЕ
		|	СписаниеТоваров.МаршрутныйЛист = &МаршрутныйЛист
		|	И НЕ СписаниеТоваров.ПометкаУдаления";
	ЗапросСписания.УстановитьПараметр("МаршрутныйЛист", ИсточникСсылка);
	
	РезультатЗапроса = ЗапросСписания.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		Выборка 		   = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ДокументСписания = Выборка.Ссылка.ПолучитьОбъект();
	Иначе 	
		ДокументСписания = Документы.СписаниеТоваров.СоздатьДокумент();	
	КонецЕсли;	
	ДокументСписания.Дата 			= Мин(ИсточникСсылка.ДатаПриезда, ТекущаяДата());
	мВалютаУправленческогоУчета 	= Константы.ВалютаУправленческогоУчета.Получить();
	мВалютаРегламентированногоУчета = Константы.ВалютаРегламентированногоУчета.Получить();
	ЗаполнениеДокументов.ЗаполнитьШапкуДокумента(ДокументСписания, глЗначениеПеременной("глТекущийПользователь"), мВалютаУправленческогоУчета);	
	ДокументСписания.ОтражатьВУправленческомУчете = Истина;	
	ДокументСписания.МаршрутныйЛист	= ИсточникСсылка;
	ДокументСписания.Склад 			= Автомобиль.Бак;
	ДокументСписания.Товары.Очистить();
	НоваяСтрока 					= ДокументСписания.Товары.Добавить();
	НоваяСтрока.Номенклатура 		= Автомобиль.Топливо;
	НормаРасхода 					= Автомобиль.РасходТоплива;
	НоваяСтрока.ЕдиницаИзмерения 	= Автомобиль.Топливо.ЕдиницаХраненияОстатков;
	НоваяСтрока.Качество 			= Справочники.Качество.Новый; 
	НоваяСтрока.Количество 			= ИсточникОбъект.Пробег/100 * НормаРасхода;
	НоваяСтрока.Коэффициент 		= НоваяСтрока.ЕдиницаИзмерения.Коэффициент;
	
	Попытка
		ДокументСписания.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
	    #Если Клиент Тогда
			Сообщить(ОписаниеОшибки());
		#Иначе
			ЗаписьЖурналаРегистрации("ОШИБКА ЗАПИСИ СПИСАНИЯ", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки());
		#КонецЕсли

		ДокументСписания.Записать(РежимЗаписиДокумента.Запись);
	КонецПопытки;		
	
КонецПроцедуры	