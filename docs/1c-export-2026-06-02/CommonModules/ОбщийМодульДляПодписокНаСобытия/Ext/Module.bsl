

Процедура ОбработкаПроведенияПоступлениеТоваровУслугОбработкаПроведения(Источник, Отказ, РежимПроведения) Экспорт
	
	// Установка цен
	ЗапросУстановкиЦен = Новый Запрос;
	ЗапросУстановкиЦен.Текст = 
	"ВЫБРАТЬ
	|	УстановкаЦенНоменклатуры.Ссылка КАК УстановкаЦен
	|ИЗ
	|	Документ.УстановкаЦенНоменклатуры КАК УстановкаЦенНоменклатуры
	|ГДЕ
	|	УстановкаЦенНоменклатуры.ДокументОснование = &ДокументОснование
	|	И УстановкаЦенНоменклатуры.Проведен";
	ЗапросУстановкиЦен.УстановитьПараметр("ДокументОснование", Источник.Ссылка);
	РезультатЗапроса = ЗапросУстановкиЦен.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		Выборка = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ДокументУстановкиЦен = Выборка.УстановкаЦен.ПолучитьОбъект();
	Иначе
		ДокументУстановкиЦен = Документы.УстановкаЦенНоменклатуры.СоздатьДокумент();
	КонецЕсли;	
	
	ДокументУстановкиЦен.Дата 				= Источник.Дата;
	ДокументУстановкиЦен.ДокументОснование 	= Источник.Ссылка;
	ДокументУстановкиЦен.Комментарий 		= "Документ создан на основании " + Источник;
	ДокументУстановкиЦен.ТипыЦен.Очистить();
	НовыйТипЦен 							= ДокументУстановкиЦен.ТипыЦен.Добавить();
	НовыйТипЦен.ТипЦен 						= Справочники.ТипыЦенНоменклатуры.ЦенаЗакупкиВес;
	НовыйТипЦен 							= ДокументУстановкиЦен.ТипыЦен.Добавить();
	НовыйТипЦен.ТипЦен 						= Справочники.ТипыЦенНоменклатуры.ЦенаПродажиВес;
	ДокументУстановкиЦен.Товары.Очистить();
	
	ТабТовары = Источник.Товары.Выгрузить();
	ТабТовары.Свернуть("Номенклатура, ЦенаЗакупкиВес, ЦенаПродажиВес");
	ЗапросТовара = Новый Запрос;
	ЗапросТовара.Текст = 
	 "ВЫБРАТЬ
	 |	ВТТовары.Номенклатура,
	 |	ВТТовары.ЦенаЗакупкиВес,
	 |	ВТТовары.ЦенаПродажиВес
	 |ПОМЕСТИТЬ ВТТовары
	 |ИЗ
	 |	&ВТТовары КАК ВТТовары
	 |;
	 |
	 |////////////////////////////////////////////////////////////////////////////////
	 |ВЫБРАТЬ
	 |	ВТТовары.Номенклатура,
	 |	ЕдиницыИзмерения.Ссылка КАК ЕдиницаИзмерения,
	 |	ВТТовары.ЦенаЗакупкиВес,
	 |	ВТТовары.ЦенаПродажиВес
	 |ИЗ
	 |	ВТТовары КАК ВТТовары
	 |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	 |		ПО ВТТовары.Номенклатура = ЕдиницыИзмерения.Владелец
	 |ГДЕ
	 |	ЕдиницыИзмерения.ЕдиницаПоКлассификатору.Код = ВЫБОР
	 |			КОГДА ЕдиницыИзмерения.Владелец.ВідображатиВШтуках = ИСТИНА
	 |				ТОГДА ""2009""
	 |			ИНАЧЕ ""0301""
	 |		КОНЕЦ";
	ЗапросТовара.УстановитьПараметр("ВТТовары", ТабТовары);
	РезультатЗапроса = ЗапросТовара.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		ТЗТовары = РезультатЗапроса.Выгрузить();
		Для Каждого СтрТовары Из ТЗТовары Цикл 
			Если ДокументУстановкиЦен.Товары.Найти(СтрТовары.Номенклатура,"Номенклатура") <> Неопределено Тогда 
				Продолжить;
			КонецЕсли;
			
			НоваяСтрока 					= ДокументУстановкиЦен.Товары.Добавить();
			НоваяСтрока.Номенклатура 		= СтрТовары.Номенклатура;
			НоваяСтрока.ТипЦен 		 		= Справочники.ТипыЦенНоменклатуры.ЦенаЗакупкиВес;
			НоваяСтрока.Цена 				= СтрТовары.ЦенаЗакупкиВес;
			НоваяСтрока.СпособРасчетаЦены	= НоваяСтрока.ТипЦен.СпособРасчетаЦены;
			НоваяСтрока.ЕдиницаИзмерения	= СтрТовары.ЕдиницаИзмерения;
			НоваяСтрока.Валюта				= НоваяСтрока.ТипЦен.ВалютаЦены;
			
			НоваяСтрока 					= ДокументУстановкиЦен.Товары.Добавить();
			НоваяСтрока.Номенклатура 		= СтрТовары.Номенклатура;
			НоваяСтрока.ТипЦен 		 		= Справочники.ТипыЦенНоменклатуры.ЦенаПродажиВес;
			НоваяСтрока.Цена 				= СтрТовары.ЦенаПродажиВес;
			НоваяСтрока.СпособРасчетаЦены	= НоваяСтрока.ТипЦен.СпособРасчетаЦены;
			НоваяСтрока.ЕдиницаИзмерения	= СтрТовары.ЕдиницаИзмерения;
			НоваяСтрока.Валюта				= НоваяСтрока.ТипЦен.ВалютаЦены;			
		КонецЦикла;			
	КонецЕсли;	
	
	Попытка
		ДокументУстановкиЦен.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		#Если Клиент Тогда
			Сообщить(ОписаниеОшибки());
		#КонецЕсли
		
		ДокументУстановкиЦен.Записать(РежимЗаписиДокумента.Запись);
	КонецПопытки;
	// -
	
	// Анализ на предмет полноты поступления
	#Если Клиент Тогда
	Если Источник.ДоговорКонтрагента.ВедениеВзаиморасчетов = Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказам 
		И ТипЗнч(Источник.Сделка) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда 
		Если Источник.Сделка <> Документы.ЗаказПоставщику.ПустаяСсылка() Тогда 
			ТекущийЗаказ 	= Источник.Сделка.ПолучитьОбъект();
			ТЗЗаказано 		= ТекущийЗаказ.Товары.Выгрузить();
			ТЗЗаказано.Свернуть("Номенклатура", "Количество, Сумма, СуммаНДС");
			ТЗПоступило   = Источник.Товары.Выгрузить();
			ТЗПоступило.Свернуть("Номенклатура", "Количество, Сумма, СуммаНДС");
			МассивДозаказать = Новый Массив;
			Для Каждого СтрЗаказано Из ТЗЗаказано Цикл 
				СтрПоступило = ТЗПоступило.Найти(СтрЗаказано.Номенклатура, "Номенклатура");
				Если СтрПоступило = Неопределено Тогда 
					МассивДозаказать.Добавить(СтрЗаказано);
				Иначе 
					Дозаказать = СтрЗаказано.Количество - СтрПоступило.Количество;
					Если Дозаказать > 0 Тогда 
						СтрЗаказано.Количество = Дозаказать;
						МассивДозаказать.Добавить(СтрЗаказано);
					КонецЕсли;	
				КонецЕсли;	
			КонецЦикла;	
			Если МассивДозаказать.Количество() > 0 Тогда 
				Ответ = Вопрос("Не весь товар поступил. Дозаказать?", РежимДиалогаВопрос.ДаНет);
				Если Ответ = КодВозвратаДиалога.Да Тогда 
					НовыйЗаказ = Документы.ЗаказПоставщику.НайтиПоРеквизиту("ДокументОснование", ТекущийЗаказ.Ссылка);
					Если НовыйЗаказ = Документы.ЗаказПоставщику.ПустаяСсылка() Тогда 
						НовыйЗаказПоставщику 					= Документы.ЗаказПоставщику.СоздатьДокумент();
						ЗаполнитьЗначенияСвойств(НовыйЗаказПоставщику, ТекущийЗаказ);
						НовыйЗаказПоставщику.Дата 				= ТекущаяДата();
						НовыйЗаказПоставщику.ДокументОснование 	= ТекущийЗаказ.Ссылка;
					Иначе 
						НовыйЗаказПоставщику = НовыйЗаказ.ПолучитьОбъект();
						НовыйЗаказПоставщику.ПометкаУдаления = Ложь;
						НовыйЗаказПоставщику.Товары.Очистить();
					КонецЕсли;
					Для Каждого ЭлМассива Из МассивДозаказать Цикл 
						ТекСтрока = ТекущийЗаказ.Товары.Найти(ЭлМассива.Номенклатура, "Номенклатура");
						Если ТекСтрока <> Неопределено Тогда 
							НоваяСтрока = НовыйЗаказПоставщику.Товары.Добавить();
							ЗаполнитьЗначенияСвойств(НоваяСтрока, ТекСтрока);
							НоваяСтрока.Количество = ЭлМассива.Количество;
						КонецЕсли;	
					КонецЦикла;
					Попытка
						НовыйЗаказПоставщику.Записать(РежимЗаписиДокумента.Проведение);
					Исключение
						НовыйЗаказПоставщику.Записать(РежимЗаписиДокумента.Запись);
					КонецПопытки;
				Иначе 
					НовыйЗаказ = Документы.ЗаказПоставщику.НайтиПоРеквизиту("ДокументОснование", ТекущийЗаказ.Ссылка);	
					Если НовыйЗаказ <> Документы.ЗаказПоставщику.ПустаяСсылка() Тогда 
						НовыйЗаказПоставщику = НовыйЗаказ.ПолучитьОбъект();
						НовыйЗаказПоставщику.ПометкаУдаления = Истина;
						НовыйЗаказПоставщику.Записать(РежимЗаписиДокумента.ОтменаПроведения);
					КонецЕсли;	
				КонецЕсли;
			КонецЕсли;	
		КонецЕсли;	
	КонецЕсли;
	#КонецЕсли
	
КонецПроцедуры

Процедура ДокументМаршрутныйЛистПриЗаписиПриЗаписи(Источник, Отказ) Экспорт
	
	Если Источник.ОбменДанными.Загрузка Тогда
    	Возврат;
	КонецЕсли;	
	
	Если НЕ Источник.Проведен Тогда 
		Возврат;
	КонецЕсли;	
	
	Если НЕ (Источник.СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Завершен) Тогда 
		Возврат;
	КонецЕсли;	
	
	Если Источник.Архивный Тогда 
		Возврат;
	КонецЕсли;
	
	
	// Создание реализаций и закрытия заказов 
    ВалютаУпрУчета = Константы.ВалютаУправленческогоУчета.Получить();
	ЗаказыИсточника = Источник.Продажи.Выгрузить();
	ЗаказыИсточника.Свернуть("ЗаказПокупателя, Контрагент");
	Для Каждого СтрЗаказ Из ЗаказыИсточника Цикл 
		СуммаСкидкиНаценки = 0;
		Для Каждого СтрРасчет Из Источник.Расчеты Цикл 
			Если СтрРасчет.Контрагент = СтрЗаказ.Контрагент 
				И СтрРасчет.ЗаказПокупателя = СтрЗаказ.ЗаказПокупателя Тогда
					СуммаСкидкиНаценки = СуммаСкидкиНаценки + СтрРасчет.СуммаСкидкиНаценки;
			КонецЕсли;		
		КонецЦикла;	
		КурсРасчетов 		= Источник.ПолучитьКурсВалютыРасчета(СтрЗаказ.Контрагент, ВалютаУпрУчета);
		КурсДокумента 		= КурсРасчетов.КурсУпр;		
		НеплановаяПродажа 	= (СтрЗаказ.ЗаказПокупателя.ДоговорКонтрагента = СтрЗаказ.Контрагент.ДоговорДляНеплановыхПродаж);
		СоздатьРеализацию(СтрЗаказ.ЗаказПокупателя, СтрЗаказ.Контрагент, Источник.Продажи, Источник.Ссылка, КурсДокумента, СуммаСкидкиНаценки, НеплановаяПродажа);
		//Если НЕ (СтрЗаказ.ЗаказПокупателя.ДоговорКонтрагента = СтрЗаказ.Контрагент.ДоговорДляНеплановыхПродаж) Тогда 
		//	СоздатьЗакрытиеЗаказа(СтрЗаказ.ЗаказПокупателя, Источник.Ссылка);	
		//КонецЕсли;	
	КонецЦикла;	
	
	// Создание кассовых ордеров (ПКО)
	//Для Каждого СтрОплата Из Источник.Оплата Цикл 
	//	Если НЕ СтрОплата.Возврат Тогда 
	//		СоздатьОплату(СтрОплата, Источник.Ссылка, Источник);
	//	Иначе 
	//		СоздатьРКО(СтрОплата, Источник.Ссылка, Источник);	
	//	КонецЕсли;	
	//КонецЦикла;		
	
	Если Источник.Автомобиль <> Справочники.Автомобили.ПустаяСсылка() Тогда 
		СоздатьСписаниеТоваров(Источник.Автомобиль, Источник.Ссылка, Источник);	
	КонецЕсли; 	
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ И ФУНКЦИИ ВЫЗЫВАЕМЫЕ ПРИ СРАБАТЫВАНИИ СОБЫТИЙ 

Процедура СоздатьРеализацию(ТекущийЗаказ, ТекущийКонтрагент, ТЧТовары, ИсточникСсылка, КурсДокумента, СкидкаНаценка, Знач НеплановаяПродажа)
	
	Если Не ЗначениеЗаполнено(ТекущийЗаказ) Тогда 
		НеплановаяПродажа = Истина;
	КонецЕсли;
	
	Если ТекущийКонтрагент 	= Справочники.Контрагенты.ПустаяСсылка() Тогда 
		Возврат;
	КонецЕсли;		
	
	ЗапросРеализации = Новый Запрос;
	Если НЕ НеплановаяПродажа Тогда 
		ЗапросРеализации.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	(РеализацияТоваровУслуг.Сделка = &Сделка
		|			И РеализацияТоваровУслуг.МаршрутныйЛист = &Маршрутний)
		|	И НЕ РеализацияТоваровУслуг.ПометкаУдаления";
		ЗапросРеализации.УстановитьПараметр("Сделка", ТекущийЗаказ);
		ЗапросРеализации.УстановитьПараметр("Маршрутний", ИсточникСсылка);
	Иначе 
		ЗапросРеализации.Текст = 
		"ВЫБРАТЬ
		|	РеализацияТоваровУслуг.Ссылка
		|ИЗ
		|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|ГДЕ
		|	РеализацияТоваровУслуг.МаршрутныйЛист = &МаршрутныйЛист
		|	И РеализацияТоваровУслуг.Контрагент = &Контрагент
		|	И НЕ РеализацияТоваровУслуг.ПометкаУдаления";
		ЗапросРеализации.УстановитьПараметр("МаршрутныйЛист", ИсточникСсылка);		
		ЗапросРеализации.УстановитьПараметр("Контрагент", ТекущийКонтрагент);		
	КонецЕсли;
	
	РезультатЗапроса = ЗапросРеализации.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		Выборка 		   = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ДокументРеализации = Выборка.Ссылка.ПолучитьОбъект();
	Иначе 	
		ДокументРеализации = Документы.РеализацияТоваровУслуг.СоздатьДокумент();	
	КонецЕсли;	
	ДокументРеализации.Дата 						= Мин(ИсточникСсылка.ДатаПриезда + 1, ТекущаяДата());
	мВалютаУправленческогоУчета 					= Константы.ВалютаУправленческогоУчета.Получить();
	мВалютаРегламентированногоУчета 				= Константы.ВалютаРегламентированногоУчета.Получить();
	ЗаполнениеДокументов.ЗаполнитьШапкуДокумента(ДокументРеализации, глЗначениеПеременной("глТекущийПользователь"), мВалютаУправленческогоУчета, "Продажа");
	//ДокументРеализации.ВалютаДокумента			= мВалютаУправленческогоУчета;
	Если Не ЗначениеЗаполнено(ДокументРеализации.КурсВзаиморасчетов) Тогда 
		ДокументРеализации.КурсВзаиморасчетов			= КурсДокумента;
		ДокументРеализации.КратностьВзаиморасчетов = 1;
	КонецЕсли;
	
	ДокументРеализации.ОтражатьВУправленческомУчете = ИсточникСсылка.ОтражатьВУправленческомУчете;
	ДокументРеализации.ОтражатьВБухгалтерскомУчете 	= ИсточникСсылка.ОтражатьВБухгалтерскомУчете;
	ДокументРеализации.ОтражатьВНалоговомУчете 		= ИсточникСсылка.ОтражатьВНалоговомУчете;
	ДокументРеализации.Контрагент 					= ТекущийКонтрагент;
	ДокументРеализации.ДоговорКонтрагента 			= ?(НеплановаяПродажа, ТекущийКонтрагент.ДоговорДляНеплановыхПродаж, ТекущийЗаказ.ДоговорКонтрагента);
	ДокументРеализации.Комментарий 					= "Створено при закритті документа " + ИсточникСсылка;
	ДокументРеализации.Сделка 						= ТекущийЗаказ;
	ДокументРеализации.Организация 					= ИсточникСсылка.Организация;
	ДокументРеализации.Склад 						= ?(НеплановаяПродажа, ИсточникСсылка.Склад, ТекущийЗаказ.СкладГруппа);
	ДокументРеализации.МаршрутныйЛист 				= ИсточникСсылка;
	ДокументРеализации.Товары.Очистить();
	Для Каждого ТекСтрока Из ТЧТовары Цикл
		Если (ТекСтрока.ЗаказПокупателя = ТекущийЗаказ) И (ТекСтрока.Контрагент = ТекущийКонтрагент) Тогда
			Если ТекСтрока.Количество = 0 Тогда
				Продолжить;
			КонецЕсли;			
			Если ТекСтрока.Возврат Тогда
				Продолжить;
			КонецЕсли;						
			СтрокаТабличнойЧасти 								= ДокументРеализации.Товары.Добавить();
			СтрокаТабличнойЧасти.Номенклатура 					= ТекСтрока.Номенклатура;
			СтрокаТабличнойЧасти.ХарактеристикаНоменклатуры 	= ТекСтрока.ХарактеристикаНоменклатуры;
			СтрокаТабличнойЧасти.Количество     				= ТекСтрока.Количество;
			ОбработкаТабличныхЧастей.ЗаполнитьСпособСписанияОстаткаТоваровТабЧасти(СтрокаТабличнойЧасти, ДокументРеализации);
			СтрокаТабличнойЧасти.ЕдиницаИзмерения 				= СтрокаТабличнойЧасти.Номенклатура.ЕдиницаХраненияОстатков;
			СтрокаТабличнойЧасти.Коэффициент      				= 1;
			СтрокаТабличнойЧасти.Цена 							= ТекСтрока.Цена;
			СтрокаТабличнойЧасти.ЦенаПродажиВес					= ТекСтрока.ЦенаПродажиВес;
			СтрокаТабличнойЧасти.Склад 							= ДокументРеализации.Склад;
			СтрокаТабличнойЧасти.СпособСписанияОстаткаТоваров 	= Перечисления.СпособыСписанияОстаткаТоваров.ИзРезерва;
			ОбработкаТабличныхЧастей.РассчитатьСуммуТабЧасти(СтрокаТабличнойЧасти, ДокументРеализации);
			ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(СтрокаТабличнойЧасти, ДокументРеализации);
		КонецЕсли;		
	КонецЦикла;	
	Если СкидкаНаценка <> 0 Тогда 
		МаксСтрока  = Неопределено;
		МаксСумма 	= 0;
		Для Каждого СтрТовар Из ДокументРеализации.Товары Цикл 
			Если СтрТовар.Сумма > МаксСумма Тогда 
				МаксСумма 	= СтрТовар.Сумма;
				МаксСтрока 	= СтрТовар;
			КонецЕсли;	
		КонецЦикла;	
		Если МаксСтрока <> Неопределено Тогда 
			МаксСтрока.Сумма = МаксСтрока.Сумма + СкидкаНаценка;
			МаксСтрока.Цена	 = ?(МаксСтрока.Количество = 0, 0, МаксСтрока.Сумма/МаксСтрока.Количество);
			ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(МаксСтрока, ДокументРеализации);
		КонецЕсли;	
	КонецЕсли;
	
	//Для Каждого СтрТов Из ДокументРеализации.Товары Цикл
	//КонецЦикла;
	
	
	Попытка
		ДокументРеализации.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
	    #Если Клиент Тогда
			Сообщить(ОписаниеОшибки());
		#Иначе
			ЗаписьЖурналаРегистрации("ОШИБКА ЗАПИСИ РЕАЛИЗАЦИИ", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки());
		#КонецЕсли

		ДокументРеализации.Записать(РежимЗаписиДокумента.Запись);
	КонецПопытки;	
	
КонецПроцедуры	

Процедура СоздатьЗакрытиеЗаказа(ТекущийЗаказ, ИсточникСсылка)
	
	ЗапросЗакрытия = Новый Запрос;
	ЗапросЗакрытия.Текст = 
	"ВЫБРАТЬ
	|	ЗакрытиеЗаказовПокупателейЗаказы.Ссылка
	|ИЗ
	|	Документ.ЗакрытиеЗаказовПокупателей.Заказы КАК ЗакрытиеЗаказовПокупателейЗаказы
	|ГДЕ
	|	ЗакрытиеЗаказовПокупателейЗаказы.Ссылка.МаршрутныйЛист = &МаршрутныйЛист
	|	И ЗакрытиеЗаказовПокупателейЗаказы.ЗаказПокупателя = &ЗаказПокупателя";
	ЗапросЗакрытия.УстановитьПараметр("МаршрутныйЛист", ИсточникСсылка);
	ЗапросЗакрытия.УстановитьПараметр("ЗаказПокупателя", ТекущийЗаказ);
	РезультатЗапроса = ЗапросЗакрытия.Выполнить();
	Если НЕ РезультатЗапроса.Пустой() Тогда 
		Выборка 		   = РезультатЗапроса.Выбрать();
		Выборка.Следующий();
		ДокументЗакрытия = Выборка.Ссылка.ПолучитьОбъект();
	Иначе 	
		ДокументЗакрытия = Документы.ЗакрытиеЗаказовПокупателей.СоздатьДокумент();	
	КонецЕсли;		
	ДокументЗакрытия.Заказы.Очистить();
	ДокументЗакрытия.Дата = ИсточникСсылка.ДатаПриезда + 1;
	ДокументЗакрытия.ВидОперации = Перечисления.ВидыОперацийЗакрытиеЗаказовПокупателей.ЗакрытиеЗаказов;
	ДокументЗакрытия.МаршрутныйЛист = ИсточникСсылка;
	ДокументЗакрытия.Комментарий 	= "Створено при закритті документа " + ИсточникСсылка;
	Если ТекущийЗаказ <> Документы.ЗаказПокупателя.ПустаяСсылка() Тогда 
		НоваяСтрока = ДокументЗакрытия.Заказы.Добавить();
		НоваяСтрока.ЗаказПокупателя = ТекущийЗаказ;
	КонецЕсли;
	
	Попытка
		ДокументЗакрытия.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ДокументЗакрытия.Записать(РежимЗаписиДокумента.Запись);
	КонецПопытки;		
	
КонецПроцедуры	

