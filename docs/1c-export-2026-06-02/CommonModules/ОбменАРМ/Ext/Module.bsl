Функция ОбработатьПакетДанных(ПарольВхода, Данные) Экспорт
	Перем ИнфоМаршруты;
	ТаблицаИД = Новый ТаблицаЗначений;
	ТаблицаИД.Колонки.Добавить("ИД");
		
	МассивОшибок = Новый Массив;
	Попытка
		
		Склад = ОбменАндроид.ПолучитьСкладПартнера(ПарольВхода);
		Продавец = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
		//ЗаписьЖурналаРегистрации("ДанніЗаказа",УровеньЖурналаРегистрации.Информация,,,Десериализовать(Данные);
		СтруктураПараметров = Десериализовать(Данные);
		//ЗаписьЖурналаРегистрации("АНДРОИД_ТЕСТ",,,,Десериализовать(Данные));
		Если СтруктураПараметров.Свойство("Контрагенты") Тогда
			ОбновитьКонтрагентов(СтруктураПараметров.Контрагенты,Склад,ТаблицаИД, Продавец, МассивОшибок);		
		КонецЕсли;
		Если СтруктураПараметров.Свойство("Заказы") Тогда
			
			СоздатьВнутренниеЗаказы(СтруктураПараметров.Заказы,Склад,Продавец,ТаблицаИД);
		КонецЕсли;
		Если СтруктураПараметров.Свойство("МаршрутныеЛисты") Тогда  //Спочатку створюються маршрутники і товари в них. Потім загружаються документи а потім вкінці ці документи підгружаються в маршрутник
			Попытка
				СоздатьМаршрутныеЛистыТовары(СтруктураПараметров.МаршрутныеЛисты, Продавец, ТаблицаИД, ИнфоМаршруты);
			Исключение
				//ЗаписьЖурналаРегистрации("ОБМЕН_МАРШРУТНИКИ", УровеньЖурналаРегистрации.Ошибка, ,,ОписаниеОшибки());
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;		
		КонецЕсли;
		
		Если СтруктураПараметров.Свойство("Реализации") Тогда 
			Попытка
				СоздатьРеализацииТоваровУслуг(СтруктураПараметров.Реализации,Склад,Продавец, ТаблицаИД);
			Исключение
				//ЗаписьЖурналаРегистрации("ОБМЕН_РЕАЛИЗАЦИИ", УровеньЖурналаРегистрации.Ошибка, ,,ОписаниеОшибки());
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЕсли;
		
		Если СтруктураПараметров.Свойство("Презентации") Тогда 
			Попытка
				СоздатьПрезентацию(СтруктураПараметров.Презентации,Склад,Продавец, ТаблицаИД);
			Исключение
				//ЗаписьЖурналаРегистрации("ОБМЕН_ПРЕЗЕНТАЦИИ", УровеньЖурналаРегистрации.Ошибка, ,,ОписаниеОшибки());
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;
		КонецЕсли;
		
		
		
		Если СтруктураПараметров.Свойство("ПКО") Тогда 
			Попытка
				СоздатьПКО(СтруктураПараметров.ПКО, ТаблицаИД, МассивОшибок);
			Исключение
				//ЗаписьЖурналаРегистрации("ОБМЕН_ПКО", УровеньЖурналаРегистрации.Ошибка, ,,ОписаниеОшибки());
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;					
		КонецЕсли;
		Если СтруктураПараметров.Свойство("МаршрутныеЛисты") Тогда 
			Попытка
				СоздатьМаршрутныеЛистыДокументы(СтруктураПараметров.МаршрутныеЛисты, Продавец, ТаблицаИД);
			Исключение
				//ЗаписьЖурналаРегистрации("ОБМЕН_МАРШРУТНИКИ", УровеньЖурналаРегистрации.Ошибка, ,,ОписаниеОшибки());
				МассивОшибок.Добавить(ОписаниеОшибки());
			КонецПопытки;		
		КонецЕсли;
		Если СтруктураПараметров.Свойство("Напоминания") Тогда 
			СоздатьНапоминания(СтруктураПараметров.Напоминания, Продавец, ТаблицаИД);
		КонецЕсли;
		
	Исключение
		Возврат Сериализовать(ОписаниеОшибки());
	КонецПопытки;
	
	 Ответ = Новый Структура("ТаблицаИД, МассивОшибок", ТаблицаИД, МассивОшибок);
	 Если ЗначениеЗаполнено(ИнфоМаршруты) Тогда 
		 Ответ.Вставить("ИнфоМаршруты", ИнфоМаршруты);
	 КонецЕсли;
	 
	Возврат Сериализовать(Ответ);
	
КонецФункции


Процедура СоздатьВозвраты(ТаблицаВозвратов,Склад, ТаблицаИД,Продавец)
	МассивДокументов = Новый Массив;         
	ИмяДок = "ВозвратТоваровОтПокупателя";
	ТекущаяСсылка = "";
	
	Для Каждого СтрокаДанныеЭлемента Из ТаблицаВозвратов Цикл
		
		
		/////
		//Для Каждого СтрокаДанныеЭлемента Из ЗначенияДокумента Цикл
		
		
		НовыйОбъект = Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка).ПолучитьОбъект();
		ДобавитьДок = Ложь;

		Если НовыйОбъект = Неопределено Тогда 
			НовыйОбъект = Документы[ИмяДок].СоздатьДокумент();	
			НовыйОбъект.УстановитьСсылкуНового(Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка));
			ДобавитьДок = Истина;
		Иначе
			НовыйОбъект.мОбменАндроид = Истина;
			НовыйОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		КонецЕсли;
		
		Если ТекущаяСсылка <> СтрокаДанныеЭлемента.Ссылка Тогда 
			НовыйОбъект.Товары.Очистить();
			ТекущаяСсылка = СтрокаДанныеЭлемента.Ссылка;
			Попытка
				Если ЗначениеЗаполнено(СтрокаДанныеЭлемента.ИД) Тогда 
					НовСтр = ТаблицаИД.Добавить();
					НовСтр.ИД = СтрокаДанныеЭлемента.ИД;
				КонецЕсли;
			Исключение
			КонецПопытки;
			ДобавитьДок = Истина;
		КонецЕсли;
		
		СтрокаТоваров = НовыйОбъект.Товары.Добавить();
		Если НЕ ЗначениеЗаполнено(НовыйОбъект.Ссылка) Тогда 
			НовыйОбъект.Дата = СтрокаДанныеЭлемента.Дата;
			//НовыйОбъект.УстановитьНовыйНомер();
			//НовыйОбъект.Номер = Документы.РеализацияТоваровУслуг.Уста;
			НовыйОбъект.Организация = Справочники.Организации.НайтиПоКоду("000000001");
			НовыйОбъект.ОтражатьВУправленческомУчете = Истина;
			НовыйОбъект.СкладОрдер = Склад;
			НовыйОбъект.Контрагент = Склад.Партнер;
			НовыйОбъект.Партнер = Склад.Партнер;
			НовыйОбъект.ДоговорКонтрагента = Склад.Партнер.ОсновнойДоговорКонтрагента;
			//НовыйОбъект.ВидПередачи = Перечисления.ВидыПередачиТоваров.СоСклада;
			НовыйОбъект.ВалютаДокумента = Склад.Партнер.ОсновнойДоговорКонтрагента.ВалютаВзаиморасчетов;
			НовыйОбъект.КонечныйПокупатель = Справочники.Контрагенты.НайтиПоКоду("000000196");
			НовыйОбъект.Комментарий = "Возврат из Андроид";
			НовыйОбъект.ТипЦен = Склад.Партнер.ОсновнойДоговорКонтрагента.ТипЦен;
			НовыйОбъект.ВидОперации = Перечисления.ВидыОперацийВозвратТоваровОтПокупателя.ПродажаКомиссия;
			НовыйОбъект.ВидПоступления = Перечисления.ВидыПоступленияТоваров.НаСклад;
//			НовыйОбъект.ОрганизацияДляПечати = НовыйОбъект.Организация;
			НовыйОбъект.Ответственный = Склад.НастройкаНаАндроид.Пользователь;
			СпособЗаполненияЦен = Перечисления.СпособыЗаполненияЦен.ПоЦенамНоменклатуры;
			СтруктураРеквизитовДокумента = Ценообразование.ПолучитьСтруктуруРеквизитовДокументаДляЦенообразования(НовыйОбъект);
			ЗаполнениеДокументов.ПриИзмененииЗначенияДоговора(НовыйОбъект, Справочники.Валюты.ПустаяСсылка(), Константы.ВалютаРегламентированногоУчета.Получить(), СпособЗаполненияЦен, СтруктураРеквизитовДокумента, "Продажа", "Товары", Справочники.ДоговорыКонтрагентов.ПустаяСсылка());
			
			
		КонецЕсли;
		ЗаполнитьЗначенияСвойств(СтрокаТоваров,СтрокаДанныеЭлемента);
		СтрокаТоваров.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.Номенклатура);
		СтрокаТоваров.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.ХарактеристикаНоменклатуры);
		СтрокаТоваров.ЕдиницаИзмерения = Справочники.ЕдиницыИзмерения.ПолучитьСсылку(СтрокаДанныеЭлемента.ЕдиницаИзмерения);
		СтрокаТоваров.Цена = СтрокаДанныеЭлемента.ЦенаПартнера;
		СтрокаТоваров.ЦенаКонечногоПокупателя = СтрокаДанныеЭлемента.Цена;
		СтрокаТоваров.СуммаКонечногоПокупателя = СтрокаТоваров.ЦенаКонечногоПокупателя * СтрокаТоваров.Количество;
		СтрокаТоваров.Качество = Справочники.Качество.Новый;
		СтрокаТоваров.Коэффициент = СтрокаТоваров.ЕдиницаИзмерения.Коэффициент;
		
		ОбработкаТабличныхЧастей.РассчитатьСуммуТабЧасти(СтрокаТоваров, НовыйОбъект);
		ОбработкаТабличныхЧастей.РассчитатьСуммуНДСТабЧасти(СтрокаТоваров, НовыйОбъект);
		УправлениеЗапасами.ДобавитьСоставНабора(СтрокаТоваров, НовыйОбъект);
		//СтрокаТоваров.МестоХранения = Общий.ЯчейкаНазначена(СтрокаТоваров.Номенклатура,Склад);	
		//Общий.ЗаписатьЯчейкиНоменклатуры(СтрокаТоваров.Номенклатура,Склад, НовыйОбъект.МестаХранения);
		
		
		НовыйОбъект.мОбменАндроид = Истина;
		
		НовыйОбъект.Записать();
		Если ДобавитьДок Тогда 
			МассивДокументов.Добавить(НовыйОбъект.Ссылка);
		КонецЕсли;
		//КонецЦикла;
		
		/////
		
		
	КонецЦикла;	
	
	Для Каждого ДокСсылка Из МассивДокументов Цикл
		ДокОб = ДокСсылка.ПолучитьОбъект();
		Попытка
			ДокОб.мОбменАндроид = Продавец;
			ДокОб.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		Исключение
			//ЗаписьЖурналаРегистрации("ОБМЕН_АНДРОИД", УровеньЖурналаРегистрации.Ошибка,,,ОписаниеОшибки());

		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьВнутренниеЗаказы(ТаблицаВозвратов,Склад,Продавец, ТаблицаИД)
	
	МассивДокументов = Новый Массив;         
	ИмяДок = "ЗаказПокупателя";
	ТекущаяСсылка = "";
	ТорговыйАгент = Продавец;
	Попытка
		ТаблицаВозвратов.Сортировать("Ссылка");
	Исключение
	КонецПопытки;
	ТекИД = Неопределено;
	
	Для Каждого СтрокаДанныеЭлемента Из ТаблицаВозвратов Цикл
				
		НовыйОбъект = Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка).ПолучитьОбъект();
		Попытка
			//
		Исключение
		КонецПопытки;
		ДобавитьДок = Ложь;
		
		Если НовыйОбъект = Неопределено Тогда 
			Если СтрокаДанныеЭлемента.ПометкаУдаления  Тогда 
				Продолжить;
			КонецЕсли;

			НовыйОбъект = Документы[ИмяДок].СоздатьДокумент();	
			НовыйОбъект.УстановитьСсылкуНового(Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка));
			НовыйОбъект.СтатусЗамовлення = Справочники.СтатусиЗамовлень.Новий;
			ДобавитьДок = Истина;
		Иначе			
			НовыйОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		КонецЕсли;
		
		////////////////////////////////////////////////////////////////////
		Если ТекущаяСсылка <> СтрокаДанныеЭлемента.Ссылка Тогда 
			
			НовыйОбъект.Товары.Очистить();
			ТекущаяСсылка = СтрокаДанныеЭлемента.Ссылка;
			Попытка
				Если ЗначениеЗаполнено(ТекИД) Тогда 
					НовСтр = ТаблицаИД.Добавить();
					НовСтр.ИД = ТекИД; 
				КонецЕсли;
				ТекИД = СтрокаДанныеЭлемента.ИД;
			Исключение
			КонецПопытки;
			ДобавитьДок = Истина;
		КонецЕсли;
		
		///////////////////////////////////////////////////////////////////
		
		НовыйОбъект.Комментарий = "" + СтрокаДанныеЭлемента.Комментарий;
		СтрокаТоваров = НовыйОбъект.Товары.Добавить();
		
		Если НЕ ЗначениеЗаполнено(НовыйОбъект.Ссылка) Тогда 
			НовыйОбъект.Дата = ТекущаяДата();
			//НовыйОбъект.УстановитьНовыйНомер();
			НовыйОбъект.Организация = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(ПараметрыСеанса.ТекущийПользователь,"ОсновнаяОрганизация");								
			
			//Попытка 
			//	пОплата =  ИмяЗначенияПеречисленияПоСинониму("СтатусОплати",СтрокаДанныеЭлемента.Оплата);
			//	пДоставка = ИмяЗначенияПеречисленияПоСинониму("НаявністьДоставки",СтрокаДанныеЭлемента.Доставка);
			//	Если не пОплата = Неопределено тогда
			//		НовыйОбъект.Оплата = Перечисления.СтатусОплати[пОплата];
			//	КонецЕсли;
			//	Если не пДоставка = Неопределено Тогда 
			//		НовыйОбъект.Доставка = Перечисления.НаявністьДоставки[пДоставка]
			//	КонецЕсли;
			//	
			//Исключение
			//КонецПопытки;
			
			
			
			НовыйОбъект.СкладГруппа = Склад;
			НовыйОбъект.Наложка = СтрокаДанныеЭлемента.Наложка;
			НовыйОбъект.ДатаВходящегоДокументаЭлектронногоОбмена = ТекущаяДата();
			НовыйОбъект.ДатаОтгрузки = ТекущаяДата() + 86400;
			НовыйОбъект.ДатаОплаты = НовыйОбъект.ДатаОтгрузки;
			НовыйОбъект.Подразделение = Склад.Подразделение;
			НовыйОбъект.ТипЦен = Справочники.ТипыЦенНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.ТипЦен);
			НовыйОбъект.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.Контрагент);
			//ЗаписьЖурналаРегистрации("АНДРОИД_ДОСТАВКА", УровеньЖурналаРегистрации.Информация,,,СтрокаДанныеЭлемента.Доставка);
			Если ЗначениеЗаполнено(СтрокаДанныеЭлемента.Доставка) Тогда 
				НовыйОбъект.Доставка = Перечисления.НаявністьДоставки[СтрокаДанныеЭлемента.Доставка];
			КонецЕсли;
						
			з = Новый Запрос;
			з.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
			          |	ДоговорыКонтрагентов.Ссылка КАК Ссылка
			          |ИЗ
			          |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
			          |ГДЕ
			          |	ДоговорыКонтрагентов.Владелец = &Владелец
			          |	И ДоговорыКонтрагентов.ВидДоговора = &ВидДоговора
			          |	И ДоговорыКонтрагентов.Организация = &Организация
					  //|	И ДоговорыКонтрагентов.ВедениеВзаиморасчетов = &ВедениеВзаиморасчетов
			          |";
			з.УстановитьПараметр("ВидДоговора",Перечисления.ВидыДоговоровКонтрагентов.СПокупателем);
			з.УстановитьПараметр("Владелец",НовыйОбъект.Контрагент);
			з.УстановитьПараметр("Организация",НовыйОбъект.Организация); 
			//з.УстановитьПараметр("ВедениеВзаиморасчетов",Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказам); 
			Выборка = з.Выполнить().Выбрать();
			Если Выборка.Следующий() Тогда 
				НовыйОбъект.ДоговорКонтрагента = Выборка.Ссылка;
			Иначе
				//ЗаписьЖурналаРегистрации("У контрагента "+НовыйОбъект.Контрагент+ " " + СтрокаДанныеЭлемента.Дата + " - " + СтрокаДанныеЭлемента.Номер + " " +  " в заказе нет договора с покупателем.");
				ВызватьИсключение "У контрагента "+НовыйОбъект.Контрагент+ " "  + СтрокаДанныеЭлемента.Дата + " - " + СтрокаДанныеЭлемента.Номер + " " +  " в заказе нет договора с покупателем.";
			КонецЕсли;
			
			НовыйОбъект.ВалютаДокумента = Константы.ВалютаУправленческогоУчета.Получить();
			НовыйОбъект.КратностьВзаиморасчетов = 1;
		КонецЕсли;
		
		Агент = НовыйОбъект.Контрагент.ТорговыйАгент; 
		НовыйОбъект.ТорговийАгент = ?(ЗначениеЗаполнено(Агент), Агент, Продавец);

		//Агент = НовыйОбъект.Контрагент.ТорговыйАгент; 
		//НовыйОбъект.ТорговийАгент = ?(СтрокаДанныеЭлемента.ПризначитиПродажТорговомуКонтрагента, Агент, Продавец);
		//НовыйОбъект.ТорговийАгент = Продавец;
		
		НовыйОбъект.ПометкаУдаления = СтрокаДанныеЭлемента.ПометкаУдаления;
		
		ЗаполнитьЗначенияСвойств(СтрокаТоваров,СтрокаДанныеЭлемента);
		СтрокаТоваров.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.Номенклатура);
		СтрокаТоваров.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.ХарактеристикаНоменклатуры);
		Попытка
			СтрокаТоваров.ЕдиницаИзмерения = СтрокаТоваров.Номенклатура.ЕдиницаХраненияОстатков;
		Исключение
		КонецПопытки;
		СтрокаТоваров.Сумма = СтрокаТоваров.Цена * СтрокаТоваров.Количество;
		СтрокаТоваров.Коэффициент = СтрокаТоваров.ЕдиницаИзмерения.Коэффициент;
		
		Попытка
			НовыйОбъект.Записать();
			
			Если НовыйОбъект.ТорговийАгент <> Продавец Тогда 
				НаборЗаписей = РегистрыСведений.РегистрацияОбмена.СоздатьНаборЗаписей();
				НаборЗаписей.Отбор.Продавец.Установить(НовыйОбъект.ТорговийАгент);
				НаборЗаписей.Отбор.Объект.Установить(НовыйОбъект.Ссылка);
				Запись = НаборЗаписей.Добавить();
				Запись.Продавец = НовыйОбъект.ТорговийАгент;
				Запись.Объект 	= НовыйОбъект.Ссылка;
				Запись.ИД		= Новый УникальныйИдентификатор;
				НаборЗаписей.Записать();
			КонецЕсли;
			

		Исключение
			ЗаписьЖурналаРегистрации("ОшибкаОбмена",УровеньЖурналаРегистрации.Ошибка,,"",ОписаниеОшибки());
			Продолжить;
		КонецПопытки;
		
		Если ДобавитьДок Тогда 
			МассивДокументов.Добавить(НовыйОбъект.Ссылка);
		КонецЕсли;
				
	КонецЦикла;	
	
	Если ЗначениеЗаполнено(ТекИД) Тогда 
		НовСтр = ТаблицаИД.Добавить();
		НовСтр.ИД = ТекИД;
	КонецЕсли;
	
	Для Каждого ДокСсылка Из МассивДокументов Цикл
		Попытка
			ДокОб = ДокСсылка.ПолучитьОбъект();
		Исключение
			Продолжить;
		КонецПопытки;
		Если ДокОб.ПометкаУдаления Тогда 
			Продолжить;
		КонецЕсли;
		
		Попытка
			ДокОб.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		Исключение
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьРеализацииТоваровУслуг(ТаблицаВозвратов,Склад,Продавец, ТаблицаИД)
	
	МассивДокументов = Новый Массив;         
	ИмяДок = "РеализацияТоваровУслуг";
	ТекущаяСсылка = "";
	ТорговыйАгент = Продавец;
	Попытка
		ТаблицаВозвратов.Сортировать("Ссылка");
	Исключение
	КонецПопытки;
	ТекИД = Неопределено;
	
	Для Каждого СтрокаДанныеЭлемента Из ТаблицаВозвратов Цикл
		///////////////////////
		//ЗаписьЖурналаРегистрации("ЛОГ_РЕАЛИЗАЦИЯ",УровеньЖурналаРегистрации.Информация,,"",СокрЛП(Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.Контрагент)) + СокрЛП(СтрокаДанныеЭлемента.Дата));
		
		НовыйОбъект = Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка).ПолучитьОбъект();
		ТекущийЗаказ = Документы.ЗаказПокупателя.ПолучитьСсылку(СтрокаДанныеЭлемента.Сделка);
		ТекущийКонтрагент = Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.Контрагент);
		
		
		Если НовыйОбъект = Неопределено ИЛИ НЕ ЗначениеЗаполнено(НовыйОбъект.Ссылка) Тогда		
			Если ЗначениеЗаполнено(ТекущийЗаказ) Тогда // ШукаємРеалізаціюПоЗаказу 
				ЗапросРеализации = Новый Запрос;
				ЗапросРеализации.Текст = 
				"ВЫБРАТЬ
				|	РеализацияТоваровУслуг.Ссылка
				|ИЗ
				|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
				|ГДЕ
				|	РеализацияТоваровУслуг.Сделка = &Сделка
				|	И НЕ РеализацияТоваровУслуг.ПометкаУдаления
				|	И РеализацияТоваровУслуг.Контрагент = &Контрагент
				|	И РеализацияТоваровУслуг.Дата > &ДатаДок";
				ЗапросРеализации.УстановитьПараметр("Сделка", ТекущийЗаказ);
				ЗапросРеализации.УстановитьПараметр("ДатаДок", ТекущаяДата() - (60*60*24 * 7));

				ЗапросРеализации.УстановитьПараметр("Контрагент", ТекущийКонтрагент);
				ВыборкаЗапросаРеализации = ЗапросРеализации.Выполнить().Выбрать();
				Если ВыборкаЗапросаРеализации.Следующий() И ЗначениеЗаполнено(ТекущийЗаказ) Тогда  // Чи була раніше створена реалізація
					
					
					Если ВозвратПоЗакритомуМаршрутнику(ВыборкаЗапросаРеализации.Ссылка.МаршрутныйЛист, СтрокаДанныеЭлемента.ИД, ТаблицаИД) Тогда 
						Продолжить;
					КонецЕсли;				
					
					НовыйОбъект = ВыборкаЗапросаРеализации.Ссылка.ПолучитьОбъект();
					НовыйОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);		
				КонецЕсли; 
			КонецЕсли;
			/////////////////////////////
			
		КонецЕсли;		
		
		
		ДобавитьДок = Ложь;
		
		
		
		ТекМаршрутныйЛист 	= Документы.МаршрутныйЛист.ПолучитьСсылку(СтрокаДанныеЭлемента.МаршрутныйЛист);
		
		Если ВозвратПоЗакритомуМаршрутнику(ТекМаршрутныйЛист, СтрокаДанныеЭлемента.ИД, ТаблицаИД) Тогда 
			Продолжить;
		КонецЕсли;	
		
		Если НовыйОбъект = Неопределено ИЛИ НЕ ЗначениеЗаполнено(НовыйОбъект.Ссылка) Тогда   // Створюєм
			Если СтрокаДанныеЭлемента.ПометкаУдаления  Тогда 
				Продолжить;
			КонецЕсли;
			
			НовыйОбъект = Документы[ИмяДок].СоздатьДокумент();	
			НовыйОбъект.УстановитьСсылкуНового(Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка));
			
			ДобавитьДок = Истина;
		Иначе			
			НовыйОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		КонецЕсли;	
		
		
		//ЗаписьЖурналаРегистрации("ЛОГ_РЕАЛИЗАЦИЯ2",УровеньЖурналаРегистрации.Информация,,"",СокрЛП(НовыйОбъект.Ссылка));
		
		
		
		////////////////////////////////////////////////////////////////////  Новий документ
		Если ТекущаяСсылка <> СтрокаДанныеЭлемента.Ссылка Тогда 
			НовыйОбъект.Комментарий = НовыйОбъект.Комментарий + " Оновлено з додатку: " + СокрЛП(ТекущаяДата()) + " " + СтрокаДанныеЭлемента.Комментарий;
			НовыйОбъект.Наложка = СтрокаДанныеЭлемента.Наложка;
			НовыйОбъект.Товары.Очистить();
			ТекущаяСсылка = СтрокаДанныеЭлемента.Ссылка;
			Попытка
				Если ЗначениеЗаполнено(ТекИД) Тогда 
					НовСтр = ТаблицаИД.Добавить();
					НовСтр.ИД = ТекИД; 
				КонецЕсли;
				ТекИД = СтрокаДанныеЭлемента.ИД;
			Исключение
			КонецПопытки;
			ДобавитьДок = Истина;
			Если НЕ ЗначениеЗаполнено(НовыйОбъект.Ссылка) Тогда 
				НовыйОбъект.Дата = СтрокаДанныеЭлемента.Дата;
				//НовыйОбъект.УстановитьНовыйНомер();
			КонецЕсли;
			НовыйОбъект.Организация = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(ПараметрыСеанса.ТекущийПользователь,"ОсновнаяОрганизация");								
			
			Попытка 
				НовыйОбъект.Доставка = Перечисления.НаявністьДоставки[СтрокаДанныеЭлемента.Доставка];			
			Исключение
			КонецПопытки;
			
			//Попытка 
			//	пОплата =  ИмяЗначенияПеречисленияПоСинониму("СтатусОплати",СтрокаДанныеЭлемента.Оплата);
			//	пДоставка = ИмяЗначенияПеречисленияПоСинониму("НаявністьДоставки",СтрокаДанныеЭлемента.Доставка);
			//	Если не пОплата = Неопределено тогда
			//		НовыйОбъект.Оплата = Перечисления.СтатусОплати[пОплата];
			//	КонецЕсли;
			//	Если не пДоставка = Неопределено Тогда 
			//		НовыйОбъект.Доставка = Перечисления.НаявністьДоставки[пДоставка]
			//	КонецЕсли;
			//	
			//Исключение
			//КонецПопытки;
			
			//НовыйОбъект.ТорговийАгент = СтрокаДанныеЭлемента.ПризначитиПродажТорговомуКонтрагента;
			НовыйОбъект.Склад = Склад;
			//НовыйОбъект.ДатаВходящегоДокументаЭлектронногоОбмена = ТекущаяДата();
			//НовыйОбъект.ДатаОтгрузки = ТекущаяДата() + 86400;
			//НовыйОбъект.ДатаОплаты = НовыйОбъект.ДатаОтгрузки;
			//НовыйОбъект.Подразделение = Склад.Подразделение;
			НовыйОбъект.ТипЦен = Справочники.ТипыЦенНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.ТипЦен);
			НовыйОбъект.Контрагент 		= ТекущийКонтрагент;
			
			//+-
			//НовыйОбъект.Сделка 			= ТекущийЗаказ;
			Если (НовыйОбъект.Доставка = Перечисления.НаявністьДоставки.Почта Или НовыйОбъект.Доставка = Перечисления.НаявністьДоставки.Самовывоз)
				  И ЗначениеЗаполнено(НовыйОбъект.Сделка) И Не ЗначениеЗаполнено(ТекущийЗаказ)  Тогда
				  //Пропускаемо бо реалызації встановили заказ раніше а в додатку його немає
			Иначе	  				  
				НовыйОбъект.Сделка 			= ТекущийЗаказ;
			КонецЕсли;	
			//+-
			
			Если СтрокаДанныеЭлемента.Неплановая ИЛИ НЕ ЗначениеЗаполнено(НовыйОбъект.Сделка) Тогда 
				НовыйОбъект.ДоговорКонтрагента = НовыйОбъект.Контрагент.ДоговорДляНеплановыхПродаж;	
			Иначе 
				НовыйОбъект.ДоговорКонтрагента = НовыйОбъект.Контрагент.ОсновнойДоговорКонтрагента;	
			КонецЕсли;	
			
			НовыйОбъект.МаршрутныйЛист 	= Документы.МаршрутныйЛист.ПолучитьСсылку(СтрокаДанныеЭлемента.МаршрутныйЛист);
			
			Если ВозвратПоЗакритомуМаршрутнику(НовыйОбъект.МаршрутныйЛист, ТекИД, ТаблицаИД) Тогда 
				Продолжить;
			КонецЕсли;
			
			НовыйОбъект.ОтражатьВУправленческомУчете = Истина;
			НовыйОбъект.ВидПередачи = Перечисления.ВидыПередачиТоваров.СоСклада;
			НовыйОбъект.ВидОперации = Перечисления.ВидыОперацийРеализацияТоваров.ПродажаКомиссия;
			Агент = НовыйОбъект.Контрагент.ТорговыйАгент; 
			НовыйОбъект.ТорговийАгент = ?(ЗначениеЗаполнено(Агент), Агент, Продавец);
			НовыйОбъект.КурсUSD = СтрокаДанныеЭлемента.КурсUSD;
			НовыйОбъект.КурсEUR = СтрокаДанныеЭлемента.КурсEUR;
			Попытка
				НовыйОбъект.СумаОплатиНаложкою = СтрокаДанныеЭлемента.СумаОплатиНаложкою;
			Исключение
			КонецПопытки;
 
			
			Если НовыйОбъект.ДоговорКонтрагента = Справочники.ДоговорыКонтрагентов.ПустаяСсылка() Тогда 
				з = Новый Запрос;
				з.Текст =  "ВЫБРАТЬ ПЕРВЫЕ 1
				|	ДоговорыКонтрагентов.Ссылка КАК Договор
				|ИЗ
				|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
				|ГДЕ
				|	ДоговорыКонтрагентов.ВедениеВзаиморасчетов = &ВедениеВзаиморасчетов
				|	И ДоговорыКонтрагентов.Владелец = &Владелец
				|	И ДоговорыКонтрагентов.Организация = &Организация
				|	И ДоговорыКонтрагентов.ВидДоговора = &ВидДоговора";
				з.УстановитьПараметр("ВидДоговора",Перечисления.ВидыДоговоровКонтрагентов.СПокупателем);
				з.УстановитьПараметр("Владелец",НовыйОбъект.Контрагент);
				з.УстановитьПараметр("Организация",НовыйОбъект.Организация); 
