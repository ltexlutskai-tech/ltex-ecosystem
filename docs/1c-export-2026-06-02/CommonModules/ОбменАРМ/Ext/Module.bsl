	Запрос.УстановитьПараметр("ПарольДоступаАндроід", ПарольВхода);
	ТзТипыЦен = Запрос.Выполнить().Выгрузить();
	
	ТзТипыЦен.Колонки.Добавить("УИДСсылка");
	ТзТипыЦен.Колонки.Добавить("Наименование");
	мас = Новый Массив;
	Для Каждого Строка Из ТзТипыЦен Цикл
		
		Если Не ЗначениеЗаполнено(Строка.Ссылка) Тогда 
			мас.Добавить(Строка);
			Продолжить;
		КонецЕсли;
		
		Строка.УИДСсылка = Строка.Ссылка.УникальныйИдентификатор();
		Строка.Наименование = СокрЛП(Строка.Ссылка);
		
	КонецЦикла;
	Для Каждого Стр Из мас Цикл
		ТзТипыЦен.Удалить(Стр);
	КонецЦикла;
	
	
	СтрукрутаСправочников.Вставить("ТипыЦенНоменклатуры", ТзТипыЦен);
	
КонецПроцедуры

Процедура ДобавитьСправочникГородаОбласти(СтрукрутаСправочников, Города = Неопределено, Области = Неопределено)
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Области.Ссылка,
	               |	Области.Наименование
	               |ИЗ
	               |	Справочник.Области КАК Области
	               |ГДЕ
	               |	(&БезОтбора
	               |			ИЛИ Области.Ссылка В (&Ссылка))";
	
	Запрос.УстановитьПараметр("БезОтбора", Области = Неопределено);
	Запрос.УстановитьПараметр("Ссылка", Области);
	ТЗОбласти = Запрос.Выполнить().Выгрузить();		
	ТЗОбласти.Колонки.Добавить("УИДСсылка");
	Для Каждого Строка Из ТЗОбласти Цикл		
		Строка.УИДСсылка = Строка.Ссылка.УникальныйИдентификатор();		
	КонецЦикла;
	
	
	СтрукрутаСправочников.Вставить("Области", ТЗОбласти);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Города.Ссылка,
	               |	Города.Наименование,
	               |	Города.Владелец
	               |ИЗ
	               |	Справочник.Города КАК Города
	               |ГДЕ
	               |	(&БезОтбора
	               |			ИЛИ Города.Ссылка В (&Ссылка))";
	Запрос.УстановитьПараметр("БезОтбора", Города = Неопределено);
	Запрос.УстановитьПараметр("Ссылка", Города);
	ТЗГорода = Запрос.Выполнить().Выгрузить();		
	ТЗГорода.Колонки.Добавить("УИДСсылка");
	ТЗГорода.Колонки.Добавить("УИДВладелец");
	Для Каждого Строка Из ТЗГорода Цикл		
		Строка.УИДСсылка = Строка.Ссылка.УникальныйИдентификатор();	
		Строка.УИДВладелец = Строка.Владелец.УникальныйИдентификатор();	
	КонецЦикла;
	
	СтрукрутаСправочников.Вставить("Города", ТЗГорода);


КонецПроцедуры

