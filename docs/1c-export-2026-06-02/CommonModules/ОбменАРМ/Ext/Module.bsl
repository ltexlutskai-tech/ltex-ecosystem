Функция ОтриматиЗалишкиХарактеристик(ПарольВхода, Номенклатура) Экспорт
	
	Продавец = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
	Склад = ОбменАндроид.ПолучитьСкладПартнера(ПарольВхода);
	Если Продавец = Неопределено Тогда 
		Возврат Сериализовать(Новый ТаблицаЗначений);
	КонецЕсли;
	СтруктураПараметров = Десериализовать(Номенклатура);

	Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(СтруктураПараметров.Номенклатура);
		
	
	
	
	з = Новый Запрос;
	з.Текст = "ВЫБРАТЬ
	          |	СУММА(ВЫБОР
	          |			КОГДА &НеВивантажуватиЗалишки
	          |				ТОГДА 0
	          |			ИНАЧЕ ТоварыНаСкладахОстатки.КоличествоОстаток - ЕСТЬNULL(ТоварыВРезервеНаСкладахОстатки.КоличествоОстаток, 0)
	          |		КОНЕЦ) КАК Остаток,
	          |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры
	          |ИЗ
	          |	РегистрНакопления.ТоварыНаСкладах.Остатки(
	          |			,
	          |			Номенклатура = &Номенклатура
	          |				И Склад = &Склад) КАК ТоварыНаСкладахОстатки
	          |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыВРезервеНаСкладах.Остатки(
	          |				,
	          |				Номенклатура = &Номенклатура
	          |					И Склад = &Склад) КАК ТоварыВРезервеНаСкладахОстатки
	          |		ПО ТоварыНаСкладахОстатки.Номенклатура = ТоварыВРезервеНаСкладахОстатки.Номенклатура
	          |			И ТоварыНаСкладахОстатки.Склад = ТоварыВРезервеНаСкладахОстатки.Склад
	          |			И ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры = ТоварыВРезервеНаСкладахОстатки.ХарактеристикаНоменклатуры
	          |
	          |СГРУППИРОВАТЬ ПО
	          |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры";
			  
	з.УстановитьПараметр("НеВивантажуватиЗалишки",Продавец.НеВивантажуватиЗалишкиВАндроїд);		  
	з.УстановитьПараметр("Номенклатура",Номенклатура);
	з.УстановитьПараметр("Склад",Склад);
	ТЗОстатков = з.Выполнить().Выгрузить();
	ТЗОстатков.Колонки.Добавить("УИДХарактеристикаНоменклатуры");
	
	Для Каждого Строка Из ТЗОстатков Цикл
		Если ЗначениеЗаполнено(Строка.ХарактеристикаНоменклатуры) Тогда 
			
			Строка.УИДХарактеристикаНоменклатуры = Строка.ХарактеристикаНоменклатуры.УникальныйИдентификатор();
			
		КонецЕсли;
	КонецЦикла;
	
	ТЗОстатков.Колонки.Удалить("ХарактеристикаНоменклатуры");	
		
		
	
	Возврат Сериализовать(ТЗОстатков);

	
	
КонецФункции

Функция ОновитиЗалишкиТаЦіниНоменклатури(ПарольВхода, Частково = Ложь) Экспорт
	Ответ = Новый Структура;
	Продавец = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
	Склад = ОбменАндроид.ПолучитьСкладПартнера(ПарольВхода);
	Если Продавец = Неопределено Тогда 
		Возврат Сериализовать(Новый ТаблицаЗначений);
	КонецЕсли;
	
	ТипЦен = Новый  Массив;
	Ответ = Новый Структура;
	ДобавитьСправочникТипыЦен(Ответ, ПарольВхода);
	Для Каждого Элемент из Ответ.ТипыЦенНоменклатуры Цикл 
		 ТипЦен.Добавить(Элемент.Ссылка);
	КонецЦикла;
	Ответ.Вставить("ПоказыватьЦены", Продавец.ВсіЦіни);
	Ответ.Вставить("ПоказыватьЦеныПоставщиков", Продавец.ЦеныПоставщиков);

	Запрос = Новый Запрос;
	//Если Частково Тогда 
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ВложенныйЗапрос.Номенклатура,
		|	ВложенныйЗапрос.ХарактеристикаНоменклатуры,
		|	ВложенныйЗапрос.Остаток,
		|	ВложенныйЗапрос.Цена,
		|	ВложенныйЗапрос.ТипЦен,
		|	ВложенныйЗапрос.НаименованиеХарактеристики,
		|	ВложенныйЗапрос.Вага,
		|	ЕСТЬNULL(ЦеныНоменклатурыСрезПоследнихАкция.Цена, 0) КАК ЦенаАкция,
		|	ВложенныйЗапрос.ХарактеристикаНоменклатуры.Целевой КАК Целевой,
		|	ВложенныйЗапрос.Цена КАК ЦенаПослеОкончаниеАкции,
		|	ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0) КАК КонецАкции,
		|	ВложенныйЗапрос.ХарактеристикаНоменклатуры.СсылкаНаYouTube КАК СсылкаНаYouTube,
		|	ВложенныйЗапрос.ХарактеристикаНоменклатуры.Описание КАК Описание,
		|	ПРЕДСТАВЛЕНИЕ(ВложенныйЗапрос.ХарактеристикаНоменклатуры.Бронь) КАК Бронь,
		|	ВложенныйЗапрос.ХарактеристикаНоменклатуры.ПериодБрони КАК ПериодБрони,
		|	ВложенныйЗапрос.ХарактеристикаНоменклатуры.Бронь = &Продавец КАК МояБронь,
		|	ЕСТЬNULL(ВложенныйЗапрос.ХарактеристикаНоменклатуры.Контрагент, ЗНАЧЕНИЕ(справочник.Контрагенты.ПустаяСсылка)) КАК Контрагент
		|ИЗ
		|	(ВЫБРАТЬ
		|		ЕСТЬNULL(ТоварыНаСкладахОстатки.Номенклатура, ЦеныНоменклатурыСрезПоследних.Номенклатура) КАК Номенклатура,
		|		ЕСТЬNULL(ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры, ЦеныНоменклатурыСрезПоследних.ХарактеристикаНоменклатуры) КАК ХарактеристикаНоменклатуры,
		|		ЕСТЬNULL(ТоварыНаСкладахОстатки.КоличествоОстаток, 0) КАК Остаток,
		|		ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) КАК Цена,
		|		ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.ТипЦен, ЗНАЧЕНИЕ(Справочник.ТипыЦенНоменклатуры.ПустаяСсылка)) КАК ТипЦен,
		|		ЕСТЬNULL(ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Наименование, ЦеныНоменклатурыСрезПоследних.ХарактеристикаНоменклатуры.Наименование) КАК НаименованиеХарактеристики,
		|		ЕСТЬNULL(ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Вага, ЦеныНоменклатурыСрезПоследних.ХарактеристикаНоменклатуры.Вага) КАК Вага
		|	ИЗ
		|		РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаОкончания, ) КАК ТоварыНаСкладахОстатки
		|			ПОЛНОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаОкончания, ТипЦен В (&ТипЦен)) КАК ЦеныНоменклатурыСрезПоследних
		|			ПО ТоварыНаСкладахОстатки.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура) КАК ВложенныйЗапрос
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаОкончания, ТипЦен = &ТипЦенАкция) КАК ЦеныНоменклатурыСрезПоследнихАкция
		|		ПО ВложенныйЗапрос.Номенклатура = ЦеныНоменклатурыСрезПоследнихАкция.Номенклатура";
	//Иначе
	//	Запрос.Текст = 
	//	"ВЫБРАТЬ
	//	|	ТоварыНаСкладахОстатки.Склад,
	//	|	ТоварыНаСкладахОстатки.Номенклатура.Артикул КАК Артикул,
	//	|	ТоварыНаСкладахОстатки.Номенклатура,
	//	|	СУММА(ТоварыНаСкладахОстатки.КоличествоОстаток) КАК КоличествоШт,
	//	|	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры
	//	|ПОМЕСТИТЬ ВТТоварыНаСкладах
	//	|ИЗ
	//	|	РегистрНакопления.ТоварыНаСкладах.Остатки(&ДатаНачала, ) КАК ТоварыНаСкладахОстатки
	//	|
	//	|СГРУППИРОВАТЬ ПО
	//	|	ТоварыНаСкладахОстатки.Склад,
	//	|	ТоварыНаСкладахОстатки.Номенклатура.Артикул,
	//	|	ТоварыНаСкладахОстатки.Номенклатура,
	//	|	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры
	//	|;
	//	|
	//	|////////////////////////////////////////////////////////////////////////////////
	//	|ВЫБРАТЬ
	//	|	Цены.Номенклатура,
	//	|	МАКСИМУМ(Цены.ЦенаПродажи) КАК ЦенаПродажи,
	//	|	Цены.ТипЦен
	//	|ПОМЕСТИТЬ ВТЦены
	//	|ИЗ
	//	|	(ВЫБРАТЬ
	//	|		ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
	//	|		ЦеныНоменклатурыСрезПоследних.Цена КАК ЦенаПродажи,
	//	|		ЦеныНоменклатурыСрезПоследних.ТипЦен КАК ТипЦен
	//	|	ИЗ
	//	|		РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаНачала, ТипЦен = ЗНАЧЕНИЕ(Справочник.ТипыЦенНоменклатуры.ЦенаПродажиВес)) КАК ЦеныНоменклатурыСрезПоследних) КАК Цены
	//	|
	//	|СГРУППИРОВАТЬ ПО
	//	|	Цены.Номенклатура,
	//	|	Цены.ТипЦен
	//	|;
	//	|
	//	|////////////////////////////////////////////////////////////////////////////////
	//	|ВЫБРАТЬ
	//	|	ТовариНаСкладахУВазіОстатки.Номенклатура,
	//	|	ВТТоварыНаСкладах.ХарактеристикаНоменклатуры,
	//	|	ЕСТЬNULL(ВТТоварыНаСкладах.КоличествоШт, 0) КАК Остаток,
	//	|	ЕСТЬNULL(ВТЦены.ЦенаПродажи, 0) КАК Цена,
	//	|	ЕСТЬNULL(ВТЦены.ТипЦен, ЗНАЧЕНИЕ(Справочник.ТипыЦенНоменклатуры.ПустаяСсылка)) КАК ТипЦен
	//	|ИЗ
	//	|	РегистрНакопления.ТовариНаСкладахУВазі.Остатки(
	//	|			&ДатаНачала,
	//	|			Номенклатура.Ссылка В ИЕРАРХИИ
	//	|				(ВЫБРАТЬ
	//	|					ВыгружатьВАндроидПоСкладам.Номенклатура
	//	|				ИЗ
