Функция НачатьОбмен(Версия, ИдентификаторКлиента, ПарольВхода,ЭтоНеПервыйОбмен) Экспорт
	
	
	
	
	УстановитьПривилегированныйРежим(Истина);
	
	Ошибка = "";    
	
	
	
	АктуальнаяВерсия = "1";
	
	Если Константы.БлокуватиРегламентСервіс.Получить() Тогда 
		Ошибка = "База заблокована. Зробіть обмін пізніше!";
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(ПарольВхода) Тогда 
		ПарольВхода = Неопределено;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ТорговіАгенти.ТорговыйАгент КАК ТорговийАгент,
	               |	ТорговіАгенти.ТорговыйАгент.Склад,
	               |	ТорговіАгенти.ТорговыйАгент.Склад КАК ОсновнийСклад,
	               |	ТорговіАгенти.ТорговыйАгент.ІдентифікаторПристрою КАК ІдентифікаторПристрою
	               |ИЗ
	               |	Справочник.Контрагенты КАК ТорговіАгенти
	               |ГДЕ
	               |	ТорговіАгенти.ТорговыйАгент.ПарольДоступаАндроід = &ПарольДоступаАндроід";
	Запрос.УстановитьПараметр("ПарольДоступаАндроід", ПарольВхода);
	Выборка = Запрос.Выполнить().Выбрать();
	Если Не (Выборка.Следующий() И ПарольВхода <> Неопределено) Тогда 
		
		ЗаписьЖурналаРегистрации("НевернаяАвторизацияАндроид",УровеньЖурналаРегистрации.Предупреждение,Неопределено,ПарольВхода);
		Ошибка = Ошибка + "Не коректно вказано пароль, або не назначені клієнти!";
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(Выборка.ІдентифікаторПристрою) Тогда 
		ТоргОб = Выборка.ТорговийАгент.ПолучитьОбъект(); 
		ТоргОб.ІдентифікаторПристрою = СокрЛП(ИдентификаторКлиента);
		ТоргОб.Записать();	
	ИначеЕсли СокрЛП(Выборка.ТорговийАгент.ІдентифікаторПристрою) <> СокрЛП(ИдентификаторКлиента) Тогда 
		//ЗаписьЖурналаРегистрации("НевернаяАвторизацияАндроид",УровеньЖурналаРегистрации.Предупреждение,Неопределено,ПарольВхода);
		//Ошибка = Ошибка + "Вже інший торговий працює під цим паролем! Очистіть в 1С ідентифікатор якщо це Ви.";		
	КонецЕсли;
	
	
	
	
	Если Не ЗначениеЗаполнено(Ошибка) Тогда 
		
		
		
		ПолнаяВыгрузка = ОбменАндроид.ПолнаяВыгрузка(ПарольВхода) ИЛИ НЕ ЭтоНеПервыйОбмен;
		Если НЕ ЭтоНеПервыйОбмен Тогда 
			ОбменАндроид.ВыключитьЧастичныйОбмен(ПарольВхода);
		КонецЕсли;
		
		
		Продавец = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
		СкладПартнера = ОбменАндроид.ПолучитьСкладПартнера(ПарольВхода);  
		Если ПолнаяВыгрузка Тогда    ////////////////////////////////////////////////// Ставим все на регистрацию и включаемо частичний обмен
			
			НЗ = РегистрыСведений.РегистрацияОбмена.СоздатьНаборЗаписей();
			НЗ.Отбор.Продавец.Установить(Продавец);
			НЗ.Записать();
			
			Если Не Продавец.НеВыгружатьРеализации Тогда 
				Запрос = Новый Запрос;
				Запрос.Текст = "ВЫБРАТЬ
				|	РеализацияТоваровУслуг.Ссылка
				|ИЗ
				|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
				|ГДЕ
				|	РеализацияТоваровУслуг.ТорговийАгент = &ТорговийАгент
				|	И РеализацияТоваровУслуг.Дата > &Дата3ДН";
				
				Запрос.УстановитьПараметр("ТорговийАгент",Продавец);
				Запрос.УстановитьПараметр("Дата3ДН",ТекущаяДата() - (1 * 24 * 60 * 60));
				
				Выборка = Запрос.Выполнить().Выбрать();
				Пока Выборка.Следующий() Цикл
					Запись = НЗ.Добавить();
					Запись.Продавец = Продавец;
					Запись.Объект = Выборка.Ссылка;
					Запись.ИД = Новый УникальныйИдентификатор;
				КонецЦикла;
			КонецЕсли;
			Запрос = Новый Запрос;
			
			
			
			Запрос.Текст = "ВЫБРАТЬ
			               |	НоменклатураТовар.Ссылка КАК Ссылка
			               |ИЗ
			               |	Справочник.Номенклатура КАК НоменклатураТовар
			               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ВыгружатьВАндроидПоСкладам КАК ВыгружатьВАндроидПоСкладам
			               |		ПО (НоменклатураТовар.Ссылка = ВыгружатьВАндроидПоСкладам.Номенклатура
			               |				ИЛИ НоменклатураТовар.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			               |				ИЛИ НоменклатураТовар.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			               |				ИЛИ НоменклатураТовар.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			               |				ИЛИ НоменклатураТовар.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура
			               |				ИЛИ НоменклатураТовар.Родитель.Родитель.Родитель.Родитель.Родитель = ВыгружатьВАндроидПоСкладам.Номенклатура)
			               |			И (ВыгружатьВАндроидПоСкладам.Выгружать)
			               |ГДЕ
			               |	НЕ НоменклатураТовар.ПометкаУдаления
			               |	И НЕ НоменклатураТовар.ЭтоГруппа
			               |	И (ВыгружатьВАндроидПоСкладам.ТорговийАгент = &Продавец
						   //|			ИЛИ &ПолныеПрава
						   |				И ВыгружатьВАндроидПоСкладам.ТорговийАгент <> ЗНАЧЕНИЕ(Справочник.ТорговыеАгенты.ПустаяСсылка)
			               |)
			               |СГРУППИРОВАТЬ ПО
			               |	НоменклатураТовар.Ссылка";
			
			
			
			
			Запрос.УстановитьПараметр("ПолныеПрава", Продавец.ПолныеПрава);
			Запрос.УстановитьПараметр("Продавец",Продавец);
			Запрос.УстановитьПараметр("Склад",СкладПартнера);
			Запрос.УстановитьПараметр("Дата",ТекущаяДата());
			Запрос.УстановитьПараметр("ДатаНач",ТекущаяДата() - (30 * 24 * 60 * 60));
			
			
			
			
			
			
			Выборка = Запрос.Выполнить().Выбрать();
			Пока Выборка.Следующий() Цикл
				Запись = НЗ.Добавить();
				Запись.Продавец = Продавец;
				Запись.Объект = Выборка.Ссылка;
				Запись.ИД = Новый УникальныйИдентификатор;
				Запись.ВыгружатьФайлы = Ложь;
			КонецЦикла;
			НЗ.Записать();
			
			//////////////////////////////////////////////// Контрагеты
			
			ЗапросКонтр = Новый Запрос;
			ЗапросКонтр.Текст = "ВЫБРАТЬ
			                    |	СкладыКонтрагентов.Ссылка КАК Контрагент
			                    |ИЗ
			                    |	Справочник.Контрагенты КАК СкладыКонтрагентов
			                    |ГДЕ
			                    |	СкладыКонтрагентов.Ссылка В ИЕРАРХИИ
			                    |			(ВЫБРАТЬ
			                    |				ВыгружатьВАндроидКонтрагентов.Контрагент
			                    |			ИЗ
			                    |				РегистрСведений.ВыгружатьВАндроидКонтрагентов КАК ВыгружатьВАндроидКонтрагентов
			                    |			ГДЕ
			                    |				ВыгружатьВАндроидКонтрагентов.ТорговийАгент = &ТорговийАгент
			                    |				И ВыгружатьВАндроидКонтрагентов.Выгружать)
			                    |	И НЕ СкладыКонтрагентов.ПометкаУдаления
			                    |
			                    |СГРУППИРОВАТЬ ПО
			                    |	СкладыКонтрагентов.Ссылка";
			ЗапросКонтр.УстановитьПараметр("ТорговийАгент", Продавец);
			ЗапросКонтр.УстановитьПараметр("ПолныеПрава", Продавец.ПолныеПрава);
			ВыборкаКонтр = ЗапросКонтр.Выполнить().Выбрать();
			Пока ВыборкаКонтр.Следующий() Цикл
				Запись = НЗ.Добавить();
				Запись.Продавец = Продавец;
				Запись.Объект = ВыборкаКонтр.Контрагент;
				Запись.ИД = Новый УникальныйИдентификатор;
				Запись.ВыгружатьФайлы = Ложь;
			КонецЦикла;
			НЗ.Записать();
			
			
			//ВключитьЧастичныйОбмен(ПарольВхода);
		КонецЕсли;
		
		//////////////////////// Подсчитываем пакеты 
		Если НЕ ЗначениеЗаполнено(Ошибка) Тогда 
			Запрос = Новый Запрос;
			
			Запрос.Текст = "ВЫБРАТЬ
			|	РегистрацияОбмена.ИД
			|ИЗ
			|	РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
			|ГДЕ
			|	РегистрацияОбмена.Продавец = &Продавец
			|
			|СГРУППИРОВАТЬ ПО
			|	РегистрацияОбмена.ИД";
			
			Запрос.УстановитьПараметр("Продавец",Продавец);
			
			ВсегоПакетов = Запрос.Выполнить().Выбрать().Количество();
			Ошибка = "*"+Формат(Цел(ВсегоПакетов)+ 1, "ЧГ=") ;
		КонецЕсли;
		
	КонецЕсли;
	
	
	
	Возврат Ошибка;
	
КонецФункции


Функция ПолучитьХешДанных(Данные)
	
	ИмяФайла = ПолучитьИмяВременногоФайла();
	
	ЗначениеВФайл(ИмяФайла, Данные);
	
	ХешированиеДанных = Новый ХешированиеДанных(ХешФункция.SHA1);
	ХешированиеДанных.ДобавитьФайл(ИмяФайла);
	Возврат Строка(ХешированиеДанных.ХешСумма);
	
КонецФункции
