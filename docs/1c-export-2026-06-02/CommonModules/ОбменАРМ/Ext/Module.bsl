Процедура ДобавитьСправочникНоменклатура(СтрукрутаСправочников, Настройка, ПолнаяВыгрузка, Продавец,КоличесвтоЗаписейДляОбмена,СкладПартнера)
	
	Запрос = Новый Запрос;
			
	Запрос.Текст = "ВЫБРАТЬ
	               |	РегистрацияОбмена.Объект,
	               |	РегистрацияОбмена.Продавец,
	               |	РегистрацияОбмена.ИД,
	               |	РегистрацияОбмена.ВыгружатьФайлы
	               |ПОМЕСТИТЬ РегистрацияОбменаПодготовка
	               |ИЗ
	               |	РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
	               |ГДЕ
	               |	РегистрацияОбмена.Продавец = &Продавец
	               |	И РегистрацияОбмена.Объект ССЫЛКА Справочник.Номенклатура
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ ПЕРВЫЕ 500
	               |	НоменклатураТовар.Ссылка КАК Ссылка,
	               |	НоменклатураТовар.Наименование,
	               |	НоменклатураТовар.ЭтоГруппа,
	               |	НоменклатураТовар.Родитель КАК Родитель,
	               |	РегистрацияОбменаПодготовка.ИД,
	               |	ИСТИНА КАК Просмотр,
	               |	ВЫБОР
	               |		КОГДА &НеВивантажуватиЗалишки
	               |			ТОГДА 0
	               |		ИНАЧЕ ТоварыНаСкладахОстатки.КоличествоОстаток
	               |	КОНЕЦ КАК Залишок,
	               |	ЕдиницыИзмерения.Коэффициент КАК ВБлоке,
	               |	ЕдиницыИзмерения.Наименование КАК ПредставлениеЕдиницыСокращенно,
	               |	НоменклатураТовар.Артикул,
	               |	НоменклатураТовар.ДополнительноеОписаниеНоменклатуры КАК ДополнительноеОписаниеНоменклатуры,
	               |	НоменклатураТовар.СсылкаНаYouTube КАК YouTube,
	               |	НоменклатураТовар.ПосиланняНаСайт,
	               |	НоменклатураТовар.ПосиланняНаНаявніЛоти КАК НаявніЛоти,
	               |	НоменклатураТовар.ДатаСозданияЭлемента,
	               |	НоменклатураТовар.ВідображатиВШтуках
	               |ИЗ
	               |	Справочник.Номенклатура КАК НоменклатураТовар
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрацияОбменаПодготовка КАК РегистрацияОбменаПодготовка
	               |		ПО НоменклатураТовар.Ссылка = РегистрацияОбменаПодготовка.Объект
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(, Склад = &Склад) КАК ТоварыНаСкладахОстатки
	               |		ПО НоменклатураТовар.Ссылка = ТоварыНаСкладахОстатки.Номенклатура
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	               |		ПО НоменклатураТовар.Ссылка = ЕдиницыИзмерения.Владелец";

		
	Запрос.УстановитьПараметр("НеВивантажуватиЗалишки",Продавец.НеВивантажуватиЗалишкиВАндроїд);				   
	Запрос.УстановитьПараметр("Продавец",Продавец);


	Запрос.УстановитьПараметр("Склад",СкладПартнера);
	Запрос.УстановитьПараметр("Дата",ТекущаяДата());
	 	
	ТзТовары = Запрос.Выполнить().Выгрузить();
	ТзНоменклатура = ТзТовары.Скопировать();
	ТзНоменклатура.Очистить();	
	
	
	ТЗРодителей = ПолучитьРодителейНоменклатуры(ТзТовары, Новый Массив);
	Пока ЗначениеЗаполнено(ТЗРодителей) Цикл	
		Для Каждого Строка Из ТЗРодителей Цикл
			Если ТзНоменклатура.Найти(Строка.Ссылка,"Ссылка") = Неопределено Тогда 
				НовСтрока = ТзНоменклатура.Вставить(0);
			КонецЕсли;
			ЗаполнитьЗначенияСвойств(НовСтрока,Строка);
		КонецЦикла;
		ТЗРодителей = ПолучитьРодителейНоменклатуры(ТЗРодителей,ТзНоменклатура.ВыгрузитьКолонку("Ссылка"));
	КонецЦикла;
	
	//ТзНоменклатура.Свернуть("Ссылка,Наименование,ЭтоГруппа,Родитель,ИД");
	
	Для Каждого Строка Из ТзТовары Цикл
		НовСтрока = ТзНоменклатура.Добавить();
		ЗаполнитьЗначенияСвойств(НовСтрока,Строка);
		КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + 1;
	КонецЦикла;
	
	ТзНоменклатура.Колонки.Добавить("УИДСсылка");
	ТзНоменклатура.Колонки.Добавить("УИДРодитель");
	ТзНоменклатура.Колонки.Добавить("Рекомендация");
	мас = Новый Массив;
	Для Каждого Строка Из ТзНоменклатура Цикл
		Если Не ЗначениеЗаполнено(Строка.Ссылка) Тогда 
			мас.Добавить(Строка);
			Продолжить;
		КонецЕсли;
		
		Строка.УИДСсылка = Строка.Ссылка.УникальныйИдентификатор();
		Строка.УИДРодитель = Строка.Родитель.УникальныйИдентификатор();

		Если НЕ Продавец.Рекомендации.найти(Строка.Ссылка) = Неопределено Тогда 
			Строка.Рекомендация = Истина;
		КонецЕсли;
		
	КонецЦикла;
	Для Каждого Стр Из мас Цикл
		ТзНоменклатура.Удалить(Стр);
	КонецЦикла;

	
	
	СтрукрутаСправочников.Вставить("Номенклатура", ТзНоменклатура);
	
	НомерСообщения = 0;
	
	
	
КонецПроцедуры	

Функция ПолучитьРодителейНоменклатуры(ТзНоменклатура,СписокГрупп)
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	|	Номенклатура.Родитель.Ссылка КАК Ссылка,
	|	Номенклатура.Родитель.Наименование КАК Наименование,
	|	Номенклатура.Родитель.ЭтоГруппа КАК ЭтоГруппа,
	|	Номенклатура.Родитель.Родитель КАК Родитель
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.Ссылка В(&СписокРодителей)
	|	И НЕ Номенклатура.Родитель.ПометкаУдаления
	|	И НЕ Номенклатура.Родитель.Ссылка В (&СписокГрупп)
	|
	|СГРУППИРОВАТЬ ПО
	|	Номенклатура.Родитель.Ссылка,
	|	Номенклатура.Родитель.Наименование,
	|	Номенклатура.Родитель.ЭтоГруппа,
	|	Номенклатура.Родитель.Родитель";
	
	Запрос.УстановитьПараметр("СписокРодителей",ТзНоменклатура.ВыгрузитьКолонку("Ссылка"));
	Запрос.УстановитьПараметр("СписокГрупп",СписокГрупп);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
КонецФункции

Процедура ДобавитьСправочникХарактеристики(СтрукрутаСправочников,СкладПартнера,Продавец)
	
	Запрос = Новый Запрос;
	
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Ссылка КАК Ссылка,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Владелец КАК Владелец,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Наименование КАК Наименование,
	               |	МАКСИМУМ(ВЫБОР
	               |			КОГДА &НеВивантажуватиЗалишки
	               |				ТОГДА 0
	               |			ИНАЧЕ ТоварыНаСкладахОстатки.КоличествоОстаток
	               |		КОНЕЦ) КАК Залишок,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Вага КАК Вага,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.СсылкаНаYouTube КАК СсылкаНаYouTube,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Описание КАК Описание,
	               |	ПРЕДСТАВЛЕНИЕ(ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Бронь) КАК Бронь,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.ПериодБрони КАК ПериодБрони,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Бронь = &Продавец КАК МояБронь,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Контрагент КАК Контрагент,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.ЕстьВидео КАК ЕстьВидео,
	               |	ТоварыНаСкладахОстатки.Период КАК ДатаПриход,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Коментар КАК Коментар,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.СекторНаСкладі КАК СекторНаСкладі,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Открыт КАК Открыт,
	               |	ВложенныйЗапрос.ДатаВідео
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ТоварыОстатки.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	               |		МАКСИМУМ(ТоварыОстатки.КоличествоОстаток) КАК КоличествоОстаток,
	               |		МАКСИМУМ(ПартииТоваровНаСкладах.Период) КАК Период
	               |	ИЗ
	               |		(ВЫБРАТЬ
	               |			Остатки.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
	               |			СУММА(Остатки.КоличествоОстаток) КАК КоличествоОстаток
	               |		ИЗ
	               |			РегистрНакопления.ТоварыНаСкладах.Остатки(
	               |					&ДатаКон,
	               |					Склад = &Склад
	               |						И Номенклатура В (&МассивТоваров)
	               |						И ХарактеристикаНоменклатуры.Владелец = Номенклатура) КАК Остатки
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			Остатки.ХарактеристикаНоменклатуры
	               |		
	               |		ОБЪЕДИНИТЬ ВСЕ
	               |		
	               |		ВЫБРАТЬ
	               |			ТоварыНаСкладахОбороты.ХарактеристикаНоменклатуры,
	               |			СУММА(0)
	               |		ИЗ
	               |			РегистрНакопления.ТоварыНаСкладах.Обороты(
	               |					&ДатаНач,
	               |					&ДатаКон,
	               |					Месяц,
	               |					Склад = &Склад
	               |						И Номенклатура В (&МассивТоваров)
	               |						И ХарактеристикаНоменклатуры.Владелец = Номенклатура) КАК ТоварыНаСкладахОбороты
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			ТоварыНаСкладахОбороты.ХарактеристикаНоменклатуры) КАК ТоварыОстатки
	               |			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ПартииТоваровНаСкладах КАК ПартииТоваровНаСкладах
	               |			ПО ТоварыОстатки.ХарактеристикаНоменклатуры = ПартииТоваровНаСкладах.ХарактеристикаНоменклатуры
	               |				И (ПартииТоваровНаСкладах.Регистратор ССЫЛКА Документ.ПоступлениеТоваровУслуг
	               |					ИЛИ ПартииТоваровНаСкладах.Регистратор ССЫЛКА Документ.Перепаковка)
	               |	
	               |	СГРУППИРОВАТЬ ПО
	               |		ТоварыОстатки.ХарактеристикаНоменклатуры) КАК ТоварыНаСкладахОстатки
	               |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |			ИзменениеСостоянияМешкаТовары.Номенклатура КАК Номенклатура,
	               |			МИНИМУМ(ИзменениеСостоянияМешкаТовары.Ссылка.Дата) КАК ДатаВідео,
	               |			ИзменениеСостоянияМешкаТовары.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры
	               |		ИЗ
	               |			Документ.ИзменениеСостоянияМешка.Товары КАК ИзменениеСостоянияМешкаТовары
	               |		ГДЕ
	               |			ИзменениеСостоянияМешкаТовары.ЕстьВидео
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			ИзменениеСостоянияМешкаТовары.Номенклатура,
	               |			ИзменениеСостоянияМешкаТовары.ХарактеристикаНоменклатуры) КАК ВложенныйЗапрос
	               |		ПО ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры = ВложенныйЗапрос.ХарактеристикаНоменклатуры
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Ссылка,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Владелец,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Наименование,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Вага,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.СсылкаНаYouTube,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Описание,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.ПериодБрони,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Бронь = &Продавец,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.ЕстьВидео,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Контрагент,
	               |	ТоварыНаСкладахОстатки.Период,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Коментар,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.СекторНаСкладі,
	               |	ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Открыт,
	               |	ВложенныйЗапрос.ДатаВідео,
	               |	ПРЕДСТАВЛЕНИЕ(ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры.Бронь)";
	
	
	Запрос.УстановитьПараметр("МассивТоваров", СтрукрутаСправочников.Номенклатура.ВыгрузитьКолонку("Ссылка"));
	Запрос.УстановитьПараметр("Склад", СкладПартнера);
	Запрос.УстановитьПараметр("НеВивантажуватиЗалишки",Продавец.НеВивантажуватиЗалишкиВАндроїд);
	Запрос.УстановитьПараметр("ДатаНач", ТекущаяДата()  - (20 * 24 * 60 * 60));
	Запрос.УстановитьПараметр("ДатаКон", ТекущаяДата());
	Запрос.УстановитьПараметр("Продавец", Продавец);

	ТзХарактеристикиНоменклатуры = Запрос.Выполнить().Выгрузить();
	
	ТзХарактеристикиНоменклатуры.Колонки.Добавить("УИДСсылка");
	ТзХарактеристикиНоменклатуры.Колонки.Добавить("УИДВладелец");
	ТзХарактеристикиНоменклатуры.Колонки.Добавить("УИДКонтрагент");

	мас = Новый Массив;
	Для Каждого Строка Из ТзХарактеристикиНоменклатуры Цикл
		Если Не ЗначениеЗаполнено(Строка.Ссылка) Тогда 
			мас.Добавить(Строка);
			Продолжить;
		КонецЕсли;
		
		Строка.УИДСсылка = Строка.Ссылка.УникальныйИдентификатор();
		Строка.УИДВладелец = Строка.Владелец.УникальныйИдентификатор();
		Строка.УИДКонтрагент = Строка.Контрагент.УникальныйИдентификатор();

	КонецЦикла;
	Для Каждого Стр Из мас Цикл
		ТзХарактеристикиНоменклатуры.Удалить(Стр);
	КонецЦикла;
	
	
	СтрукрутаСправочников.Вставить("ХарактеристикиНоменклатуры", ТзХарактеристикиНоменклатуры);
	
КонецПроцедуры

Процедура ДобавитьСправочникЕдиницыИзмерения(СтрукрутаСправочников)
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	КлассификаторЕдиницИзмерения.Наименование,
	               |	КлассификаторЕдиницИзмерения.Ссылка,
	               |	КлассификаторЕдиницИзмерения.МеждународноеСокращение
	               |ИЗ
	               |	Справочник.КлассификаторЕдиницИзмерения КАК КлассификаторЕдиницИзмерения
	               |ГДЕ
	               |	НЕ КлассификаторЕдиницИзмерения.ПометкаУдаления";
	
	
	ТзКлассификаторЕдиницИзмерения = Запрос.Выполнить().Выгрузить();
	ТзКлассификаторЕдиницИзмерения.Колонки.Добавить("УИДСсылка");
	Для Каждого Строка Из ТзКлассификаторЕдиницИзмерения Цикл
		Строка.УИДСсылка = Строка.Ссылка.УникальныйИдентификатор();
	КонецЦикла;
	
	СтрукрутаСправочников.Вставить("КлассификаторЕдиницИзмерения", ТзКлассификаторЕдиницИзмерения);
	//////////////////////////////
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЕдиницыИзмерения.ЕдиницаПоКлассификатору,
	               |	ЕдиницыИзмерения.Коэффициент,
	               |	ЕдиницыИзмерения.Владелец,
	               |	ЕдиницыИзмерения.Наименование,
	               |	ЕдиницыИзмерения.Ссылка
	               |ИЗ
	               |	Справочник.ЕдиницыИзмерения КАК ЕдиницыИзмерения
	               |ГДЕ
	               |	ЕдиницыИзмерения.Владелец В(&МассивТоваров)
	               |	И НЕ ЕдиницыИзмерения.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("МассивТоваров", СтрукрутаСправочников.Номенклатура.ВыгрузитьКолонку("Ссылка"));
	
	ТзЕдиницыИзмерения = Запрос.Выполнить().Выгрузить();
	
	ТзЕдиницыИзмерения.Колонки.Добавить("УИДСсылка");
	ТзЕдиницыИзмерения.Колонки.Добавить("УИДВладелец");
	ТзЕдиницыИзмерения.Колонки.Добавить("УИДЕдиницаПоКлассификатору");
	Для Каждого Строка Из ТзЕдиницыИзмерения Цикл
		Строка.УИДСсылка = Строка.Ссылка.УникальныйИдентификатор();
		Строка.УИДВладелец = Строка.Владелец.УникальныйИдентификатор();
		Строка.УИДЕдиницаПоКлассификатору = Строка.ЕдиницаПоКлассификатору.УникальныйИдентификатор();
	КонецЦикла;

	
	СтрукрутаСправочников.Вставить("ЕдиницыИзмерения", ТзЕдиницыИзмерения);
	
КонецПроцедуры

Процедура ДобавитьСправочникТипыЦен(СтрукрутаСправочников, ПарольВхода)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ТорговыеАгенты.Ссылка КАК Агент,
	               |	ТорговыеАгенты.ПолныеПрава
	               |ПОМЕСТИТЬ Агент
	               |ИЗ
	               |	Справочник.ТорговыеАгенты КАК ТорговыеАгенты
	               |ГДЕ
	               |	ТорговыеАгенты.ПарольДоступаАндроід = &ПарольДоступаАндроід
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ТЗ.ТипЦен КАК Ссылка,
	               |	ТЗ.ЭтоЦенаПартнера
	               |ИЗ
	               |	(ВЫБРАТЬ
	               |		ДоговорыКонтрагентов.ТипЦен КАК ТипЦен,
	               |		ЛОЖЬ КАК ЭтоЦенаПартнера
	               |	ИЗ
	               |		Справочник.Контрагенты КАК СкладыКонтрагентов
	               |			ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	               |			ПО СкладыКонтрагентов.Ссылка = ДоговорыКонтрагентов.Владелец
	               |				И (ДоговорыКонтрагентов.ВидДоговора = ЗНАЧЕНИЕ(Перечисление.ВидыДоговоровКонтрагентов.СПокупателем))
	               |				И (ДоговорыКонтрагентов.ВестиПоДокументамРасчетовСКонтрагентом)
	               |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Агент КАК Агенты
	               |			ПО (СкладыКонтрагентов.ТорговыйАгент = Агенты.Агент
	               |					ИЛИ Агенты.ПолныеПрава
	               |						И СкладыКонтрагентов.ТорговыйАгент <> ЗНАЧЕНИЕ(справочник.ТорговыеАгенты.ПустаяСсылка))
	               |	
	               |	СГРУППИРОВАТЬ ПО
	               |		ДоговорыКонтрагентов.ТипЦен
	               |	
	               |	ОБЪЕДИНИТЬ ВСЕ
	               |	
	               |	ВЫБРАТЬ
	               |		ВыгружатьВАндроидПоТипамЦен.ТипЦен,
	               |		ЛОЖЬ
	               |	ИЗ
	               |		РегистрСведений.ВыгружатьВАндроидПоТипамЦен КАК ВыгружатьВАндроидПоТипамЦен
	               |			ЛЕВОЕ СОЕДИНЕНИЕ Агент КАК Агенты
	               |			ПО ВыгружатьВАндроидПоТипамЦен.ТорговийАгент = Агенты.Агент
	               |	ГДЕ
	               |		ВыгружатьВАндроидПоТипамЦен.Выгружать
	               |		И ВыгружатьВАндроидПоТипамЦен.ТорговийАгент.ПарольДоступаАндроід = &ПарольДоступаАндроід) КАК ТЗ
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	ТЗ.ТипЦен,
	               |	ТЗ.ЭтоЦенаПартнера";
	Запрос.УстановитьПараметр("ТЗОВ", Справочники.Организации.НайтиПоКоду("000000001"));
