			СтруктураТовары.Вставить("ЕдиницаИзмерения", 			Выборка.ЕдиницаИзмерения.УникальныйИдентификатор());
			СтруктураТовары.Вставить("Количество", 					Выборка.Количество); 
			СтруктураТовары.Вставить("КоличествоЗагружено", 		Выборка.КоличествоЗагружено); 
			СтруктураТовары.Вставить("Цена", 						Выборка.Цена);		 
			СтруктураТовары.Вставить("Сумма", 						Выборка.Сумма);		 
			Товары.Добавить(СтруктураТовары);
			
		КонецЦикла;
		СтруктураДокумента.Вставить("Заказы", Заказы);		
		СтруктураДокумента.Вставить("Товары", Товары);
		МассивДокументов.Добавить(СтруктураДокумента);
	КонецЦикла;
	
	КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + МассивДокументов.Количество();
	
	Запрос 				= Новый Запрос;	
	Запрос.Текст = "ВЫБРАТЬ
	               |	МаршрутныйЛист.Ссылка КАК Ссылка,
	               |	РегистрацияОбмена.ИД КАК ИД,
	               |	ВЫРАЗИТЬ(МаршрутныйЛист.Комментарий КАК СТРОКА(254)) КАК Комментарий,
	               |	МаршрутныйЛист.СтатусДокумента,
	               |	МаршрутныйЛист.СуммаДокумента,
	               |	МаршрутныйЛист.Дата,
	               |	МаршрутныйЛист.ПометкаУдаления,
	               |	МаршрутныйЛистЗагрузкаМашины.ЗаказПокупателя КАК ЗаказПокупателяЗагрузка,
	               |	МаршрутныйЛистЗагрузкаМашины.Контрагент КАК КонтрагентЗагрузка,
	               |	МаршрутныйЛистЗагрузкаМашины.Номенклатура КАК НоменклатураЗагрузка,
	               |	МаршрутныйЛистЗагрузкаМашины.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатурыЗагрузка,
	               |	МаршрутныйЛистЗагрузкаМашины.ЕдиницаИзмерения КАК ЕдиницаИзмеренияЗагрузка,
	               |	МаршрутныйЛистЗагрузкаМашины.Количество КАК КоличествоЗагрузка,
	               |	МаршрутныйЛистЗагрузкаМашины.Вес,
	               |	МаршрутныйЛистЗагрузкаМашины.Цена КАК ЦенаЗагрузка,
	               |	МаршрутныйЛистЗагрузкаМашины.Сумма КАК СуммаЗагрузка,
	               |	МаршрутныйЛистЗагрузкаМашины.Загружен,
	               |	МаршрутныйЛистЗагрузкаМашины.Возврат,
	               |	МаршрутныйЛистЗагрузкаМашины.Штрихкод,
	               |	МаршрутныйЛистЗагрузкаМашины.ЦенаПродажиВес
	               |ИЗ
	               |	Документ.МаршрутныйЛист КАК МаршрутныйЛист
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
	               |		ПО МаршрутныйЛист.Ссылка = РегистрацияОбмена.Объект
	               |			И (РегистрацияОбмена.Продавец = &ТорговийАгент)
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.МаршрутныйЛист.ЗагрузкаМашины КАК МаршрутныйЛистЗагрузкаМашины
	               |		ПО (МаршрутныйЛистЗагрузкаМашины.Ссылка = МаршрутныйЛист.Ссылка)
	               |ИТОГИ
	               |	МАКСИМУМ(ИД)
	               |ПО
	               |	Ссылка";
	Запрос.УстановитьПараметр("ТорговийАгент", ПродавецПартнера);
	
	ВыборкаДокументи = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаДокументи.Следующий() Цикл 
		Если НЕ ЗначениеЗаполнено(ВыборкаДокументи.Ссылка) Тогда 
			Продолжить;
		КонецЕсли;
		СтруктураДокумента = Новый Структура();
		СтруктураДокумента.Вставить("ИД", 				ВыборкаДокументи.ИД);
		СтруктураДокумента.Вставить("Ссылка", 			ВыборкаДокументи.Ссылка.УникальныйИдентификатор());
		СтруктураДокумента.Вставить("Дата", 			ВыборкаДокументи.Дата);
		СтруктураДокумента.Вставить("СтатусДокумента", 	?(ВыборкаДокументи.СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Составляется, "Составляется", ?(ВыборкаДокументи.СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Отправлен, "Отправлен", ?(ВыборкаДокументи.СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Завершен, "Завершен", Неопределено))));
		СтруктураДокумента.Вставить("Комментарий", 		ВыборкаДокументи.Комментарий);
		СтруктураДокумента.Вставить("ПометкаУдаления",  ВыборкаДокументи.ПометкаУдаления);
		
		Загрузка 	= Новый Массив;
		Выборка 	= ВыборкаДокументи.Выбрать();
		Пока Выборка.Следующий() Цикл
			СтруктураЗагрузка = Новый Структура;
			СтруктураЗагрузка.Вставить("ЗаказПокупателя",				Выборка.ЗаказПокупателяЗагрузка.УникальныйИдентификатор());
			СтруктураЗагрузка.Вставить("Контрагент",					Выборка.КонтрагентЗагрузка.УникальныйИдентификатор());			
			СтруктураЗагрузка.Вставить("Номенклатура", 					Выборка.НоменклатураЗагрузка.УникальныйИдентификатор());
			СтруктураЗагрузка.Вставить("ХарактеристикаНоменклатуры", 	Выборка.ХарактеристикаНоменклатурыЗагрузка.УникальныйИдентификатор());
			СтруктураЗагрузка.Вставить("ЕдиницаИзмерения", 				Выборка.ЕдиницаИзмеренияЗагрузка.УникальныйИдентификатор());
			СтруктураЗагрузка.Вставить("Количество", 					Выборка.КоличествоЗагрузка); 
			СтруктураЗагрузка.Вставить("Вес", 							Выборка.Вес);		 
			СтруктураЗагрузка.Вставить("Цена", 							Выборка.ЦенаЗагрузка);		 
			СтруктураЗагрузка.Вставить("Сумма", 						Выборка.СуммаЗагрузка);		 
			СтруктураЗагрузка.Вставить("Штрихкод", 						Выборка.Штрихкод);		 
			СтруктураЗагрузка.Вставить("ЦенаПродажиВес", 				Выборка.ЦенаПродажиВес);		 			
			Загрузка.Добавить(СтруктураЗагрузка);			
		КонецЦикла;
		Для Каждого ЭлементМассива Из МассивДокументов Цикл 
			Если ЭлементМассива.Ссылка = СтруктураДокумента.Ссылка Тогда 
				ЭлементМассива.Вставить("Загрузка", Загрузка);
			КонецЕсли;	
		КонецЦикла;
	КонецЦикла;	
	
	Для Каждого ЭлементМассива Из МассивДокументов Цикл 
		Если НЕ ЭлементМассива.Свойство("Загрузка") Тогда 
			ЭлементМассива.Вставить("Загрузка", Новый Массив);
		КонецЕсли;	
	КонецЦикла;	
	
	
	Для Каждого Элемент Из МассивДокументов Цикл
		
		Элемент.Вставить("НеХватает", ПолучитьТаблицуНеХватаетМаршрутныйЛист(Элемент.Ссылка));

	КонецЦикла;
	

	
	КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + МассивДокументов.Количество();
	СтруктураДокументы.Вставить("МаршрутныйЛист", МассивДокументов);
	
КонецПроцедуры
 
Функция ПолучитьТаблицуНеХватаетМаршрутныйЛист(МаршрутныйЛист)
	
	ТЗ_НеХватает = Новый ТаблицаЗначений;
	
	ТЗ_НеХватает.Колонки.Добавить("Ссылка");
	ТЗ_НеХватает.Колонки.Добавить("Заказ");
	ТЗ_НеХватает.Колонки.Добавить("Номенклатура");
	ТЗ_НеХватает.Колонки.Добавить("НеХватает");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	МаршрутныйЛистТоварыЗаказов.Ссылка,
	|	МаршрутныйЛистТоварыЗаказов.Номенклатура КАК Номенклатура,
	|	МаршрутныйЛистТоварыЗаказов.ЗаказПокупателя,
	|	МаршрутныйЛистТоварыЗаказов.КоличествоЗагружено,
	|	МаршрутныйЛистТоварыЗаказов.Количество,
	|	ВЫБОР
	|		КОГДА МаршрутныйЛистТоварыЗаказов.КоличествоФакт = 0
	|			ТОГДА МаршрутныйЛистТоварыЗаказов.Количество
	|		ИНАЧЕ МаршрутныйЛистТоварыЗаказов.КоличествоФакт
	|	КОНЕЦ - МаршрутныйЛистТоварыЗаказов.КоличествоЗагружено КАК мКоличество,
	|	МаршрутныйЛистЗаказы.НомерСтроки КАК НомерСтроки,
	|	0 КАК КоличествоОстаток
	|ИЗ
	|	Документ.МаршрутныйЛист.ТоварыЗаказов КАК МаршрутныйЛистТоварыЗаказов
	|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаршрутныйЛист.Заказы КАК МаршрутныйЛистЗаказы
	|		ПО МаршрутныйЛистТоварыЗаказов.Ссылка = МаршрутныйЛистЗаказы.Ссылка
	|			И МаршрутныйЛистТоварыЗаказов.ЗаказПокупателя = МаршрутныйЛистЗаказы.ЗаказПокупателя
	|ГДЕ
	|	МаршрутныйЛистТоварыЗаказов.Ссылка = &Ссылка
	|
	|УПОРЯДОЧИТЬ ПО
	|	НомерСтроки
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МаршрутныйЛистТоварыЗаказов.Номенклатура,
	|	ЕСТЬNULL(ТоварыНаСкладахОстатки.КоличествоОстаток, 0) КАК КоличествоОстаток
	|ИЗ
	|	Документ.МаршрутныйЛист.ТоварыЗаказов КАК МаршрутныйЛистТоварыЗаказов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах.Остатки(&Период, Склад = &Склад) КАК ТоварыНаСкладахОстатки
	|		ПО МаршрутныйЛистТоварыЗаказов.Ссылка.Склад = ТоварыНаСкладахОстатки.Склад
	|			И МаршрутныйЛистТоварыЗаказов.Номенклатура = ТоварыНаСкладахОстатки.Номенклатура
	|ГДЕ
	|	МаршрутныйЛистТоварыЗаказов.Ссылка = &Ссылка
	|
	|СГРУППИРОВАТЬ ПО
	|	МаршрутныйЛистТоварыЗаказов.Номенклатура,
	|	ЕСТЬNULL(ТоварыНаСкладахОстатки.КоличествоОстаток, 0)";
	
	Ссылка = Документы.МаршрутныйЛист.ПолучитьСсылку(МаршрутныйЛист);
	Если НЕ ЗначениеЗаполнено(Ссылка.ВерсияДанных) Тогда 
		Возврат ТЗ_НеХватает;
	КонецЕсли;
	
	Параметры = Новый Массив(2);
	Параметры[0] = Ссылка.МоментВремени();
	Параметры[1] = ВидГраницы.Исключая;
	ПериодОстатков = Новый(Тип("Граница"), Параметры);	
	
	Запрос.УстановитьПараметр("Период", ПериодОстатков);
	Запрос.УстановитьПараметр("Склад", Ссылка.Склад);
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	
	Результат = Запрос.ВыполнитьПакет();
	Остатки = Результат.Получить(1).Выгрузить();
	Выборка = Результат.Получить(0).Выгрузить();
	
	Для Каждого СтрТоварыЗаказов  Из Выборка Цикл
		
		СтрОстатков = Остатки.Найти(СтрТоварыЗаказов.Номенклатура, "Номенклатура");
		
		Если СтрОстатков <> Неопределено Тогда 
			СтрТоварыЗаказов.КоличествоОстаток 	= СтрОстатков.КоличествоОстаток - СтрТоварыЗаказов.КоличествоЗагружено;
			СтрОстатков.КоличествоОстаток 		= СтрОстатков.КоличествоОстаток - СтрТоварыЗаказов.КоличествоЗагружено;
		КонецЕсли;	
	КонецЦикла;
	
	
	Для Каждого СтрТоварыЗаказов Из Выборка Цикл 
		Если (СтрТоварыЗаказов.Количество - СтрТоварыЗаказов.КоличествоЗагружено)  > СтрТоварыЗаказов.КоличествоОстаток Тогда 
			//мНеХватает = НеХватает + 
			СтрНеХватает = ТЗ_НеХватает.Добавить();
			СтрНеХватает.Номенклатура = СтрТоварыЗаказов.Номенклатура.УникальныйИдентификатор();
			СтрНеХватает.Заказ = СтрТоварыЗаказов.ЗаказПокупателя.УникальныйИдентификатор();
			СтрНеХватает.НеХватает = (СтрТоварыЗаказов.мКоличество - СтрТоварыЗаказов.КоличествоОстаток);
			
		КонецЕсли;
	КонецЦикла;	
	
	Возврат ТЗ_НеХватает;
	
КонецФункции


#КонецОбласти

#Область ЗАПОЛНЕНИЕ_РЕГИСТРОВ

Функция ДобавитьРегистрыСведений(Настройка,Справочники,Склад,КоличесвтоЗаписейДляОбмена,ПродавецПартнера,ПолнаяВыгрузка)
	
	СтруктураРегистрыСведений = Новый Структура;
	ДобавитьРегистрШтрихкоды(СтруктураРегистрыСведений,Справочники,КоличесвтоЗаписейДляОбмена);
	ДобавитьРегистрЦеныНоменклатуры(СтруктураРегистрыСведений,Справочники,КоличесвтоЗаписейДляОбмена);
	ДобавитьРегистрКатегорииОбъектов(СтруктураРегистрыСведений, Справочники, КоличесвтоЗаписейДляОбмена); //intrata_wald_08092021
	ДобавитьРегистрИсторияРаботыСКлиентом(СтруктураРегистрыСведений, Справочники, КоличесвтоЗаписейДляОбмена,ПродавецПартнера); 
	
	Возврат СтруктураРегистрыСведений;
	
КонецФункции

Функция ДобавитьРегистрыНакопления(Настройка,КоличесвтоЗаписейДляОбмена)
	
	СтруктураРегистрыНакопления = Новый Структура;
	
	Возврат СтруктураРегистрыНакопления;
	
КонецФункции

Процедура ДобавитьРегистрШтрихкоды(СтруктураРегистрыСведений, СтрукрутаСправочников, КоличесвтоЗаписейДляОбмена)
	
	Если НЕ СтрукрутаСправочников.Номенклатура.Количество() Тогда 
		СтруктураРегистрыСведений.Вставить("Штрихкоды", Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;
	
	
	Запрос = Новый Запрос;	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ПРЕДСТАВЛЕНИЕ(Штрихкоды.Штрихкод) КАК Штрихкод,
	               |	Штрихкоды.Владелец,
	               |	Штрихкоды.ЕдиницаИзмерения,
	               |	Штрихкоды.ХарактеристикаНоменклатуры
	               |ИЗ
	               |	РегистрСведений.Штрихкоды КАК Штрихкоды
	               |ГДЕ
	               |	Штрихкоды.Владелец В(&МассивТоваров)";
	
	Запрос.УстановитьПараметр("МассивТоваров", СтрукрутаСправочников.Номенклатура.ВыгрузитьКолонку("Ссылка"));
	
	ТзШтрихкоды = Запрос.Выполнить().Выгрузить();
	КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + ТзШтрихкоды.Количество();	
	
	ТзШтрихкоды.Колонки.Добавить("УИДВладелец");
	ТзШтрихкоды.Колонки.Добавить("УИДЕдиницаИзмерения");
	ТзШтрихкоды.Колонки.Добавить("УИДХарактеристикаНоменклатуры");
	Для Каждого Строка Из ТзШтрихкоды Цикл
		Строка.УИДВладелец = Строка.Владелец.УникальныйИдентификатор();
		Строка.УИДЕдиницаИзмерения = Строка.ЕдиницаИзмерения.УникальныйИдентификатор();
		Строка.УИДХарактеристикаНоменклатуры = Строка.ХарактеристикаНоменклатуры.УникальныйИдентификатор();
	КонецЦикла;
	
	СтруктураРегистрыСведений.Вставить("Штрихкоды", ТзШтрихкоды);
	
КонецПроцедуры

Процедура ДобавитьРегистрКатегорииОбъектов(СтруктураРегистрыСведений,Справочники,КоличесвтоЗаписейДляОбмена) //intrata_wald_08092021
	
	Если НЕ Справочники.Номенклатура.Количество() Тогда 
		СтруктураРегистрыСведений.Вставить("КатегорииОбъектов", Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;	
	Запрос.Текст = "ВЫБРАТЬ
	               |	КатегорииОбъектов.Объект,
	               |	КатегорииОбъектов.Категория
	               |ИЗ
	               |	РегистрСведений.КатегорииОбъектов КАК КатегорииОбъектов
	               |ГДЕ
	               |	КатегорииОбъектов.Объект В(&МассивТоваров)";
	
	Запрос.УстановитьПараметр("МассивТоваров", Справочники.Номенклатура.ВыгрузитьКолонку("Ссылка"));
	
	ТзКатегорииОбъектов = Запрос.Выполнить().Выгрузить();
	КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + ТзКатегорииОбъектов.Количество();	
	
	ТзКатегорииОбъектов.Колонки.Добавить("УИДОбъект");
	ТзКатегорииОбъектов.Колонки.Добавить("УИДКатегория");
	Для Каждого Строка Из ТзКатегорииОбъектов Цикл
		Строка.УИДОбъект = Строка.Объект.УникальныйИдентификатор();
		Строка.УИДКатегория = Строка.Категория.УникальныйИдентификатор();
	КонецЦикла;
	
	СтруктураРегистрыСведений.Вставить("КатегорииОбъектов", ТзКатегорииОбъектов);
	
КонецПроцедуры


Процедура ДобавитьРегистрИсторияРаботыСКлиентом(СтруктураРегистрыСведений,Справочники,КоличесвтоЗаписейДляОбмена, ТорговыйАгент) 
	
	Если НЕ Справочники.Контрагенты.Количество() Тогда 
		СтруктураРегистрыСведений.Вставить("ИсторияРаботыСКлиентом", Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ИсторияРаботыСКлиентом.Период,
	               |	ИсторияРаботыСКлиентом.Клиент,
	               |	ИсторияРаботыСКлиентом.Запись,
	               |	ИсторияРаботыСКлиентом.УИД_Записи,
	               |	ИсторияРаботыСКлиентом.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом
	               |ИЗ
	               |	РегистрСведений.ИсторияРаботыСКлиентом КАК ИсторияРаботыСКлиентом
	               |ГДЕ
	               |	ИсторияРаботыСКлиентом.Клиент.ТорговыйАгент = &ТорговыйАгент
				   |	И ИсторияРаботыСКлиентом.Клиент В (&Контрагенты)";
	
	Запрос.УстановитьПараметр("ТорговыйАгент", ТорговыйАгент);
	Запрос.УстановитьПараметр("Контрагенты", Справочники.Контрагенты.ВыгрузитьКолонку("Контрагент"));
	
	ТзИстории = Запрос.Выполнить().Выгрузить();
	КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + ТзИстории.Количество();	
	
	ТзИстории.Колонки.Добавить("УИДКлиент");
	Для Каждого Строка Из ТзИстории Цикл
		Строка.УИДКлиент = Строка.Клиент.УникальныйИдентификатор();
	КонецЦикла;
	
	СтруктураРегистрыСведений.Вставить("ИсторияРаботыСКлиентом", ТзИстории);
	
КонецПроцедуры


Процедура ДобавитьРегистрЦеныНоменклатуры(СтруктураРегистрыСведений,МасСправочники,КоличесвтоЗаписейДляОбмена)
	Если НЕ МасСправочники.Номенклатура.Количество() Тогда 
		СтруктураРегистрыСведений.Вставить("ЦеныНоменклатуры",  Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЦеныНоменклатурыСрезПоследних.Цена,
	               |	ЦеныНоменклатурыСрезПоследних.ЕдиницаИзмерения,
	               |	ЦеныНоменклатурыСрезПоследних.ХарактеристикаНоменклатуры,
	               |	ЦеныНоменклатурыСрезПоследних.Номенклатура,
	               |	ЦеныНоменклатурыСрезПоследних.ТипЦен
	               |ИЗ
	               |	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	               |			,
	               |			Номенклатура В (&МассивТоваров)
	               |				И ХарактеристикаНоменклатуры В (&МассивХарактеристик)
	               |				И ТипЦен В (&МассивТиповЦен)) КАК ЦеныНоменклатурыСрезПоследних";
	
	МассивХарактеристик = МасСправочники.ХарактеристикиНоменклатуры.ВыгрузитьКолонку("Ссылка");
	МассивХарактеристик.Добавить(Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	
	Запрос.УстановитьПараметр("МассивТоваров", МасСправочники.Номенклатура.ВыгрузитьКолонку("Ссылка"));
	Запрос.УстановитьПараметр("МассивХарактеристик", МассивХарактеристик);
	Запрос.УстановитьПараметр("МассивТиповЦен", МасСправочники.ТипыЦенНоменклатуры.ВыгрузитьКолонку("Ссылка"));
	
	ТзЦенНоменклатуры = Запрос.Выполнить().Выгрузить();
	
	ОбзорЦен = ТзЦенНоменклатуры.Скопировать();
	Для Каждого Строка Из МассивХарактеристик Цикл
		Если ОбзорЦен.Найти(Строка) = Неопределено Тогда 
			ТекНоменклатура = ОбзорЦен.Найти(Строка.Владелец);
			Если ТекНоменклатура <> Неопределено Тогда
				НовСтр = ТзЦенНоменклатуры.Добавить();
				ЗаполнитьЗначенияСвойств(НовСтр,ТекНоменклатура);
				НовСтр.ХарактеристикаНоменклатуры = Строка;
			КонецЕсли;
			
		КонецЕсли; 
	КонецЦикла;
	
	КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + ТзЦенНоменклатуры.Количество();	
	
	ТзЦенНоменклатуры.Колонки.Добавить("УИДНоменклатура");
	ТзЦенНоменклатуры.Колонки.Добавить("УИДТипЦен");
	ТзЦенНоменклатуры.Колонки.Добавить("УИДЕдиницаИзмерения");
	ТзЦенНоменклатуры.Колонки.Добавить("УИДХарактеристикаНоменклатуры");
	Для Каждого Строка Из ТзЦенНоменклатуры Цикл
		Строка.УИДНоменклатура = Строка.Номенклатура.УникальныйИдентификатор();
		Строка.УИДТипЦен = Строка.ТипЦен.УникальныйИдентификатор();
		Строка.УИДЕдиницаИзмерения = Строка.ЕдиницаИзмерения.УникальныйИдентификатор();
		Строка.УИДХарактеристикаНоменклатуры = Строка.ХарактеристикаНоменклатуры.УникальныйИдентификатор();
	КонецЦикла;
	
	СтруктураРегистрыСведений.Вставить("ЦеныНоменклатуры", ТзЦенНоменклатуры);
	
КонецПроцедуры

Процедура ДобавитьРегистрНормыЗапасов(СтруктураРегистрыСведений,МасСправочники,Склад,КоличесвтоЗаписейДляОбмена)
	Если НЕ МасСправочники.Номенклатура.Количество() Тогда 
		СтруктураРегистрыСведений.Вставить("НормыЗапасов",  Новый ТаблицаЗначений);
		Возврат;
	КонецЕсли;

	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	НормыЗапасов.ЕдиницаИзмерения,
	               |	НормыЗапасов.ХарактеристикаНоменклатуры,
	               |	НормыЗапасов.Номенклатура,
	               |	НормыЗапасов.Количество,
	               |	НормыЗапасов.Дата
	               |ИЗ
	               |	РегистрСведений.НормыЗапасов КАК НормыЗапасов
	               |ГДЕ
	               |	НормыЗапасов.Номенклатура В(&МассивТоваров)
	               |	И НормыЗапасов.ХарактеристикаНоменклатуры В(&МассивХарактеристик)
	               |	И НормыЗапасов.Склад = &Склад";
	
	МассивХарактеристик = МасСправочники.ХарактеристикиНоменклатуры.ВыгрузитьКолонку("Ссылка");
	МассивХарактеристик.Добавить(Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка());
	
	Запрос.УстановитьПараметр("МассивТоваров", МасСправочники.Номенклатура.ВыгрузитьКолонку("Ссылка"));
	Запрос.УстановитьПараметр("МассивХарактеристик", МассивХарактеристик);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	ТзНормЗапасов = Запрос.Выполнить().Выгрузить();
	КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + ТзНормЗапасов.Количество();	
	СтруктураРегистрыСведений.Вставить("НормыЗапасов", ТзНормЗапасов);
	
КонецПроцедуры

Процедура ДобавитьОтгруженныеЗаказы(СтруктураРегистрыСведений,ПродавецПартнера,КоличесвтоЗаписейДляОбмена)
	
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаказПокупателяДок.Ссылка
	               |ИЗ
	               |	Документ.ЗаказПокупателя КАК ЗаказПокупателяДок
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ЗаказыПокупателей.Остатки КАК ЗаказыПокупателейОстатки
	               |		ПО ЗаказыПокупателейОстатки.ЗаказПокупателя = ЗаказПокупателяДок.Ссылка
	               |			И ЗаказыПокупателейОстатки.СуммаУпрОстаток <> ЗаказПокупателяДок.СуммаДокумента
	               |ГДЕ
	               |	ЗаказПокупателяДок.ТорговийАгент = &ТорговийАгент
	               |	И ЗаказПокупателяДок.Дата > &ДатаНач";
	
	Запрос.УстановитьПараметр("ТорговийАгент", ПродавецПартнера);
	Запрос.УстановитьПараметр("ДатаНач", ТекущаяДата() - 345600);
	ТЗДок = Запрос.Выполнить().Выгрузить();
//	ТзШтрихкоды = Запрос.Выполнить().Выгрузить();
КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + ТЗДок.Количество();	

	ТЗДок.Колонки.Добавить("УИДСсылка");
//	ТзШтрихкоды.Колонки.Добавить("УИДЕдиницаИзмерения");
//	ТзШтрихкоды.Колонки.Добавить("УИДХарактеристикаНоменклатуры");
	Для Каждого Строка Из ТЗДок Цикл
		Строка.УИДСсылка = Строка.Ссылка.УникальныйИдентификатор();
	КонецЦикла;

	СтруктураРегистрыСведений.Вставить("ОтгруженныеЗаказы", ТЗДок);
	

КонецПроцедуры

Функция  ЗаписатиКурсВалют(ПарольВхода, Данные) Экспорт
	Ответ = Новый Структура("Результат, Ошибка");
	ТорговийАгент = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
	Если ТорговийАгент = Неопределено Или Не ТорговийАгент.ПравоМінятиКурсиВалют Тогда 
		Ответ.Вставить("Результат", Ложь);
		Ответ.Вставить("Ошибка", "Не має прав доступу!");
		Перейти ~Возврат; 
	КонецЕсли;

	СтруктураДанных = Десериализовать(Данные);

	Запись = РегистрыСведений.КурсыВалют.СоздатьМенеджерЗаписи();
	Запись.Валюта = Справочники.Валюты.НайтиПоКоду("978");
	Запись.Курс = СтруктураДанных.В978;
	Запись.Кратность = 1;
	Запись.Период = ТекущаяДата();
	Запись.Записать(Истина);
	
	Запись = РегистрыСведений.КурсыВалют.СоздатьМенеджерЗаписи();
	Запись.Валюта = Справочники.Валюты.НайтиПоКоду("840");
	Запись.Курс = СтруктураДанных.В840;
	Запись.Кратность = 1;
	Запись.Период = ТекущаяДата();
	Запись.Записать(Истина);
	
	Ответ.Вставить("Результат", Истина);
	~Возврат:
	Возврат Сериализовать(Ответ);
	
