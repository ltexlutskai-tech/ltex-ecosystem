		|	ЗаказПокупателя.СуммаДокумента,
		|	ЗаказПокупателя.Дата,
		|	ЗаказПокупателяТовары.Номенклатура,
		|	ЗаказПокупателяТовары.ХарактеристикаНоменклатуры,
		|	ЗаказПокупателяТовары.Количество,
		|	ЗаказПокупателяТовары.Цена,
		|	ЗаказПокупателяТовары.Сумма,
		|	ЗаказПокупателяТовары.ЦенаПродажиВес,
		|	ЗаказПокупателяТовары.ЕдиницаИзмерения,
		|	ЕСТЬNULL(ЗаказПокупателя.СтатусДоставки.Код, """") КАК Доставка,
		|	ЗаказПокупателя.ПометкаУдаления,
		//+wald_intrata_19112021
		|	ЗаказПокупателя.Наложка КАК Наложка
		//-wald_intrata_19112021
		|ИЗ
		|	Документ.ЗаказПокупателя.Товары КАК ЗаказПокупателяТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
		|			ПО ЗаказПокупателя.Ссылка = РегистрацияОбмена.Объект
		|				И (РегистрацияОбмена.Продавец = &Продавец)
		|		ПО ЗаказПокупателяТовары.Ссылка = ЗаказПокупателя.Ссылка
		|ИТОГИ
		|	МАКСИМУМ(ИД)
		|ПО
		|	Ссылка";
	
	Запрос.УстановитьПараметр("Продавец", Продавец);
	ВыборкаДокументи = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	//Если ВыборкаДокументи.Количество() > 1 Тогда 
	//	ВыборкаДокументи.Количество(); 
	//КонецЕсли;	
	Пока ВыборкаДокументи.Следующий() Цикл 
		Если НЕ ЗначениеЗаполнено(ВыборкаДокументи.Ссылка) Тогда 
			Продолжить;
		КонецЕсли;
				
				
		СтруктураДокумента = Новый Структура();
		СтруктураДокумента.Вставить("ИД", 				ВыборкаДокументи.ИД);
		СтруктураДокумента.Вставить("Ссылка", 			ВыборкаДокументи.Ссылка.УникальныйИдентификатор());
		СтруктураДокумента.Вставить("Комментарий", 		ВыборкаДокументи.Комментарий);
		СтруктураДокумента.Вставить("Контрагент", 		ВыборкаДокументи.Контрагент.УникальныйИдентификатор());
		СтруктураДокумента.Вставить("ТипЦен", 			ВыборкаДокументи.ТипЦен.УникальныйИдентификатор());
		СтруктураДокумента.Вставить("СуммаДокумента", 	ВыборкаДокументи.СуммаДокумента);
		СтруктураДокумента.Вставить("Дата", 			ВыборкаДокументи.Дата);
		СтруктураДокумента.Вставить("Доставка", 		ВыборкаДокументи.Доставка);
		СтруктураДокумента.Вставить("ПометкаУдаления",  ВыборкаДокументи.ПометкаУдаления);
		СтруктураДокумента.Вставить("Наложка",  		ВыборкаДокументи.Наложка); //+wald_intrata_19112021
 
		Товары = Новый Массив;
		
		Выборка = ВыборкаДокументи.Выбрать();
		
		Пока Выборка.Следующий() Цикл
			
			СтруктураТовары = Новый Структура;
			
			СтруктураТовары.Вставить("Номенклатура", 				Выборка.Номенклатура.УникальныйИдентификатор());
			СтруктураТовары.Вставить("ХарактеристикаНоменклатуры", 	Выборка.ХарактеристикаНоменклатуры.УникальныйИдентификатор());
			СтруктураТовары.Вставить("ЕдиницаИзмерения", 			Выборка.ЕдиницаИзмерения.УникальныйИдентификатор());
			СтруктураТовары.Вставить("Количество", 					Выборка.Количество); 
			СтруктураТовары.Вставить("Цена", 						Выборка.Цена);		 
			СтруктураТовары.Вставить("Сумма", 						Выборка.Сумма);		 
			СтруктураТовары.Вставить("ЦенаПродажиВес", 				Выборка.ЦенаПродажиВес);
			
			Товары.Добавить(СтруктураТовары);
			
		КонецЦикла;
		
		СтруктураДокумента.Вставить("Товары", Товары);
		МассивДокументов.Добавить(СтруктураДокумента);
	КонецЦикла;
	
	КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + МассивДокументов.Количество();
	СтруктураДокументы.Вставить("Заказы", МассивДокументов);
	
КонецПроцедуры

Процедура ДобавитьМаршрутныйЛист(СтруктураДокументы, ПродавецПартнера, КоличесвтоЗаписейДляОбмена)
	
	МассивДокументов 	= Новый Массив;
	Запрос 				= Новый Запрос;
