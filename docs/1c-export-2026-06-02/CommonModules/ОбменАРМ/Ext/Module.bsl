Процедура ЗаписьНовыхСообщений(Продавец, Данные, Дата, МассивИД) Экспорт 
	
	Организация = Справочники.Организации.НайтиПоКоду("000000001");
	мДанные = Десериализовать(Данные);
	Дата = мДанные.Дата;
	
	Для Каждого НовоеСообщение Из мДанные.Сообщения Цикл 
		
		Набор = РегистрыСведений.Чат1С.СоздатьНаборЗаписей();
		Набор.Отбор.Уид_Сообщения.Установить(НовоеСообщение.Уид_Сообщения);
		Набор.Прочитать();
		Если  Набор.Количество() Тогда 
			Продолжить;
		КонецЕсли;
		
		МенеджерЗаписи 					= Набор.Добавить();	
		МенеджерЗаписи.Уид_Сообщения 	= НовоеСообщение.Уид_Сообщения;
		МенеджерЗаписи.Організація 		= Организация;
		МенеджерЗаписи.Відправник  		= Продавец.Користувач;
		
		Если НовоеСообщение.ПолучательГруппа Тогда 
			МенеджерЗаписи.Одержувач  = Справочники.ГруппыЧата.ПолучитьСсылку(НовоеСообщение.УИД_Получатель);
		Иначе
			МенеджерЗаписи.Одержувач   = Справочники.Пользователи.ПолучитьСсылку(НовоеСообщение.УИД_Получатель);
		КонецЕсли;
		
		МенеджерЗаписи.Повідомлення 	= НовоеСообщение.Повідомлення;
		МенеджерЗаписи.Период       	= НовоеСообщение.Дата; 	
		МенеджерЗаписи.ДатаНаСервере 	= ТекущаяДата();
		Набор.Записать();
		
		Если НовоеСообщение.ПолучательГруппа Тогда 
			мПолучатели = МенеджерЗаписи.Одержувач.Учасники.ВыгрузитьКолонку("Пользователь");
			Відправник = МенеджерЗаписи.Одержувач;
		Иначе
			мПолучатели = Новый Массив;
			мПолучатели.Добавить( МенеджерЗаписи.Одержувач);
			Відправник =  МенеджерЗаписи.Відправник;
		КонецЕсли;
		
		Для Каждого ТекПользовательДляОтправки Из мПолучатели Цикл
			
			Если ТекПользовательДляОтправки = МенеджерЗаписи.Відправник Тогда
				Продолжить;
			КонецЕсли;	
			
			если ТекПользовательДляОтправки <> Справочники.Пользователи.ПустаяСсылка() тогда
				РегНепрочитані = РегистрыСведений.НепрочитаніПовідомлення.СоздатьМенеджерЗаписи();			
				РегНепрочитані.Одержувач = ТекПользовательДляОтправки;
				РегНепрочитані.Відправник =  Відправник;
				РегНепрочитані.ГруппаЧата  = Відправник;
				РегНепрочитані.Кол = 1;
				РегНепрочитані.Период = ТекущаяДата();
				РегНепрочитані.Записать(); 		
			КонецЕсли;
			
		КонецЦикла;	
	КонецЦикла;

	ЗаписатьНепрочитаныеСообщения(мДанные.Прочытаные, Продавец.Користувач);
	ЗаписатьУдаленныеСообщения(мДанные.Удаленные);
	ЗаписатьРеакциюСообщения(мДанные.Реакции);
	
	ЗаписатьИсториюРаботыСКлиентом(мДанные.РаботаСКлиентом, Продавец);
	
	ОновитьСинхронизациюУведомлений(мДанные.Уведомления, МассивИД);
	
	СоздатьНапоминания(мДанные.СправочникУведомления, Продавец, МассивИД);
	
КонецПроцедуры



Процедура ЗаписатьНепрочитаныеСообщения(Прочитано, Користувач)
	
	Если Не Прочитано.Количество() Тогда 
		Возврат
	КонецЕсли;
	
	ТипКолонки = Новый Массив;
	ТипКолонки.Добавить(Тип("СправочникСсылка.ГруппыЧата"));
	ТипКолонки.Добавить(Тип("СправочникСсылка.Пользователи"));
	
	Прочитано.Колонки.Добавить("Відправник", Новый ОписаниеТипов(ТипКолонки));

	Для Каждого Элемент Из Прочитано Цикл 
		УИД = Новый УникальныйИдентификатор(Элемент.УИД_Отправитель);
		Элемент.Відправник = ?(Элемент.ГруппаЧата
									, Справочники.ГруппыЧата.ПолучитьСсылку(УИД)
									, Справочники.Пользователи.ПолучитьСсылку(УИД));
			
	КонецЦикла;
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВТ.Відправник,
	|	ВТ.Период
	|ПОМЕСТИТЬ Прочитано
	|ИЗ
	|	&ВТ КАК ВТ
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	НепрочитаніПовідомлення.Период,
	|	НепрочитаніПовідомлення.Одержувач,
	|	НепрочитаніПовідомлення.Відправник
	|ИЗ
	|	Прочитано КАК Прочитано
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НепрочитаніПовідомлення КАК НепрочитаніПовідомлення
	|		ПО Прочитано.Відправник = НепрочитаніПовідомлення.Відправник
	|			И (НепрочитаніПовідомлення.Одержувач = &Одержувач)
	|			И Прочитано.Период >= НепрочитаніПовідомлення.Период";
	
	Запрос.УстановитьПараметр("ВТ", Прочитано);
	Запрос.УстановитьПараметр("Одержувач", Користувач);
	Выборка = Запрос.Выполнить().Выбрать();
	набор = РегистрыСведений.НепрочитаніПовідомлення.СоздатьНаборЗаписей();
	
	Пока Выборка.Следующий() Цикл
		Набор.Отбор.Период.Установить(Выборка.Период);
		Набор.Отбор.Одержувач.Установить(Выборка.Одержувач);
		Набор.Отбор.Відправник.Установить(Выборка.Відправник);
		Набор.Записать();
	КонецЦикла;
	
КонецПроцедуры

Процедура ЗаписатьУдаленныеСообщения(Сообщения)
	
	Для Каждого Элемент Из Сообщения Цикл
		Менеджер = РегистрыСведений.УдаленныеСообщения.СоздатьМенеджерЗаписи();
		Менеджер.УИД_Сообщения = Элемент.УИД_Сообщения;		
		Менеджер.Прочитать();
		Если ЗначениеЗаполнено(Менеджер.Дата) Тогда 
			Продолжить;
		КонецЕсли;
		Менеджер.УИД_Сообщения = Элемент.УИД_Сообщения;		
		Менеджер.Дата = ТекущаяДата();
		Менеджер.Записать();
	КонецЦикла;
	
КонецПроцедуры


Процедура ЗаписатьРеакциюСообщения(Сообщения)
	
	Для Каждого Элемент Из Сообщения Цикл
		Менеджер = РегистрыСведений.РекацииНаСобщения.СоздатьМенеджерЗаписи();
		Менеджер.УИД_Сообщения = Элемент.УИД_Сообщения;
		Менеджер.УчастникЧата = Справочники.Пользователи.ПолучитьСсылку(Элемент.УИД_УчастникЧата);
		Менеджер.Прочитать();
		Если ЗначениеЗаполнено(Менеджер.Дата) И Менеджер.Реакция = Элемент.Реакция Тогда 
			Продолжить;
		КонецЕсли;
		Менеджер.УИД_Сообщения = Элемент.УИД_Сообщения;
		Менеджер.УчастникЧата = Справочники.Пользователи.ПолучитьСсылку(Элемент.УИД_УчастникЧата);

		Менеджер.Реакция = Элемент.Реакция;
		Менеджер.Дата = ТекущаяДата();
		
		Менеджер.Записать(Истина);
	КонецЦикла;
	
КонецПроцедуры


Процедура ЗаписатьИсториюРаботыСКлиентом(Данные, Торговый)
	
	Для Каждого  Элемент Из Данные Цикл 
		
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИСТИНА КАК Поле1
		|ИЗ
		|	РегистрСведений.ИсторияРаботыСКлиентом КАК ИсторияРаботыСКлиентом
		|ГДЕ
		|	ИсторияРаботыСКлиентом.УИД_Записи = &УИД_Записи";
		
		Запрос.УстановитьПараметр("УИД_Записи", Элемент.УИД_Записи);
		
		Результат = Запрос.Выполнить();
		Если Результат.Пустой() Тогда 
			МенеджерЗаписи = РегистрыСведений.ИсторияРаботыСКлиентом.СоздатьМенеджерЗаписи();
			МенеджерЗаписи.Торговый  = Торговый;
			МенеджерЗаписи.Клиент = Справочники.Контрагенты.ПолучитьСсылку(Элемент.КлиентУИД);
			МенеджерЗаписи.Запись = Элемент.Запись;
			МенеджерЗаписи.Период = Элемент.Период;
			МенеджерЗаписи.УИД_Записи  = Элемент.УИД_Записи;
			МенеджерЗаписи.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом = Элемент.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом;
			Попытка 
				МенеджерЗаписи.Записать();
			Исключение 
				Текст = ИнформацияОбОшибке();
			КонецПопытки;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ОновитьСинхронизациюУведомлений(Данные, МассивИД)
	
	Для Каждого Элемент Из Данные Цикл 
		Набор = РегистрыСведений.ЗапланированыеУведомления.СоздатьНаборЗаписей();
		Набор.Отбор.УИД_Уведомления.Установить(Элемент.ИД);
		Набор.Прочитать();
		Если Набор.Количество() Тогда 
			Набор[0].Синхронизировано = Истина;
			Набор.Записать();
			МассивИД.Добавить(Элемент.ИД);
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

