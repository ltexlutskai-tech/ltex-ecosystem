Функция ПолучитьДанныеНезакрытыхЗаказов(ПарольВхода, Контрагент_уид) Экспорт //intrata_wald_02072021
	
	Продавец = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
	Если Не ЗначениеЗаполнено(Продавец) Тогда
		Возврат Новый ХранилищеЗначения("по такому паролю входа не найден продавец");
	КонецЕсли;
	
	Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Контрагент_уид.Получить());
	Если Контрагент.ПолучитьОбъект() = Неопределено ИЛИ НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Возврат Новый ХранилищеЗначения("по такому уникальному идентификатору не найден контрагент");
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказыПокупателейОстатки.ЗаказПокупателя КАК Заказ,
		|	ЗаказыПокупателейОстатки.Номенклатура КАК Номенклатура,
		|	ЗаказыПокупателейОстатки.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
		|	ЗаказыПокупателейОстатки.Цена,
		|	ЗаказыПокупателейОстатки.КоличествоОстаток КАК Количество,
		|	ЗаказыПокупателейОстатки.СуммаВзаиморасчетовОстаток КАК Сумма,
		|	ПРЕДСТАВЛЕНИЕ(ЗаказыПокупателейОстатки.ЗаказПокупателя) КАК мЗаказ,
		|	ПРЕДСТАВЛЕНИЕ(ЗаказыПокупателейОстатки.Номенклатура) КАК мНоменклатура,
		|	ПРЕДСТАВЛЕНИЕ(ЗаказыПокупателейОстатки.ХарактеристикаНоменклатуры) КАК мХарактеристика
		|ИЗ
		|	РегистрНакопления.ЗаказыПокупателей.Остатки(
		|			,
		|			ЗаказПокупателя.Контрагент = &Контрагент
		|				И ЗаказПокупателя.ТорговийАгент = &Продавец) КАК ЗаказыПокупателейОстатки
		|ГДЕ
		|	ЗаказыПокупателейОстатки.КоличествоОстаток > 0";
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Продавец", Продавец);
	Результат = Запрос.Выполнить().Выгрузить();
	Результат.Колонки.Добавить("Заказ_уид", Новый ОписаниеТипов("УникальныйИдентификатор"));
	Результат.Колонки.Добавить("Номенклатура_уид", Новый ОписаниеТипов("УникальныйИдентификатор"));
	Результат.Колонки.Добавить("Характеристика_уид", Новый ОписаниеТипов("УникальныйИдентификатор"));
	Для Каждого СтрокаРезультат Из Результат Цикл
		СтрокаРезультат.Заказ_уид = СтрокаРезультат.Заказ.УникальныйИдентификатор();
		СтрокаРезультат.Номенклатура_уид = СтрокаРезультат.Номенклатура.УникальныйИдентификатор();
		СтрокаРезультат.Характеристика_уид = СтрокаРезультат.ХарактеристикаНоменклатуры.УникальныйИдентификатор();
		//СтрокаРезультат.Заказ_уид = СтрокаРезультат.Заказ.УникальныйИдентификатор();

	КонецЦикла;
	
	Возврат Новый ХранилищеЗначения(Результат);
	
КонецФункции

