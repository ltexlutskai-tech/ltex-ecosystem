Функция ДублиКонтрагента(Параметры)
	Перем НомерТелефона, Контрагент, ЭтоПоиск;
	
	Параметры.Свойство("НомерТелефона", НомерТелефона);
	Параметры.Свойство("Контрагент", Контрагент);
	Параметры.Свойство("Пошук", ЭтоПоиск);

	НовыйТелефон = ОбработкаНомераТелефона(НомерТелефона);
	ЗапросНомеров = Новый Запрос;
	
	ЗапросНомеров.Текст = 
	"ВЫБРАТЬ
	|	Контрагенты.НомерТелефона,
	|	Контрагенты.Ссылка КАК Контрагент,
	|	Контрагенты.ТорговыйАгент
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.НомерТелефона ПОДОБНО &НомерТелефона
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	КонтрагентыДополнительныеНомераТелефонов.Номер,
	|	КонтрагентыДополнительныеНомераТелефонов.Ссылка,
	|	КонтрагентыДополнительныеНомераТелефонов.Ссылка.ТорговыйАгент
	|ИЗ
	|	Справочник.Контрагенты.ДополнительныеНомераТелефонов КАК КонтрагентыДополнительныеНомераТелефонов
	|ГДЕ
	|	КонтрагентыДополнительныеНомераТелефонов.Номер ПОДОБНО &НомерТелефона";
	ЗапросНомеров.УстановитьПараметр("НомерТелефона", Прав(НовыйТелефон, 10));
	
	Выборка = ЗапросНомеров.Выполнить().Выбрать();
	
	Отказ = Ложь;
	ТекстОшибки = "";
	Пока Выборка.Следующий() Цикл 
		
		Если ЗначениеЗаполнено(Контрагент) 
			И Контрагент = Выборка.Контрагент.УникальныйИдентификатор() Тогда 
			Продолжить;	
		КонецЕсли;
		Если ЭтоПоиск Тогда 
			ТекстОшибки = "" + Выборка.Контрагент + ", Відповідальний: " + Выборка.ТорговыйАгент;		
		иначе	
			ТекстОшибки = "Номер телефону контрагента не унікальний! " + Выборка.Контрагент + ", Номер: " + Выборка.НомерТелефона + ", Відповідальний: " + Выборка.ТорговыйАгент + Символы.ПС;
		КонецЕсли;
		Отказ = Истина;

		
	КонецЦикла;
	

	Ответ = Новый Структура;
	Ответ.Вставить("ЕстьДубли", Отказ);
	Ответ.Вставить("ТекстОшибки", ТекстОшибки);
	Возврат Ответ;
КонецФункции




