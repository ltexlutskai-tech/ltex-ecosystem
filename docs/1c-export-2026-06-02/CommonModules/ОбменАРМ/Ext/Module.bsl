Функция ВозвратПоЗакритомуМаршрутнику(МаршрутныйЛист, ТекИД, ТаблицаИД)
	Попытка
		Если ЗначениеЗаполнено(МаршрутныйЛист) И МаршрутныйЛист.СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Завершен Тогда 
			Если ЗначениеЗаполнено(ТекИД) Тогда 
				НовСтр = ТаблицаИД.Добавить();
				НовСтр.ИД = ТекИД;
			КонецЕсли;	
			Возврат Истина;
		КонецЕсли;
	Исключение
	КонецПопытки;
	Возврат Ложь;
КонецФункции


Функция ВыборДоговора(ВидДоговора,Контрагент,Организация,ВедениеВзаиморасчетов)
	з = Новый Запрос;
	з.Текст =  "ВЫБРАТЬ ПЕРВЫЕ 1
	|	ДоговорыКонтрагентов.Ссылка КАК Договор
	|ИЗ
	|	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
	|ГДЕ
	|	ДоговорыКонтрагентов.ВедениеВзаиморасчетов = &ВедениеВзаиморасчетов
	|	И ДоговорыКонтрагентов.Владелец = &Владелец
	|	И ДоговорыКонтрагентов.Организация = &Организация
	|	И ДоговорыКонтрагентов.ВидДоговора = &ВидДоговора";
	з.УстановитьПараметр("ВидДоговора",ВидДоговора);
	з.УстановитьПараметр("Владелец",Контрагент);
	з.УстановитьПараметр("Организация",Организация); 
	з.УстановитьПараметр("ВедениеВзаиморасчетов",ВедениеВзаиморасчетов); 
	Выборка = з.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда 
		Возврат Выборка.Договор;
	Иначе
		Возврат Справочники.ДоговорыКонтрагентов.ПустаяСсылка();
	КонецЕсли;
КонецФункции

Процедура ОбновитьНормыЗапасов(ТаблицаНормЗапасов,Склад, ТаблицаИД)
	//МассивДокументов = Новый Массив;         
	//ИмяДок = "ВозвратТоваровОтПокупателя";
	//ТекущаяСсылка = "";
	
	Для Каждого СтрокаДанныеЭлемента Из ТаблицаНормЗапасов Цикл
		
			  //        |	РегистрацияОбмена.ИД,
			  //|	НормыЗапасов.Номенклатура КАК Номенклатура,
			  //|	НормыЗапасов.ХарактеристикаНоменклатуры КАК ХарактеристикаНоменклатуры,
			  //|	НормыЗапасов.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
			  //|	НормыЗапасов.Количество,
			  //|	НормыЗапасов.Дата
			  
			ТекНом = Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.Номенклатура);
			ТекХар = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.ХарактеристикаНоменклатуры);
			ТекЕдИзм = Справочники.ЕдиницыИзмерения.ПолучитьСсылку(СтрокаДанныеЭлемента.ЕдиницаИзмерения);
			
			Запрос = Новый Запрос;
			Запрос.Текст="ВЫБРАТЬ
			             |	НормыЗапасов.Количество,
			             |	НормыЗапасов.Дата
			             |ИЗ
			             |	РегистрСведений.НормыЗапасов КАК НормыЗапасов
			             |ГДЕ
			             |	НормыЗапасов.Номенклатура = &Номенклатура
			             |	И НормыЗапасов.ХарактеристикаНоменклатуры = &ХарактеристикаНоменклатуры
			             |	И НормыЗапасов.ЕдиницаИзмерения = &ЕдиницаИзмерения
			             |	И НормыЗапасов.Склад = &Склад";
			Запрос.УстановитьПараметр("Номенклатура",ТекНом);
			Запрос.УстановитьПараметр("ХарактеристикаНоменклатуры",ТекХар);
			Запрос.УстановитьПараметр("ЕдиницаИзмерения",ТекЕдИзм);
			Запрос.УстановитьПараметр("Склад",Склад);
			Выборка = Запрос.Выполнить().Выбрать();
			Если Выборка.Следующий() И Выборка.Дата > СтрокаДанныеЭлемента.Дата Тогда 
				
			Иначе 
			
			
			
			
			нз = РегистрыСведений.НормыЗапасов.СоздатьНаборЗаписей();
			нз.Отбор.ЕдиницаИзмерения.Использование = Истина;
			нз.Отбор.Номенклатура.Использование = Истина;
			нз.Отбор.ХарактеристикаНоменклатуры.Использование = Истина;
			нз.Отбор.Склад.Использование = Истина;

			
			
			нз.Отбор.ЕдиницаИзмерения.Значение = ТекЕдИзм;
			нз.Отбор.Номенклатура.Значение = ТекНом;
			нз.Отбор.Склад.Значение = Склад;
			нз.Отбор.ХарактеристикаНоменклатуры.Значение = ТекХар;
			
			з = нз.Добавить();
			
			з.Номенклатура = ТекНом;
			з.ХарактеристикаНоменклатуры = ТекХар;
			з.Количество = СтрокаДанныеЭлемента.Количество;
			з.Дата = СтрокаДанныеЭлемента.Дата;
			з.ЕдиницаИзмерения = ТекЕдИзм;
			з.Склад = Склад;
			нз.Записать();	
			КонецЕсли;
					НовСтр = ТаблицаИД.Добавить();
					НовСтр.ИД = СтрокаДанныеЭлемента.ИД;

		
	КонецЦикла;
	
