		Если ОшибкаТранзакции Тогда
			ЗаписьЖурналаРегистрации("ОБМЕН", УровеньЖурналаРегистрации.Ошибка, ,,ОписаниеОшибки());

			//ОтменитьТранзакцию();
		Иначе 

			НовСтр 		= ТаблицаИД.Добавить();
			НовСтр.ИД 	= Элемент.ИД;

		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

