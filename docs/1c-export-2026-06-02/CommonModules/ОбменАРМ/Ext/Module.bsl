 //   КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;	
 //   МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, Настройки, ДанныеРасшифровки);	
 //   
	
	СхемаСКД = ПолучитьОбщийМакет("АнализКлиентскойБазы");
	КомпоновщикНастроекДанныхОтчета = Новый КомпоновщикНастроекКомпоновкиДанных;
	КомпоновщикНастроекДанныхОтчета.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(СхемаСКД));
	КомпоновщикНастроекДанныхОтчета.ЗагрузитьНастройки(СхемаСКД.НастройкиПоУмолчанию);
	
	// В том случае, если нам нужно учитывать настройки, выполненные пользователем, их необходимо загрузить
	//КомпоновщикНастроекДанныхОтчета.ЗагрузитьПользовательскиеНастройки(Отчет.КомпоновщикНастроек.ПользовательскиеНастройки);
	
	КомпоновщикНастроекДанныхОтчета.Настройки.Отбор.Элементы[0].Использование = Истина;
	КомпоновщикНастроекДанныхОтчета.Настройки.Отбор.Элементы[0].ВидСравнения = ВидСравненияКомпоновкиДанных.ВСписке;
	КомпоновщикНастроекДанныхОтчета.Настройки.Отбор.Элементы[0].ПравоеЗначение = СписокКонтраегнтв;
	
	КомпоновщикНастроекДанныхОтчета.Настройки.ПараметрыДанных.Элементы[4].Использование = Истина;
	КомпоновщикНастроекДанныхОтчета.Настройки.ПараметрыДанных.Элементы[4].Значение = Продавец;


	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки = КомпоновщикМакета.Выполнить(СхемаСКД, КомпоновщикНастроекДанныхОтчета.ПолучитьНастройки());
		
	
	
	
	ВнешнийНаборДанных = Новый Структура("ТЗКонтрагентов", ТЗКонтрагентов); 
	ПроцессорКомпоновкиДанных = Новый ПроцессорКомпоновкиДанных; 
	ПроцессорКомпоновкиДанных.Инициализировать(МакетКомпоновки, ВнешнийНаборДанных); 
	
	
 	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВТабличныйДокумент; 
	ПроцессорВывода.УстановитьДокумент(ТабДокумент); 
	ПроцессорВывода.Вывести(ПроцессорКомпоновкиДанных);
	
	
	ТабДокумент.ОтображатьСетку = Ложь;
	ТабДокумент.ОтображатьЗаголовки = Ложь;
	ТабДокумент.ТолькоПросмотр = Истина;
	
	ТабДокумент.ПоказатьУровеньГруппировокСтрок(1);
	ТабДокумент.ПоказатьУровеньГруппировокСтрок(0);
	

	
	Возврат ТабДокумент;
	
КонецФункции

Функция ЗаписатьИзмененияХарактеристик(Параметры, Продавец);
	
	Ответ = Новый Массив;
	
	НетКолонкиОткрыт = Параметры.Колонки.Найти("Открыт") = Неопределено;
	Для Каждого Элемент Из Параметры Цикл 
		
		Структура = Новый Структура("УИД, ИД", Элемент.УИД_Ссылка, Элемент.ИД);
		Ответ.Добавить(Структура);
		
		Ссылка = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Элемент.УИД_Ссылка);
		Если ПустаяСтрока(Ссылка.ВерсияДанных) Тогда 
			Продолжить;
		КонецЕсли;
		
		Объект = Ссылка.ПолучитьОбъект();
		
		Объект.Коментар = Элемент.Коментар;
		Объект.СекторНаСкладі = Элемент.СекторНаСкладі;
	
		Если НЕ НетКолонкиОткрыт Тогда  
			Объект.Открыт = Элемент.Открыт;
		КонецЕсли;
		
		Объект.Записать();
		
	КонецЦикла;
	
	Общий.ЗаписІсторіїЗміниХарактеристики(Объект.Ссылка, Продавец);
		
	Возврат Ответ;
	
КонецФункции

