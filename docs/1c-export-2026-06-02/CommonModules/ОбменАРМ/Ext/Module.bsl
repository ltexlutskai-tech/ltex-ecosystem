Функция ЗакрытьСтарыеЗаказы_v1(ПарольВхода, Товары, Контрагент_уид) Экспорт //taras
	
	Продавец = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
	Если Не ЗначениеЗаполнено(Продавец) Тогда
		Возврат "по такому паролю входа не найден продавец";
	КонецЕсли;
	
	Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Контрагент_уид.Получить());
	Если ПустаяСтрока(Контрагент.ВерсияДанных) ИЛИ НЕ ЗначениеЗаполнено(Контрагент) Тогда
		Возврат "по такому уникальному идентификатору не найден контрагент";
	КонецЕсли;
	
	ТЗ_Товары = Товары.Получить();
	ТЗ_Товары.Колонки.Добавить("Заказ",Новый ОписаниеТипов("ДокументСсылка.ЗаказПокупателя"));
	ТЗ_Товары.Колонки.Добавить("Номенклатура",Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗ_Товары.Колонки.Добавить("ХарактеристикаНоменклатуры",Новый ОписаниеТипов("СправочникСсылка.ХарактеристикиНоменклатуры"));
	
	//імпортовано і перероблено з обробки ЗакрытиеСтарыхЗаказов
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗаказыПокупателейОстатки.Цена,
		|	ЗаказыПокупателейОстатки.ЗаказПокупателя.Организация КАК Организация,
		|	ЗаказыПокупателейОстатки.ЗаказПокупателя.ВалютаДокумента КАК ВалютаДокумента,
		|	ЗаказыПокупателейОстатки.ЗаказПокупателя.ДоговорКонтрагента КАК ДоговорКонтрагента,
		|	ЗаказыПокупателейОстатки.ЗаказПокупателя.КратностьВзаиморасчетов КАК КратностьВзаиморасчетов,
		|	ЗаказыПокупателейОстатки.ЗаказПокупателя.СкладГруппа КАК СкладГруппа
		|ИЗ
		|	РегистрНакопления.ЗаказыПокупателей.Остатки(
		|			,
		|			ЗаказПокупателя.Контрагент = &Контрагент
		|				И ЗаказПокупателя.Торговийагент = &Продавец) КАК ЗаказыПокупателейОстатки
		|ГДЕ
		|	ЗаказыПокупателейОстатки.КоличествоОстаток > 0";
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("Продавец", Продавец);
	Выборка = Запрос.Выполнить().Выбрать();
	
	НачатьТранзакцию();
	Если ТЗ_Товары.Количество() > 0 Тогда
		НовыйЗаказ = Документы.ЗаказПокупателя.СоздатьДокумент();
		НовыйЗаказ.Контрагент = Контрагент;
		НовыйЗаказ.ТорговийАгент = Продавец;
		НовыйЗаказ.Дата = ТекущаяДата();
		НовыйЗаказ.Комментарий = "создано с помощью механизма закрытия старых заказов.";
		Если Выборка.Следующий() Тогда
			ЗаполнитьЗначенияСвойств(НовыйЗаказ, Выборка);
		Иначе
			ОтменитьТранзакцию();
			Возврат "Не найдено данных.";
		КонецЕсли;
				
		Для Каждого СтрокаТЗ Из ТЗ_Товары Цикл
			СтрокаТЗ.Заказ = Документы.ЗаказПокупателя.ПолучитьСсылку(СтрокаТЗ.Заказ_уид);
			СтрокаТЗ.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(СтрокаТЗ.Номенклатура_уид);
			СтрокаТЗ.ХарактеристикаНоменклатуры = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаТЗ.Характеристика_уид);
		КонецЦикла;
		ТЗ = ТЗ_Товары.Скопировать();
		ТЗ.Свернуть("Номенклатура, ХарактеристикаНоменклатуры, ДобавитьВЗаказ", "Количество, Цена, Сумма");
		
		Для Каждого СтрокаТЗ Из ТЗ Цикл
			Если СтрокаТЗ.ДобавитьВЗаказ Тогда
				СтрокаТов = НовыйЗаказ.Товары.Добавить();
				ЗаполнитьЗначенияСвойств(СтрокаТов, СтрокаТЗ, "Номенклатура, ХарактеристикаНоменклатуры, Цена, Количество, Сумма");
				СтрокаТов.ЕдиницаИзмерения = СтрокаТов.Номенклатура.ЕдиницаХраненияОстатков;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ НовыйЗаказ.Товары.Количество() Тогда
			Возврат "В заказе нет товаров";
		КонецЕсли;
		
		Попытка
			НовыйЗаказ.Записать();
			НовыйЗаказ.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ОтменитьТранзакцию();
			Возврат ОписаниеОшибки();
		КонецПопытки;
		
		ТЗ = ТЗ_Товары.Скопировать();
		ТЗ.Свернуть("Заказ");
		Для Каждого Строка Из ТЗ Цикл
			Если НЕ Строка.Заказ.Пустая() Тогда
				Закрытие = Документы.ЗакрытиеЗаказовПокупателей.СоздатьДокумент();
				Закрытие.Заполнить(Строка.Заказ);
				Закрытие.Дата = ТекущаяДата();
				Закрытие.Комментарий = "создано с помощью механизма закрытия старых заказов.";
				Попытка
					Закрытие.Записать();
					Закрытие.Записать(РежимЗаписиДокумента.Проведение);
				Исключение
					ОтменитьТранзакцию();
					Возврат ОписаниеОшибки();
				КонецПопытки;
			КонецЕсли;
		КонецЦикла;
	Иначе
		ОтменитьТранзакцию();
		Возврат "Пустая таблица";
	КонецЕсли;
	ЗафиксироватьТранзакцию();
	
	Возврат "";
	
КонецФункции



Процедура СоздатьМаршрутныеЛистыТовары(ТаблицаВозвратов, Продавец, ТаблицаИД, НеХватает = Неопределено)
	
	МассивДокументов 	= Новый Массив;         
	ИмяДок 				= "МаршрутныйЛист";
	ТекущаяСсылка 		= "";
	ТорговыйАгент 		= Продавец;
	ТекИД 				= Неопределено;
	НеХватает			= Новый Массив;
	Попытка
		ТаблицаВозвратов.Сортировать("Ссылка");
	Исключение
	КонецПопытки;
	
	ЭтоНовыйМаршрутный = Ложь;
	Для Каждого СтрокаДанныеЭлемента Из ТаблицаВозвратов Цикл
		НовыйОбъект = Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка).ПолучитьОбъект();
		ДобавитьДок = Ложь;
		

		
		Если НовыйОбъект = Неопределено Тогда 
			Если СтрокаДанныеЭлемента.ПометкаУдаления  Тогда 
				Продолжить;
			КонецЕсли;
			НовыйОбъект 				= Документы[ИмяДок].СоздатьДокумент();
			НовыйОбъект.Дата 			= ТекущаяДата();
			НовыйОбъект.Организация 	= Справочники.Организации.НайтиПоКоду("000000001");
			НовыйОбъект.Склад 			= Справочники.Склады.НайтиПоКоду("000000001");
			НовыйОбъект.ДатаПриезда		= СтрокаДанныеЭлемента.ДатаПриезда;
			НовыйОбъект.СтатусДокумента = ?(СтрокаДанныеЭлемента.СтатусДокумента = "Составляется", Перечисления.СтатусыМаршрутногоЛиста.Составляется,
			                       ?(СтрокаДанныеЭлемента.СтатусДокумента = "Отправлен", Перечисления.СтатусыМаршрутногоЛиста.Отправлен,
								   ?(СтрокаДанныеЭлемента.СтатусДокумента = "Завершен", Перечисления.СтатусыМаршрутногоЛиста.Завершен, 
								                                                  Перечисления.СтатусыМаршрутногоЛиста.ПустаяСсылка())));		
			НовыйОбъект.Комментарий = СтрокаДанныеЭлемента.Комментарий;
			НовыйОбъект.УстановитьСсылкуНового(Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка));
			//НовыйОбъект.УстановитьНовыйНомер();
			НовыйОбъект.ТорговийАгент 					= Продавец;
			ТабТоргові = НовыйОбъект.ТорговыеАгенты.Добавить();
			ТабТоргові.ТорговыйАгент                    = Продавец;
			НовыйОбъект.ОтражатьВУправленческомУчете 	= Истина;

			ДобавитьДок 		= Истина;
		Иначе	
			Если ВозвратПоЗакритомуМаршрутнику(НовыйОбъект, СтрокаДанныеЭлемента.ИД, ТаблицаИД) Тогда 
				Продолжить;
			КонецЕсли;

			НовыйОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		КонецЕсли;
		//////////////////////////////////////////////////////////////////     
		Если ТекущаяСсылка <> СтрокаДанныеЭлемента.Ссылка Тогда 
			Если НовыйОбъект.Заказы.Количество() Тогда 
				ЭтоНовыйМаршрутный = Ложь;
			Иначе 
				ЭтоНовыйМаршрутный = Истина;
			КонецЕсли;
			
		//	НовыйОбъект.Заказы.Очистить();
		//	НовыйОбъект.ТоварыЗаказов.Очистить();
			ТекущаяСсылка = СтрокаДанныеЭлемента.Ссылка;
			Попытка
				Если ЗначениеЗаполнено(ТекИД) Тогда 
					НовСтр = ТаблицаИД.Добавить();
					НовСтр.ИД = ТекИД; 
				КонецЕсли;
				ТекИД = СтрокаДанныеЭлемента.ИД;
			Исключение
			КонецПопытки;
		//	ДобавитьДок = Истина;
		КонецЕсли;
		/////////////////////////////////////////////////////////////////
		НовыйОбъект.ПометкаУдаления = СтрокаДанныеЭлемента.ПометкаУдаления; 
		
		//Шукаэм чи заказ вже э
		ТекЗаказПокупателя = Документы.ЗаказПокупателя.ПолучитьСсылку(СтрокаДанныеЭлемента.ЗаказПокупателя);
		ЗаказВжеЄ =  НовыйОбъект.Заказы.Найти(ТекЗаказПокупателя);
		Если ЗаказВжеЄ = Неопределено Тогда 
			ЗаказВжеЄ = Ложь;
		Иначе 
			ЗаказВжеЄ = Истина;
		КонецЕсли;
				
		// Заказы   // Відключили загрузку
		Если СтрокаДанныеЭлемента.ТабЧасть = "Заказы" И НЕ ЗаказВжеЄ Тогда 
			СтрокаЗаказов = НовыйОбъект.Заказы.Добавить();
			ЗаполнитьЗначенияСвойств(СтрокаЗаказов, СтрокаДанныеЭлемента);
			СтрокаЗаказов.ЗаказПокупателя = ТекЗаказПокупателя;
			СтрокаЗаказов.Контрагент 	  = Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.Контрагент);
		КонецЕсли;
		
		// Товары заказов
		Если СтрокаДанныеЭлемента.ТабЧасть = "ТоварыЗаказов" И НЕ ЗаказВжеЄ Тогда 
			СтрокаТоваров = НовыйОбъект.ТоварыЗаказов.Добавить();		
			ЗаполнитьЗначенияСвойств(СтрокаТоваров, СтрокаДанныеЭлемента);
			СтрокаТоваров.ЗаказПокупателя 				= ТекЗаказПокупателя;
			СтрокаТоваров.Номенклатура 					= Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.Номенклатура);
			СтрокаТоваров.ХарактеристикаНоменклатуры 	= Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.ХарактеристикаНоменклатуры);
			Попытка
				СтрокаТоваров.ЕдиницаИзмерения 			= СтрокаТоваров.Номенклатура.ЕдиницаХраненияОстатков;
			Исключение
			КонецПопытки;
			СтрокаТоваров.Сумма 						= СтрокаТоваров.Цена * СтрокаТоваров.Количество;
			СтрокаТоваров.Качество 						= Справочники.Качество.Новый;
		КонецЕсли;
		
		// Завдання
		Если СтрокаДанныеЭлемента.ТабЧасть = "Завдання"  Тогда 
			
			ТекКонтрагент 	  = Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.Контрагент);
			
			СтрокаТоваров = НовыйОбъект.Завдання.Найти(ТекКонтрагент);
			Если СтрокаТоваров = Неопределено Тогда 
				  СтрокаТоваров =    НовыйОбъект.Завдання.Добавить();
				  СтрокаТоваров.Контрагент = ТекКонтрагент;
			КонецЕсли;
			СтрокаТоваров.Коментар = СтрокаДанныеЭлемента.Коментар;	
	
		КонецЕсли;

		
		// Загрузка
		Если СтрокаДанныеЭлемента.ТабЧасть = "ЗагрузкаМашины" Тогда 
			ЗаказПокупателя 				= Документы.ЗаказПокупателя.ПолучитьСсылку(СтрокаДанныеЭлемента.ЗаказПокупателя);
			Номенклатура 					= Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.Номенклатура);
			ХарактеристикаНоменклатуры 		= Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.ХарактеристикаНоменклатуры);			
			СтрокиЗагрузки 					= НовыйОбъект.ЗагрузкаМашины.НайтиСтроки(Новый Структура("ЗаказПокупателя, Номенклатура, ХарактеристикаНоменклатуры", ЗаказПокупателя, Номенклатура, ХарактеристикаНоменклатуры));
			Если СтрокиЗагрузки.Количество() Тогда 
				СтрокаТоваров = СтрокиЗагрузки[0];
			Иначе 
				СтрокаТоваров = НовыйОбъект.ЗагрузкаМашины.Добавить();
			КонецЕсли;				
			ЗаполнитьЗначенияСвойств(СтрокаТоваров, СтрокаДанныеЭлемента);
			СтрокаТоваров.ЗаказПокупателя 				= ЗаказПокупателя;
			СтрокаТоваров.Номенклатура 					= Номенклатура;
			СтрокаТоваров.ХарактеристикаНоменклатуры 	= ХарактеристикаНоменклатуры;
			Попытка
				СтрокаТоваров.ЕдиницаИзмерения 			= СтрокаТоваров.Номенклатура.ЕдиницаХраненияОстатков;
			Исключение
			КонецПопытки;
			СтрокаТоваров.Качество 						= Справочники.Качество.Новый;
		КонецЕсли;		
		
		Попытка
			НовыйОбъект.Записать();
		Исключение
			ЗаписьЖурналаРегистрации("ОшибкаОбмена", УровеньЖурналаРегистрации.Ошибка , , "" ,ОписаниеОшибки());
		КонецПопытки;
		
		Если ДобавитьДок Тогда 
			МассивДокументов.Добавить(НовыйОбъект.Ссылка);
		КонецЕсли;
	КонецЦикла;	
	
	Если ЗначениеЗаполнено(ТекИД) Тогда 
		НовСтр 		= ТаблицаИД.Добавить();
		НовСтр.ИД 	= ТекИД;
	КонецЕсли;
	
	Для Каждого ДокСсылка Из МассивДокументов Цикл
		Если ДокСсылка.ПометкаУдаления Тогда 
			Продолжить;
		КонецЕсли;
		ДокОб = ДокСсылка.ПолучитьОбъект();
		Попытка
			ДокОб.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		Исключение
		КонецПопытки;
	КонецЦикла;
	
	мМаршрут = ТаблицаВозвратов.Скопировать(, "Ссылка");
	мМаршрут.Свернуть( "Ссылка");
	Для Каждого Элемент Из мМаршрут Цикл 
		
		 мСтруктура = Новый Структура;
		 мСтруктура.Вставить("Маршрут", Элемент.Ссылка);
		 мСтруктура.Вставить("НеХватает", ПолучитьТаблицуНеХватаетМаршрутныйЛист(Элемент.Ссылка));
		 НеХватает.Добавить(мСтруктура);

	 КонецЦикла;
	 
	
КонецПроцедуры

Процедура СоздатьМаршрутныеЛистыДокументы(ТаблицаВозвратов, Продавец, ТаблицаИД)
	
	МассивДокументов 	= Новый Массив;         
	ИмяДок 				= "МаршрутныйЛист";
	ТекущаяСсылка 		= "";
	ТорговыйАгент 		= Продавец;
	ТекИД 				= Неопределено;
	Попытка
		ТаблицаВозвратов.Сортировать("Ссылка");
	Исключение
	КонецПопытки;
	
	Для Каждого СтрокаДанныеЭлемента Из ТаблицаВозвратов Цикл
		НовыйОбъект = Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка).ПолучитьОбъект();
		ДобавитьДок = Ложь;
		Если НовыйОбъект = Неопределено Тогда 
			Если СтрокаДанныеЭлемента.ПометкаУдаления  Тогда 
				Продолжить;
			КонецЕсли;
			//ЗаписьЖурналаРегистрации("СтворенняМарщрутного", УровеньЖурналаРегистрации.Информация,,,"Створення");
			НовыйОбъект 		= Документы[ИмяДок].СоздатьДокумент();	
			НовыйОбъект.Дата 	= ТекущаяДата();
			НовыйОбъект.ДатаПриезда		= СтрокаДанныеЭлемента.ДатаПриезда;
			НовыйОбъект.СтатусДокумента = ?(СтрокаДанныеЭлемента.СтатусДокумента = "Составляется", Перечисления.СтатусыМаршрутногоЛиста.Составляется,
			                       ?(СтрокаДанныеЭлемента.СтатусДокумента = "Отправлен", Перечисления.СтатусыМаршрутногоЛиста.Отправлен,
								   ?(СтрокаДанныеЭлемента.СтатусДокумента = "Завершен", Перечисления.СтатусыМаршрутногоЛиста.Завершен, 
								                                                  Перечисления.СтатусыМаршрутногоЛиста.ПустаяСсылка())));		
			НовыйОбъект.Комментарий = СтрокаДанныеЭлемента.Комментарий;
			НовыйОбъект.УстановитьСсылкуНового(Документы[ИмяДок].ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка));
			НовСтр = НовыйОбъект.ТорговыеАгенты.Добавить();
			НовСтр.ТорговыйАгент = ТорговыйАгент;
			ДобавитьДок 		= Истина;
		Иначе
			Если ВозвратПоЗакритомуМаршрутнику(НовыйОбъект, СтрокаДанныеЭлемента.ИД, ТаблицаИД) Тогда 
				Продолжить;
			КонецЕсли;

			НовыйОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
		КонецЕсли;
		//////////////////////////////////////////////////////////////////
		Если ТекущаяСсылка <> СтрокаДанныеЭлемента.Ссылка Тогда 
			//НовыйОбъект.Продажи.Очистить();
			//НовыйОбъект.Оплата.Очистить();
			ТекущаяСсылка = СтрокаДанныеЭлемента.Ссылка;
			Попытка
				Если ЗначениеЗаполнено(ТекИД) Тогда 
					НовСтр = ТаблицаИД.Добавить();
					НовСтр.ИД = ТекИД; 
				КонецЕсли;
				ТекИД = СтрокаДанныеЭлемента.ИД;
			Исключение
			КонецПопытки;
			ДобавитьДок = Истина;
		КонецЕсли;
		/////////////////////////////////////////////////////////////////
		Если НЕ ЗначениеЗаполнено(НовыйОбъект.Ссылка) Тогда 
			НовыйОбъект.Дата 							= ТекущаяДата();
			//НовыйОбъект.УстановитьНовыйНомер();
			НовыйОбъект.ТорговийАгент 					= Продавец;
			НовыйОбъект.ОтражатьВУправленческомУчете 	= Истина;
		КонецЕсли;
		НовыйОбъект.ПометкаУдаления = СтрокаДанныеЭлемента.ПометкаУдаления; 
		//ЗаписьЖурналаРегистрации("МАРШРУТНИЙ_ДОКУМЕНТИ", УровеньЖурналаРегистрации.Информация,,,"1");

		
		// Продажи
		Если СтрокаДанныеЭлемента.ТабЧасть = "Продажи" Тогда 
			//ЗаписьЖурналаРегистрации("МАРШРУТНИЙ_ДОКУМЕНТИ", УровеньЖурналаРегистрации.Информация,,,"12");

			Контрагент 	  				= Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.Контрагент);
			ЗаказПокупателя 			= Документы.ЗаказПокупателя.ПолучитьСсылку(СтрокаДанныеЭлемента.ЗаказПокупателя);
			Номенклатура 				= Справочники.Номенклатура.ПолучитьСсылку(СтрокаДанныеЭлемента.Номенклатура);
			ХарактеристикаНоменклатуры 	= Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.ХарактеристикаНоменклатуры);
			
			ОтборСтрок = Новый Структура;
			ОтборСтрок.Вставить("Контрагент", Контрагент);
			ОтборСтрок.Вставить("ЗаказПокупателя", ЗаказПокупателя);
			ОтборСтрок.Вставить("Номенклатура", Номенклатура);
			ОтборСтрок.Вставить("ХарактеристикаНоменклатуры", ХарактеристикаНоменклатуры);
			СтрокиПродаж = НовыйОбъект.Продажи.НайтиСтроки(ОтборСтрок);
			Если СтрокиПродаж.Количество() > 0 Тогда 
				СтрокаПродаж = СтрокиПродаж[0];			
			Иначе 	
				СтрокаПродаж = НовыйОбъект.Продажи.Добавить();
			КонецЕсли;
			//ЗаписьЖурналаРегистрации("МАРШРУТНИЙ_ДОКУМЕНТИ", УровеньЖурналаРегистрации.Информация,,,"13");

			ЗаполнитьЗначенияСвойств(СтрокаПродаж, СтрокаДанныеЭлемента);
			СтрокаПродаж.Контрагент 	  				= Контрагент;
			СтрокаПродаж.ЗаказПокупателя 				= ЗаказПокупателя;
			СтрокаПродаж.Номенклатура 					= Номенклатура;
			СтрокаПродаж.ХарактеристикаНоменклатуры 	= ХарактеристикаНоменклатуры;
			СтрокаПродаж.Качество 						= Справочники.Качество.Новый;
			СтрокаПродаж.Штрихкод 						= ВесовойУчет.ПолучитьШтрихкодПоХарактеристике(ХарактеристикаНоменклатуры);
			СтрокаПродаж.ЦенаПродажиВес 				= ВесовойУчет.ПолучитьЦенуЗаВес(НовыйОбъект.Дата, Номенклатура, Истина);
			Попытка
				СтрокаПродаж.ЕдиницаИзмерения 			= СтрокаПродаж.Номенклатура.ЕдиницаХраненияОстатков;
			Исключение
			КонецПопытки;
			//СтрокаПродаж.Сумма 							= СтрокаПродаж.Цена * СтрокаПродаж.Количество;   // 
			//ЗаписьЖурналаРегистрации("МАРШРУТНИЙ_ДОКУМЕНТИ", УровеньЖурналаРегистрации.Информация,,,"14");

		КонецЕсли;		
		//ЗаписьЖурналаРегистрации("МАРШРУТНИЙ_ДОКУМЕНТИ", УровеньЖурналаРегистрации.Информация,,,"2");
		МассивСтрок = Новый Массив;
		Для Каждого СтрПродажи Из  НовыйОбъект.Продажи Цикл 
			СтрокаЗагрузки 	= НовыйОбъект.ЗагрузкаМашины.Найти(СтрПродажи.Штрихкод, "Штрихкод");	
			Если СтрокаЗагрузки <> Неопределено Тогда  
				МассивСтрок.Добавить(СтрокаЗагрузки);
			КонецЕсли;	
		КонецЦикла;	
		Для Каждого ЭлементМассива Из МассивСтрок Цикл 
			НовыйОбъект.ЗагрузкаМашины.Удалить(ЭлементМассива);
		КонецЦикла;	
		
		// Оплата
		ВалютаУправленческогоУчета = Константы.ВалютаУправленческогоУчета.Получить();
		Таблица = ПолныеПрава.ПолучитьСписокДокументовПоКритериюОтбора("СвязанныеДокументы", НовыйОбъект.Ссылка);
		//ЗаписьЖурналаРегистрации("МАРШРУТНИЙ_ДОКУМЕНТИ", УровеньЖурналаРегистрации.Информация,,,"3");
		Для Каждого СтрДокумент Из Таблица Цикл 
			Если НЕ СтрДокумент.Ссылка.Проведен Тогда
				Продолжить;
			КонецЕсли;

			Если ТипЗнч(СтрДокумент.Ссылка) = Тип("ДокументСсылка.ПриходныйКассовыйОрдер")
				ИЛИ ТипЗнч(СтрДокумент.Ссылка) = Тип("ДокументСсылка.РасходныйКассовыйОрдер")
				ИЛИ ТипЗнч(СтрДокумент.Ссылка) = Тип("ДокументСсылка.ПлатежноеПоручениеВходящее") Тогда 
					СтрокаОплаты = 	НовыйОбъект.Оплата.Найти(СтрДокумент.Ссылка, "КассовыйОрдер");
					Если СтрокаОплаты = Неопределено Тогда 
						СтрокаОплаты = НовыйОбъект.Оплата.Добавить();
					КонецЕсли;	
					//ЗаписьЖурналаРегистрации("МАРШРУТНИЙ_ДОКУМЕНТИ", УровеньЖурналаРегистрации.Информация,,,"21");
					Кассовыйордер 					= СтрДокумент.Ссылка.ПолучитьОбъект();
					СтрокаОплаты.Контрагент 		= Кассовыйордер.Контрагент;
					СтрокаОплаты.ДоговорКонтрагента = Кассовыйордер.ДоговорКонтрагента;
					СтрокаОплаты.ЗаказПокупателя 	= Кассовыйордер.РасшифровкаПлатежа[0].Сделка;
					СтрокаОплаты.Валюта 			= Кассовыйордер.ВалютаДокумента;
					СтрокаОплаты.КурсВал			= Общий.ПолучитьКурсОплаты(Кассовыйордер, Кассовыйордер.ВалютаДокумента);
					Попытка
						СтрокаОплаты.КурсУпр		= Кассовыйордер.РасшифровкаПлатежа[0].КурсВзаиморасчетов;
					Исключение
						СтрокаОплаты.КурсУпр		= 1;      // Платіжка завжди в гривнях

					КонецПопытки;
					СтрокаОплаты.Сумма      		= Кассовыйордер.СуммаДокумента;
					СтрокаОплаты.Возврат 			= ТипЗнч(СтрДокумент.Ссылка) = Тип("ДокументСсылка.РасходныйКассовыйОрдер");
					СтрокаОплаты.КассовыйОрдер 		= СтрДокумент.Ссылка;
					Если ТипЗнч(СтрДокумент.Ссылка) = Тип("ДокументСсылка.ПлатежноеПоручениеВходящее") Тогда 
						СтрокаОплаты.Безналичные = Истина;
					КонецЕсли;
					//ЗаписьЖурналаРегистрации("МАРШРУТНИЙ_ДОКУМЕНТИ", УровеньЖурналаРегистрации.Информация,,,"22");
					//Тільки непланові заповнюєм
					Если НЕ НовыйОбъект.Расчеты.НайтиСтроки(Новый Структура("Контрагент, ДоговорКонтрагента", СтрокаОплаты.Контрагент, СтрокаОплаты.ДоговорКонтрагента)).Количество() И СтрокаОплаты.ДоговорКонтрагента = СтрокаОплаты.Контрагент.ДоговорДляНеплановыхПродаж Тогда
									
						
						НовРасчетыСтрока =  НовыйОбъект.Расчеты.Добавить();
						ЗаполнитьЗначенияСвойств(НовРасчетыСтрока, СтрокаОплаты);
						НовРасчетыСтрока.СуммаБезСкидки = СтрокаОплаты.Сумма;
						НовРасчетыСтрока.СуммаОплаты = СтрокаОплаты.Сумма;
					КонецЕсли;
					
						
			КонецЕсли;	
		КонецЦикла;				
		 
		Попытка
			НовыйОбъект.Записать();
		Исключение
			ЗаписьЖурналаРегистрации("ОшибкаОбмена", УровеньЖурналаРегистрации.Ошибка , , "" ,ОписаниеОшибки());
		КонецПопытки;
	
		
		Если ДобавитьДок Тогда 
			МассивДокументов.Добавить(НовыйОбъект.Ссылка);
		КонецЕсли;
	КонецЦикла;	
	
	Если ЗначениеЗаполнено(ТекИД) Тогда 
		НовСтр 		= ТаблицаИД.Добавить();
		НовСтр.ИД 	= ТекИД;
	КонецЕсли;
	
	Для Каждого ДокСсылка Из МассивДокументов Цикл
		Если ДокСсылка.ПометкаУдаления Тогда 
			Продолжить;
		КонецЕсли;
		ДокОб = ДокСсылка.ПолучитьОбъект();
		Попытка
			ДокОб.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		Исключение
		КонецПопытки;
	КонецЦикла;
	
КонецПроцедуры

Процедура СоздатьНапоминания(Данные, Продавец, ТаблицаИД);
	
	Для Каждого Напоминания Из Данные Цикл;
		
		Ссылка  = Справочники.Напоминания.ПолучитьСсылку(Напоминания.УИДСсылка);
		Если ЗначениеЗаполнено(Ссылка.ВерсияДанных) Тогда 
			Объект = Ссылка.ПолучитьОбъект();
		Иначе
			Объект = Справочники.Напоминания.СоздатьЭлемент();
			Объект.УстановитьСсылкуНового(Ссылка);
			Объект.УстановитьНовыйКод();
		КонецЕсли;
		Объект.ОбменДанными.Загрузка = Истина;
		
		Объект.ТорговийАгент = Продавец;
		Объект.Наименование = Напоминания.Наименование;
		Объект.ОписаниеНапоминания = Напоминания.ОписаниеНапоминания;
		Объект.Активно = Напоминания.Активно;
		Объект.НапоминаниеОТоваре = Напоминания.НапоминаниеОТоваре;
		
		Объект.ДатаСоздания = Напоминания.ДатаСоздания;
		Объект.ИзЗаказа = Напоминания.ИзЗаказа;
	
		Если Напоминания.НапоминаниеОТоваре Тогда 
			
			Объект.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Напоминания.Контрагент);
			Объект.Товары.Очистить();
			
			Для Каждого Артикул Из Напоминания.Товары Цикл 
				Строка = Объект.Товары.Добавить();
				Строка.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Артикул.Номенклатура);
				Строка.Выполнено = Артикул.Выполнено; 
				Строка.Количество = Артикул.Количество;
			КонецЦикла;
			
		Иначе
			Объект.Периодичность = Перечисления.ПериодичностьНапоминаний.Получить(Напоминания.Периодичность);
			Объект.ДеньНедели = Напоминания.ДеньНедели;
			Объект.ДатаНапоминания = Напоминания.ДатаНапоминания;
			
		КонецЕсли;
	      Объект.Записать();
		  
		  Если ТипЗнч(ТаблицаИД) = Тип("Массив") Тогда 
			  ТаблицаИД.Добавить(Напоминания.ИД);
		  Иначе 
			  ТаблицаИД.Добавить().ИД = Напоминания.ИД;
		  КонецЕсли;
		  
	КонецЦикла;
	
	
КонецПроцедуры


