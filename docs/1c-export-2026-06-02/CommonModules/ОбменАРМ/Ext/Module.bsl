Функция  УстановитьБроньМешка(Знач Данные, Торговый) Экспорт 
	Ответ = Новый Структура;
	Ответ.Вставить("Успешно", Истина);
	
	Данные = Десериализовать(Данные);
	
	
	Если Данные.Команда = "ЗапросНаОбновлениеИнформацииОБрони" Тогда 
		
		Ответ.Вставить("ИнфоОБрони", ПолучитьИзмененныеБрониМешков(Торговый));
		Возврат Ответ;
 
	ИначеЕсли Данные.Команда = "ОтветНаОбновлениеИнформацииОБрони" Тогда 
		
		РегистрыСведений.ИзмененияБрониХарактеристики.УдалитьИзменение(Данные.МассивИД);
		Возврат Ответ;

	Иначе
		
		Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Данные.Характеристика);
		Если Характеристика.ВерсияДанных = "" Тогда 
			Ответ.Вставить("Успешно", Ложь);
			Ответ.Вставить("Ошибка", "Не вдалося знайти характеристику номенклатури в 1с!");
			Возврат Ответ;
		КонецЕсли;
		
		
		Если Данные.Команда = "УстановитьБронь" Тогда 
			
			Если Характеристика.ПериодБрони > ТекущаяДата() Тогда 
				Ответ.Вставить("Успешно", Ложь);
				Ответ.Вставить("Ошибка", "На мішок є активна бронь");
				Возврат Ответ;
			КонецЕсли;
			
			
			Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Данные.Контрагент);
			Если Контрагент.ВерсияДанных = "" Тогда 
				Ответ.Вставить("Успешно", Ложь);
				Ответ.Вставить("Ошибка", "Не вдалося знайти контрагента в 1с!");
				Возврат Ответ;
			КонецЕсли;
			
			Если НетНаСкладе(Характеристика) Тогда 
				
				Ответ.Вставить("Успешно", Ложь);
				Ответ.Вставить("Ошибка", "Мішка не має у наявності");
				Возврат Ответ;

			КонецЕсли;
			
			
			обХарактеристики = Характеристика.ПолучитьОбъект();
			обХарактеристики.Бронь = Торговый;
			обХарактеристики.Контрагент = Контрагент;
			обХарактеристики.ПериодБрони = Данные.ПериодБрони;
			обХарактеристики.ОбменДанными.Загрузка = Истина;
			обХарактеристики.Записать();
			
			Ответ.Вставить("Бронь", Строка(Торговый));
			
		ИначеЕсли Данные.Команда = "ВилучитиБронь" Тогда
			
			обХарактеристики = Характеристика.ПолучитьОбъект();
			обХарактеристики.Бронь = Неопределено;
			обХарактеристики.Контрагент = Неопределено;
			обХарактеристики.ПериодБрони = Неопределено;
			обХарактеристики.ОбменДанными.Загрузка = Истина;
			обХарактеристики.Записать();
			
		КонецЕсли;
	КонецЕсли;   
	Возврат Ответ;
	
КонецФункции

Процедура ОбновитьИдентификаторКлиента(знач Данные, Торговый) Экспорт 
	
	Данные = Десериализовать(Данные);
	
	Запись = РегистрыСведений.ИдентификаториКлиентов.СоздатьМенеджерЗаписи();
	Запись.ИдентификаторПриложения = Новый УникальныйИдентификатор(Данные.ИдентификаторПриложения);
	запись.Торговый = Торговый;
	Запись.ИдентификаторПолучателя = Данные.ИдентификаторПолучателя;    	
	Запись.Записать(Истина);
		
КонецПроцедуры


Функция ПолучитьИзмененныеБрониМешков(ТорговийАгент)
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ИзмененияБрониХарактеристики.Характеристика,
		|	ИзмененияБрониХарактеристики.УИД,
		|	ХарактеристикиНоменклатуры.Бронь = &Торговий КАК МояБронь,
		|	ХарактеристикиНоменклатуры.ПериодБрони,
		|	ПРЕДСТАВЛЕНИЕ(ИзмененияБрониХарактеристики.Характеристика.Бронь) КАК Бронь,
		|	ХарактеристикиНоменклатуры.Контрагент,
		|	ХарактеристикиНоменклатуры.СекторНаСкладі,
		|	ХарактеристикиНоменклатуры.Коментар,
		|	ХарактеристикиНоменклатуры.Открыт
		|ИЗ
		|	РегистрСведений.ИзмененияБрониХарактеристики КАК ИзмененияБрониХарактеристики
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ХарактеристикиНоменклатуры КАК ХарактеристикиНоменклатуры
		|		ПО ИзмененияБрониХарактеристики.Характеристика = ХарактеристикиНоменклатуры.Ссылка
		|ГДЕ
		|	ИзмененияБрониХарактеристики.Торговий = &Торговий";
	
	Запрос.УстановитьПараметр("Торговий", ТорговийАгент);
	ИнфоОБрони = Запрос.Выполнить().Выгрузить();
	ИнфоОБрони.Колонки.Добавить("УИДХарактеристики");
	ИнфоОБрони.Колонки.Добавить("УИДКонтрагент");
	
	Для Каждого Элемент Из ИнфоОБрони Цикл 
		Элемент.УидХарактеристики 	= Элемент.Характеристика.УникальныйИдентификатор();
		Элемент.УидКонтрагент		= Элемент.Контрагент.УникальныйИдентификатор();		
	КонецЦикла;
	
	ИнфоОБрони.Колонки.Удалить("Характеристика");
	ИнфоОБрони.Колонки.Удалить("Контрагент");
	
	Возврат ИнфоОБрони 
КонецФункции

Функция НетНаСкладе(Характеристика) 
	
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СУММА(ТоварыНаСкладахОстатки.КоличествоОстаток - ЕСТЬNULL(ТоварыВРезервеНаСкладахОстатки.КоличествоОстаток, 0)) КАК СвободныйОстаток
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.Остатки(&ТекущаяДата, ХарактеристикаНоменклатуры = &Характеристика) КАК ТоварыНаСкладахОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыВРезервеНаСкладах.Остатки(, ХарактеристикаНоменклатуры = &Характеристика) КАК ТоварыВРезервеНаСкладахОстатки
		|		ПО ТоварыНаСкладахОстатки.Склад = ТоварыВРезервеНаСкладахОстатки.Склад
		|			И ТоварыНаСкладахОстатки.Номенклатура = ТоварыВРезервеНаСкладахОстатки.Номенклатура
		|			И ТоварыНаСкладахОстатки.ХарактеристикаНоменклатуры = ТоварыВРезервеНаСкладахОстатки.ХарактеристикаНоменклатуры
		|
		|ИМЕЮЩИЕ
		|	СУММА(ТоварыНаСкладахОстатки.КоличествоОстаток - ЕСТЬNULL(ТоварыВРезервеНаСкладахОстатки.КоличествоОстаток, 0)) > 0";
	
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	Запрос.УстановитьПараметр("Характеристика", Характеристика);
	
	
	Возврат Запрос.Выполнить().Пустой()	
КонецФункции

Функция СформироватьДанныеОРезервах()
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТоварыНаСкладахОстатки.Номенклатура КАК Номенклатура,
		|	СУММА(ТоварыНаСкладахОстатки.КоличествоОстаток) КАК КоличествоОстаток
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.Остатки(, ) КАК ТоварыНаСкладахОстатки
		|ГДЕ
		|	ТоварыНаСкладахОстатки.КоличествоОстаток > 0
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыНаСкладахОстатки.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ТоварыВРезервеНаСкладахОстатки.Номенклатура КАК Номенклатура,
		|	СУММА(ТоварыВРезервеНаСкладахОстатки.КоличествоОстаток) КАК КоличествоОстаток,
		|	ТоварыВРезервеНаСкладахОстатки.ДокументРезерва.ТорговийАгент КАК ТорговийАгент
		|ИЗ
		|	РегистрНакопления.ТоварыВРезервеНаСкладах.Остатки КАК ТоварыВРезервеНаСкладахОстатки
		|ГДЕ
		|	НЕ ТоварыВРезервеНаСкладахОстатки.ДокументРезерва.ПометкаУдаления
		|
		|СГРУППИРОВАТЬ ПО
		|	ТоварыВРезервеНаСкладахОстатки.Номенклатура,
		|	ТоварыВРезервеНаСкладахОстатки.ДокументРезерва.ТорговийАгент";
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		// Вставити обробку вибірки ВыборкаДетальныеЗаписи
	КонецЦикла;
	
	//}}КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА

	
