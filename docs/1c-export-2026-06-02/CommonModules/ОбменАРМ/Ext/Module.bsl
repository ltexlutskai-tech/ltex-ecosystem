Функция ОтриматиДаніХарактеристики(Данные, Сектор) Экспорт

	Характеристика = Справочники.ХарактеристикиНоменклатуры.ПолучитьСсылку(Новый УникальныйИдентификатор(Данные));
	Если НЕ ЗначениеЗаполнено(Характеристика) Тогда 
		Возврат "";
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(Сектор) Тогда
		ХарОб = Характеристика.ПолучитьОбъект();
		ХарОб.СекторНаСкладі = Сектор;
		ХарОб.Записать();
	КонецЕсли;
	
	
	
	Возврат Характеристика.СекторНаСкладі;	
