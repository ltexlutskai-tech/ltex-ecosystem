
#Область ФОРМИРОВАНИЕ_ДАННЫХ_ДЛЯ_ОТПРАВКИ

Функция СформироватьПакетДанных(ИдентификаторКлиента, ПарольВхода) Экспорт
		
	Настройка = Неопределено;
	КолНеФиксироватьЗаписиОбмена = 0;
	Данные = Новый Структура;
	КоличесвтоЗаписейДляОбмена = 0;

	ПолнаяВыгрузка = ОбменАндроид.ПолнаяВыгрузка(ПарольВхода);
	СкладПартнера = ОбменАндроид.ПолучитьСкладПартнера(ПарольВхода);
	ПродавецПартнера = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
	//ЗаписьЖурналаРегистрации("Обмен АРМ",,,ПродавецПартнера, ИдентификаторКлиента);
	
	Данные.Вставить("Константы",		ДобавитьКонстанты(Настройка,СкладПартнера,ПродавецПартнера));	
	Данные.Вставить("Справочники",		ДобавитьСправочники(Настройка, ПарольВхода, ПолнаяВыгрузка,КоличесвтоЗаписейДляОбмена,СкладПартнера));	
	Данные.Вставить("РегистрСведений",	ДобавитьРегистрыСведений(Настройка,Данные.Справочники,СкладПартнера,КолНеФиксироватьЗаписиОбмена,ПродавецПартнера,ПолнаяВыгрузка));
	Данные.Вставить("РегистрНакопления",ДобавитьРегистрыНакопления(Настройка,КолНеФиксироватьЗаписиОбмена));
	Данные.Вставить("Документы",		ДобавитьДокументы(Настройка,Данные.Справочники,СкладПартнера,ПолнаяВыгрузка,КоличесвтоЗаписейДляОбмена,ПродавецПартнера));	 
	Данные.Вставить("ЭтоПолнаяВыгрузка",ПолнаяВыгрузка);
	
	
	Данные.Вставить("КоличествоЗаписейОбмена",КоличесвтоЗаписейДляОбмена);
	
	Возврат Сериализовать(Данные);
	
КонецФункции

Функция ВивантажитиТовари(ИдентификаторКлиента, ПарольВхода) Экспорт
		
	Настройка = Неопределено;
	КолНеФиксироватьЗаписиОбмена = 0;
	Данные = Новый Структура;
	КоличесвтоЗаписейДляОбмена = 0;

	ПолнаяВыгрузка = Ложь;
	СкладПартнера = ОбменАндроид.ПолучитьСкладПартнера(ПарольВхода);
	ПродавецПартнера = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);	
	
	СтрукрутаСправочников = Новый Структура;
	
	ДобавитьСправочникНоменклатура(СтрукрутаСправочников, Настройка, ПолнаяВыгрузка, ПродавецПартнера,КоличесвтоЗаписейДляОбмена,СкладПартнера);
	ДобавитьСправочникХарактеристики(СтрукрутаСправочников,СкладПартнера,ПродавецПартнера);
	ДобавитьСправочникЕдиницыИзмерения(СтрукрутаСправочников);	
		
	Данные.Вставить("Константы",		ДобавитьКонстанты(Настройка,СкладПартнера,ПродавецПартнера));
	Данные.Вставить("Справочники",		СтрукрутаСправочников);	
	
	
	СтруктураРегистрыСведений = Новый Структура;
	ДобавитьРегистрШтрихкоды(СтруктураРегистрыСведений, СтрукрутаСправочников, КоличесвтоЗаписейДляОбмена);

	Данные.Вставить("РегистрСведений",	СтруктураРегистрыСведений);
	Данные.Вставить("РегистрНакопления",Неопределено);
	Данные.Вставить("Документы",		Неопределено);	 
	Данные.Вставить("ЭтоПолнаяВыгрузка", Ложь);
	Данные.Вставить("КоличествоЗаписейОбмена",КоличесвтоЗаписейДляОбмена);
	
	Возврат Сериализовать(Данные);
	
КонецФункции

