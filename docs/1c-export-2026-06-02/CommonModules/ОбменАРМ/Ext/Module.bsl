Функция ПолучитьДанныеДляАктуализацииЗаказовПокупателя(Контрагент)
	
	  	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Даний фрагмент побудований конструктором.
	// При повторному використанні конструктора, внесені вручну зміни будуть втрачені!!!
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказПокупателяТовары.Ссылка КАК Заказ,
		|	ЗаказПокупателяТовары.Номенклатура,
		|	СУММА(ЗаказПокупателяТовары.Количество) КАК Количество,
		|	СУММА(ЗаказПокупателяТовары.Сумма) КАК Сумма
		|ПОМЕСТИТЬ Заказы
		|ИЗ
		|	Документ.ЗаказПокупателя.Товары КАК ЗаказПокупателяТовары
		|ГДЕ
		|	ЗаказПокупателяТовары.Ссылка.СтатусЗамовлення = &СтатусЗамовлення
		|	И ЗаказПокупателяТовары.Ссылка.Проведен
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаказПокупателяТовары.Ссылка,
		|	ЗаказПокупателяТовары.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РеализацияТоваровУслугТовары.Ссылка.Сделка КАК Заказ,
		|	РеализацияТоваровУслугТовары.Номенклатура,
		|	СУММА(РеализацияТоваровУслугТовары.Количество) КАК Количество
		|ПОМЕСТИТЬ Реализации
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|ГДЕ
		|	РеализацияТоваровУслугТовары.Ссылка.Сделка.СтатусЗамовлення = &СтатусЗамовлення
		|	И РеализацияТоваровУслугТовары.Ссылка.Проведен
		|
		|СГРУППИРОВАТЬ ПО
		|	РеализацияТоваровУслугТовары.Ссылка.Сделка,
		|	РеализацияТоваровУслугТовары.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Заказы.Заказ,
		|	Заказы.Номенклатура
		|ПОМЕСТИТЬ ЗакрытиеПозиции
		|ИЗ
		|	Заказы КАК Заказы
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Реализации КАК Реализации
		|		ПО Заказы.Заказ = Реализации.Заказ
		|			И Заказы.Номенклатура = Реализации.Номенклатура
		|ГДЕ
		|	Заказы.Количество = Реализации.Количество
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.Заказ КАК Заказ
		|ИЗ
		|	(ВЫБРАТЬ
		|		Заказы.Заказ КАК Заказ,
		|		Заказы.Номенклатура КАК Номенклатура
		|	ИЗ
		|		Заказы КАК Заказы
		|			ЛЕВОЕ СОЕДИНЕНИЕ ЗакрытиеПозиции КАК ЗакрытиеПозиции
		|			ПО Заказы.Заказ = ЗакрытиеПозиции.Заказ
		|	
		|	СГРУППИРОВАТЬ ПО
		|		Заказы.Заказ,
		|		Заказы.Номенклатура) КАК ВложенныйЗапрос
		|		ЛЕВОЕ СОЕДИНЕНИЕ ЗакрытиеПозиции КАК ЗакрытиеПозиции
		|		ПО (ЗакрытиеПозиции.Заказ = ВложенныйЗапрос.Заказ)
		|			И (ЗакрытиеПозиции.Номенклатура = ВложенныйЗапрос.Номенклатура)
		|
		|СГРУППИРОВАТЬ ПО
		|	ВложенныйЗапрос.Заказ
		|
		|ИМЕЮЩИЕ
		|	НЕ МАКСИМУМ(ЗакрытиеПозиции.Заказ ЕСТЬ NULL)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Заказы.Заказ,
		|	Заказы.Номенклатура,
		|	Заказы.Количество - ЕСТЬNULL(Реализации.Количество, 0) КАК Количество,
		|	Заказы.Заказ.Номер КАК Номер,
		|	Заказы.Сумма,
		|	ПРЕДСТАВЛЕНИЕ(Заказы.Номенклатура) КАК НоменклатураПредставление
		|ИЗ
		|	Заказы КАК Заказы
		|		ЛЕВОЕ СОЕДИНЕНИЕ Реализации КАК Реализации
		|		ПО Заказы.Заказ = Реализации.Заказ
		|			И Заказы.Номенклатура = Реализации.Номенклатура
		|ГДЕ
		|	Заказы.Количество - ЕСТЬNULL(Реализации.Количество, 0) > 0
		|	И Заказы.Заказ.Контрагент = &Контрагент";
	
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказПокупателя.Ссылка,
		|	ЗаказПокупателяТовары.Номенклатура,
		|	СУММА(ЗаказПокупателяТовары.Количество) КАК Количество,
		|	ЗаказПокупателя.Контрагент,
		|	ЗаказПокупателя.Дата,
		|	ЗаказПокупателяТовары.Сумма
		|ПОМЕСТИТЬ Заказы
		|ИЗ
		|	Документ.ЗаказПокупателя.Товары КАК ЗаказПокупателяТовары
