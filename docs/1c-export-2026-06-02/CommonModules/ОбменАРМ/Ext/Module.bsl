Функция ДобавитьСправочникиДляКонтрагентов(СтрукрутаСправочников)
	
	ТЗ = СтрукрутаСправочников.Контрагенты;
	
	мГорода = ТЗ.Скопировать();
	мГорода.Свернуть("Город");
	
	мОбласти = ТЗ.Скопировать();
	мОбласти.Свернуть("Область");
	
	мСтатус = ТЗ.Скопировать();
	мСтатус.Свернуть("СтатусКонтрагента");
	
	мТорговыйАгент = ТЗ.Скопировать();
	мТорговыйАгент.Свернуть("ТорговыйАгент");
	
	//++
	мСтатусОперативный = ТЗ.Скопировать();
	мСтатусОперативный.Свернуть("ОперативныйСтатусКонтрагента");
	
	Для Каждого стрЭлемента Из мСтатусОперативный Цикл
		НоваяСтрока = мСтатус.Добавить();
		НоваяСтрока.СтатусКонтрагента = стрЭлемента.ОперативныйСтатусКонтрагента;		
	КонецЦикла;	
	мСтатус.Свернуть("СтатусКонтрагента");
	//++
	
	//++
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КонтрагентыБанковскиеСчетаДляОплаты.БанковскийСчет КАК БанковскийСчет
		|ИЗ
		|	Справочник.Контрагенты.БанковскиеСчетаДляОплаты КАК КонтрагентыБанковскиеСчетаДляОплаты
		|ГДЕ
		|	КонтрагентыБанковскиеСчетаДляОплаты.Ссылка В(&Ссылка)";
	
	Запрос.УстановитьПараметр("Ссылка", ТЗ.ВыгрузитьКолонку("Контрагент"));
	
	мБанковскийСчет = Запрос.Выполнить().Выгрузить();
	мБанковскийСчет.Свернуть("БанковскийСчет");
	//++
	
	Запрос = Новый Запрос("ВЫБРАТЬ
	                      |	КонтрагентыМаршруты.Маршрут
	                      |ИЗ
	                      |	Справочник.Контрагенты.Маршруты КАК КонтрагентыМаршруты
	                      |
	                      |ОБЪЕДИНИТЬ ВСЕ
	                      |
	                      |ВЫБРАТЬ
	                      |	Контрагенты.Маршрут
	                      |ИЗ
	                      |	Справочник.Контрагенты КАК Контрагенты
	                      |ГДЕ
	                      |	Контрагенты.Ссылка В(&Ссылка)");
	Запрос.УстановитьПараметр("Ссылка", ТЗ.ВыгрузитьКолонку("Контрагент"));

	мМаршрут = Запрос.Выполнить().Выгрузить();
	мМаршрут.Свернуть("Маршрут");
	
	мКатегорииТТ = ТЗ.Скопировать();
	мКатегорииТТ.Свернуть("КатегорияТТ");

	
	мСпособыДоставки = ТЗ.Скопировать();
	мСпособыДоставки.Свернуть("СпособДоставки");

	мКаналиПошуку = ТЗ.Скопировать();
	мКаналиПошуку.Свернуть("КаналПошуку");

	
	
	ДобавитьСправочникГородаОбласти(СтрукрутаСправочников, мГорода.ВыгрузитьКолонку("Город"), мОбласти.ВыгрузитьКолонку("Область"));
	ДобавитьСправочникМаршруты(СтрукрутаСправочников, мМаршрут.ВыгрузитьКолонку("Маршрут"));
	ДобавитьСправочникСтатусКонтрагента(СтрукрутаСправочников, мСтатус.ВыгрузитьКолонку("СтатусКонтрагента"));
	ДобавитьСправочникКатегорииТТ(СтрукрутаСправочников, мКатегорииТТ.ВыгрузитьКолонку("КатегорияТТ"));
	ДобавитьСправочникСпособыДоставки(СтрукрутаСправочников, мСпособыДоставки.ВыгрузитьКолонку("СпособДоставки"));
	ДобавитьСправочникТорговыйАгент(СтрукрутаСправочников, мТорговыйАгент.ВыгрузитьКолонку("ТорговыйАгент"));
	ДобавитьСправочникБанковскиеСчета(СтрукрутаСправочников, мБанковскийСчет.ВыгрузитьКолонку("БанковскийСчет"));
	ДобавитьСправочникКаналиПошуку(СтрукрутаСправочников, мКаналиПошуку.ВыгрузитьКолонку("КаналПошуку"));	
	
КонецФункции




Процедура ДобавитьХранилищеДополнительнойИнформации(СтрукрутаСправочников,Продавец)
	
	Запрос = Новый Запрос;
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	РегистрацияОбмена.Объект КАК Номенклатура
	               |ИЗ
	               |	РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
	               |ГДЕ
	               |	РегистрацияОбмена.ВыгружатьФайлы
	               |	И РегистрацияОбмена.Объект В (&Объект)
	               |	И РегистрацияОбмена.Продавец = &Продавец";
	Запрос.УстановитьПараметр("Объект",СтрукрутаСправочников.Номенклатура.ВыгрузитьКолонку("Ссылка"));
	Запрос.УстановитьПараметр("Продавец",Продавец);
	МассивНоменклатуры = Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Номенклатура");
	
	Запрос.Текст = "ВЫБРАТЬ
	|	ХранилищеДополнительнойИнформации.Ссылка КАК Ссылка,
	|	ХранилищеДополнительнойИнформации.Объект.Наименование КАК Наименование,
	|	ВЫРАЗИТЬ(ХранилищеДополнительнойИнформации.Объект КАК Справочник.Номенклатура) КАК Номенклатура,
	|	ХранилищеДополнительнойИнформации.Характеристика,
	|	ХранилищеДополнительнойИнформации.Хранилище
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации КАК ХранилищеДополнительнойИнформации
	|ГДЕ
	|	НЕ ХранилищеДополнительнойИнформации.ПометкаУдаления
	|	И ХранилищеДополнительнойИнформации.Объект В (&МассивГрупп)";
	
	Запрос.УстановитьПараметр("МассивГрупп", МассивНоменклатуры);
	
	ТЗ = Запрос.Выполнить().Выгрузить();
	
	СтрукрутаСправочников.Вставить("ХранилищеДополнительнойИнформации", ТЗ);
	
КонецПроцедуры	

Процедура ОтриматиБорг(Контрагент, Борг, ПросроченийБорг, боргТзОВ, ПросроченийБоргТзОВ)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.Организация КАК Організація,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.Контрагент,
		|	СУММА(ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.СуммаВзаиморасчетовОстаток) КАК Борг,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДокументРасчетовСКонтрагентом.Ссылка,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДокументРасчетовСКонтрагентом.Дата
		|ПОМЕСТИТЬ боргТзОВ
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентамиПоДокументамРасчетов.Остатки(
		|			&НаДату,
		|			Контрагент = &ВідбірКонтрагент
		|				И Организация = &ТзОВ) КАК ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.Контрагент,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.Организация,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДоговорКонтрагента,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДокументРасчетовСКонтрагентом.Ссылка,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДокументРасчетовСКонтрагентом.Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	боргТзОВ.Контрагент,
		|	боргТзОВ.Борг,
		|	боргТзОВ.ДокументРасчетовСКонтрагентомДата
		|ПОМЕСТИТЬ просрочТзОВ
		|ИЗ
		|	боргТзОВ КАК боргТзОВ
		|ГДЕ
		|	боргТзОВ.ДокументРасчетовСКонтрагентомДата < &ПрДата
		|
		|СГРУППИРОВАТЬ ПО
		|	боргТзОВ.Контрагент,
		|	боргТзОВ.Борг,
		|	боргТзОВ.ДокументРасчетовСКонтрагентомДата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(0) КАК ПросроченийБорг,
		|	боргТзОВ.Контрагент КАК Контрагент,
		|	СУММА(боргТзОВ.Борг) КАК Борг
		|ПОМЕСТИТЬ БоргиДоГрупуванняТзОВ
		|ИЗ
		|	боргТзОВ КАК боргТзОВ
		|
		|СГРУППИРОВАТЬ ПО
		|	боргТзОВ.Контрагент
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	просрочТзОВ.Борг,
		|	просрочТзОВ.Контрагент,
		|	СУММА(0)
		|ИЗ
		|	просрочТзОВ КАК просрочТзОВ
		|
		|СГРУППИРОВАТЬ ПО
		|	просрочТзОВ.Контрагент,
		|	просрочТзОВ.Борг
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.Организация КАК Організація,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.Контрагент,
		|	СУММА(ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.СуммаВзаиморасчетовОстаток) КАК Борг,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДокументРасчетовСКонтрагентом.Ссылка,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДокументРасчетовСКонтрагентом.Дата
		|ПОМЕСТИТЬ боргБезТзОВ
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентамиПоДокументамРасчетов.Остатки(
		|			&НаДату,
		|			Контрагент = &ВідбірКонтрагент
		|				И Организация = &БезТзОВ) КАК ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.Контрагент,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.Организация,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДоговорКонтрагента,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДокументРасчетовСКонтрагентом.Ссылка,
		|	ВзаиморасчетыСКонтрагентамиПоДокументамРасчетовОстатки.ДокументРасчетовСКонтрагентом.Дата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	боргБезТзОВ.Контрагент,
		|	боргБезТзОВ.Борг,
		|	боргБезТзОВ.ДокументРасчетовСКонтрагентомДата
		|ПОМЕСТИТЬ просрочБезТзОВ
		|ИЗ
		|	боргБезТзОВ КАК боргБезТзОВ
		|ГДЕ
		|	боргБезТзОВ.ДокументРасчетовСКонтрагентомДата < &ПрДата
		|
		|СГРУППИРОВАТЬ ПО
		|	боргБезТзОВ.Контрагент,
		|	боргБезТзОВ.Борг,
		|	боргБезТзОВ.ДокументРасчетовСКонтрагентомДата
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	СУММА(0) КАК ПросроченийБорг,
		|	боргБезТзОВ.Контрагент КАК Контрагент,
		|	СУММА(боргБезТзОВ.Борг) КАК Борг
		|ПОМЕСТИТЬ БоргиДоГрупуванняБезТзОВ
		|ИЗ
		|	боргБезТзОВ КАК боргБезТзОВ
		|
		|СГРУППИРОВАТЬ ПО
		|	боргБезТзОВ.Контрагент
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	просрочБезТзОВ.Борг,
		|	просрочБезТзОВ.Контрагент,
		|	СУММА(0)
		|ИЗ
		|	просрочБезТзОВ КАК просрочБезТзОВ
		|
		|СГРУППИРОВАТЬ ПО
		|	просрочБезТзОВ.Контрагент,
		|	просрочБезТзОВ.Борг
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	БоргиДоГрупування.Контрагент,
		|	СУММА(БоргиДоГрупування.Борг) КАК БоргТзОВ,
		|	СУММА(0) КАК БоргБезТзОВ,
		|	СУММА(БоргиДоГрупування.ПросроченийБорг) КАК ПросроченийБоргТзОВ,
		|	СУММА(0) КАК ПросроченийБоргБезТзОВ
		|ПОМЕСТИТЬ ОбэднаныБорги
		|ИЗ
		|	БоргиДоГрупуванняТзОВ КАК БоргиДоГрупування
		|
		|СГРУППИРОВАТЬ ПО
		|	БоргиДоГрупування.Контрагент
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	БоргиДоГрупуванняБезТзОВ.Контрагент,
		|	СУММА(0),
		|	СУММА(БоргиДоГрупуванняБезТзОВ.Борг),
		|	СУММА(0),
		|	СУММА(БоргиДоГрупуванняБезТзОВ.ПросроченийБорг)
		|ИЗ
		|	БоргиДоГрупуванняБезТзОВ КАК БоргиДоГрупуванняБезТзОВ
		|
		|СГРУППИРОВАТЬ ПО
		|	БоргиДоГрупуванняБезТзОВ.Контрагент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ОбэднаныБорги.Контрагент,
		|	СУММА(ОбэднаныБорги.БоргТзОВ) КАК БоргТзОВ,
		|	СУММА(ОбэднаныБорги.БоргБезТзОВ) КАК БоргБезТзОВ,
		|	СУММА(ОбэднаныБорги.ПросроченийБоргТзОВ) КАК ПросроченийБоргТзОВ,
		|	СУММА(ОбэднаныБорги.ПросроченийБоргБезТзОВ) КАК ПросроченийБоргБезТзОВ
		|ИЗ
		|	ОбэднаныБорги КАК ОбэднаныБорги
		|
		|СГРУППИРОВАТЬ ПО
		|	ОбэднаныБорги.Контрагент";
	
	Запрос.УстановитьПараметр("ВідбірКонтрагент", Контрагент);
	Запрос.УстановитьПараметр("ТзОВ", Справочники.Организации.НайтиПоКоду("000000001"));
	Запрос.УстановитьПараметр("БезТзОВ", Справочники.Организации.ВолиньТабак);
	Запрос.УстановитьПараметр("НаДату", ТекущаяДата());
	Запрос.УстановитьПараметр("ПрДата", ТекущаяДата() + (24*60*60) - 604800);
	
	Выборка	 = Запрос.Выполнить().Выбрать();
	
	
	Если Выборка.Следующий() тогда 
		Борг =Выборка.БоргБезТзОВ;
		ПросроченийБорг = Выборка.ПросроченийБоргБезТзОВ;
		боргТзОВ =Выборка.БоргТзОВ;
		ПросроченийБоргТзОВ=Выборка.ПросроченийБоргТзОВ ;
	иначе 
		Борг =0;
		ПросроченийБорг = 0;
		боргТзОВ =0;
		ПросроченийБоргТзОВ=0; 
	КонецЕсли;	
	
КонецПроцедуры

Процедура ЗаповнитиБоргиКонтрагентів_НеВикористовувати(ТзКонтрагентов)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТЗКонтрагентів.Контрагент КАК Ссилка
		|ПОМЕСТИТЬ ТЗКонтрагентів
		|ИЗ
		|	&ТЗКонтрагентів КАК ТЗКонтрагентів
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссилка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗРЕШЕННЫЕ
		|	ВзаиморасчетыСКонтрагентамиОстатки.Контрагент,
		|	СУММА(0) КАК БоргТЗОВ,
		|	СУММА(0) КАК ПростроченийБоргТЗОВ,
		|	СУММА(ВзаиморасчетыСКонтрагентамиОстатки.СуммаУпрОстаток) КАК Борг,
		|	СУММА(0) КАК ПростроченийБорг
		//|	СУММА(ВЫБОР
		//|			КОГДА ВзаиморасчетыСКонтрагентамиОстатки.ДокументРасчетовСКонтрагентом.Дата < &ПрДата
		//|				ТОГДА ВзаиморасчетыСКонтрагентамиОстатки.СуммаВзаиморасчетовОстаток
		//|			ИНАЧЕ 0
		//|		КОНЕЦ) КАК ПростроченийБорг
		|ИЗ
		|	РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки(
		|			&НаДату,
		|			Контрагент В
		|					(ВЫБРАТЬ
		|						ТЗКонтрагентів.Ссилка
		|					ИЗ
		|						ТЗКонтрагентів КАК ТЗКонтрагентів)) КАК ВзаиморасчетыСКонтрагентамиОстатки
		|
		|СГРУППИРОВАТЬ ПО
		|	ВзаиморасчетыСКонтрагентамиОстатки.Контрагент";
	
	Запрос.УстановитьПараметр("ТЗКонтрагентів", ТзКонтрагентов);
	Запрос.УстановитьПараметр("НаДату", ТекущаяДата());
	Запрос.УстановитьПараметр("ПрДата", ТекущаяДата() + (24*60*60) - 604800);
	
	Выборка	 = Запрос.Выполнить().Выбрать();
		
	Пока Выборка.Следующий() Цикл  
		СтрокаТЗ = ТзКонтрагентов.Найти(Выборка.Контрагент, "Контрагент");
		Если СтрокаТЗ <> Неопределено Тогда 
			СтрокаТЗ.Борг =Выборка.Борг;
			СтрокаТЗ.ПросроченийБорг = Выборка.ПростроченийБорг;
			СтрокаТЗ.боргТзОВ =Выборка.БоргТзОВ;
			СтрокаТЗ.ПросроченийБоргТзОВ=Выборка.ПростроченийБоргТзОВ ;
		КонецЕсли;
	КонецЦикла;		
КонецПроцедуры

Процедура ЗаповнитиБоргиКонтрагентів(ТзКонтрагентов)
	
	ДатаПрострочки = ТекущаяДата() + (24*3600) - (3600 * 24 * 14);
	
	Запрос = Новый Запрос;
	Запрос.Текст ="ВЫБРАТЬ
	              |	ТЗКонтрагентів.Контрагент КАК Контрагент
	              |ПОМЕСТИТЬ ТЗКонтрагентів
	              |ИЗ
	              |	&ТЗКонтрагентів КАК ТЗКонтрагентів
	              |
	              |ИНДЕКСИРОВАТЬ ПО
	              |	Контрагент
	              |;
	              |
	              |////////////////////////////////////////////////////////////////////////////////
	              |ВЫБРАТЬ
	              |	РеализацияТоваровУслуг.Дата КАК Дата,
	              |	ВложенныйЗапрос.Контрагент КАК Контрагент,
	              |	ЕСТЬNULL(РеализацияТоваровУслуг.СуммаДокумента, 0) КАК СуммаДокумента,
	              |	ВложенныйЗапрос.СуммаВзаиморасчетовОстаток КАК БоргКонтрагента
	              |ИЗ
	              |	(ВЫБРАТЬ
	              |		ВзаиморасчетыСКонтрагентамиОстатки.Контрагент КАК Контрагент,
	              |		ВзаиморасчетыСКонтрагентамиОстатки.СуммаУпрОстаток КАК СуммаВзаиморасчетовОстаток
	              |	ИЗ
	              |		РегистрНакопления.ВзаиморасчетыСКонтрагентами.Остатки КАК ВзаиморасчетыСКонтрагентамиОстатки
	              |			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ТЗКонтрагентів КАК ТЗКонтрагентів
	              |			ПО ВзаиморасчетыСКонтрагентамиОстатки.Контрагент = ТЗКонтрагентів.Контрагент) КАК ВложенныйЗапрос
	              |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	              |		ПО (ВложенныйЗапрос.Контрагент = РеализацияТоваровУслуг.Контрагент)
	              |			И (РеализацияТоваровУслуг.Проведен)
				  //|ГДЕ
				  //|	РеализацияТоваровУслуг.СуммаДокумента > 0
	              |
	              |УПОРЯДОЧИТЬ ПО
	              |	Дата УБЫВ
	              |ИТОГИ
	              |	СРЕДНЕЕ(БоргКонтрагента)
	              |ПО
	              |	Контрагент";
	
	Запрос.УстановитьПараметр("ТЗКонтрагентів", ТзКонтрагентов);
	Запрос.УстановитьПараметр("НаДату", ТекущаяДата());

	ВыборкаКонтрагент = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаКонтрагент.Следующий() Цикл
		
		СуммаБоргу 			= ВыборкаКонтрагент.БоргКонтрагента;
	    Борг				= 0;
		ПростроченийБорг 	= 0;
		Выборка 			= ВыборкаКонтрагент.Выбрать();
	
		Пока Выборка.Следующий() Цикл
			Если Выборка.СуммаДокумента = 0 Тогда 
				Продолжить;
			КонецЕсли;
			
			Если СуммаБоргу = 0 Тогда 
				
				Прервать;
				
			ИначеЕсли СуммаБоргу < 0 Тогда 
				
				Борг = Борг + СуммаБоргу;
				
				Прервать;
				
			ИначеЕсли СуммаБоргу >= Выборка.СуммаДокумента  Тогда 
				
				Борг 				= Борг + Выборка.СуммаДокумента;
				ПростроченийБорг 	= ПростроченийБорг + ?(ДатаПрострочки > Выборка.Дата, Выборка.СуммаДокумента, 0);
				СуммаБоргу 			= СуммаБоргу - Выборка.СуммаДокумента;
				
			ИначеЕсли Выборка.СуммаДокумента > СуммаБоргу Тогда 
				
				Борг 				= Борг + СуммаБоргу;
				ПростроченийБорг 	= ПростроченийБорг + ?(ДатаПрострочки > Выборка.Дата, СуммаБоргу, 0);

				Прервать;
				
			КонецЕсли;
			
		КонецЦикла;
		
		СтрокаТЗ = ТзКонтрагентов.Найти(ВыборкаКонтрагент.Контрагент, "Контрагент");
		Если СтрокаТЗ <> Неопределено Тогда 
			СтрокаТЗ.Борг = ВыборкаКонтрагент.БоргКонтрагента;
			СтрокаТЗ.ПросроченийБорг = ПростроченийБорг;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция АсортиментКонтрагентов(Контрагенты)
	
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	АсортиментПокупателя.Контрагент,
		|	АсортиментПокупателя.Асортимент
		|ИЗ
		|	РегистрСведений.АсортиментПокупателя КАК АсортиментПокупателя
		|ГДЕ
		|	АсортиментПокупателя.Контрагент В(&Контрагент)";
	
	Запрос.УстановитьПараметр("Контрагент", Контрагенты);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
	
КонецФункции

