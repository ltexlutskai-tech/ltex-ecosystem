			//ЗаписьЖурналаРегистрации("ЛОГ_РЕАЛИЗАЦИЯ3",УровеньЖурналаРегистрации.Информация,,"",СокрЛП(НовыйОбъект.Контрагент));
			
		КонецЕсли;
		Агент = НовыйОбъект.Контрагент.ТорговыйАгент; 
