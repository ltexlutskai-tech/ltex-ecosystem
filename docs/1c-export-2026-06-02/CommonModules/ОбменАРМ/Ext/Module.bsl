		БанковскиеСчетаДляОплаты.Колонки.Добавить("УИДБанковскийСчет");
		Для Каждого Элемент Из БанковскиеСчетаДляОплаты Цикл
			Элемент.УИДБанковскийСчет = Элемент.БанковскийСчетСсылка.УникальныйИдентификатор();
		КонецЦикла;
		БанковскиеСчетаДляОплаты.Колонки.Удалить("БанковскийСчетСсылка");
		

		Отбор = Новый Структура("Контрагент", Строка.Контрагент);
		Для Каждого Элемент Из ТЗ_Асортимент.НайтиСтроки(Отбор) Цикл 
			аСтрока = Строка.Асортимент.Добавить();
			аСтрока.Артикул = Элемент.Асортимент;
			аСтрока.РучнаяЗапись = ложь;
		КонецЦикла;
		
		Отбор = Новый Структура("Контрагент", Строка.Контрагент);
		Для Каждого Элемент Из ТЗ_АсортиментПрезентацій.НайтиСтроки(Отбор) Цикл 
			аСтрока = Строка.АсортиментПрезентацій.Добавить();
			аСтрока.Артикул = Элемент.Асортимент;
			аСтрока.РучнаяЗапись = ложь;
		КонецЦикла; 		
		
		КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + 1;
	КонецЦикла;
	
	СтрукрутаСправочников.Вставить("Контрагенты", ТзКонтрагентов);
	
	ТЗ_УдалитьКонтрагентов = Результат[2].Выгрузить();
	ТЗ_УдалитьКонтрагентов.Колонки.Добавить("Ссылка");
	
	Для Каждого Строка Из ТЗ_УдалитьКонтрагентов Цикл
		Строка.Ссылка = Строка.Контрагент.УникальныйИдентификатор();
	КонецЦикла;
	
	ТЗ_УдалитьКонтрагентов.Колонки.Удалить("Контрагент");
	КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена  + ТЗ_УдалитьКонтрагентов.Количество();
	СтрукрутаСправочников.Вставить("Удалить_Контрагенты", ТЗ_УдалитьКонтрагентов);

	
	///////// СкладыКонтрагентов
	
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	РегистрацияОбмена.Объект КАК Объект
	               |ПОМЕСТИТЬ РегистрацияТоргового
	               |ИЗ
	               |	РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
	               |ГДЕ
	               |	РегистрацияОбмена.Продавец = &ТорговийАгент
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	Объект
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	СкладыКонтрагентов.Ссылка КАК Контрагент
	               |ПОМЕСТИТЬ СкладиКонтрагентів
	               |ИЗ
	               |	Справочник.Контрагенты КАК СкладыКонтрагентов
	               |ГДЕ
	               |	СкладыКонтрагентов.ТорговыйАгент = &ТорговийАгент
	               |	И НЕ СкладыКонтрагентов.ПометкаУдаления
	               |	И СкладыКонтрагентов.Ссылка В ИЕРАРХИИ
	               |			(ВЫБРАТЬ
	               |				ВыгружатьВАндроидКонтрагентов.Контрагент
	               |			ИЗ
	               |				РегистрСведений.ВыгружатьВАндроидКонтрагентов КАК ВыгружатьВАндроидКонтрагентов
	               |			ГДЕ
	               |				ВыгружатьВАндроидКонтрагентов.ТорговийАгент = &ТорговийАгент
	               |				И ВыгружатьВАндроидКонтрагентов.Выгружать)
	               |	И НЕ СкладыКонтрагентов.ЭтоГруппа
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	СкладыКонтрагентов.Ссылка
	               |
	               |ИНДЕКСИРОВАТЬ ПО
	               |	Контрагент
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ДАТАВРЕМЯ(1, 1, 1) КАК СтрокДіїЛіцензії,
	               |	СкладиКонтрагентів.Контрагент КАК Контрагент,
	               |	ЗНАЧЕНИЕ(Справочник.склады.ПустаяСсылка) КАК Склад
	               |ИЗ
	               |	РегистрацияТоргового КАК РегистрацияТоргового
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ СкладиКонтрагентів КАК СкладиКонтрагентів
	               |		ПО РегистрацияТоргового.Объект = СкладиКонтрагентів.Контрагент
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	СкладиКонтрагентів.Контрагент";
	
	
	Запрос.УстановитьПараметр("ТорговийАгент", ТорговийАгент);
	
	ТзКонтрагентов = Запрос.Выполнить().Выгрузить();
	
	ТзКонтрагентов.Колонки.Добавить("УИДСсылка");
	ТзКонтрагентов.Колонки.Добавить("УИДКонтрагент");
	ТзКонтрагентов.Колонки.Добавить("Наименование");
	
	Для Каждого Строка Из ТзКонтрагентов Цикл
		Строка.УИДСсылка = Строка.Склад.УникальныйИдентификатор();
		Строка.УИДКонтрагент = Строка.Контрагент.УникальныйИдентификатор();
		Строка.Наименование = "";
		КоличесвтоЗаписейДляОбмена = КоличесвтоЗаписейДляОбмена + 1;
	КонецЦикла;
	
	СтрукрутаСправочников.Вставить("СкладыКонтрагентов", ТзКонтрагентов);
	
КонецПроцедуры

Процедура ДобавитьСправочникНапоминание(СтрукрутаСправочников, ТорговийАгент)
	
	Массив = Новый Массив;
 	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Напоминания.Ссылка,
		|	Напоминания.ТорговийАгент,
		|	Напоминания.Наименование,
		|	Напоминания.ОписаниеНапоминания,
		|	Напоминания.Периодичность.Порядок Как Периодичность,
		|	Напоминания.Активно,
		|	Напоминания.НапоминаниеОТоваре,
		|	Напоминания.Контрагент,
		|	РегистрацияОбмена.ИД,
		|	Напоминания.ДеньНедели,
		|	Напоминания.ДатаНапоминания
		|ИЗ
		|	Справочник.Напоминания КАК Напоминания
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
		|		ПО Напоминания.Ссылка = РегистрацияОбмена.Объект
		|			И Напоминания.ТорговийАгент = РегистрацияОбмена.Продавец
		|			И (Напоминания.ТорговийАгент = &ТорговийАгент)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	НапоминанияТовары.Номенклатура,
		|	НапоминанияТовары.Выполнено,
		|	РегистрацияОбмена.ИД
		|ИЗ
		|	Справочник.Напоминания.Товары КАК НапоминанияТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.РегистрацияОбмена КАК РегистрацияОбмена
		|		ПО НапоминанияТовары.Ссылка = РегистрацияОбмена.Объект
		|			И НапоминанияТовары.Ссылка.ТорговийАгент = РегистрацияОбмена.Продавец
		|			И (РегистрацияОбмена.Продавец = &ТорговийАгент)";
	Запрос.УстановитьПараметр("ТорговийАгент", ТорговийАгент);
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	Напоминания = РезультатЗапроса.Получить(0).Выбрать();
	Артикулы = РезультатЗапроса.Получить(1).Выгрузить();
	
	Пока Напоминания.Следующий() Цикл 
		
		Элемент = Новый Структура;
		Элемент.Вставить("УИДСсылка", Напоминания.Ссылка.УникальныйИдентификатор());
		Элемент.Вставить("Нагадування", Напоминания.ОписаниеНапоминания);
		Элемент.Вставить("Періодичність", Напоминания.Периодичность);
		Элемент.Вставить("Активне", Напоминания.Активно);
		Элемент.Вставить("НагадатиПроТовар", Напоминания.НапоминаниеОТоваре);
		Если  Напоминания.НапоминаниеОТоваре Тогда 
			
			Элемент.Вставить("Контрагент", Напоминания.Контрагент.УникальныйИдентификатор());
			Элемент.Вставить("Товары", Новый Массив);
			Для Каждого Артикул Из Артикулы.НайтиСтроки(Новый Структура("ИД", Напоминания.ИД)) Цикл
				СтруктураАртикул = Новый Структура();
				СтруктураАртикул.Вставить("Номенклатура", Артикул.Номенклатура.УникальныйИдентификатор());
				СтруктураАртикул.Вставить("Виконано", Артикул.Виконано);
				Элемент.Товары.Добавить(СтруктураАртикул);
			КонецЦикла;
			
		Иначе
			
			Элемент.Вставить("ДеньНедели", Напоминания.ДеньНедели);
			Элемент.Вставить("ДатаНапоминания", Напоминания.ДатаНапоминания);

		КонецЕсли;
		Массив.Добавить(Элемент);
	КонецЦикла;
	
	
	СтрукрутаСправочников.Вставить("Нагадування", Массив);
	
КонецПроцедуры

