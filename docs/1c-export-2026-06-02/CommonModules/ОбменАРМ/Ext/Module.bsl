	Пока Выборка.Следующий() Цикл 
		
		Если Отобрать И Объекты.Найти(Выборка.Ссылка) = Неопределено Тогда 
			Продолжить;
		КонецЕсли;
		
			ЭлементСправочника = Новый Структура;
			ЭлементСправочника.Вставить("УИДСсылка", 		Выборка.Ссылка.УникальныйИдентификатор());
			ЭлементСправочника.Вставить("Наименование",	 	Выборка.Наименование);
			ЭлементСправочника.Вставить("ПометкаУдаления", 	Выборка.ПометкаУдаления);
			ЭлементСправочника.Вставить("ЭтоГруппа", 		Выборка.ЭтоГруппа);
			Массив.Добавить(ЭлементСправочника);
		
		
	КонецЦикла;
	
	
	
	СтрукрутаСправочников.Вставить("СпособыДоставки", Массив);
КонецПроцедуры

