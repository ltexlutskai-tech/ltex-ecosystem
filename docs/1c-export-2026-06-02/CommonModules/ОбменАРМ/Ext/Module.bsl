Процедура ЗаписатьКілометражТорговогоАгента(ТаблицаЗаписів,Продавец)
	
	Для Каждого стр из ТаблицаЗаписів Цикл 
		
		Статус=ИмяЗначенияПеречисленияПоСинониму("СтатусДня",стр.Статус);
		Если Статус = Неопределено тогда
			Продолжить;
		КонецЕсли;
		НабірЗаписів = РегистрыСведений.КілометражТорговогоАгента.СоздатьНаборЗаписей();
		НабірЗаписів.Отбор.ТорговийАгент.Установить(Продавец);
		НабірЗаписів.Отбор.Период.Установить(стр.Период);
		
		НоваяЗапись = НабірЗаписів.Добавить(); 
		НоваяЗапись.Период = стр.Период; 
		НоваяЗапись.ТорговийАгент = Продавец; 
		НоваяЗапись.СтатусДня = Перечисления.СтатусДня[Статус];
		НоваяЗапись.Кілометраж = стр.Кілометраж; 
		Попытка
			НабірЗаписів.Записать();
	Исключение
		//Сообщить("Помилка при записі регістра відомостей ""Кілометраж торгового агента"" при обміні Андроїд");
		ЗаписьЖурналаРегистрации("ОбмінАндроїдЧитанняДаних",,,,"Помилка при записі регістра відомостей ""Кілометраж торгового агента"" при обміні Андроїд");
	КонецПопытки;

	КонецЦикла;

КонецПроцедуры

Процедура ЗаписатьКоординатыТорговогоАгента(ТаблицаЗаписів,Продавец)
	
	Для Каждого стр из ТаблицаЗаписів Цикл 
		
		НабірЗаписів = РегистрыСведений.РегистрацияКоординатТорговых.СоздатьНаборЗаписей();
		НабірЗаписів.Отбор.ТорговийАгент.Установить(Продавец);
		НабірЗаписів.Отбор.Дата.Установить(стр.Дата);
		
		НоваяЗапись = НабірЗаписів.Добавить(); 
		НоваяЗапись.Дата = стр.Дата; 
		НоваяЗапись.ТорговийАгент = Продавец; 
		НоваяЗапись.Широта = стр.Широта;
		НоваяЗапись.Долгота = стр.Долгота; 
		Попытка
			НабірЗаписів.Записать();
		Исключение
			ЗаписьЖурналаРегистрации("ОбмінАндроїдЧитанняДаних",,,,"Помилка при записі регістра відомостей ""Реєстрація координат торгового агента"" при обміні Андроїд");
		КонецПопытки;
		
	КонецЦикла;

КонецПроцедуры

Функция ОбработкаНомераТелефона(Телефон) Экспорт 
	
		
	
	Телефон = СтрЗаменить(Телефон,")","");
	Телефон = СтрЗаменить(Телефон,"(","");
	Телефон = СтрЗаменить(Телефон,"+38","");
	Телефон = СтрЗаменить(Телефон,"-","");
	Телефон = СтрЗаменить(Телефон,"_","");
	Телефон = СтрЗаменить(Телефон,".","");
	Телефон = СтрЗаменить(Телефон,",","");
	Телефон = СтрЗаменить(Телефон,"}","");
	Телефон = СтрЗаменить(Телефон,"{","");
	Телефон = СтрЗаменить(Телефон,"=","");
	Телефон = СтрЗаменить(Телефон," ","");
	Телефон = СтрЗаменить(Телефон,":","");
	Если СтрДлина(Телефон) > 13 Тогда 
		Если Сред(СокрЛП(Телефон),1,3) = "+38" Тогда
			Телефон = Сред(СокрЛП(Телефон),3);
		КонецЕсли;	
	КонецЕсли;
	
	Возврат СокрЛП(Телефон);
	
КонецФункции


Процедура ОбновитьКонтрагентов(ТаблицаКонтрагентов,Склад, ТаблицаИД, Продавец, МассивОшибок)
	Для Каждого СтрокаДанныеЭлемента Из ТаблицаКонтрагентов Цикл
					  
		ТекКонтрОб = Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка).ПолучитьОбъект();
		ТекТипЦен = Справочники.ТипыЦенНоменклатуры.ПолучитьСсылку(СтрокаДанныеЭлемента.ТипЦен);
		
		Если ТекКонтрОб = Неопределено Тогда  // Знайдемо може такий контрагент э вже в базі
			
			
			////
			Для Индекс = 1 по СтрЧислоСтрок(СтрокаДанныеЭлемента.НомерТелефона) Цикл
				ТекНомерТелефона = СокрЛП(СтрПолучитьСтроку(СтрокаДанныеЭлемента.НомерТелефона, Индекс));
				Если НЕ ЗначениеЗаполнено(ТекНомерТелефона) Тогда
					Продолжить;
				КонецЕсли;
				
				зПоНомеруТелефона = Новый Запрос;
				зПоНомеруТелефона.Текст = "ВЫБРАТЬ
				                          |	Контрагенты.Ссылка
				                          |ИЗ
				                          |	Справочник.Контрагенты КАК Контрагенты
				                          |ГДЕ
				                          |	Контрагенты.НомерТелефона = &НомерТелефона
				                          |
				                          |ОБЪЕДИНИТЬ ВСЕ
				                          |
				                          |ВЫБРАТЬ
				                          |	КонтрагентыДополнительныеНомераТелефонов.Ссылка
				                          |ИЗ
				                          |	Справочник.Контрагенты.ДополнительныеНомераТелефонов КАК КонтрагентыДополнительныеНомераТелефонов
				                          |ГДЕ
				                          |	КонтрагентыДополнительныеНомераТелефонов.Номер = &НомерТелефона";
				зПоНомеруТелефона.УстановитьПараметр("НомерТелефона", ОбработкаНомераТелефона(ТекНомерТелефона));
				Выборка = зПоНомеруТелефона.Выполнить().Выбрать();
				Если Выборка.Следующий() Тогда 
					ТекКонтрОб = Выборка.Ссылка.ПолучитьОбъект();
					ТекКонтрОб.мОбменАндроид = Истина;
					ТекКонтрОб.ТорговыйАгент = Продавец;
					ТекКонтрОб.Записать();
					МассивОшибок.Добавить("Клієнт з номером телефону " + ТекНомерТелефона + " вже є в базі! Виконайте повний обмін!");
				КонецЕсли;
				
				
			КонецЦикла;
			
			////	
			
			
		Иначе
			Попытка 
				ТекКонтрОб.Заблокировать();
			Исключение
				Продолжить;
			КонецПопытки;
			
		КонецЕсли;	
		
		
		
		
		Если ТекКонтрОб = Неопределено Тогда 
			
			
			ТекКонтрОб = Справочники.Контрагенты.СоздатьЭлемент();	
			ЗаполнитьЗначенияСвойств(ТекКонтрОб, СтрокаДанныеЭлемента,,"НомерТелефона"); 
			ТекКонтрОб.УстановитьСсылкуНового(Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка));
			ТекКонтрОб.мОбменАндроид = Истина;
			ЗаписьЖурналаРегистрации("ЗмінаКонтрагента", УровеньЖурналаРегистрации.Информация, , СокрЛП(ТекКонтрОб.Наименование) + " - " + СокрЛП(СтрокаДанныеЭлемента.Наименование), "ОбменАРМ1");
			ТекКонтрОб.Наименование = СтрокаДанныеЭлемента.Наименование;
			ТекКонтрОб.Покупатель = Истина;
			ТекКонтрОб.Родитель = Справочники.Контрагенты.НайтиПоКоду("000000004");
			ТекКонтрОб.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо;
			ТекКонтрОб.НомерТелефона = ОбработкаНомераТелефона(СтрокаДанныеЭлемента.НомерТелефона);
			Если СтрокаДанныеЭлемента.Телефоны.Количество() Тогда 
				ОбновитьНомерыТелефоновКонтрагента(ТекКонтрОб, СтрокаДанныеЭлемента.Телефоны);
			КонецЕсли;

			
			ОбластьСсылка = Справочники.Области.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДОбласть);
			ОбъектОбласть = Неопределено;
			Попытка
				ОбъектОбласть = ОбластьСсылка.ПолучитьОбъект();
			Исключение КонецПопытки;
			Если ОбъектОбласть = Неопределено Тогда  
				ОбластьОб = Справочники.Области.СоздатьЭлемент();
				ОбластьОб.УстановитьСсылкуНового(ОбластьСсылка);
				ОбластьОб.Наименование = СтрокаДанныеЭлемента.ОбластьНаименование;
				ОбластьОб.Записать();
				ОбластьСсылка = ОбластьОб.Ссылка;
			КонецЕсли;
			
			ГородСсылка = Справочники.Города.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДГород);
			ОбъектГород = Неопределено;
			Попытка
				ОбъектГород = ГородСсылка.ПолучитьОбъект();
			Исключение
			КонецПопытки;
			Если ОбъектГород = Неопределено Тогда  
				ГородОб = Справочники.Города.СоздатьЭлемент();
				ГородОб.УстановитьСсылкуНового(ГородСсылка);
				//ЗаписьЖурналаРегистрации("Обмен", УровеньЖурналаРегистрации.Информация,,,СтрокаДанныеЭлемента.ГородНаименование);
				ГородОб.Наименование = СтрокаДанныеЭлемента.ГородНаименование;
				ГородОб.Владелец = ОбластьСсылка;
				ГородОб.Записать();
				ГородСсылка = ГородОб.Ссылка;
			КонецЕсли;
			
			
			ТекКонтрОб.Область = ОбластьСсылка;
			ТекКонтрОб.Город = ГородСсылка;
			
			ТекКонтрОб.ТорговыйАгент = Продавец;
			
			ТекКонтрОб.Маршрут = Справочники.Маршруты.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДМаршрут);
			ТекКонтрОб.СтатусКонтрагента = Справочники.СтатусыКонтрагентов.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСтатусКонтрагента);
			ТекКонтрОб.ОперативныйСтатусКонтрагента = Справочники.СтатусыКонтрагентов.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДОперативныйСтатусКонтрагента);
			ТекКонтрОб.КатегорияТТ = Справочники.КатегорииТТ.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКатегорияТТ);
			ТекКонтрОб.СпособДоставки = Справочники.СпособыДоставки.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСпособДоставки);
			ТекКонтрОб.КаналПошуку = Справочники.КаналиПошуку.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКаналПошуку);


			Если ТипЗнч(СтрокаДанныеЭлемента.КодАсортимента) = Тип("Число") Тогда 	
				ТекКонтрОб.КодАсортимета = Перечисления.КодыАсортимета[СтрокаДанныеЭлемента.КодАсортимента]
			КонецЕсли;

			Попытка
				ТекКонтрОб.ДополнительныеСвойства.Вставить("ТорговыйАгент", Продавец); 
				//ДопСво ТекКонтрОб.ТорговыйАгент = Продавец;
				ТекКонтрОб.Записать();
			Исключение
				//Попытка	
				//	ТекКонтрОб.Комментарий = ТекКонтрОб.Комментарий + " " + ТекКонтрОб.НомерТелефона; 
				//	ТекКонтрОб.НомерТелефона = "";
				//Исключение	
				
					ТекНомТел = Строка(ТекКонтрОб.НомерТелефона);
					Для Каждого Стр Из ТекКонтрОб.ДополнительныеНомераТелефонов Цикл
						ТекНомТел = ТекНомТел + ", " + Стр.Номер;
					КонецЦикла;
					
				
					ЗаписьЖурналаРегистрации("ОБМЕН АНДРОИД", УровеньЖурналаРегистрации.Ошибка, ,,ОписаниеОшибки() + ", " + ТекНомТел);
					//Продолжить;
					
					
					
					МассивОшибок.добавить(ОписаниеОшибки() + ", " + ТекНомТел);
					Продолжить;
				//КонецПопытки;
			КонецПопытки;
			/////////////////
			
			НовДог = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
			НовДог.Владелец = ТекКонтрОб.Ссылка;
			НовДог.Организация = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(ПараметрыСеанса.ТекущийПользователь,"ОсновнаяОрганизация");
			НовДог.Наименование = "Основний";
			НовДог.ВедениеВзаиморасчетов = Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоЗаказам;
			НовДог.ВестиПоДокументамРасчетовСКонтрагентом = Истина;
			НовДог.ВидВзаиморасчетов = Перечисления.ВидыДоговоровКонтрагентов.СПокупателем;
			НовДог.ВалютаВзаиморасчетов = Константы.ВалютаУправленческогоУчета.Получить();
			НовДог.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СПокупателем;
			НовДог.ТипЦен = ТекТипЦен;
			//НовДог.ОбособленноеПодразделение = Склад.Подразделение.РСП;
			НовДог.Записать();
			ТекКонтрОб.ОсновнойДоговорКонтрагента = НовДог.Ссылка;
			
			// Неплановий
			
			НовДогНепл = Справочники.ДоговорыКонтрагентов.СоздатьЭлемент();
			НовДогНепл.Владелец = ТекКонтрОб.Ссылка;
			НовДогНепл.Организация = УправлениеПользователями.ПолучитьЗначениеПоУмолчанию(ПараметрыСеанса.ТекущийПользователь,"ОсновнаяОрганизация");
			НовДогНепл.Наименование = "Непланові продажі";
			НовДогНепл.ВедениеВзаиморасчетов = Перечисления.ВедениеВзаиморасчетовПоДоговорам.ПоДоговоруВЦелом;
			НовДогНепл.ВестиПоДокументамРасчетовСКонтрагентом = Истина;
			НовДогНепл.ВидВзаиморасчетов = Перечисления.ВидыДоговоровКонтрагентов.СПокупателем;
			НовДогНепл.ВалютаВзаиморасчетов = Константы.ВалютаУправленческогоУчета.Получить();
			НовДогНепл.ВидДоговора = Перечисления.ВидыДоговоровКонтрагентов.СПокупателем;
			НовДогНепл.ТипЦен = ТекТипЦен;
			//НовДог.ОбособленноеПодразделение = Склад.Подразделение.РСП;
			НовДогНепл.Записать();
			ТекКонтрОб.ДоговорДляНеплановыхПродаж = НовДогНепл.Ссылка;
			
			ТекКонтрОб.Маршруты.Очистить();
			Для Каждого Элемент Из СтрокаДанныеЭлемента.Маршруты Цикл 
				Строка = ТекКонтрОб.Маршруты.ДОбавить();
				Строка.Маршрут = Справочники.Маршруты.ПолучитьСсылку(Элемент.УИД_Маршрут);
			КонецЦикла;
			
			ТекКонтрОб.Асортимент.Очистить();
			Для Каждого Элемент Из СтрокаДанныеЭлемента.Асортимент Цикл 
				Строка = ТекКонтрОб.Асортимент.ДОбавить();
				Строка.Артикул = Элемент.Артикул;
			КонецЦикла;


			Попытка
				ТекКонтрОб.ДополнительныеСвойства.Вставить("ТорговыйАгент", Продавец);
				//ДопСво ТекКонтрОб.ТорговыйАгент = Продавец;	
				ТекКонтрОб.Записать();
			Исключение
				////ЗаписьЖурналаРегистрации("ОБМЕН АНДРОИД", УровеньЖурналаРегистрации.Ошибка, ,,ОписаниеОшибки());
				МассивОшибок.добавить(ОписаниеОшибки());
				Продолжить;

			КонецПопытки;
			
		Иначе 
			//ЗаполнитьЗначенияСвойств(ТекКонтрОб, СтрокаДанныеЭлемента,, "ДатаСоздания");
						
			Для Каждого мет Из Метаданные.Справочники.Контрагенты.Реквизиты Цикл
						
				Если мет.Имя = "ДатаСоздания"
					ИЛИ мет.Имя = "ТорговыйАгент" Тогда 
					Продолжить;
				КонецЕсли;
				
				//Если СтрокаДанныеЭлемента.Колонки.Найти(мет.Имя) <> Неопределено Тогда  
				Попытка
					Если ЗначениеЗаполнено(СтрокаДанныеЭлемента[мет.Имя]) Тогда 
						ТекКонтрОб[мет.Имя] = СтрокаДанныеЭлемента[мет.Имя];
					КонецЕсли;
				Исключение
				КонецПопытки;
				
				//КонецЕсли;
												
			КонецЦикла;
				
			
			ОбновитьНомерыТелефоновКонтрагента(ТекКонтрОб, СтрокаДанныеЭлемента.Телефоны);
			
			ТекКонтрОб.Область = Справочники.Области.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДОбласть);
						
			ГородСсылка = Справочники.Города.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДГород);
			ОбъектГород = Неопределено;
			Попытка
				ОбъектГород = ГородСсылка.ПолучитьОбъект();
			Исключение
			КонецПопытки;
			Если ОбъектГород = Неопределено Тогда  
				ГородОб = Справочники.Города.СоздатьЭлемент();
				ГородОб.УстановитьСсылкуНового(ГородСсылка);
				//ЗаписьЖурналаРегистрации("Обмен", УровеньЖурналаРегистрации.Информация,,,СтрокаДанныеЭлемента.ГородНаименование);
				ГородОб.Наименование = СтрокаДанныеЭлемента.ГородНаименование;
				ГородОб.Владелец = ТекКонтрОб.Область;
				Если НЕ ЗначениеЗаполнено(ГородОб.Владелец) Тогда 
					ГородОб.Владелец = Справочники.Области.НайтиПоКоду("000000003");
					ТекКонтрОб.Область = ГородОб.Владелец;
				КонецЕсли;
				ГородОб.Записать();
				ГородСсылка = ГородОб.Ссылка;
			КонецЕсли;
			
			ТекКонтрОб.Наименование = СтрокаДанныеЭлемента.Наименование;
			ТекКонтрОб.Город = ГородСсылка;
			ТекКонтрОб.Маршрут = Справочники.Маршруты.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДМаршрут);
			ТекКонтрОб.СтатусКонтрагента = Справочники.СтатусыКонтрагентов.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСтатусКонтрагента);
			ТекКонтрОб.ОперативныйСтатусКонтрагента = Справочники.СтатусыКонтрагентов.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДОперативныйСтатусКонтрагента);
			ТекКонтрОб.КатегорияТТ = Справочники.КатегорииТТ.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКатегорияТТ);
			ТекКонтрОб.СпособДоставки = Справочники.СпособыДоставки.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДСпособДоставки);
			ТекКонтрОб.КаналПошуку = Справочники.КаналиПошуку.ПолучитьСсылку(СтрокаДанныеЭлемента.УИДКаналПошуку);

			Если ТипЗнч(СтрокаДанныеЭлемента.КодАсортимента) = Тип("Число") Тогда 	
				ТекКонтрОб.КодАсортимета = Перечисления.КодыАсортимета[СтрокаДанныеЭлемента.КодАсортимента]
			КонецЕсли;
			
			
			ТекКонтрОб.НомерВідділенняНП = СтрокаДанныеЭлемента.НомерВідділенняНП;
						
			ТекКонтрОб.Маршруты.Очистить();
			Для Каждого Элемент Из СтрокаДанныеЭлемента.Маршруты Цикл 
				Строка = ТекКонтрОб.Маршруты.ДОбавить();
				Строка.Маршрут = Справочники.Маршруты.ПолучитьСсылку(Элемент.УИД_Маршрут);
			КонецЦикла;
			
			ТекКонтрОб.Асортимент.Очистить();
			Попытка
				Для Каждого Элемент Из СтрокаДанныеЭлемента.Асортимент Цикл 
					Строка = ТекКонтрОб.Асортимент.ДОбавить();
					Строка.Артикул = Элемент.Артикул;
				КонецЦикла;
			Исключение
			КонецПопытки;
			
			
			Попытка
				ТекКонтрОб.СоцМережі.Очистить();
				Для Каждого Элемент Из СтрокаДанныеЭлемента.СоцМережі Цикл 
					Строка = ТекКонтрОб.СоцМережі.ДОбавить();
					Строка.Коментар = Элемент.Коментар;
					Строка.Посилання = Элемент.Посилання;
					Строка.Мережа = Элемент.Мережа;
				КонецЦикла;
			Исключение
			КонецПопытки;
			
			
			Если НЕ ЗначениеЗаполнено(ТекКонтрОб.ОсновнойДоговорКонтрагента) Тогда 
				з = Новый Запрос;
				з.Текст = "ВЫБРАТЬ
				          |	ДоговорыКонтрагентов.Ссылка
				          |ИЗ
				          |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
				          |ГДЕ
				          |	ДоговорыКонтрагентов.Владелец = &Владелец
				          |	И ДоговорыКонтрагентов.Наименование ПОДОБНО &Наименование";
				з.УстановитьПараметр("Владелец", ТекКонтрОб.Ссылка);
				з.УстановитьПараметр("Наименование", "%Основний%");
				Выборка = з.Выполнить().Выбрать();
				Если Выборка.Следующий() Тогда 
					ТекКонтрОб.ОсновнойДоговорКонтрагента = Выборка.Ссылка;
				КонецЕсли;
				

			КонецЕсли;
			Если НЕ ЗначениеЗаполнено(ТекКонтрОб.ДоговорДляНеплановыхПродаж) Тогда 
				з = Новый Запрос;
				з.Текст = "ВЫБРАТЬ
				          |	ДоговорыКонтрагентов.Ссылка
				          |ИЗ
				          |	Справочник.ДоговорыКонтрагентов КАК ДоговорыКонтрагентов
				          |ГДЕ
				          |	ДоговорыКонтрагентов.Владелец = &Владелец
				          |	И ДоговорыКонтрагентов.Наименование ПОДОБНО &Наименование";
				з.УстановитьПараметр("Владелец", ТекКонтрОб.Ссылка);
				з.УстановитьПараметр("Наименование", "%Непланові продажі%");
				Выборка = з.Выполнить().Выбрать();
				Если Выборка.Следующий() Тогда 
					ТекКонтрОб.ДоговорДляНеплановыхПродаж = Выборка.Ссылка;
				КонецЕсли;
			КонецЕсли;

			

			
			Если ТекКонтрОб.Модифицированность() Тогда 
				ТекКонтрОб.ДополнительныеСвойства.Вставить("ТорговыйАгент", Продавец);
				//ДопСво ТекКонтрОб.ТорговыйАгент = Продавец;
				ТекКонтрОб.Записать()
			КонецЕсли;

		КонецЕсли;
		
		НовСтр = ТаблицаИД.Добавить();
		НовСтр.ИД = СтрокаДанныеЭлемента.ИД;		
	КонецЦикла;	
КонецПроцедуры

Процедура ОбновитьНомерыТелефоновКонтрагента(КонтрагентОбъект, НомерТелефона);
	
	КонтрагентОбъект.ДополнительныеНомераТелефонов.Очистить();	
	
	Если ТипЗнч(НомерТелефона) = Тип("Строка") Тогда 
		
		
		Для Индекс = 1 по СтрЧислоСтрок(НомерТелефона) Цикл
			ТекНомерТелефона = СокрЛП(СтрПолучитьСтроку(НомерТелефона, Индекс));
			Если Не ЗначениеЗаполнено(КонтрагентОбъект.НомерТелефона) Тогда
				КонтрагентОбъект.НомерТелефона = ОбработкаНомераТелефона(ТекНомерТелефона);
			ИначеЕсли КонтрагентОбъект.НомерТелефона = ТекНомерТелефона Тогда  
				Продолжить;
			КонецЕсли;
			Строка = КонтрагентОбъект.ДополнительныеНомераТелефонов.Найти(ОбработкаНомераТелефона(ТекНомерТелефона), "Номер");
			Если Строка = Неопределено Тогда 
				НоваяСтрока = КонтрагентОбъект.ДополнительныеНомераТелефонов.Добавить();
				НоваяСтрока.Номер = ОбработкаНомераТелефона(ТекНомерТелефона);
			КонецЕсли;
		КонецЦикла;
		
	Иначе
		
		Для Каждого Элемент Из НомерТелефона Цикл 
			
			Строка = КонтрагентОбъект.ДополнительныеНомераТелефонов.Найти(ОбработкаНомераТелефона(Элемент.НомерТелефона), "Номер");
			Если Строка = Неопределено  Тогда 
				
				Если Не ЗначениеЗаполнено(КонтрагентОбъект.НомерТелефона) Тогда
					КонтрагентОбъект.НомерТелефона = ОбработкаНомераТелефона(Элемент.НомерТелефона);
				ИначеЕсли КонтрагентОбъект.НомерТелефона = ОбработкаНомераТелефона(Элемент.НомерТелефона) Тогда  
					Продолжить;
				КонецЕсли;

				НоваяСтрока = КонтрагентОбъект.ДополнительныеНомераТелефонов.Добавить();
				НоваяСтрока.Номер = ОбработкаНомераТелефона(Элемент.НомерТелефона);
				Если ТипЗнч(Элемент.Месенджер) = тип("число") Тогда 
					НоваяСтрока.ВидМесенджера = Перечисления.ВидыМесендеров.Получить(Элемент.Месенджер);
				КонецЕсли;
			КонецЕсли;

		КонецЦикла;
		
		
		
	КонецЕсли;

КонецПроцедуры

Процедура ОбновитьСкладыКонтрагентов(ТаблицаСкладов,Склад, ТаблицаИД)
	Для Каждого СтрокаДанныеЭлемента Из ТаблицаСкладов Цикл
					  
		ТекСкладОб = Справочники.СкладыКонтрагентов.ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка).ПолучитьОбъект();
		ТекКонтр = Справочники.Контрагенты.ПолучитьСсылку(СтрокаДанныеЭлемента.Контрагент);

		
		Если ТекСкладОб = Неопределено Тогда 
			ТекСкладОб = Справочники.СкладыКонтрагентов.СоздатьЭлемент();	
			ТекСкладОб.УстановитьСсылкуНового(Справочники.СкладыКонтрагентов.ПолучитьСсылку(СтрокаДанныеЭлемента.Ссылка));
			ТекСкладОб.мОбменАндроид = Истина;
			ТекСкладОб.Наименование = СтрокаДанныеЭлемента.Наименование;
			ТекСкладОб.Владелец = ТекКонтр;
			ТекСкладОб.СкидатиВАТ = Истина;
			//ТекСкладОб.Записать();
		Иначе
			ТекСкладОб.Наименование = СтрокаДанныеЭлемента.Наименование;
			ТекСкладОб.мОбменАндроид = Истина;
		КонецЕсли;
		Попытка
			ТекСкладОб.Записать();
	
			///////////
			НовСтр = ТаблицаИД.Добавить();
			НовСтр.ИД = СтрокаДанныеЭлемента.ИД;	
		Исключение 
		КонецПопытки;
	КонецЦикла;	
КонецПроцедуры

