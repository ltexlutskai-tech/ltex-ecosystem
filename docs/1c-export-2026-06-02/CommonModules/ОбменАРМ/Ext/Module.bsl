Функция ОновитиКурси(ПарольВхода) Экспорт
	СтруктураКурсов = Новый Структура;
	СтруктураКурсов.Вставить("В978", МодульВалютногоУчета.ПолучитьКурсВалюты(Справочники.Валюты.НайтиПоКоду("978"), ТекущаяДата())); // Эвро
	СтруктураКурсов.Вставить("В840", МодульВалютногоУчета.ПолучитьКурсВалюты(Справочники.Валюты.НайтиПоКоду("840"), ТекущаяДата())); // Доллар
	
	
	ТорговийАгент = ОбменАндроид.ПолучитьПродавцаПоКодуПартнера(ПарольВхода);
	Если Не ТорговийАгент = Неопределено Тогда 
		СтруктураКурсов.Вставить("ПравоМінятиКурсиВалют", ТорговийАгент.ПравоМінятиКурсиВалют);
	КонецЕсли;
	СтруктураКурсов.Вставить("ВідображатиВсіхКлієнтів", ТорговийАгент.ВідображатиВсіхКлієнтів);

		
	Возврат Новый ХранилищеЗначения(СтруктураКурсов); 	
КонецФункции



Функция ПолучитьЦенныПоставщиков() Экспорт 
	ТЗ_Цен = Новый ТаблицаЗначений;
		Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПоступлениеТоваровУслугТовары.Номенклатура КАК Номенклатура,
	|	ПРЕДСТАВЛЕНИЕ(ПоступлениеТоваровУслугТовары.Ссылка.Контрагент) КАК Поставщик,
	|	МАКСИМУМ(ПоступлениеТоваровУслугТовары.ЦенаЗакупкиВес) КАК ЦенаЗакупкиВес
	|ИЗ
	|	Документ.ПоступлениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
	|ГДЕ
	|	ПоступлениеТоваровУслугТовары.Ссылка.Проведен
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоступлениеТоваровУслугТовары.Номенклатура,
	|	ПРЕДСТАВЛЕНИЕ(ПоступлениеТоваровУслугТовары.Ссылка.Контрагент)";
	
	РезультатЗапроса = Запрос.Выполнить();
	ТЗ_Цен = РезультатЗапроса.Выгрузить();;
	ТЗ_Цен.Колонки.Добавить("УИДНоменклатуры",  Новый ОписаниеТипов("Строка", ,,,Новый КвалификаторыСтроки(36)));
	
	Для Каждого Элемент Из ТЗ_Цен Цикл 
		Элемент.УИДНоменклатуры =  Элемент.Номенклатура.УникальныйИдентификатор();
	КонецЦикла;
	
	Запрос.Текст = 
	"Выбрать * 
	|ПОМЕСТИТЬ ТЗ 
	|Из 
	|	&ТЗ как ТЗ; 
	|Выбрать 
	|	УИДНоменклатуры, 
	|	Поставщик, 
	|	ЦенаЗакупкиВес   
	|Из 
	|	ТЗ как ТЗ 
	|Итоги 
	|По
	|	УИДНоменклатуры";
	Запрос.УстановитьПараметр("ТЗ", ТЗ_Цен);
	
	Возврат Запрос.Выполнить();	
КонецФункции


