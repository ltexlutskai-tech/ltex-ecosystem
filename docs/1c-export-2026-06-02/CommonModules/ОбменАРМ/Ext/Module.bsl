Функция ВыполнитьКоманду(Продавец, Данные, отказ)  Экспорт
	перем Команда, Параметры;
	
	Отказ = Ложь;
	Данные = Десериализовать(Данные);
	
	Если Не ТипЗнч(Данные) = Тип("Структура") Тогда 
		Отказ = истина;
	КонецЕсли;
	
	Если Не (Данные.Свойство("Команда", Команда)
		И Данные.Свойство("Параметры", Параметры)) Тогда 
		Отказ = Истина;
	КонецЕсли;
	Если отказ Тогда 
		Возврат Неопределено
	КонецЕсли;
	
	Если Команда = "ПолучитьАктуальныеЗаказы" Тогда 
		Ответ = ПолучитьАктуальныеЗаказы(Параметры);
	КонецЕсли;
	
	Если Команда = "ПолучитьОтчетПродажиПоКонтрагенту" Тогда 
		Ответ = ПолучитьОтчетПродажиПоКонтрагенту(Параметры);
	КонецЕсли;
	
	Если Команда = "ПолучитьОчередьНапоминанийСДействием" Тогда 
		Ответ = ПолучитьОчередьНапоминанийСДействием(Параметры, Продавец);
	КонецЕсли;
	
	Если Команда = "ПолучитьСтатусыЗаказовПоКонтрагенту" Тогда 
		Ответ = ПолучитьСтатусыЗаказовПоКонтрагенту(Параметры);
	КонецЕсли;
	
	Если Команда = "ПолучитьАнализКлиентскойБазы" Тогда 
		Ответ = ПолучитьАнализКлиентскойБазы(Параметры, Продавец);
	КонецЕсли;
	
	Если Команда = "ПолучитьОтчетПрезентацииПоКонтрагенту" Тогда 
		Ответ = ПолучитьОтчетПрезентацииПоКонтрагенту(Параметры);
	КонецЕсли;
	
	Если Команда = "ЗаписатьСообщение" Тогда 
		Ответ = ЗаписатьСообщениеЧат1С(Параметры, Продавец);
	КонецЕсли;
	
	Если Команда = "ИзмененияХарактеристик" Тогда 
		Ответ = ЗаписатьИзмененияХарактеристик(Параметры, Продавец);
	КонецЕсли;
	
	Если Команда = "ДублиКонтрагента" Тогда 
		Ответ = ДублиКонтрагента(Параметры);
	КонецЕсли;
	
	Возврат Ответ;
КонецФункции

Функция ПолучитьАктуальныеЗаказы(Параметры)
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказПокупателя.Ссылка,
		|	ЗаказПокупателя.Дата,
		|	ЗаказПокупателя.Номер
		|ИЗ
		|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|ГДЕ
		|	ЗаказПокупателя.Контрагент = &Контрагент
		|	И ЗаказПокупателя.СтатусЗамовлення = &СтатусЗамовлення
		|	И ЗаказПокупателя.Проведен";
	
	Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПолучитьСсылку(Параметры.Контрагент));
	Запрос.УстановитьПараметр("СтатусЗамовлення", Справочники.СтатусиЗамовлень.Новий);
	
	Результат = Запрос.Выполнить().Выгрузить();
	Результат.Колонки.Добавить("УИДЗаказ");
	Для Каждого Элемент из Результат Цикл 
		
		Элемент.УИДЗаказ = Элемент.Ссылка.УникальныйИдентификатор();		
		
	КонецЦикла;
	
	Результат.Колонки.Удалить("Ссылка");
	
Возврат Результат;
	
КонецФункции

Функция ПолучитьОтчетПродажиПоКонтрагенту(Параметры)
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПродажиОбороты.Период КАК Период,
		|	ПродажиОбороты.Контрагент,
		|	ПродажиОбороты.Номенклатура,
		|	ПродажиОбороты.ВесОборот КАК Количество
		|ИЗ
		|	РегистрНакопления.Продажи.Обороты(&НачПериода, &КонПериода, Месяц, Контрагент = &Контрагент) КАК ПродажиОбороты
		|
		|УПОРЯДОЧИТЬ ПО
		|	Период";
	
	Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПолучитьСсылку(Параметры.Контрагент));
	Запрос.УстановитьПараметр("НачПериода", Параметры.НачалоПериодаПродаж);
	Запрос.УстановитьПараметр("КонПериода", Параметры.КонецПериодаПродаж);
	
	Результат = Запрос.Выполнить().Выгрузить();
	Результат.Колонки.Добавить("УИДКонтрагент");
	Результат.Колонки.Добавить("УИДНоменклатура");

	Для Каждого Элемент из Результат Цикл 
		
		Элемент.УИДКонтрагент = Элемент.Контрагент.УникальныйИдентификатор();		
		Элемент.УИДНоменклатура = Элемент.Номенклатура.УникальныйИдентификатор();		
		
	КонецЦикла;
	
	Результат.Колонки.Удалить("Контрагент");
	Результат.Колонки.Удалить("Номенклатура");
	
	Возврат Результат;
	
КонецФункции

Функция ПолучитьОтчетПрезентацииПоКонтрагенту(Параметры)
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	Презентації.Период КАК Период,
	|	НАЧАЛОПЕРИОДА(Презентації.Период, МЕСЯЦ) КАК ПериодНачалоМесяца,
	|	Презентації.Контрагент,
	|	Презентації.Номенклатура,
	|	Презентації.Коментар,
	|	Презентації.КоментарМенеджера,
	|	СУММА(Презентації.Количество) КАК Количество
	|ИЗ
	|	РегистрНакопления.Презентації КАК Презентації
	|ГДЕ
	|	Презентації.Период МЕЖДУ &НачПериода И &КонПериода
	|	И Презентації.Контрагент = &Контрагент
	|
	|СГРУППИРОВАТЬ ПО
	|	Презентації.Период,
	|	НАЧАЛОПЕРИОДА(Презентації.Период, МЕСЯЦ),
	|	Презентації.Контрагент,
	|	Презентації.Номенклатура,
	|	Презентації.Коментар,
	|	Презентації.КоментарМенеджера
	|
	|УПОРЯДОЧИТЬ ПО
	|	Период";
	
	Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПолучитьСсылку(Параметры.Контрагент));
	Запрос.УстановитьПараметр("НачПериода", Параметры.НачалоПериодаПродаж);
	Запрос.УстановитьПараметр("КонПериода", Параметры.КонецПериодаПродаж);
	

	
	Результат = Запрос.Выполнить().Выгрузить();
	Результат.Колонки.Добавить("УИДКонтрагент");
	Результат.Колонки.Добавить("УИДНоменклатура");

	Для Каждого Элемент из Результат Цикл 
		
		Элемент.УИДКонтрагент = Элемент.Контрагент.УникальныйИдентификатор();		
		Элемент.УИДНоменклатура = Элемент.Номенклатура.УникальныйИдентификатор();		
		
	КонецЦикла;
	
	Результат.Колонки.Удалить("Контрагент");
	Результат.Колонки.Удалить("Номенклатура");
	
	Возврат Результат;
	
КонецФункции

Функция ЗаписатьСообщениеЧат1С(НовоеСообщение, Продавец)
	
	МенеджерЗаписи = РегистрыСведений.Чат1С.СоздатьМенеджерЗаписи();
	
		
	МенеджерЗаписи.Уид_Сообщения 	= НовоеСообщение.Уид_Сообщения;
	МенеджерЗаписи.Організація 		= Справочники.Организации.НайтиПоКоду("000000001");
	МенеджерЗаписи.Відправник  		= Продавец.Користувач;
	
	Если НовоеСообщение.ПолучательГруппа Тогда 
		МенеджерЗаписи.Одержувач  = Справочники.ГруппыЧата.ПолучитьСсылку(НовоеСообщение.УИД_Получатель);
	Иначе
		МенеджерЗаписи.Одержувач   = Справочники.Пользователи.ПолучитьСсылку(НовоеСообщение.УИД_Получатель);
	КонецЕсли;
	
	МенеджерЗаписи.Повідомлення 	= НовоеСообщение.Повідомлення;
	МенеджерЗаписи.Период       	= НовоеСообщение.Дата; 	
	МенеджерЗаписи.ДатаНаСервере 	= ТекущаяДата();
	МенеджерЗаписи.Записать();//Набор.Записать();
	
	Если НовоеСообщение.ПолучательГруппа Тогда 
		мПолучатели = МенеджерЗаписи.Одержувач.Учасники.ВыгрузитьКолонку("Пользователь");
		Відправник = МенеджерЗаписи.Одержувач;
	Иначе
		мПолучатели = Новый Массив;
		мПолучатели.Добавить( МенеджерЗаписи.Одержувач);
		Відправник =  МенеджерЗаписи.Відправник;
	КонецЕсли;
	
	Для Каждого ТекПользовательДляОтправки Из мПолучатели Цикл
		
		Если ТекПользовательДляОтправки = МенеджерЗаписи.Відправник Тогда
			Продолжить;
		КонецЕсли;	
		
		если ТекПользовательДляОтправки <> Справочники.Пользователи.ПустаяСсылка() тогда
			РегНепрочитані = РегистрыСведений.НепрочитаніПовідомлення.СоздатьМенеджерЗаписи();			
			РегНепрочитані.Одержувач = ТекПользовательДляОтправки;
			РегНепрочитані.Відправник =  Відправник;
			РегНепрочитані.ГруппаЧата  = Відправник;
			РегНепрочитані.Кол = 1;
			РегНепрочитані.Период = ТекущаяДата();
			РегНепрочитані.Записать(); 		
		КонецЕсли;
		
	КонецЦикла;	
	
	Возврат Истина;
	
КонецФункции


Функция ПолучитьОчередьНапоминанийСДействием(Параметры, Продавец)
			
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОчередьНапоминанийСДействием.ТорговыйАгент,
		|	ОчередьНапоминанийСДействием.КонтрагентДляДействий,
		|	ОчередьНапоминанийСДействием.ХарактеристикаДляДействий,
		|	ОчередьНапоминанийСДействием.ТипДействяПриНапоминании		
		|ИЗ
		|	РегистрСведений.ОчередьНапоминанийСДействием КАК ОчередьНапоминанийСДействием
		|ГДЕ
		|	ОчередьНапоминанийСДействием.ТорговыйАгент = &ТорговыйАгент";
	
	Запрос.УстановитьПараметр("ТорговыйАгент", Продавец);
	
	ТЗРезультат = Запрос.Выполнить().Выгрузить();
	ТЗРезультат.Колонки.Добавить("УИДКонтрагентДляДействий");
	ТЗРезультат.Колонки.Добавить("УИДХарактеристикаДляДействий");
	ТЗРезультат.Колонки.Добавить("ИмяТипДействяПриНапоминании");
	
	Для Каждого Элемент из ТЗРезультат Цикл 
		
		Элемент.УИДКонтрагентДляДействий = Элемент.КонтрагентДляДействий.УникальныйИдентификатор();		
		Элемент.УИДХарактеристикаДляДействий = Элемент.ХарактеристикаДляДействий.УникальныйИдентификатор();		
		
		ЗначениеПеречисления = Элемент.ТипДействяПриНапоминании;;
		ИмяПеречисления = ЗначениеПеречисления.Метаданные().Имя; 
		ИндексЗначенияПеречисления = Перечисления[ИмяПеречисления].Индекс(ЗначениеПеречисления); 
		ИмяЗначенияПеречисления = Метаданные.Перечисления[ИмяПеречисления].ЗначенияПеречисления[ИндексЗначенияПеречисления].Имя;		
		
		Элемент.ИмяТипДействяПриНапоминании = ИмяЗначенияПеречисления;
		
		ЗаписьОчередиДляУдаления = РегистрыСведений.ОчередьНапоминанийСДействием.СоздатьМенеджерЗаписи();
		
		ЗаписьОчередиДляУдаления.ТорговыйАгент = Элемент.ТорговыйАгент;
		ЗаписьОчередиДляУдаления.КонтрагентДляДействий = Элемент.КонтрагентДляДействий;		
		ЗаписьОчередиДляУдаления.ХарактеристикаДляДействий = Элемент.ХарактеристикаДляДействий;
		ЗаписьОчередиДляУдаления.ТипДействяПриНапоминании = Элемент.ТипДействяПриНапоминании;
		ЗаписьОчередиДляУдаления.Удалить();
		
	КонецЦикла;
	
	
	СтрукрутаСправочников = Новый Структура;
	ТЗНоменклатуры = Новый ТаблицаЗначений;
	ТЗНоменклатуры.Колонки.Добавить("Ссылка");
	Для Каждого стрРезультат Из ТЗРезультат Цикл
		    НоваяСтрока = ТЗНоменклатуры.Добавить();
			НоваяСтрока.Ссылка = стрРезультат.ХарактеристикаДляДействий.Владелец;
	КонецЦикла;	
	СтрукрутаСправочников.Вставить("Номенклатура", ТЗНоменклатуры);
	
	ДобавитьСправочникХарактеристики(СтрукрутаСправочников, Продавец.Склад, Продавец);
	
	
	
	
	
	
	
	ТЗРезультат.Колонки.Удалить("КонтрагентДляДействий");
	ТЗРезультат.Колонки.Удалить("ХарактеристикаДляДействий");
	ТЗРезультат.Колонки.Удалить("ТипДействяПриНапоминании");
	
	
	
	//Очистимо чергу більше 10 днів	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОчередьНапоминанийСДействием.ТорговыйАгент,
		|	ОчередьНапоминанийСДействием.КонтрагентДляДействий,
		|	ОчередьНапоминанийСДействием.ХарактеристикаДляДействий,
		|	ОчередьНапоминанийСДействием.ТипДействяПриНапоминании		
		|ИЗ
		|	РегистрСведений.ОчередьНапоминанийСДействием КАК ОчередьНапоминанийСДействием
		|ГДЕ
		|	ОчередьНапоминанийСДействием.ПериодДобавления < &ПериодДобавления";
	
	Запрос.УстановитьПараметр("ПериодДобавления", ТекущаяДата() - 10 * 60 * 60 * 24);
	
	Результат = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Элемент из Результат Цикл 
		
		ЗаписьОчередиДляУдаления = РегистрыСведений.ОчередьНапоминанийСДействием.СоздатьМенеджерЗаписи();
		ЗаписьОчередиДляУдаления.ТорговыйАгент = Элемент.ТорговыйАгент;
		ЗаписьОчередиДляУдаления.КонтрагентДляДействий = Элемент.КонтрагентДляДействий;		
		ЗаписьОчередиДляУдаления.ХарактеристикаДляДействий = Элемент.ХарактеристикаДляДействий;
		ЗаписьОчередиДляУдаления.ТипДействяПриНапоминании = Элемент.ТипДействяПриНапоминании;
		ЗаписьОчередиДляУдаления.Удалить();
		
	КонецЦикла;

	СтруктураОтвета = Новый Структура;
	СтруктураОтвета.Вставить("ТЗОчереди", ТЗРезультат);
	СтруктураОтвета.Вставить("ТЗХарактеристик", СтрукрутаСправочников.ХарактеристикиНоменклатуры);
	
	Возврат СтруктураОтвета;
	
КонецФункции

Функция ПолучитьСтатусыЗаказовПоКонтрагенту(Параметры)
			
				
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказПокупателя.Ссылка КАК Заказ,
		|	ВЫБОР
		|		КОГДА ЗаказПокупателя.СтатусЗамовлення = ЗНАЧЕНИЕ(Справочник.СтатусиЗамовлень.Новий) И НЕ ЗаказПокупателя.ПометкаУдаления
		|			ТОГДА ИСТИНА
		|		ИНАЧЕ ЛОЖЬ
		|	КОНЕЦ КАК Актуальный
		|ИЗ
		|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|ГДЕ
		|	ЗаказПокупателя.Контрагент = &Контрагент
		//|	И ЗаказПокупателя.ПометкаУдаления = ЛОЖЬ
		|";
	
	Запрос.УстановитьПараметр("Контрагент", Справочники.Контрагенты.ПолучитьСсылку(Параметры.Контрагент));

	
	ТЗРезультат = Запрос.Выполнить().Выгрузить();
	ТЗРезультат.Колонки.Добавить("УИДЗаказ");


	Для Каждого Элемент из ТЗРезультат Цикл 
		
		Элемент.УИДЗаказ = Элемент.Заказ.УникальныйИдентификатор();		

		
	КонецЦикла;
	
	ТЗРезультат.Колонки.Удалить("Заказ");
	
	Возврат ТЗРезультат;
	
КонецФункции

Функция ПолучитьАнализКлиентскойБазы(Параметры, Продавец)
			
				

	ТЗКонтрагентов = Параметры.ТЗКонтрагентов;
	ТЗКонтрагентов.Колонки.Добавить("Контрагент", Новый ОписаниеТипов("СправочникСсылка.Контрагенты")); 
	Для Каждого стрКонтрагент Из ТЗКонтрагентов Цикл
		стрКонтрагент.Контрагент = Справочники.Контрагенты.ПолучитьСсылку(стрКонтрагент.УИДКонтрагент);
	КонецЦикла;	
	ТЗКонтрагентов.Колонки.Удалить("УИДКонтрагент");
	
	СписокКонтраегнтв = Новый СписокЗначений;
	СписокКонтраегнтв.ЗагрузитьЗначения(ТЗКонтрагентов.ВыгрузитьКолонку("Контрагент"));
	
	ТабДокумент = Новый ТабличныйДокумент;

	
 //   СхемаКомпоновкиДанных = ПолучитьОбщийМакет("АнализКлиентскойБазы");
 //   
 //   //Настройки = СхемаКомпоновкиДанных.НастройкиПоУмолчанию;  
 //   // - Если сделать так, как показано выше(рекомендуют на некоторых ресурсах), то при изменении настроек в режиме клиента
 //   // этих изменений Вы не увидите, потому что настройки всегда будут по умолчанию. Как правильно - вариант ниже
 //   Настройки = КомпоновщикНастроек.ПолучитьНастройки(); 
