	СтрукрутаКонстант.Вставить("ПравоМінятиКурсиВалют", Продавец.ПравоМінятиКурсиВалют);
	
	СтрукрутаКонстант.Вставить("ТипЦенПродаж", Продавец.ТипЦенПродажи.УникальныйИдентификатор());
	
	СтрукрутаКонстант.Вставить("ВідображатиВсіхКлієнтів", Продавец.ВідображатиВсіхКлієнтів);
	
	//СтрукрутаКонстант.Вставить("Пользователь1с", Продавец.Користувач.УникальныйИдентификатор());

	
	ДобавитьКурсыВалют(СтрукрутаКонстант);
	
	Возврат СтрукрутаКонстант;
	
КонецФункции

Процедура ДобавитьКурсыВалют(Структура)
	EUR = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекущаяДата(), Новый Структура("Валюта", Справочники.Валюты.НайтиПоКоду("978")));
	USD = РегистрыСведений.КурсыВалют.ПолучитьПоследнее(ТекущаяДата(), Новый Структура("Валюта", Справочники.Валюты.НайтиПоКоду("840")));
	Структура.Вставить("КурсUSD", USD.Курс); 
	Структура.Вставить("КурсEUR", EUR.Курс);
КонецПроцедуры

