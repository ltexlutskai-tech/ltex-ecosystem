Функция СформируватьДанныеДляЧата(Пользователь, ДатаНаСервере, ОбработныеУведомления, УИД_Клиента, Продавец) Экспорт 
	
	
	 Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ГруппыЧатаУчасники.Ссылка КАК Группа,
		|	ГруппыЧатаУчасники.Ссылка.Наименование,
		|	ГруппыЧатаУчасники.Пользователь КАК Користувач,
		|	ГруппыЧатаУчасники.Ссылка.КартинкаГруппы,
		|	ГруппыЧатаУчасники.ЛишеСвої
		|ПОМЕСТИТЬ ГруппыЧата
		|ИЗ
		|	Справочник.ГруппыЧата.Учасники КАК ГруппыЧатаУчасники
		|ГДЕ
		|	ГруппыЧатаУчасники.Пользователь = &Пользователь
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВложенныйЗапрос.Учасник КАК Учасник,
		|	ВложенныйЗапрос.Учасник.Наименование КАК Наименование
		|ИЗ
		|	(ВЫБРАТЬ
		|		ГруппыЧатаУчасники.Пользователь КАК Учасник
		|	ИЗ
		|		ГруппыЧата КАК ГруппыЧата
		|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.ГруппыЧата.Учасники КАК ГруппыЧатаУчасники
		|			ПО ГруппыЧата.Группа = ГруппыЧатаУчасники.Ссылка
		|	
		|	СГРУППИРОВАТЬ ПО
		|		ГруппыЧатаУчасники.Пользователь) КАК ВложенныйЗапрос
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Чат1С.Відправник,
		|	Чат1С.Одержувач,
		|	Чат1С.Повідомлення,
		|	Чат1С.Период,
		|	Чат1С.Уид_Сообщения,
		|	Чат1С.Одержувач ССЫЛКА Справочник.ГруппыЧата КАК ПолучательГруппа
		|ИЗ
		|	РегистрСведений.Чат1С КАК Чат1С
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ГруппыЧата КАК ГруппыЧата
		|		ПО (Чат1С.Одержувач = ГруппыЧата.Группа
		|				ИЛИ Чат1С.Одержувач = ГруппыЧата.Користувач)
		|			И (Чат1С.ДатаНаСервере > &ДатаНаСервере)
		|			И Чат1С.Відправник <> ГруппыЧата.Користувач
		|			И (НЕ ГруппыЧата.ЛишеСвої)
		|ГДЕ
		|	Чат1С.ДатаНаСервере >= &ДатаНаСервере
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Чат1С.Период КАК Период,
		|	Чат1С.Уид_Сообщения КАК Уид_Сообщения,
		|	Чат1С.Одержувач,
		|	Чат1С.Повідомлення,
		|	Чат1С.Одержувач ССЫЛКА Справочник.ГруппыЧата КАК ПолучательГруппа
		|ИЗ
		|	ГруппыЧата КАК ГруппыЧата
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.Чат1С КАК Чат1С
		|		ПО ГруппыЧата.Користувач = Чат1С.Відправник
		|			И (Чат1С.ДатаНаСервере > &ДатаНаСервере)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ГруппыЧата.Группа КАК Відправник,
		|	СУММА(ЕСТЬNULL(НепрочитаніПовідомлення.Кол, 0)) КАК Кол,
		|	ГруппыЧата.Группа ССЫЛКА Справочник.ГруппыЧата КАК ОтГруппы
		|ИЗ
		|	ГруппыЧата КАК ГруппыЧата
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НепрочитаніПовідомлення КАК НепрочитаніПовідомлення
		|		ПО ГруппыЧата.Группа = НепрочитаніПовідомлення.Відправник
		|			И ГруппыЧата.Користувач = НепрочитаніПовідомлення.Одержувач
		|
		|СГРУППИРОВАТЬ ПО
		|	НепрочитаніПовідомлення.Одержувач,
		|	ГруппыЧата.Группа
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	УдаленныеСообщения.УИД_Сообщения,
		|	УдаленныеСообщения.Дата
		|ИЗ
		|	РегистрСведений.УдаленныеСообщения КАК УдаленныеСообщения
		|ГДЕ
		|	УдаленныеСообщения.Дата >= &ДатаНаСервере
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	РекацииНаСобщения.УИД_Сообщения,
		|	РекацииНаСобщения.УчастникЧата,
		|	РекацииНаСобщения.Реакция,
		|	РекацииНаСобщения.Дата
		|ИЗ
		|	РегистрСведений.РекацииНаСобщения КАК РекацииНаСобщения
		|ГДЕ
		|	РекацииНаСобщения.Дата >= &ДатаНаСервере
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗапланированыеУведомления.УИД_Уведомления,
		|	ЗапланированыеУведомления.ДанныеУведомления,
		|	ЗапланированыеУведомления.Объект
		|ИЗ
		|	РегистрСведений.ЗапланированыеУведомления КАК ЗапланированыеУведомления
		|ГДЕ
		|	НЕ ЗапланированыеУведомления.Синхронизировано
		|	И ЗапланированыеУведомления.ТорговийАгент.Користувач = &Пользователь
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ИсторияРаботыСКлиентом.Период,
		|	ИсторияРаботыСКлиентом.Клиент,
		|	ИсторияРаботыСКлиентом.Запись,
		|	ИсторияРаботыСКлиентом.УИД_Записи,
		|	ИсторияРаботыСКлиентом.АвтоматичнийЗаписБезВзаємодіїЗКлієнтом
		|ИЗ
		|	РегистрСведений.ИсторияРаботыСКлиентом КАК ИсторияРаботыСКлиентом
		|ГДЕ
		|	ИсторияРаботыСКлиентом.Период >= &ДатаНаСервере
		//|	И ИсторияРаботыСКлиентом.Клиент.ТорговыйАгент.Користувач = &Пользователь
		|	И ИсторияРаботыСКлиентом.Клиент В (&СписокКонтрагентовТоргового)		
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказПокупателяТовары.Номенклатура,
		|	СУММА(ЗаказПокупателяТовары.Количество) КАК Количество,
		|	ЗаказПокупателя.ТорговийАгент,
		|	ПРЕДСТАВЛЕНИЕ(ЗаказПокупателя.ТорговийАгент) КАК ТорговийАгентПредставление
		|ИЗ
		|	Документ.ЗаказПокупателя.Товары КАК ЗаказПокупателяТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|		ПО ЗаказПокупателяТовары.Ссылка = ЗаказПокупателя.Ссылка
		|			И (ЗаказПокупателя.Проведен)
		|			И (ЗаказПокупателя.СтатусЗамовлення = &СтатусЗамовлення)
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаказПокупателяТовары.Номенклатура,
		|	ЗаказПокупателя.ТорговийАгент
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказПокупателя.Контрагент,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ЗаказПокупателя.Доставка = ЗНАЧЕНИЕ(Перечисление.НаявністьДоставки.Доставка)
		|				ТОГДА ВЫБОР
		|						КОГДА ЗаказПокупателя.Дата > &ДатаСемДнейНазад
		|							ТОГДА ЛОЖЬ
		|						ИНАЧЕ ИСТИНА
		|					КОНЕЦ
		|			ИНАЧЕ ВЫБОР
		|					КОГДА ЗаказПокупателя.Дата > &ДатаТриДнейНазад
		|						ТОГДА ЛОЖЬ
		|					ИНАЧЕ ИСТИНА
		|				КОНЕЦ
		|		КОНЕЦ) КАК ЕстьПростроченыеАктуальныеЗаказы,
		|	МАКСИМУМ(ЕСТЬNULL(МаршрутныйЛистЗаказы.ЗаказЕстьВМаршрутномЛисте, ЛОЖЬ)) КАК ЗаказВключенВМаршрутныйЛист
		|ИЗ
		|	Документ.ЗаказПокупателя КАК ЗаказПокупателя
		|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			МаршрутныйЛистЗаказы.ЗаказПокупателя КАК ЗаказПокупателяДок,
		|			ИСТИНА КАК ЗаказЕстьВМаршрутномЛисте
		|		ИЗ
		|			Документ.МаршрутныйЛист.Заказы КАК МаршрутныйЛистЗаказы
		|				ЛЕВОЕ СОЕДИНЕНИЕ Документ.МаршрутныйЛист КАК МаршрутныйЛист
		|				ПО МаршрутныйЛистЗаказы.Ссылка = МаршрутныйЛист.Ссылка
		|		ГДЕ
		|			НЕ МаршрутныйЛист.ПометкаУдаления) КАК МаршрутныйЛистЗаказы
		|		ПО ЗаказПокупателя.Ссылка = МаршрутныйЛистЗаказы.ЗаказПокупателяДок
		|ГДЕ
		|	ЗаказПокупателя.СтатусЗамовлення = &СтатусЗамовлення
		|	И ЗаказПокупателя.ПометкаУдаления = ЛОЖЬ
		|	И ЗаказПокупателя.Контрагент.ТорговыйАгент = &Продавец
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаказПокупателя.Контрагент";
	
	Запрос.УстановитьПараметр("Пользователь", Пользователь);
	Запрос.УстановитьПараметр("ДатаНаСервере", ДатаНаСервере);
	Запрос.УстановитьПараметр("СтатусЗамовлення", Справочники.СтатусиЗамовлень.Новий);
	Запрос.УстановитьПараметр("ДатаСемДнейНазад", НачалоДня(ТекущаяДата() - 7 * 60 * 60 * 24));
	Запрос.УстановитьПараметр("ДатаТриДнейНазад", НачалоДня(ТекущаяДата() - 3 * 60 * 60 * 24));
	Запрос.УстановитьПараметр("Продавец", Продавец);
	
	
	СписокКонтрагентовТоргового = Новый СписокЗначений;
	ЗапросКонтрагентыТоргового = Новый Запрос;
	ЗапросКонтрагентыТоргового.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.ТорговыйАгент = &ТорговыйАгент";
	
	ЗапросКонтрагентыТоргового.УстановитьПараметр("ТорговыйАгент", Продавец);
	
	РезультатЗапросаКонтрагентыТоргового = ЗапросКонтрагентыТоргового.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапросаКонтрагентыТоргового.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		СписокКонтрагентовТоргового.Добавить(ВыборкаДетальныеЗаписи.Ссылка);
	КонецЦикла;
	
	Запрос.УстановитьПараметр("СписокКонтрагентовТоргового", СписокКонтрагентовТоргового);
	
	
	Результат = Запрос.ВыполнитьПакетСПромежуточнымиДанными();

	тзЧаты 					= Результат.Получить(0).Выгрузить();
	тзУчасники 				= Результат.Получить(1).Выгрузить();
	тзВходящиеСообщения 	= Результат.Получить(2).Выгрузить();
	тзИсходящиеСообщения 	= Результат.Получить(3).Выгрузить();
	тзНепрочитано           = Результат.Получить(4).Выгрузить();
	тзУдаленно           	= Результат.Получить(5).Выгрузить();
