		Попытка
			ДокОб.Записать(РежимЗаписиДокумента.Проведение,РежимПроведенияДокумента.Неоперативный);
		Исключение
		КонецПопытки;
		//++
		Общий.СнятьАктуальностьСЗаказаСоСтатусомДоставкиПочтаСамовывоз(ДокСсылка);
		//++
	КонецЦикла;
	
