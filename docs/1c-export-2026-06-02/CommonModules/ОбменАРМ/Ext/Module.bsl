Процедура СоздатьПКО(МассивДокументов, ТаблицаИД, МассивОшибок) Экспорт;
	//НомОб = Справочники.ХранилищеДополнительнойИнформации.НайтиПоНаименованию("Тест").ПолучитьОбъект();
	//НомОб.Хранилище = Новый ХранилищеЗначения(МассивДокументов);
	//НомОб.Записать();
	Для Каждого Элемент Из МассивДокументов Цикл
		Если Элемент.ПометкаУдаления Тогда 
			Продолжить;
		КонецЕсли;
		РеализицияОбъект = Неопределено;
		ОшибкаТранзакции = Ложь;
		//НачатьТранзакцию();
		Реализация 		= Документы.РеализацияТоваровУслуг.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.Реализация_УИД));
		Попытка
			Если Реализация.ПолучитьОбъект() = Неопределено Тогда 
				Реализация = Документы.РеализацияТоваровУслуг.ПустаяСсылка();
			КонецЕсли;
		Исключение
		КонецПопытки;
		
		МаршрутныйЛист 	= Документы.МаршрутныйЛист.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.МаршрутныйЛист_УИД));
		
		Если ВозвратПоЗакритомуМаршрутнику(МаршрутныйЛист, Элемент.ИД, ТаблицаИД) Тогда 
			Продолжить;
		КонецЕсли;
		
		ЗаказПокупателя 				= Документы.ЗаказПокупателя.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.ЗаказПокупателя_УИД));
		БакновскийСчет 					= Справочники.БанковскиеСчета.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.БанковскийСчет_УИД));
		СтатьяДвиженияДенежныхСредств   = Справочники.СтатьиДвиженияДенежныхСредств.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.СтатьяДвиженияДенежныхСредств_УИД));
		Если Не Реализация.Пустая() Тогда  //перевіряю чи ПКО на основі реалізації зроблений
			РеализицияОбъект = Реализация.ПолучитьОбъект();
			Если РеализицияОбъект = Неопределено Тогда        // Значить була створена по іншому - шукаєм реалізацію
				
		
			Если ЗначениеЗаполнено(ЗаказПокупателя) Тогда // ШукаємРеалізаціюПоЗаказу 
				ЗапросРеализации = Новый Запрос;
				ЗапросРеализации.Текст = 
				"ВЫБРАТЬ
				|	РеализацияТоваровУслуг.Ссылка
				|ИЗ
				|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
				|ГДЕ
				|	РеализацияТоваровУслуг.Сделка = &Сделка
				|	И НЕ РеализацияТоваровУслуг.ПометкаУдаления
				|	И РеализацияТоваровУслуг.Контрагент = &Контрагент";
				ЗапросРеализации.УстановитьПараметр("Сделка", ЗаказПокупателя);
				ЗапросРеализации.УстановитьПараметр("Контрагент", ЗаказПокупателя.Контрагент);
				ВыборкаЗапросаРеализации = ЗапросРеализации.Выполнить().Выбрать();
				Если ВыборкаЗапросаРеализации.Следующий() И ЗначениеЗаполнено(ЗаказПокупателя) Тогда  // Чи була раніше створена реалізація
					Реализация = ВыборкаЗапросаРеализации.Ссылка;
					РеализицияОбъект = Реализация.ПолучитьОбъект();
					Если РеализицияОбъект = Неопределено Тогда 
						МассивОшибок.Добавить("Не знайдена реалізація в 1С для оплати " + ЗаказПокупателя.Контрагент);
						Продолжить;
					КонецЕсли;	
				Иначе 
					МассивОшибок.Добавить("Не знайдена реалізація в 1С для оплати " + ЗаказПокупателя.Контрагент);
					Продолжить;
				КонецЕсли; 
			КонецЕсли;
			
			
		
				

			КонецЕсли;
			Контрагент = РеализицияОбъект.Контрагент;
			Если НЕ ЗначениеЗаполнено(ЗаказПокупателя) Тогда 
				ЗаказПокупателя = РеализицияОбъект.Сделка;
			КонецЕсли;
			
		Иначе 
			
			Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(Элемент.Контрагент_УИД));
		КонецЕсли;
		
		//intrata_wald_22112021 ↓
		СумаUAH_Безнал = 0;
		Попытка
			СумаUAH_Безнал = Элемент.СумаUAH_Безнал;
		Исключение
		КонецПопытки;
		
		СтруктураВалют = Новый Структура("СумаUAH,СумаEUR,СумаUSD", 
		Справочники.Валюты.НайтиПоКоду("980"),
		Справочники.Валюты.НайтиПоКоду("978"),
		Справочники.Валюты.НайтиПоКоду("840"));

		Суми = Новый Соответствие;
		Суми.Вставить("СумаUAH", Элемент.СумаUAH);
		Суми.Вставить("СумаEUR", Элемент.СумаEUR); 
		Суми.Вставить("СумаUSD", Элемент.СумаUSD);
		Ссилки = Новый Соответствие;
		Ссилки.Вставить("СумаUAH", "УИДГРН");
		Ссилки.Вставить("СумаEUR", "ПКО_УИД"); 
		Ссилки.Вставить("СумаUSD", "УИДUSD");

		Курси = Новый Соответствие;
		Курси.Вставить(СтруктураВалют.СумаUAH, 1);
		Курси.Вставить(СтруктураВалют.СумаEUR, Элемент.КурсEUR); 
		Курси.Вставить(СтруктураВалют.СумаUSD, Элемент.КурсUSD);

		
		Если СумаUAH_Безнал > 0 Тогда
			//--
			//ТипКассовогоОрдера = "ПлатежноеПоручениеВходящее";
			//--
			
			//Если Элемент.ВидДвижения = "Приход" Тогда
			//	ТипКассовогоОрдера = "ПриходныйКассовыйОрдер";
			//ИначеЕсли Элемент.ВидДвижения = "Расход" Тогда
			//	ТипКассовогоОрдера = "РасходныйКассовыйОрдер";
			//КонецЕсли; 			
			
			
			//Попытка
			//	НайденныйОрдер = Документы[ТипКассовогоОрдера].ПолучитьСсылку(Элемент["УИДГРН"]).ПолучитьОбъект();
			//Исключение
			//	НайденныйОрдер = Документы[ТипКассовогоОрдера].ПолучитьСсылку(Элемент["ПКО_УИД"]).ПолучитьОбъект();
			//КонецПопытки;
			
			//++
			Если Элемент.ВидДвижения = "Приход" Тогда
				ТипКассовогоОрдера = "ПлатежноеПоручениеВходящее"; 				
				Попытка
					НайденныйОрдер = Документы[ТипКассовогоОрдера].ПолучитьСсылку(Элемент["УИДГРН"]).ПолучитьОбъект();
				Исключение
					НайденныйОрдер = Документы[ТипКассовогоОрдера].ПолучитьСсылку(Элемент["ПКО_УИД"]).ПолучитьОбъект();
				КонецПопытки;     			
				
			ИначеЕсли Элемент.ВидДвижения = "Расход" Тогда
				ТипКассовогоОрдера = "ПлатежноеПоручениеИсходящее";  				
				Попытка
					НайденныйОрдер = Документы[ТипКассовогоОрдера].ПолучитьСсылку(Элемент["ПКО_УИД"]).ПолучитьОбъект();
				Исключение
					НайденныйОрдер = Документы[ТипКассовогоОрдера].ПолучитьСсылку(Элемент["УИДГРН"]).ПолучитьОбъект();	
				КонецПопытки;
			
			КонецЕсли;		
