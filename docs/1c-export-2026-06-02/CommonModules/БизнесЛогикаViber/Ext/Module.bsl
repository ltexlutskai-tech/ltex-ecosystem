/// отправить дополнительные действия Вайбер ////////////////////////
Процедура ОтправитьДополнительныеДействияВайбер() Экспорт
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ДополнительныеДействияВайбер.Контакт,
		|	ДополнительныеДействияВайбер.Дата,
		|	ДополнительныеДействияВайбер.Текст,
		|	ДополнительныеДействияВайбер.Настройка
		|ИЗ
		|	РегистрСведений.ДополнительныеДействияВайбер КАК ДополнительныеДействияВайбер
		|ГДЕ
		|	ДополнительныеДействияВайбер.Отправлено = ЛОЖЬ";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Если ТекущаяДата() - Выборка.Дата > 4 Тогда 
			Ответ = МодульУправленияViber.ОтправитьСообщениеПользователю(Выборка.Настройка, Выборка.Контакт, Выборка.Текст);
				
			Если Ответ.Свойство("status_message") Тогда
				Запись = РегистрыСведений.ДополнительныеДействияВайбер.СоздатьМенеджерЗаписи();
				ЗаполнитьЗначенияСвойств(Запись, Выборка);
				Запись.Прочитать();
				Если Запись.Выбран() Тогда
					Запись.Отправлено = Истина;
					Запись.Записать();
				КонецЕсли;				
			КонецЕсли;
		КонецЕсли;		
	КонецЦикла; 
	
	
	
КонецПроцедуры

#КонецОбласти

#Область Вспомогательное

Процедура ВыполнитьОбновлениеСесиеСКонтактом()Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КонтактыViber.Ссылка
		|ИЗ
		|	Справочник.КонтактыViber КАК КонтактыViber";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Контакт = ВыборкаДетальныеЗаписи.Ссылка;
		Если Контакт.СтатусДиалога = Перечисления.СтатусДиалога.Запрещен Тогда
			Если Контакт.ОстатокСесии <> 0 Тогда
				Спр = Контакт.ПолучитьОбъект();
				Спр.ОстатокСесии = 0;
				Спр.Записать();
			КонецЕсли;
		Иначе
			ОстатокСесии = ПолучитьВремяПоследнегоСообщения(Контакт);
			Если Контакт.ОстатокСесии <> ОстатокСесии Тогда
				Спр = Контакт.ПолучитьОбъект();
				Спр.ОстатокСесии = ОстатокСесии;
				Спр.Записать();
			КонецЕсли;
		КонецЕсли;	
	КонецЦикла;	
	
КонецПроцедуры

Функция ПолучитьВремяПоследнегоСообщения(Контакт)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ViberИсторииСообщений.Дата КАК Дата
		|ИЗ
		|	РегистрСведений.ViberИсторииСообщений КАК ViberИсторииСообщений
		|ГДЕ
		|	ViberИсторииСообщений.Контакт = &Контакт
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата УБЫВ";
	
	Запрос.УстановитьПараметр("Контакт", Контакт);
	
	РезультатЗапроса = Запрос.Выполнить(); 	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	
	ДатаПоследнего = ВыборкаДетальныеЗаписи.Дата;
	
	Если ЗначениеЗаполнено(ДатаПоследнего) Тогда
		СрокОкончания = ДатаПоследнего + 24*60*60;
		РазницаДат = (СрокОкончания - ТекущаяДата()) / 3600;
	    ОстатокВремени = Окр(РазницаДат, 0, РежимОкругления.Окр15как10);
		
		Если ОстатокВремени > 24 ИЛИ ОстатокВремени < 0 Тогда
			Возврат 0;
		Иначе
			Возврат ОстатокВремени;
		КонецЕсли;		
		
		Возврат ОстатокВремени;
	КонецЕсли;
	
	Возврат 0; 	
	
КонецФункции	

Процедура ОбновлениеВремяСесийViber() Экспорт
	ВыполнитьОбновлениеСесиеСКонтактом();
КонецПроцедуры



