Функция ЗаполнитьТекстПоШаблону(Текст, Контакт)
	
	ТекстДляОтправки = СтрЗаменить(Текст, "[Покупатель.Наименование]", Контакт.Наименование);
	
	Возврат ТекстДляОтправки;  
	
КонецФункции	

Функция ПользовательОтписалсяОтБота(ДанныеЗапроса, НастройкиВайбер)
	
	Идентификатор = ДанныеЗапроса.user_id;
	
	УчетнаяЗапись = Справочники.КонтактыViber.НайтиПоРеквизиту("Идентификатор",(СокрЛП(Идентификатор)));
	Если НЕ УчетнаяЗапись = Справочники.КонтактыViber.ПустаяСсылка() Тогда
		СпрОбъект = УчетнаяЗапись.ПолучитьОбъект();
	КонецЕсли;
	
	СпрОбъект.СтатусДиалога = Перечисления.СтатусДиалога.Запрещен;
	СпрОбъект.Подписан = Ложь;
	
	СпрОбъект.ДатаОтписки = ТекущаяДатаСеанса(); 
	
	Если Не ЗначениеЗАполнено(СпрОбъект.ИсточникПривличения) Тогда
		СпрОбъект.ИсточникПривличения = НастройкиВайбер;
	КонецЕсли;	
	
	СпрОбъект.Записать();
	
	Возврат СпрОбъект.Ссылка;
	
КонецФункции

Процедура ЗафиксироватьВходящееСообщение(ДанныеЗапроса, Контакт, НастройкиВайбер)
	
	Спр = Контакт.ПолучитьОбъект();
	Спр.НовоеСообщение = Истина;
	Спр.Записать();
	
	
	НовоеСообщение = РегистрыСведений.ViberИсторииСообщений.СоздатьМенеджерЗаписи();
	НовоеСообщение.Контакт = Контакт;
	НовоеСообщение.Напрвление = Перечисления.Viber_Направление.Входящее;
	НовоеСообщение.Дата = ТекущаяДатаСеанса();
	НовоеСообщение.ИсточникПривличения = НастройкиВайбер;
	НовоеСообщение.Непрочитаное = истина;
	
	
	Если ДанныеЗапроса.Свойство("message") Тогда
		Если ДанныеЗапроса.message.type = "text" Тогда
			НовоеСообщение.Текст = ДанныеЗапроса.message.text;
		ИначеЕсли ДанныеЗапроса.message.type = "picture" Тогда
			НовоеСообщение.Текст        = ДанныеЗапроса.message.thumbnail;
			
			ФайлВБазе = ЗафиксироватьВходящийФайл(Контакт, ДанныеЗапроса.message.file_name,  ДанныеЗапроса.message.media);
			Если ЗначениеЗаполнено(ФайлВБазе) Тогда
				НовоеСообщение.ПутьКФайлу   = ФайлВБазе;
			Иначе
				НовоеСообщение.ПутьКФайлу   = ДанныеЗапроса.message.media;
			КонецЕсли;	
			НовоеСообщение.Размер       = ДанныеЗапроса.message.size;
			НовоеСообщение.Наименование = ДанныеЗапроса.message.file_name;
			НовоеСообщение.Картинка     = Истина;
			
		ИначеЕсли ДанныеЗапроса.message.type = "file" Тогда
			НовоеСообщение.Текст        = ДанныеЗапроса.message.media;
			ФайлВБазе = ЗафиксироватьВходящийФайл(Контакт, ДанныеЗапроса.message.file_name,  ДанныеЗапроса.message.media);
			Если ЗначениеЗаполнено(ФайлВБазе) Тогда
				НовоеСообщение.ПутьКФайлу   = ФайлВБазе;
			Иначе
				НовоеСообщение.ПутьКФайлу   = ДанныеЗапроса.message.media;
			КонецЕсли;
			
			НовоеСообщение.Размер       = ДанныеЗапроса.message.size;
			НовоеСообщение.Наименование = ДанныеЗапроса.message.file_name;
			НовоеСообщение.Файл         = Истина;  
		ИначеЕсли ДанныеЗапроса.message.type = "video" Тогда
			НовоеСообщение.Текст        = ДанныеЗапроса.message.thumbnail;
			НовоеСообщение.ПутьКФайлу   = ДанныеЗапроса.message.media;
			НовоеСообщение.Размер       = ДанныеЗапроса.message.size;
			НовоеСообщение.Наименование = ДанныеЗапроса.message.file_name;
			НовоеСообщение.Видео        = Истина; 
		ИначеЕсли ДанныеЗапроса.message.type = "contact" Тогда
			Если ДанныеЗапроса.message.text = "phone_reply" Тогда 
				НовоеСообщение.Текст        = ДанныеЗапроса.message.contact.phone_number;
			КонецЕсли;
    	КонецЕсли;			
	ИначеЕсли
		ДанныеЗапроса.event = "subscribed" Тогда
		НовоеСообщение.Текст = "Пользователь разрешил получать сообщения";
	ИначеЕсли
		ДанныеЗапроса.event = "unsubscribed" Тогда	
		НовоеСообщение.Текст = "Пользователь отписался и запретил получать уведомления";
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("chat_hostname") Тогда
		НовоеСообщение.ЧатID = ДанныеЗапроса.chat_hostname;
	КонецЕсли; 
	
	Если ДанныеЗапроса.Свойство("message_token") Тогда
		НовоеСообщение.ТокенСообщния = ДанныеЗапроса.message_token;
	КонецЕсли; 
	
	

	НовоеСообщение.Записать();
	
	
	
КонецПроцедуры

Функция ЗафиксироватьВходящийФайл(Контакт, Наименование, Путь)
	
	ФайлНаСервере = "";
	
	Если ЗначениеЗаполнено(Путь) Тогда
		
		МассивИмен = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Наименование, ".");
		Расш = МассивИмен[МассивИмен.Количество() - 1];    
		
		ФайлТут = ПолучитьИмяВременногоФайла(Расш);
	
		КопироватьФайл(Путь, ФайлТут);

		ГруппаФайла = ПолучитьГруппуФайла(Контакт);
		
		Спр = Справочники.ПрикрепленныеФайлыViber.СоздатьЭлемент();
		Спр.Наименование = Наименование;
		Спр.Путь = Путь;
		Спр.Контакт = Контакт;
		Спр.ДатаСоздания = ТекущаяДатаСеанса();
		Спр.Родитель     = ГруппаФайла;
		
		Адрес = ПоместитьВоВременноеХранилище(Новый ДвоичныеДанные(ФайлТут));
		Данные = ПолучитьИзВременногоХранилища(Адрес);
		Спр.Изображение   = Новый ХранилищеЗначения(Данные);
		
		Спр.Записать();
		
		
		ФайлВБазе = "C:\Apache24\htdocs\file\" + Наименование;
		КопироватьФайл(ФайлТут, ФайлВБазе);
		ФайлНаСервере = "https://ltex1c.com.ua/file/" + Наименование;
		
		УдалитьИзВременногоХранилища(Адрес);
		УдалитьФайлы(ФайлТут);

	КонецЕсли;
	
	Возврат ФайлНаСервере;
	
КонецФункции

Функция ПолучитьГруппуФайла(Контакт)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПрикрепленныеФайлыViber.Ссылка КАК Ссылка
		|ИЗ
		|	Справочник.ПрикрепленныеФайлыViber КАК ПрикрепленныеФайлыViber
		|ГДЕ
		|	ПрикрепленныеФайлыViber.ЭтоГруппа = ИСТИНА
		|	И ПрикрепленныеФайлыViber.Контакт = &Контакт";
	
	Запрос.УстановитьПараметр("Контакт", Контакт);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Спр = Справочники.ПрикрепленныеФайлыViber.СоздатьГруппу();
		Спр.Наименование = Контакт.Наименование;
		Спр.Контакт      = Контакт;
		Спр.Записать();
		Возврат Спр.Ссылка;
		
	КонецЕсли;
	
КонецФункции	

