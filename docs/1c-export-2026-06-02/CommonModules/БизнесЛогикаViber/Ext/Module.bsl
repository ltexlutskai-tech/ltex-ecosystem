///// команды чат бот /////////////////////////
Процедура ЗафиксироватьТелефонКонтактаИОтправитьТекст(Контакт, НастройкиВайбер, Телефон)
	
	ЗарегистрироватьДоп = Ложь;
	
	СпрОбъект = Контакт.ПолучитьОбъект();
	СпрОбъект.Телефон = Телефон;
	//СпрОбъект.Контрагент = ПолучитьКонтрагентаПоНомеруТелефона(Телефон);
	СпрОбъект.СтатусДиалога = Перечисления.СтатусДиалога.Разрешон;
	СпрОбъект.ДатаПодписки  = ТекущаяДатаСеанса();
	СпрОбъект.Подписан      = Истина;
	СпрОбъект.ИсточникПривличения = НастройкиВайбер;
	СпрОбъект.Контрагент    = ПолучитьКонтрагентаПоНомеруТелефона(Телефон);
	Если ЗначениеЗаполнено(СпрОбъект.Контрагент) Тогда
		СпрОбъект.Область = СпрОбъект.Контрагент.Область;
	КонецЕсли;	
	СпрОбъект.Записать(); 
	
	Клавиатура = Новый Структура;
	Кнопки = Новый Массив;
		   
	Если Не ЗначениеЗаполнено(Контакт.Контрагент) Тогда	
		СписокКоманд = ПолучитьСписокКоманд();
		Сп = СпрОбъект.Ссылка.ПолучитьОбъект();
		Сп.ЗапросОбласти = Истина;
		Сп.Записать();
		
		Если ЗначениеЗаполнено(СписокКоманд) Тогда
			Для Каждого Строка Из СписокКоманд Цикл
				НазваниеКнопки = Строка(Строка);
				Кнопка = Новый Структура;
				Кнопка.Вставить("Columns", 3);
				Кнопка.Вставить("Rows", 1);
				Кнопка.Вставить("TextSize","regular");
				Кнопка.Вставить("Text", НазваниеКнопки);
				Кнопка.Вставить("ActionType", "reply");
				Кнопка.Вставить("ActionBody", Строка(Строка));
				Кнопка.Вставить("BgColor", "#87CEEB");
				Кнопки.Добавить(Кнопка);
			КонецЦикла;
			
			Клавиатура.Вставить("Type","keyboard");
			Клавиатура.Вставить("DefaultHeight", "false");
			Клавиатура.Вставить("Buttons", Кнопки);	
		КонецЕсли;	
		
		Текст = "З якої Ви області?" + Символы.ПС + "Виберіть з наведених варіантів.";
	Иначе
		Текст = "Дякуємо за реєстрацію!" + Символы.ПС + Символы.ПС + "Менеджер зв'яжеться з Вами найближчим часом.";
		ЗарегистрироватьДоп = Истина;
	КонецЕсли;	

	ИмяМетода = "send_message";
	СтруктураЗапроса = Новый Структура();
	СтруктураЗапроса.Вставить("sender", Новый Структура("name", НастройкиВайбер.ИмяОтправителя));
	СтруктураЗапроса.Вставить("receiver", СокрЛП(Контакт.Идентификатор));
	СтруктураЗапроса.Вставить("text", Текст);
	СтруктураЗапроса.Вставить("type", "text");
	СтруктураЗапроса.Вставить("min_api_version", 7);
	
	Если ЗначениеЗАполнено(Клавиатура) Тогда
		СтруктураЗапроса.Вставить("keyboard", Клавиатура);
	КонецЕсли;	

	Ответ = МодульУправленияViber.ОтправитьЗапросViber(НастройкиВайбер, ИмяМетода, СтруктураЗапроса);
	
	Если ЗарегистрироватьДоп Тогда
		ЗафиксироватьДополнительнуюФункциюВайбер(Контакт, НастройкиВайбер);
	
	КонецЕсли;	
	
КонецПроцедуры	

/////получить менеджера по області //////////////
Процедура ПодобратьМенеджераПоОбласти(Сообщение, Контакт, НастройкиВайбер)
	
	ТекстПоиска = "%" + СокрЛП(Сообщение.text) + "%";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТорговыеАгенты.Ссылка
		|ИЗ
		|	Справочник.ТорговыеАгенты КАК ТорговыеАгенты
		|ГДЕ
		|	ТорговыеАгенты.Область ПОДОБНО &Область
		|	И НЕ ТорговыеАгенты.ПометкаУдаления";
	
	Запрос.УстановитьПараметр("Область", ТекстПоиска);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	Если РезультатЗапроса.Количество() > 0 Тогда
		Спр = Контакт.ПолучитьОбъект();
		Спр.ЗапросОбласти = Ложь;
		Спр.Менеджер = РезультатЗапроса[0].Ссылка;
		Спр.Записать();
	Иначе
		Спр = Контакт.ПолучитьОбъект();
		Спр.ЗапросОбласти = Ложь;
		Спр.Записать();
	КонецЕсли;
	
	Текст = "Дякуємо за реєстрацію!" + Символы.ПС + Символы.ПС + "Ваш менеджер зв'яжеться з Вами найближчим часом.";
		

	ИмяМетода = "send_message";
	СтруктураЗапроса = Новый Структура();
	СтруктураЗапроса.Вставить("sender", Новый Структура("name", НастройкиВайбер.ИмяОтправителя));
	СтруктураЗапроса.Вставить("receiver", СокрЛП(Контакт.Идентификатор));
	СтруктураЗапроса.Вставить("text", Текст);
	СтруктураЗапроса.Вставить("type", "text");
	СтруктураЗапроса.Вставить("min_api_version", 7);
	
	Ответ = МодульУправленияViber.ОтправитьЗапросViber(НастройкиВайбер, ИмяМетода, СтруктураЗапроса);  
	
	
	ЗафиксироватьДополнительнуюФункциюВайбер(Контакт, НастройкиВайбер); 	
	
КонецПроцедуры	

///// получить контрагента по телефону /////////////////////////
Функция ПолучитьКонтрагентаПоНомеруТелефона(Телефон)
	
	ТелефонПоиска = "%" + Прав(СтрЗаменить(Телефон, Символ(160), ""), 9) + "%";
	
		
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.Ссылка
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|ГДЕ
		|	Контрагенты.НомерТелефона ПОДОБНО &НомерТелефона";
	
	Запрос.УстановитьПараметр("НомерТелефона", ТелефонПоиска);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	КонецЕсли;
	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	КонтрагентыДополнительныеНомераТелефонов.Ссылка
		|ИЗ
		|	Справочник.Контрагенты.ДополнительныеНомераТелефонов КАК КонтрагентыДополнительныеНомераТелефонов
		|ГДЕ
		|	КонтрагентыДополнительныеНомераТелефонов.Номер ПОДОБНО &Номер";
	
	Запрос.УстановитьПараметр("Номер", ТелефонПоиска);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.ссылка;
	КонецЕсли;
	
	Возврат Справочники.Контрагенты.ПустаяСсылка();
	
	
КонецФункции	






////// получить список команд ////////////////////
Функция ПолучитьСписокКоманд()
	
	КнопкаСтрокой = "";
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТорговыеАгенты.Область
		|ИЗ
		|	Справочник.ТорговыеАгенты КАК ТорговыеАгенты
		|ГДЕ
		|	НЕ ТорговыеАгенты.ПометкаУдаления";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Область) Тогда
			КнопкаСтрокой = "" + КнопкаСтрокой + ВыборкаДетальныеЗаписи.Область + ",";
		КонецЕсли;	
	КонецЦикла;
	
	Если ЗначениеЗаполнено(КнопкаСтрокой) Тогда
		КнопкаСтрокой = СтрЗаменить(КнопкаСтрокой, " ", "");
		
		СписокКнопок = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(КнопкаСтрокой, ",");
		Возврат СписокКнопок;
	КонецЕсли;
	
	Возврат Неопределено;
	
	
КонецФункции	





