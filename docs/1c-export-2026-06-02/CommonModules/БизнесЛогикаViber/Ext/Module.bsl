#Область Старт_Вайбер_Бота

Функция ЗафиксироватьНовогоОтправителяИОтправитьТекстПриведствия(ДанныеЗапроса, НастройкиВайбер)Экспорт
	
	Контакт = ЗафиксироватьОтправителя(ДанныеЗапроса, НастройкиВайбер);
		
	Приведствие = ОтправитьТекстПриветствияНаВходВБот(Контакт, НастройкиВайбер);
		
	Возврат Приведствие; 

КонецФункции 

Функция ОтправитьТекстПриветствияНаВходВБот(Контакт, НастройкиВайбер)Экспорт
	
	ИмяМетода = "send_message";
	
	Клавиатура = Новый Структура;
	Кнопки = Новый Массив;
		   
	
	НазваниеКнопки = "ЗАРЕЄСТРУВАТИСЬ";
	Кнопка = Новый Структура;
	Кнопка.Вставить("TextSize","regular");
	Кнопка.Вставить("Text", НазваниеКнопки);
	Кнопка.Вставить("ActionType", "share-phone");
	Кнопка.Вставить("ActionBody", "phone_reply");
	Кнопка.Вставить("BgColor", "#00FF7F");
	Кнопки.Добавить(Кнопка);
	
	Клавиатура.Вставить("Type","keyboard");
	Клавиатура.Вставить("DefaultHeight", "false");
	Клавиатура.Вставить("Buttons",Кнопки);
	//Клавиатура.Вставить("InputFieldState","hidden");
		
	
	ТекстПриведствия = НастройкиВайбер.ТекстПриветствия;
	Текст = ЗаполнитьТекстПоШаблону(ТекстПриведствия, Контакт); 

	
	СтруктураОтвета = Новый Структура();
    СтруктураОтвета.Вставить("receiver", СокрЛП(Контакт.Идентификатор));	
	СтруктураОтвета.Вставить("sender", Новый Структура("name", НастройкиВайбер.ИмяОтправителя));
	СтруктураОтвета.Вставить("text", Текст);
	СтруктураОтвета.Вставить("type", "text");
	СтруктураОтвета.Вставить("min_api_version", 7);
	СтруктураОтвета.Вставить("keyboard", Клавиатура);
	
	Возврат ОбщегоНазначенияHTTPViber.ОтветJSON(СтруктураОтвета);
	
	//Ответ = МодульУправленияViber.ОтправитьЗапросViber(НастройкиВайбер, ИмяМетода, СтруктураОтвета);
	//
	//
	//
	//Возврат ОбщегоНазначенияHTTPViber.ПростойУспешныйОтвет();
	
КонецФункции

Функция ЗафиксироватьСтатусРазрешенияДиалога(ДанныеЗапроса, НастройкиВайбер)Экспорт
	
	Контакт = ЗафиксироватьСтатусДиалога(ДанныеЗапроса.user, НастройкиВайбер);
	ЗафиксироватьВходящееСообщение(ДанныеЗапроса, Контакт, НастройкиВайбер);
	Возврат ОбщегоНазначенияHTTPViber.ПростойУспешныйОтвет(); 
	
КонецФункции

Функция ЗафиксироватьСтатусОтпискиОтБота(ДанныеЗапроса, НастройкиВайбер)Экспорт
	
	Контакт = ПользовательОтписалсяОтБота(ДанныеЗапроса, НастройкиВайбер);
	ЗафиксироватьВходящееСообщение(ДанныеЗапроса, Контакт, НастройкиВайбер);
	
	Возврат ОбщегоНазначенияHTTPViber.ПростойУспешныйОтвет();
	
КонецФункции   
 
//////// входящие сообщения ////////////////////
Функция ОбработатьСообщение(ДанныеЗапроса, НастройкиВайбер)Экспорт 
	 
	Если ДанныеЗапроса.Свойство("sender") Тогда
		Контакт = ОбновитьОтправителя(ДанныеЗапроса.sender, НастройкиВайбер);
	КонецЕсли;
	
	Если НастройкиВайбер.ВестиИсториюПереписки Тогда
		ЗафиксироватьВходящееСообщение(ДанныеЗапроса, Контакт, НастройкиВайбер);
	КонецЕсли;
	
	Если ДанныеЗапроса.Свойство("message") Тогда
		Если ДанныеЗапроса.message.Свойство("text") Тогда
			Если ДанныеЗапроса.message.text = "phone_reply" Тогда
				ЗафиксироватьТелефонКонтактаИОтправитьТекст(Контакт, НастройкиВайбер, ДанныеЗапроса.message.contact.phone_number);
				Возврат ОбщегоНазначенияHTTPViber.ПростойУспешныйОтвет();
			ИначеЕсли Контакт.ЗапросОбласти Тогда
				ПодобратьМенеджераПоОбласти(ДанныеЗапроса.message, Контакт, НастройкиВайбер);
			КонецЕсли;
		//Иначе
		//	Возврат ОбщегоНазначенияHTTPViber.ПростойУспешныйОтвет();		
		КонецЕсли;
	КонецЕсли;	
			//
	Возврат ОбщегоНазначенияHTTPViber.ПростойУспешныйОтвет();	
	
КонецФункции 

/////// статус прочтено ///////////////////////
Функция ЗафиксироватьСтатусПрочитано(ДанныеЗапроса, НастройкиВайбер)Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ViberИсторииСообщений.Контакт КАК Контакт,
		|	ViberИсторииСообщений.Дата КАК Дата,
		|	ViberИсторииСообщений.Напрвление КАК Напрвление,
		|	ViberИсторииСообщений.ЧатID КАК ЧатID,
		|	ViberИсторииСообщений.ТокенСообщния КАК ТокенСообщния,
		|	ViberИсторииСообщений.ИсточникПривличения КАК ИсточникПривличения,
		|	ViberИсторииСообщений.Картинка КАК Картинка,
		|	ViberИсторииСообщений.Файл КАК Файл,
		|	ViberИсторииСообщений.Видео КАК Видео,
		|	ViberИсторииСообщений.Текст КАК Текст,
		|	ViberИсторииСообщений.ПутьКФайлу КАК ПутьКФайлу,
		|	ViberИсторииСообщений.Размер КАК Размер,
		|	ViberИсторииСообщений.Наименование КАК Наименование,
		|	ViberИсторииСообщений.ФайлВБазе КАК ФайлВБазе,
		|	ViberИсторииСообщений.Доставлено КАК Доставлено,
		|	ViberИсторииСообщений.Прочтено КАК Прочтено
		|ИЗ
		|	РегистрСведений.ViberИсторииСообщений КАК ViberИсторииСообщений
		|ГДЕ
		|	ViberИсторииСообщений.ТокенСообщния = &ТокенСообщния";
	
	Запрос.УстановитьПараметр("ТокенСообщния", СтрЗаменить(Строка(ДанныеЗапроса.message_token), Символ(160), ""));
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Запись = РегистрыСведений.ViberИсторииСообщений.СоздатьМенеджерЗаписи();
		Запись.Контакт             = ВыборкаДетальныеЗаписи.Контакт;
		Запись.Дата                = ВыборкаДетальныеЗаписи.Дата;
		Запись.Напрвление          = ВыборкаДетальныеЗаписи.Напрвление;
		Запись.ЧатID               = ВыборкаДетальныеЗаписи.ЧатID;
		Запись.ТокенСообщния       = ВыборкаДетальныеЗаписи.ТокенСообщния;
		Запись.ИсточникПривличения = ВыборкаДетальныеЗаписи.ИсточникПривличения;
		Запись.Картинка            = ВыборкаДетальныеЗаписи.Картинка;
		Запись.Файл                = ВыборкаДетальныеЗаписи.Файл;
		Запись.Видео               = ВыборкаДетальныеЗаписи.Видео;
		
		Запись.Прочитать();
		Если Запись.Выбран() Тогда
			Запись.Прочтено = Истина;
			Запись.Записать();
		КонецЕсли;
	КонецЕсли;
	
	Возврат ОбщегоНазначенияHTTPViber.ПростойУспешныйОтвет();

	
КонецФункции	

