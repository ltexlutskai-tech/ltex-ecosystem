Функция ЗафиксироватьОтправителя(ДанныеОтправителя, НастройкиВайбер) 

	//ОтправитьДоплнительныеДействия = Ложь;
	
	Идентификатор = Строка(СокрЛП(ДанныеОтправителя.id));
	
	УчетнаяЗапись = Справочники.КонтактыViber.НайтиПоРеквизиту("Идентификатор", Идентификатор);
	Если УчетнаяЗапись = Справочники.КонтактыViber.ПустаяСсылка() Тогда
		СпрОбъект = Справочники.КонтактыViber.СоздатьЭлемент();
		ОтправитьДоплнительныеДействия = Истина;
	Иначе
		СпрОбъект = УчетнаяЗапись.ПолучитьОбъект();
	КонецЕсли;	

	Если ДанныеОтправителя.Свойство("name") Тогда
		ИмяПользователя = ДанныеОтправителя.name;
	КонецЕсли;
	
	Если ДанныеОтправителя.Свойство("avatar") Тогда
		Фото = ДанныеОтправителя.avatar;
	КонецЕсли; 
	
	СпрОбъект.Идентификатор  = Идентификатор;	
	СпрОбъект.Наименование = ИмяПользователя;
	СпрОбъект.Фото = Фото;
	СпрОбъект.Подписан = Ложь;
	СпрОбъект.ДатаРегистрации = ТекущаяДатаСеанса();
	СпрОбъект.СтатусДиалога = Перечисления.СтатусДиалога.Запрещен;
	СпрОбъект.ИсточникПривличения = НастройкиВайбер;
	
	СпрОбъект.Записать();
	
	//Если ОтправитьДоплнительныеДействия Тогда
	//	Запись = РегистрыСведений.ДополнительныеДействияВайбер.СоздатьМенеджерЗаписи();
	//	Запись.Контакт = СпрОбъект.Ссылка;
	//	Запись.Дата    = ТекущаяДата();
	//	Запись.Текст   = ПолучитьТекстКлиентНеВыбралДействия();
	//	Запись.Записать();
	//	
	//КонецЕсли;	
	
	Возврат СпрОбъект.Ссылка;
	
КонецФункции

Функция ОбновитьОтправителя(ДанныеОтправителя, НастройкиВайбер)
	
	Идентификатор = Строка(СокрЛП(ДанныеОтправителя.id));
	
	УчетнаяЗапись = Справочники.КонтактыViber.НайтиПоРеквизиту("Идентификатор", Идентификатор);
	Если УчетнаяЗапись = Справочники.КонтактыViber.ПустаяСсылка() Тогда
		СпрОбъект = Справочники.КонтактыViber.СоздатьЭлемент();
	Иначе
		СпрОбъект = УчетнаяЗапись.ПолучитьОбъект();
	КонецЕсли;	

	Если ДанныеОтправителя.Свойство("name") Тогда
		ИмяПользователя = ДанныеОтправителя.name;
	КонецЕсли;
	
	Если ДанныеОтправителя.Свойство("avatar") Тогда
		Фото = ДанныеОтправителя.avatar;
	КонецЕсли; 
	
	СпрОбъект.Идентификатор  = Идентификатор;	
	СпрОбъект.Наименование = ИмяПользователя;
	СпрОбъект.Фото = Фото;
	СпрОбъект.Подписан = Истина;
	Если Не ЗначениеЗаполнено(СпрОбъект.ДатаРегистрации) Тогда
		СпрОбъект.ДатаРегистрации = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если Не ЗначениеЗаполнено(СпрОбъект.ДатаПодписки) Тогда
		СпрОбъект.ДатаПодписки = ТекущаяДатаСеанса();
	КонецЕсли;
	
	Если не ЗначениеЗаполнено(СпрОбъект.Контрагент) И ЗначениеЗаполнено(СпрОбъект.Телефон) Тогда
		СпрОбъект.Контрагент =  ПолучитьКонтрагентаПоНомеруТелефона(СпрОбъект.Телефон);
		Если ЗначениеЗаполнено(СпрОбъект.Контрагент) Тогда
			СпрОбъект.Менеджер = СпрОбъект.Контрагент.ТорговыйАгент;
		КонецЕсли;	
	КонецЕсли;	
	
	СпрОбъект.СтатусДиалога = Перечисления.СтатусДиалога.Разрешон;
	СпрОбъект.ИсточникПривличения = НастройкиВайбер;
	
	СпрОбъект.Записать();
	
	Возврат СпрОбъект.Ссылка;

	
	
КонецФункции

