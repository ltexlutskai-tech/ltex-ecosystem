		Спр.НомерТелефона      = ДанныеЗапроса.Телефон;
		Спр.Записать();
		
		Договора = СоздатьДоговорыКонтрагенту(Спр.Ссылка, ТипЦен);
		Спр.ОсновнойДоговорКонтрагента = Договора.ОсновнойДоговорКонтрагента;
		Спр.ДоговорДляНеплановыхПродаж = Договора.ДоговорДляНеплановыхПродаж;
		Спр.Записать();

		
		УИДКонтакт = Новый УникальныйИдентификатор(ДанныеЗапроса.Контакт);
		
	КонецЕсли;
	
	УИДКонтакт = Новый УникальныйИдентификатор(ДанныеЗапроса.Контакт);
	СправочникКонтакт = Справочники.КонтактыViber.ПолучитьСсылку(УИДКонтакт);
	Если СсылкаСуществует(СправочникКонтакт) Тогда
		Спр = СправочникКонтакт.ПолучитьОбъект();
		Спр.Контрагент = СправочникКонтрагент.Ссылка;
		Спр.Записать();
	КонецЕсли;	
	
	МассивСообщений = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ViberИсторииСообщений.ТокенСообщния
		|ИЗ
		|	РегистрСведений.ViberИсторииСообщений КАК ViberИсторииСообщений
		|ГДЕ
		|	ViberИсторииСообщений.Контакт = &Контакт";
	
	Запрос.УстановитьПараметр("Контакт", СправочникКонтакт);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Стр из РезультатЗапроса Цикл
		
		МассивСообщений.Добавить(Новый Структура("Токен, Контрагент", СтрЗаменить(Стр.ТокенСообщния, Символ(160), ""), Строка(СправочникКонтакт.УникальныйИдентификатор())));

	КонецЦикла;	
	
	
	СтруктураОтвета = Новый Структура();
	СтруктураОтвета.Вставить("Result", "Ok");
	СтруктураОтвета.Вставить("СписокСообщений", МассивСообщений);
	
	
