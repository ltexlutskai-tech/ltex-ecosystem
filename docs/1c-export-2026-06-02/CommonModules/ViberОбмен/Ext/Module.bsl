////// получить контакт по контрагенту ////////////////////////////////////
Функция ПолучитьКонтактПоКонтрагенту(ИДКонтрагента)
	
	Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(ИДКонтрагента));
	Если ЗначениеЗаполнено(Контрагент) Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	КонтактыViber.Ссылка
			|ИЗ
			|	Справочник.КонтактыViber КАК КонтактыViber
			|ГДЕ
			|	КонтактыViber.Контрагент = &Контрагент";
		
		Запрос.УстановитьПараметр("Контрагент", Контрагент);
		
		РезультатЗапроса = Запрос.Выполнить();
		
		ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
		
		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
			Возврат ВыборкаДетальныеЗаписи.Ссылка;
		КонецЦикла;
	КонецЕсли;
	
	
	Возврат Справочники.КонтактыViber.ПустаяСсылка();
		
	
	
КонецФункции

