Функция СоздатьИСвязатьКонтрагента(ДанныеЗапроса)
	
	УИДКонтрагента = Новый УникальныйИдентификатор(ДанныеЗапроса.Контрагент);
	СправочникКонтрагент = Справочники.Контрагенты.ПолучитьСсылку(УИДКонтрагента);
	Если СсылкаСуществует(СправочникКонтрагент) Тогда
		УИДКонтакт = Новый УникальныйИдентификатор(ДанныеЗапроса.Контакт);
	    СправочникКонтакт = Справочники.КонтактыViber.ПолучитьСсылку(УИДКонтакт);
		Если СсылкаСуществует(СправочникКонтакт) Тогда
			Спр = СправочникКонтакт.ПолучитьОбъект();
			Спр.Контрагент = СправочникКонтрагент.Ссылка;
			Спр.Записать();
		КонецЕсли;
	ИначеЕсли ДанныеЗапроса.Свойство("Пароль") Тогда 
		
		ОбменАРМ.ОбработатьПакетДанных(ДанныеЗапроса.Пароль, XMLЗначение(Тип("ХранилищеЗначения"), ДанныеЗапроса.ДанныеКонтрагента)	);
		
	Иначе
