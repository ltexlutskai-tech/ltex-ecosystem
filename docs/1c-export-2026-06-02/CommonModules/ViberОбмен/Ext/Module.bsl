
#Область Програмный_Интерфейс  

Функция СтрокаJSON(ОбъектJSON)Экспорт
	
	ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(, Символы.Таб);
	
	Запись = Новый ЗаписьJSON;
	Запись.УстановитьСтроку(ПараметрыЗаписи);
	ЗаписатьJSON(Запись, ОбъектJSON);
	
	Возврат Запись.Закрыть();
	
КонецФункции 

Функция ОбъектJSON(СтрокаJSON)Экспорт
	
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(СтрокаJSON);
	ОбъектJSON = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();
	
	Возврат ОбъектJSON;	
	
КонецФункции

Функция ОтветJSON(Объект, КодСостояния = 200)Экспорт
	
	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Объект));
	Ответ.Заголовки.Вставить("Content-Type", ТипКонтентаJSON());
	
	Возврат Ответ;	
	
КонецФункции 

Функция ПростойУспешныйОтвет()Экспорт  
	
	Результат = Новый Структура;
	Результат.Вставить("Result", "Ok");
	
	Возврат ОтветJSON(Результат);
	
КонецФункции

Функция ОтветОбОшибке(ИнформацияОбОшибке)Экспорт
	
	ЗаписьЖурналаРегистрации("НТТРСервисы.Ошибка", УровеньЖурналаРегистрации.Ошибка,,,
		ПодробноеПредставлениеОшибки(ИнформацияОбОшибке));
		
	Результат = Новый Структура;
	Результат.Вставить("Result", "Error");
	Результат.Вставить("ErrorText", КраткоеПредставлениеОшибки(ИнформацияОбОшибке));

	Возврат ОтветJSON(Результат, 500);	
	
КонецФункции	

Процедура ЗаписьЛогированияЗапросов(ИмяМетода, Запрос, Ответ)Экспорт

	Лог = РегистрыСведений.ВходящийНТТРЗапрос.СоздатьМенеджерЗаписи();
	Лог.ИмяМетода    = ИмяМетода;
	ТелоЗапроса  = Запрос.ПолучитьТелоКакСтроку();
		
	Попытка
		ТелоЗапроса = СтрокаJSON(ОбъектJSON(ТелоЗапроса));	
	Исключение
	КонецПопытки;
	
	Лог.ИсточникПривлечения = "Мобільний додаток";
	Лог.ТелоЗапроса  = ТелоЗапроса;	
	Лог.КодСостояния = Ответ.КодСостояния;
	Лог.Дата         = ТекущаяДатаСеанса();
	
	Лог.Записать();
	

	
КонецПроцедуры

Функция ТипКонтентаJSON()
	
	 Возврат "application/json";
	
КонецФункции	

#КонецОбласти

#Область Проциддуры_Функции_Входящего_Запроса

Функция ДанныеЗапроса(Запрос)
	
	ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку();
	Возврат ОбъектJSON(ТелоЗапроса);	
	
КонецФункции

Функция ОбработатьВходящийЗапрос(Запрос) Экспорт
	
	ДанныеЗапроса = ДанныеЗапроса(Запрос);
	
	Если ДанныеЗапроса.method = "vibermobile" Тогда
		Возврат СформироватьИОтправитьРегистрСообщений(ДанныеЗапроса);
	ИначеЕсли ДанныеЗапроса.method = "SendMessage" Тогда
		Возврат ОбработатьИОтправитьВсемСообщения(ДанныеЗапроса);
	ИначеЕсли ДанныеЗапроса.method = "smsoff" Тогда
		Возврат СообщениеПрочитано(ДанныеЗапроса);
	ИначеЕсли ДанныеЗапроса.method = "contakt" Тогда
		Возврат СвязатьКонтрагента(ДанныеЗапроса);
	ИначеЕсли ДанныеЗапроса.method = "svias" Тогда
		Возврат СоздатьИСвязатьКонтрагента(ДанныеЗапроса);		
	КонецЕсли;	

	     
	Возврат ПростойУспешныйОтвет();
	
КонецФункции
                                                                         
#КонецОбласти

#Область Процедуры_И_Функции_Программы

///////отправляем сообщения в вайбер ////////////////////////////////////////
Функция ОбработатьИОтправитьВсемСообщения(ДанныеЗапроса)
	
	Если ДанныеЗапроса.Свойство("Контакты") Тогда
		СписокПолучателей = ПолучитьСписокПолучателей(ДанныеЗапроса.Контакты, ДанныеЗапроса);
	КонецЕсли;
	
	ЧатБот = Справочники.НастройкиViber.НайтиПоКоду("000000001");
	
	НовоеСообщение = ДанныеЗапроса.НовоеСообщение;
	
	Если ДанныеЗапроса.Свойство("СтруктуруФайла") Тогда
		
		СтруктуруФайлаНаОтправку = ПолучитьСтруктуруФайлаНаОтправку(ДанныеЗапроса.СтруктуруФайла);
		
	КонецЕсли;	
	
	Для Каждого Стр Из СписокПолучателей Цикл
		
		Если ЗначениеЗаполнено(НовоеСообщение) Тогда
			Ответ = МодульУправленияViber.ОтправитьСообщениеПользователю(ЧатБот, Стр.Ссылка, НовоеСообщение);
				
			Если Ответ.Свойство("status_message") Тогда
				Если Ответ.status_message = "ok" Тогда
					МодульУправленияViber.ЗарегистрироватьСообщениеПользователяИсходящее(Ответ, Неопределено, Стр.Ссылка, ЧатБот, НовоеСообщение, ПользователиИнформационнойБазы.ТекущийПользователь());    
				КонецЕсли;			
			КонецЕсли;
		КонецЕсли;	
		
		Если ЗначениеЗаполнено(СтруктуруФайлаНаОтправку) Тогда
			Ответ = МодульУправленияViber.ОтправитьСообщениеФайлПользователю(ЧатБот, Стр.Ссылка, СтруктуруФайлаНаОтправку);
			Если Ответ.Свойство("status_message") Тогда
				Если Ответ.status_message = "ok" Тогда
					МодульУправленияViber.ЗарегистрироватьСообщениеПользователяИсходящее(Ответ, СтруктуруФайлаНаОтправку, Стр.Ссылка, ЧатБот, НовоеСообщение, ПользователиИнформационнойБазы.ТекущийПользователь());  	
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;	
		
	КонецЦикла;	
	
	
	Возврат ПростойУспешныйОтвет();		
	
КонецФункции

///// получаем список получателей из контрагентов ///////////////////////////
Функция ПолучитьСписокПолучателей(СписокКонтрагентовСтрокой, ДанныеЗапроса)
	
	МассивКонтрагентов = Новый Массив;
	
	Если ДанныеЗапроса.КонтрагентСсылка Тогда
		Для Каждого Стр из СписокКонтрагентовСтрокой Цикл
			Контрагент = Справочники.Контрагенты.ПолучитьСсылку(Новый УникальныйИдентификатор(Стр));
			Если ЗначениеЗаполнено(Контрагент) Тогда
				МассивКонтрагентов.Добавить(Контрагент);
			КонецЕсли;
		КонецЦикла;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
			"ВЫБРАТЬ
			|	КонтактыViber.Ссылка
			|ИЗ
			|	Справочник.КонтактыViber КАК КонтактыViber
			|ГДЕ
			|	КонтактыViber.Контрагент В(&Контрагент)
			|	И КонтактыViber.СтатусДиалога = &СтатусДиалога";
		
		Запрос.УстановитьПараметр("Контрагент", МассивКонтрагентов);
		Запрос.УстановитьПараметр("СтатусДиалога", Перечисления.СтатусДиалога.Разрешон);
		
		РезультатЗапроса = Запрос.Выполнить().Выгрузить();
		
		Возврат РезультатЗапроса;
	Иначе
		Для Каждого Стр из СписокКонтрагентовСтрокой Цикл
			УИДКонтакта = Новый УникальныйИдентификатор(Стр);
			СпрКонтакт = Справочники.КонтактыViber.ПолучитьСсылку(УИДКонтакта);
			Если СсылкаСуществует(СпрКонтакт) Тогда
				МассивКонтрагентов.Добавить(Новый Структура("Ссылка", СпрКонтакт.Ссылка));
			КонецЕсли;
		КонецЦикла;	
				
		Возврат МассивКонтрагентов; 
	КонецЕсли;	
	   
	   
		
	
КонецФункции	

/////Сформировать структуру файла на отправку сервере //////////////////////
Функция ПолучитьСтруктуруФайлаНаОтправку(ДанныеФайла)
	
	ДвДанные = base64значение(ДанныеФайла.Строка64);
	
	Настройкки = Справочники.НастройкиViber.НайтиПоКоду("000000001");
	ИмяФайлаТут = "" + Настройкки.КаталогДляСохранения + "" + ДанныеФайла.ИмяФайла;
	
	ДвДанные.Записать(ИмяФайлаТут);
	
	Файл = Новый Файл(ИмяФайлаТут);
	
	Имя = Файл.Имя;
	Размер   = Файл.Размер();
	Путь     = "" + Настройкки.КаталогДляОтправки + "" + Имя;
	
	
	Если ДанныеФайла.ТипФайлаОтправки = "Изображение" и Размер < 300000  Тогда
		ТипФайлаОтправки = Перечисления.ТипФайлаОтправки.Изображение;
	ИначеЕсли ДанныеФайла.ТипФайлаОтправки = "Видео" и Размер < 500000000 Тогда
		ТипФайлаОтправки = Перечисления.ТипФайлаОтправки.Видео;
	Иначе
		ТипФайлаОтправки = Перечисления.ТипФайлаОтправки.Файл;
	КонецЕсли;	

	
	СтруктураФайла = Новый Структура("Имя, Размер, Путь, ТипФайла, ФайлТам", Имя, Размер, Путь, ТипФайлаОтправки, ИмяФайлаТут);
	
	Возврат СтруктураФайла;
	
	
КонецФункции

/////// убераем отметку новое сообщение ////////////////////////////////////
Функция СообщениеПрочитано(ДанныеЗапроса)
	
	Если ДанныеЗапроса.Свойство("Контрагент") Тогда
		Если ДанныеЗапроса.КонтрагентСсылка Тогда 
			Контакт = ПолучитьКонтактПоКонтрагенту(ДанныеЗапроса.Контрагент);
		Иначе
			УИД = Новый УникальныйИдентификатор(ДанныеЗапроса.Контрагент);
			СпрКонтрагент = Справочники.КонтактыViber.ПолучитьСсылку(УИД);
			
			Контакт = СпрКонтрагент.Ссылка;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Контакт) Тогда
			Спр = Контакт.ПолучитьОбъект();
			Спр.НовоеСообщение = Ложь;
			Спр.Записать();
		КонецЕсли;
	КонецЕсли;	
	
	Возврат ПростойУспешныйОтвет();	
	
КонецФункции	

/////// получить список и структуру сообщений //////////////////////////////
Функция СформироватьИОтправитьРегистрСообщений(ДанныеЗапроса)Экспорт
	
	Дата = ДанныеЗапроса.Дата; 
	ТовАгент = Справочники.ТорговыеАгенты.НайтиПоРеквизиту("ПарольДоступаАндроід", ДанныеЗапроса.IDdesktop);
	Если НЕ ЗначениеЗаполнено(ТовАгент) Тогда
		Возврат ОбщегоНазначенияHTTPViber.ПростойУспешныйОтвет();
	КонецЕсли;	
	
	Если Дата = "0" Тогда
		ДатаОбновления = Дата("01.01.2023 00:00:01");
	Иначе
		ДатаСтрокой = Лев(Дата, 2) + "." + Сред(Дата, 3,2) + "." + Сред(Дата, 5, 4) + " " + Сред(Дата, 9, 2) + ":" + Сред(Дата, 11, 2) + ":" + Сред(Дата, 13, 2);
		Попытка
			ДатаОбновления = Дата(ДатаСтрокой);
		Исключение
			ДатаОбновления = Дата("01.01.2023 00:00:01");
		КонецПопытки	
	КонецЕсли;
	
	МассивСообщений = Новый  Массив;	
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ViberИсторииСообщений.Контакт,
		|	ViberИсторииСообщений.Дата,
		|	ViberИсторииСообщений.Напрвление,
		|	ViberИсторииСообщений.ЧатID,
		|	ViberИсторииСообщений.ТокенСообщния,
		|	ViberИсторииСообщений.ИсточникПривличения,
		|	ViberИсторииСообщений.Непрочитаное,
		|	ViberИсторииСообщений.Картинка,
		|	ViberИсторииСообщений.Файл,
		|	ViberИсторииСообщений.Видео,
		|	ViberИсторииСообщений.Текст,
		|	ViberИсторииСообщений.ПутьКФайлу,
		|	ViberИсторииСообщений.Размер,
		|	ViberИсторииСообщений.Наименование,
		|	ViberИсторииСообщений.Менеджер,
		|	ViberИсторииСообщений.ФайлВБазе,
		|	ViberИсторииСообщений.Прочтено,
		|	ViberИсторииСообщений.Доставлено,
		|	ViberИсторииСообщений.Контакт.Контрагент КАК Контрагент,
		|	ViberИсторииСообщений.Контакт.НовоеСообщение КАК НовоеСообщение,
		|	ViberИсторииСообщений.Контакт.Подписан КАК Подписан
		|ИЗ
		|	РегистрСведений.ViberИсторииСообщений КАК ViberИсторииСообщений
		|ГДЕ
		|	ViberИсторииСообщений.Дата >= &Дата
		|	И ViberИсторииСообщений.Контакт.Менеджер = &Менеджер";
	
	Запрос.УстановитьПараметр("Дата", ДатаОбновления);
	Запрос.УстановитьПараметр("Менеджер", ТовАгент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		//Если ЗначениеЗаполнено(Выборка.Контрагент) Тогда
		Если СсылкаСуществует(Выборка.Контакт) Тогда 
				
			СтруктураСообщения = Новый Структура;
			СтруктураСообщения.Вставить("Контакт", Строка(Выборка.Контакт));
			СтруктураСообщения.Вставить("Дата", СформироватьДатуДляОттправки(Выборка.Дата));//Формат(Выборка.Дата,"ДФ=yyyy-MM-dd"));
			СтруктураСообщения.Вставить("Напрвление", Строка(Выборка.Напрвление));
			СтруктураСообщения.Вставить("ЧатID", Выборка.ЧатID);
			СтруктураСообщения.Вставить("ТокенСообщния", Выборка.ТокенСообщния);
			СтруктураСообщения.Вставить("ИсточникПривличения", Строка(Выборка.ИсточникПривличения));
			СтруктураСообщения.Вставить("Непрочитаное", Выборка.Непрочитаное);
			СтруктураСообщения.Вставить("Картинка", Выборка.Картинка);
			СтруктураСообщения.Вставить("Файл", Выборка.Файл);
			СтруктураСообщения.Вставить("Видео", Выборка.Видео);
			СтруктураСообщения.Вставить("Подписан", Выборка.Подписан);

			Если ЗначениеЗаполнено(Выборка.Контрагент) Тогда
				СтруктураСообщения.Вставить("Контрагент", СформироватьСтруктуруКонтрагент(Выборка.Контрагент));
			Иначе
				СтруктураСообщения.Вставить("Контрагент", СформироватьСтруктуруКонтрагент(Выборка.Контрагент));
			КонецЕсли;	
			СтруктураСообщения.Вставить("КлиентВайбер", Строка(Выборка.Контакт.УникальныйИдентификатор()));

			
			СтруктураСообщения.Вставить("Текст", ?(ЗначениеЗаполнено(Выборка.Текст), Выборка.Текст, ""));  
			СтруктураСообщения.Вставить("ПутьКФайлу", ?(ЗначениеЗаполнено(Выборка.ПутьКФайлу), Выборка.ПутьКФайлу, "")); 
			СтруктураСообщения.Вставить("Размер", ?(ЗначениеЗаполнено(Выборка.Размер), Выборка.Размер, "")); 
			СтруктураСообщения.Вставить("Наименование", ?(ЗначениеЗаполнено(Выборка.Наименование), Выборка.Наименование, "")); 
			СтруктураСообщения.Вставить("Менеджер", ?(ЗначениеЗаполнено(Выборка.Менеджер), ПолучитьИдентификаторУчастникаЧата(Выборка.Менеджер), "")); 
			СтруктураСообщения.Вставить("ФайлВБазе", ?(ЗначениеЗаполнено(Выборка.ФайлВБазе), Выборка.ФайлВБазе, "")); 
					
			СтруктураСообщения.Вставить("НовоеСообщение", Выборка.НовоеСообщение);
			СтруктураСообщения.Вставить("Прочтено", Выборка.Прочтено);
			СтруктураСообщения.Вставить("Доставлено", Выборка.Доставлено);
			

			МассивСообщений.Добавить(СтруктураСообщения);
		КонецЕсли;		
	КонецЦикла;
	
	МассивШаблонов = Новый Массив;
	СписокШаблонов = Справочники.ШаблоныСообщений.Выбрать();
	Пока СписокШаблонов.Следующий() Цикл
		Если НЕ СписокШаблонов.ПометкаУдаления Тогда
			МассивШаблонов.Добавить(Новый Структура("Код, Текст, Наименование", СписокШаблонов.Код, СписокШаблонов.Текст, СписокШаблонов.Наименование));
		КонецЕсли;	
	КонецЦикла;	
	
	МассивНовых = Новый Массив;
	НовыеКонтакты = ПолучитьСписокНовыхКонтактов(ТовАгент);
	Для Каждого Ст из НовыеКонтакты Цикл    		                                                                                                                                         
		МассивНовых.Добавить(Новый Структура("ИДКонтакта, Наименование, Телефон, Дата, Идентификатор", Строка(Ст.Ссылка.УникальныйИдентификатор()), Ст.Наименование, Ст.Телефон, Строка(Ст.ДатаПодписки), Ст.Идентификатор));
	КонецЦикла;
	
	СписокКонтактов = ПолучитьСписокКонтактовВайбер();
	МассивКонтактыВайбер = Новый Массив();
	Для Каждого Ст из СписокКонтактов Цикл    		                                                                                                                                         
		МассивКонтактыВайбер.Добавить(Новый Структура("ИДКонтакта, Наименование, Телефон, Дата, Идентификатор, ИДКонтрагента, Статус, Сесия"
		, Строка(Ст.Ссылка.УникальныйИдентификатор()), Ст.Наименование, Ст.Телефон, Строка(Ст.ДатаПодписки), Ст.Идентификатор
		,  Строка(?(ТипЗнч(Ст.Контрагент) = Тип("СправочникСсылка.Контрагенты"),Ст.Контрагент.УникальныйИдентификатор(), Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000"))), Строка(Ст.Статус), Строка(Ст.Сесия)));
	КонецЦикла;
	
	
	
	СтруктураОтвета = Новый Структура;
