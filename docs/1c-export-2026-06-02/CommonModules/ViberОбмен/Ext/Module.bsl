Функция СформироватьДатуДляОттправки(Дата)
	
	ДатаСтрокой = СтрЗаменить(Строка(Дата), ".", "");
	ДатаСтрокой = СтрЗаменить(ДатаСтрокой, " ", "");
	ДатаСтрокой = СтрЗаменить(ДатаСтрокой, ":", "");
	
	Возврат  ДатаСтрокой;
	
КонецФункции

Функция СформироватьСтруктуруКонтрагент(Контрагент)
	
	МассивТелефонов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	Контрагенты.НомерТелефона,
		|	ВложенныйЗапрос.Номер
		|ИЗ
		|	Справочник.Контрагенты КАК Контрагенты
		|		ПОЛНОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
		|			КонтрагентыДополнительныеНомераТелефонов.Номер КАК Номер,
		|			КонтрагентыДополнительныеНомераТелефонов.Ссылка КАК Ссылка
		|		ИЗ
		|			Справочник.Контрагенты.ДополнительныеНомераТелефонов КАК КонтрагентыДополнительныеНомераТелефонов) КАК ВложенныйЗапрос
		|		ПО Контрагенты.Ссылка = ВложенныйЗапрос.Ссылка
		|ГДЕ
		|	Контрагенты.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Для Каждого Стр из РезультатЗапроса Цикл
		Если ЗначениеЗаполнено(Стр.Номер) Тогда
			МассивТелефонов.Добавить(ОтформатироватьТелефон(Стр.Номер));
		КонецЕсли;
	КонецЦикла;
	
	Если РезультатЗапроса.Количество() > 0 Тогда
		Если ЗначениеЗаполнено(РезультатЗапроса[0].НомерТелефона) Тогда
			МассивТелефонов.Добавить(ОтформатироватьТелефон(РезультатЗапроса[0].НомерТелефона));		
		КонецЕсли;
	КонецЕсли;
	
	СтруктураКонтрагент = Новый Структура("Телефон", МассивТелефонов);
	СтруктураКонтрагент.Вставить("Наименование", Контрагент.Наименование);
	СтруктураКонтрагент.Вставить("Код", Контрагент.Код);
	СтруктураКонтрагент.Вставить("ИД", Строка(Контрагент.УникальныйИдентификатор()));

	
	Возврат СтруктураКонтрагент;
	
	
КонецФункции
		
Функция ОтформатироватьТелефон(Номер)
	
	НовСтрока = "";
  
	ПравильныеСимволы = "0123456789";
    
	Для Сч = 1 по СтрДлина(Номер) Цикл
    	ТекСимв = Сред(Номер, Сч, 1);
   		Если Найти(ПравильныеСимволы, ТекСимв) > 0 Тогда
    		НовСтрока = НовСтрока + ТекСимв;
    	КонецЕсли;
	КонецЦикла;
       

	Возврат НовСтрока;

	
