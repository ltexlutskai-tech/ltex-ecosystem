   		ЗаполнитьСтатьюКнигиПродаж(НоваяСтрока, "Прочее");	
		НоваяСтрока.КодУКТВЭД                  = Выборка.КодУКТВЭД;
		НоваяСтрока.НомерГТД                  = Выборка.НомерГТД;
		
	КонецЦикла;
	
