		СуммаПлан = 0;
		Для Каждого Стр Из Заказы Цикл
			СуммаПлан = СуммаПлан + Стр.ЗаказПокупателя.СуммаДокумента;
		КонецЦикла;
		
		ОбластьМакета.Параметры.СумаПланДолар = Ценообразование.ПересчитатьЦенуПриИзмененииВалюты(СуммаПлан,Евро,Долар,ВалютаТЗ.Найти(Долар).Курс,,);
		ОбластьМакета.Параметры.СумаПланЕвро = СуммаПлан;
		ОбластьМакета.Параметры.СумаПланГрн = Ценообразование.ПересчитатьЦенуПриИзмененииВалюты(СуммаПлан,Евро,Грн,ВалютаТЗ.Найти(Грн).Курс,,);
		
		Итог1 = 0;
		Итог2 = 0;
		Итог3 = 0;
		Итог4 = 0;
		Для Каждого Строка Из Оплата Цикл
			Если Строка.Валюта = Справочники.Валюты.НайтиПоКоду("980") И Не Строка.Безналичные Тогда
				Если Строка.Возврат Тогда
					Итог1 = Итог1 - Строка.Сумма;
				Иначе
					Итог1 = Итог1 + Строка.Сумма;
				КонецЕсли;
			ИначеЕсли Строка.Валюта = Справочники.Валюты.НайтиПоКоду("840") Тогда
				Если Строка.Возврат Тогда
					Итог2 = Итог2 - Строка.Сумма;
				Иначе
					Итог2 = Итог2 + Строка.Сумма;
				КонецЕсли;
			ИначеЕсли Строка.Валюта = Справочники.Валюты.НайтиПоКоду("978") И НЕ Строка.Безналичные Тогда     // грн    готівка
				Если Строка.Возврат Тогда
					Итог3 = Итог3 - Строка.Сумма;
				Иначе
					Итог3 = Итог3 + Строка.Сумма;
				КонецЕсли;
			ИначеЕсли Строка.Валюта = Справочники.Валюты.НайтиПоКоду("980") И Строка.Безналичные Тогда     // грн  безнал
				Если Строка.Возврат Тогда
					Итог4 = Итог4 - Строка.Сумма;
				Иначе
					Итог4 = Итог4 + Строка.Сумма;
				КонецЕсли;
			КонецЕсли;
		КонецЦикла;
		
		//Форма = ЭтотОбъект.ПолучитьФорму("ФормаДокумента");
		ОбластьМакета.Параметры.СумаФактДолар = Итог2;
		ОбластьМакета.Параметры.СумаФактЕвро = Итог3;
		ОбластьМакета.Параметры.СумаФактГрн = Итог1;
		ОбластьМакета.Параметры.СумаФактГрнБезготівка = Итог4;
		
		ОбластьМакета.Параметры.Кілометраж = ОдометрКонец - ОдометрНачало;
		
		ОбластьМакета.Параметры.ОплатаТранспортуГрн = (ОдометрКонец - ОдометрНачало) * ЦенаЗаКМ;
		//ОбластьМакета.Параметры.ОплатаТранспортуДолар = 
		//ОбластьМакета.Параметры.ОплатаТранспортуЕвро =
		
		ОбластьМакета.Параметры.ДобовіВитратиГрн = Витрати.Итог("СУма");
		//ОбластьМакета.Параметры.ДобовіВитратиДолар =
		//ОбластьМакета.Параметры.ДобовіВитратиЕвро = 
		
		ТабДокумент.Вывести(ОбластьМакета);
		
		Если Витрати.Количество() > 0 Тогда 
			ОбластьМакета = Макет.ПолучитьОбласть("ДобовіВитратиШапка");
			ТабДокумент.Вывести(ОбластьМакета);
			
			Для каждого Строка Из Витрати Цикл
				ОбластьМакета = Макет.ПолучитьОбласть("ДобовіВитрати");
				ОбластьМакета.Параметры.СтаттяВитрат = Строка.СтаттяВитрат;
				ОбластьМакета.Параметры.Сума = "" + Строка.Сума + " " + Грн;
				ТабДокумент.Вывести(ОбластьМакета);
			КонецЦикла;
		КонецЕсли;
		
		Если ЗначениеЗаполнено(Шапка.Комментарий) Тогда
			ОбластьМакета 						= Макет.ПолучитьОбласть("Примітка");
			ОбластьМакета.Параметры.Комментарий = Шапка.Комментарий;
			ТабДокумент.Вывести(ОбластьМакета);
		КонецЕсли;
		// -
		
				
		Возврат ТабДокумент;	
		
		
	КонецФункции
	
	Функция НайтиШтрихкод(ХарактеристикаСсылка)
		з = Новый Запрос;
		з.Текст = "ВЫБРАТЬ
		|	Штрихкоды.Штрихкод
		|ИЗ
		|	РегистрСведений.Штрихкоды КАК Штрихкоды
		|ГДЕ
		|	Штрихкоды.ХарактеристикаНоменклатуры = &ХарактеристикаНоменклатуры";
		з.УстановитьПараметр("ХарактеристикаНоменклатуры", ХарактеристикаСсылка);
		Выборка = з.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда 
			Возврат Выборка.Штрихкод;
		Иначе 
			Возврат Неопределено;
		КонецЕсли;
		
	КонецФункции
	
	Функция	ПолучитьСписокВсехКонтрагентов()
		
		Запрос = Новый Запрос;
		Запрос.Текст =
		"ВЫБРАТЬ
		|	МаршрутныйЛистЗаказы.Контрагент
		|ИЗ
		|	Документ.МаршрутныйЛист.Заказы КАК МаршрутныйЛистЗаказы
		|ГДЕ
		|	МаршрутныйЛистЗаказы.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МаршрутныйЛистПродажи.Контрагент
		|ИЗ
		|	Документ.МаршрутныйЛист.Продажи КАК МаршрутныйЛистПродажи
		|ГДЕ
		|	МаршрутныйЛистПродажи.Ссылка = &Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	МаршрутныйЛистОплата.Контрагент
		|ИЗ
		|	Документ.МаршрутныйЛист.Оплата КАК МаршрутныйЛистОплата
		|ГДЕ
		|	МаршрутныйЛистОплата.Ссылка = &Ссылка";
		Запрос.УстановитьПараметр("Ссылка", Ссылка);
		
		ТЗ = Запрос.Выполнить().Выгрузить();
		ТЗ.Свернуть("Контрагент");
		
		Возврат ТЗ;
		
	КонецФункции
	
	// Процедура осуществляет печать документа. Можно направить печать на 
	// экран или принтер, а также распечатать необходмое количество копий.
	//
	//  Название макета печати передается в качестве параметра,
	// по переданному названию находим имя макета в соответствии.
	//
	// Параметры:
	//  НазваниеМакета - строка, название макета.
	//
	Процедура Печать(ИмяМакета, КоличествоЭкземпляров = 1, НаПринтер = Ложь) Экспорт
		
		Если ЭтоНовый() Тогда
			Предупреждение("Документ можно распечатать только после его записи");
			Возврат;
		КонецЕсли;
		
		Если Не РаботаСДиалогами.ПроверитьМодифицированность(ЭтотОбъект) Тогда
			Возврат;
		КонецЕсли;
		
		Если ИмяМакета = "МаршрутныйЛист" Тогда
			ТабДокумент = ПечатьМаршрутногоЛиста(ИмяМакета);
		ИначеЕсли ИмяМакета = "МаршрутныйЛистСОплатой" Тогда
			ТабДокумент = ПечатьМаршрутногоЛистаСОплатой(ИмяМакета);
		КонецЕсли;
		
		УниверсальныеМеханизмы.НапечататьДокумент(ТабДокумент, КоличествоЭкземпляров, НаПринтер, ОбщегоНазначения.СформироватьЗаголовокДокумента(ЭтотОбъект, ЭтотОбъект.Метаданные().Представление()));
		
	КонецПроцедуры // Печать()
#КонецЕсли

// Возвращает доступные варианты печати документа
//
// Вовращаемое значение:
//  Струткура, каждая строка которой соответствует одному из вариантов печати
//  
Функция ПолучитьСтруктуруПечатныхФорм() Экспорт
	
	СтруктураДляПечати = Новый Структура;
	СтруктураДляПечати.Вставить("МаршрутныйЛист","Маршрутный лист");
	СтруктураДляПечати.Вставить("МаршрутныйЛистСОплатой","Маршрутный лист с оплатой");
	
	Возврат СтруктураДляПечати;		
	
КонецФункции // ПолучитьСтруктуруПечатныхФорм()

// Возвращает значение типа штрихкода для использования в ЭУ
// "1С:Печать штрихкодов"
//
// Параметры
// 	ТипКода -	ПланыВидовХарактеристик.ТипыШтрихкодов - тип, значение для которого
//				нужно получить
//
// Возвращаемое значение:
//   Число, которое может быть присвоено свойству ЭУ "ТипКода"
//
Функция ПолучитьЗначениеТипаШтрихкодаДляЭУ(ТипКода)
	
	Перем Значение;
	
	Если ТипКода = ПланыВидовХарактеристик.ТипыШтрихкодов.EAN8 Тогда
		Значение = 0;
	ИначеЕсли ТипКода = ПланыВидовХарактеристик.ТипыШтрихкодов.EAN13 Тогда
		Значение = 1;
	ИначеЕсли ТипКода = ПланыВидовХарактеристик.ТипыШтрихкодов.EAN128 Тогда
		Значение = 2;
	ИначеЕсли ТипКода = ПланыВидовХарактеристик.ТипыШтрихкодов.Code39 Тогда
		Значение = 3;
	ИначеЕсли ТипКода = ПланыВидовХарактеристик.ТипыШтрихкодов.Code128 Тогда
		Значение = 4;
	Иначе
		Значение = -1;
	КонецЕсли;
	
	Возврат Значение;
	
КонецФункции // ПолучитьЗначениеТипаШтрихкодаДляЭУ()

Процедура КонтрольЗагрузкиИРеализаций()
	Для Каждого Строка Из Продажи Цикл
		НайденныеСтроки = ЗагрузкаМашины.НайтиСтроки(Новый Структура("ЗаказПокупателя, Номенклатура, ХарактеристикаНоменклатуры, Возврат", Строка.ЗаказПокупателя, Строка.Номенклатура, Строка.ХарактеристикаНоменклатуры, Ложь));
		Для Каждого Стр Из НайденныеСтроки Цикл
			ЗагрузкаМашины.Удалить(Стр);
		КонецЦикла;
		
		//по ШК
		НайденныеСтроки = ЗагрузкаМашины.НайтиСтроки(Новый Структура("Штрихкод", Строка.Штрихкод));
		Для Каждого Стр Из НайденныеСтроки Цикл
			ЗагрузкаМашины.Удалить(Стр);
		КонецЦикла;
		НайденныеСтроки = ЗагрузкаМашины.НайтиСтроки(Новый Структура("Штрихкод", НРЕГ(Строка.Штрихкод)));
		Для Каждого Стр Из НайденныеСтроки Цикл
			ЗагрузкаМашины.Удалить(Стр);
		КонецЦикла;
		НайденныеСтроки = ЗагрузкаМашины.НайтиСтроки(Новый Структура("Штрихкод", ВРЕГ(Строка.Штрихкод)));
		Для Каждого Стр Из НайденныеСтроки Цикл
			ЗагрузкаМашины.Удалить(Стр);
		КонецЦикла;

		
		
		// Перевірим чи правильний заказ підтянутий, якщо ні очистим і потім проставим правильний. Тут очистка тільки
		Если ЗначениеЗаполнено(Строка.ЗаказПокупателя) Тогда
			СтрокиЗаказа = Заказы.НайтиСтроки(Новый Структура("ЗаказПокупателя", Строка.ЗаказПокупателя));
			Для Каждого СтрокаЗаказа Из СтрокиЗаказа Цикл
				Если СтрокаЗаказа.Контрагент <> Строка.Контрагент Тогда 
					Строка.ЗаказПокупателя = Документы.ЗаказПокупателя.ПустаяСсылка();
					Прервать;
				КонецЕсли;			
			КонецЦикла;			
		КонецЕсли;
		
		
		
		// Контроль проставлення заказів покупця
		Если НЕ ЗначениеЗаполнено(Строка.ЗаказПокупателя) Тогда 
			СтрокиЗаказа = Заказы.НайтиСтроки(Новый Структура("Контрагент", Строка.Контрагент));
			Для Каждого СтрокаЗаказа Из СтрокиЗаказа Цикл
				Если НЕ ЗначениеЗаполнено(Строка.ЗаказПокупателя) Тогда
					Строка.ЗаказПокупателя = СтрокаЗаказа.ЗаказПокупателя;
				КонецЕсли;
				
				СтрокиТовараВЗаказе = СтрокаЗаказа.ЗаказПокупателя.Товары.НайтиСтроки(Новый Структура("Номенклатура, ХарактеристикаНоменклатуры", Строка.Номенклатура, Строка.ХарактеристикаНоменклатуры));
				Если СтрокиТовараВЗаказе.Количество() Тогда 
					Строка.ЗаказПокупателя = СтрокаЗаказа.ЗаказПокупателя;
					Прервать;
				КонецЕсли;				
			КонецЦикла;	
		КонецЕсли;
		
	КонецЦикла;
	
	Продажи.Свернуть("Контрагент, ЗаказПокупателя, Номенклатура, ХарактеристикаНоменклатуры, СерияНоменклатуры, ЕдиницаИзмерения, Количество, Цена, Сумма, Качество, ДокументРезерва, Загружен, Возврат, Штрихкод, ЦенаПродажиВес");
	
КонецПроцедуры

Процедура КонтрольЦенВРеализациях()
	Для Каждого Строка Из Продажи Цикл
		з = Новый Запрос;
		з.Текст = "ВЫБРАТЬ
		          |	РеализацияТоваровУслуг.Ссылка
		          |ПОМЕСТИТЬ тз
		          |ИЗ
		          |	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		          |ГДЕ
		          |	РеализацияТоваровУслуг.Сделка = &Сделка
		          |;
		          |
		          |////////////////////////////////////////////////////////////////////////////////
		          |ВЫБРАТЬ ПЕРВЫЕ 1
		          |	РеализацияТоваровУслугТовары.ЦенаПродажиВес,
		          |	РеализацияТоваровУслугТовары.Знижка
		          |ИЗ
		          |	тз КАК тз
		          |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		          |		ПО тз.Ссылка = РеализацияТоваровУслугТовары.Ссылка
		          |ГДЕ
		          |	РеализацияТоваровУслугТовары.Номенклатура = &Номенклатура
		          |	И РеализацияТоваровУслугТовары.ХарактеристикаНоменклатуры = &ХарактеристикаНоменклатуры
		          |	И РеализацияТоваровУслугТовары.ЦенаПродажиВес > 0";
		з.УстановитьПараметр("Сделка", Строка.ЗаказПокупателя);
		з.УстановитьПараметр("Номенклатура", Строка.Номенклатура);
		з.УстановитьПараметр("ХарактеристикаНоменклатуры", Строка.ХарактеристикаНоменклатуры);
		Выборка = з.Выполнить().Выбрать();
		Если Выборка.Следующий() Тогда 
			Если Строка.ЦенаПродажиВес <> Выборка.ЦенаПродажиВес И Выборка.ЦенаПродажиВес > 0 Тогда 
				Строка.ЦенаПродажиВес = Выборка.ЦенаПродажиВес;
				Если НЕ Выборка.Знижка Тогда
					ЗаписьЖурналаРегистрации("МАРШРУТНИЙ_ДОКУМЕНТИ", УровеньЖурналаРегистрации.Информация,,," Д5----" +Строка.Сумма + Строка.ЗаказПокупателя);

					Строка.Цена = Строка.ХарактеристикаНоменклатуры.Вага * Строка.ЦенаПродажиВес; 
					Строка.Сумма = Строка.Цена * Строка.Количество;
				КонецЕсли;
			КонецЕсли;		
		КонецЕсли;	
	КонецЦикла;
КонецПроцедуры

Процедура ПриЗаписи(Отказ)
	Перем Значение;
	
	ПерепровестиВсеРеализацииБезДВижений();
	Если ЗначениеЗаполнено(Ссылка) И (СтатусДокумента <> Ссылка.СтатусДокумента) Тогда 
		ПерепровестиВсеРеализацииПоДанномуМаршрутнику();
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("ЗакрытьЗаказы", Значение) И Значение = Истина Тогда 
		ИзменитьАктуальностьЗаказа();
	КонецЕсли;
	
	Если ДополнительныеСвойства.Свойство("ОтменитьБронь", Значение) И Значение = Истина Тогда 
		ДополнительныеСвойства.Вставить("ОтменитьБронь", Ложь);
		
		ОчиститьБронь();
		
	КонецЕсли;

КонецПроцедуры

Процедура  ПерепровестиВсеРеализацииБезДВижений()
	Если Проведен И СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Завершен Тогда 
		з = новый Запрос;
		з.Текст = "ВЫБРАТЬ
		|	ТЗ.Ссылка
		|ИЗ
		|	(ВЫБРАТЬ
		|		РеализацияТоваровУслугТовары.Ссылка КАК Ссылка,
		|		ТоварыНаСкладах.Регистратор КАК Регистратор
		|	ИЗ
		|		Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
		|			ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыНаСкладах КАК ТоварыНаСкладах
		|			ПО (ТоварыНаСкладах.Регистратор = РеализацияТоваровУслугТовары.Ссылка)
		|				И РеализацияТоваровУслугТовары.Номенклатура = ТоварыНаСкладах.Номенклатура
		|				И (РеализацияТоваровУслугТовары.Ссылка.Проведен)
		|	
		|	СГРУППИРОВАТЬ ПО
		|		РеализацияТоваровУслугТовары.Ссылка,
		|		ТоварыНаСкладах.Регистратор) КАК ТЗ
		|ГДЕ
		|	ТЗ.Регистратор ЕСТЬ NULL";
		Выборка = з.Выполнить().Выбрать();
		Пока Выборка.Следующий() Цикл
			Если Выборка.Ссылка.Проведен Тогда 
				РеаОб = Выборка.Ссылка.ПолучитьОбъект();
				Попытка
					РеаОб.Записать(РежимЗаписиДокумента.Проведение, РежимПроведенияДокумента.Неоперативный);
				Исключение
					Сообщить(ОписаниеОшибки(), СтатусСообщения.Информация);
				КонецПопытки;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ПерепровестиВсеРеализацииПоДанномуМаршрутнику() Экспорт
