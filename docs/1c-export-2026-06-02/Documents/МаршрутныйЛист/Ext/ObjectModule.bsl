Процедура ИзменитьАктуальностьЗаказа()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаршрутныйЛистЗаказы.ЗаказПокупателя
		|ИЗ
		|	Документ.МаршрутныйЛист.Заказы КАК МаршрутныйЛистЗаказы
		|ГДЕ
		|	МаршрутныйЛистЗаказы.Ссылка = &Ссылка
		|	И МаршрутныйЛистЗаказы.ЗаказПокупателя.СтатусЗамовлення = &СтатусЗамовлення
		|
		|СГРУППИРОВАТЬ ПО
		|	МаршрутныйЛистЗаказы.ЗаказПокупателя";
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("СтатусЗамовлення", Справочники.СтатусиЗамовлень.Новий);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Выборка = РезультатЗапроса.Выбрать();
	
	Пока Выборка.Следующий() Цикл
		Заказ = Выборка.ЗаказПокупателя.ПолучитьОбъект();
		Заказ.СтатусЗамовлення = Справочники.СтатусиЗамовлень.Неактуальний;
		Заказ.ОбменДанными.Загрузка = Истина;
		Заказ.Записать(РежимЗаписиДокумента.Запись);
	КонецЦикла;
	
	

