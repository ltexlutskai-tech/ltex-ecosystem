// ОБРАБОТЧИКИ СОБЫТИЙ

Процедура ПередЗаписью(Отказ, РежимЗаписи, РежимПроведения)
	
	мУдалятьДвижения = НЕ ЭтоНовый();
	
	Если ОбменДанными.Загрузка  Тогда
		Возврат;
	КонецЕсли;
	
	// Посчитать суммы документа и записать ее в соответствующий реквизит шапки для показа в журналах
	СуммаДокумента = ТоварыЗаказов.Итог("Сумма");
	Если НЕ КурсыВалют.Количество()	Тогда      // в случае перепроведения старых документов
		ПерезаполнитьКурсыВалют();
	КонецЕсли;
	ПоверкаДублейТаблицыЗаказов();
	ОтменаПроведенияСвязанныхДокументов();
	КонтрольЗагрузкиИРеализаций();
	КонтрольЦенВРеализациях();
	Если Ссылка.СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Завершен Тогда 
		Архивный = Истина;
	КонецЕсли;
	
	ДополнительныеСвойства.Вставить("ЗакрытьЗаказы", СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Отправлен Или  СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Завершен);
	Если Ссылка.СтатусДокумента =  Перечисления.СтатусыМаршрутногоЛиста.Составляется
		И СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Отправлен Тогда 
		ДополнительныеСвойства.Вставить("ОтменитьБронь", Истина);
		//СкасованаБронь = Истина;
	КонецЕсли;

КонецПроцедуры

Процедура ПоверкаДублейТаблицыЗаказов()
	Заказы.Свернуть("ЗаказПокупателя, Контрагент, Отгружен, Количество, КоличествоЗагружено, КоличествоОстаток, КоличествоФакт"); 
КонецПроцедуры


Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// Дерево значений, содержащее имена необходимых полей в запросе по шапке.
	Перем ДеревоПолейЗапросаПоШапке;	
	
	Если СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Составляется Тогда 
		ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
		Возврат;
	КонецЕсли;	
	
	// ПРОВЕРКА ОПЛАТЫ
	#Если Клиент Тогда
		КонтрагентыЗаказы = Заказы.Выгрузить();
		КонтрагентыЗаказы.Свернуть("Контрагент");
		КонтрагентыОплаты = Оплата.Выгрузить();
		КонтрагентыОплаты.Свернуть("Контрагент");
		МассивНеОплатили = Новый Массив;
		Для Каждого СтрКонтрагент Из КонтрагентыЗаказы Цикл 
			СтрокаОплаты = КонтрагентыОплаты.Найти(СтрКонтрагент.Контрагент, "Контрагент");
			Если СтрокаОплаты = Неопределено Тогда 
				МассивНеОплатили.Добавить(СтрКонтрагент);
			КонецЕсли;	
		КонецЦикла;
		ТекстСообщения = "";
		Если МассивНеОплатили.Количество() > 0 Тогда 
			ТекстСообщения = ТекстСообщения + "Нет оплаты: ";
			Для Каждого НеОпратил Из МассивНеОплатили Цикл 
				ТекстСообщения = ТекстСообщения + НеОпратил.Контрагент + ", ";
			КонецЦикла;
			Предупреждение(ТекстСообщения,10);
		КонецЕсли;
	#КонецЕсли	
	
	// ПРОВЕДЕНИЕ СПИСАНИЯ
	Если мУдалятьДвижения Тогда
		ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
	КонецЕсли;
	
	СтруктураШапкиДокумента = ОбщегоНазначения.СформироватьСтруктуруШапкиДокумента(ЭтотОбъект);
	
	// Заполним по шапке документа дерево параметров, нужных при проведении.
	ДеревоПолейЗапросаПоШапке = ОбщегоНазначения.СформироватьДеревоПолейЗапросаПоШапке();
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "Константы",        "ВалютаУправленческогоУчета",                 "ВалютаУправленческогоУчета");
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "Константы",        "КурсВалютыУправленческогоУчета",             "КурсВалютыУправленческогоУчета");
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "УчетнаяПолитика" , "ВестиПартионныйУчетПоСкладам",               "ВестиПартионныйУчетПоСкладам");
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "Склад",            "ВидСклада",                                  "ВидСклада");
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "Организации",      "ОтражатьВРегламентированномУчете" ,          "ОтражатьВРегламентированномУчете");
	ОбщегоНазначения.ДобавитьСтрокуВДеревоПолейЗапросаПоШапке(ДеревоПолейЗапросаПоШапке, "УчетнаяПолитика",  "ВестиУчетТоваровОрганизацийВРазрезеСкладов", "ВестиУчетТоваровОрганизацийВРазрезеСкладов");
	
	// Сформируем запрос на дополнительные параметры, нужные при проведении, по данным шапки документа
	СтруктураШапкиДокумента = УправлениеЗапасами.СформироватьЗапросПоДеревуПолей(ЭтотОбъект, ДеревоПолейЗапросаПоШапке, СтруктураШапкиДокумента, мВалютаРегламентированногоУчета);
	
	// Перезаполним курсы
	СтруктураШапкиДокумента.КурсВалютыУправленческогоУчета = ПолучитьКурсВалютыДокумента(СтруктураШапкиДокумента.ВалютаУправленческогоУчета);
	
	// Заголовок для сообщений об ошибках проведения.
	Заголовок = ОбщегоНазначения.ПредставлениеДокументаПриПроведении(СтруктураШапкиДокумента);
	
	// Проверим правильность заполнения шапки документа
	ПроверитьЗаполнениеШапки(СтруктураШапкиДокумента, Отказ, Заголовок);
	
	// Получим необходимые данные для проведения и проверки заполнения данных по табличной части "Товары".
	СтруктураПолей = Новый Структура();
	СтруктураПолей.Вставить("Номенклатура"              	, "Номенклатура");
	СтруктураПолей.Вставить("Услуга"                    	, "Номенклатура.Услуга");
	СтруктураПолей.Вставить("Набор"                     	, "Номенклатура.Набор");
	СтруктураПолей.Вставить("Комплект"                  	, "Номенклатура.Комплект");
	СтруктураПолей.Вставить("Количество"                	, "Количество");
	СтруктураПолей.Вставить("Цена"                      	, "Цена");
	СтруктураПолей.Вставить("Сумма"                     	, "Сумма");
	СтруктураПолей.Вставить("Качество"                  	, "Качество");
	СтруктураПолей.Вставить("ХарактеристикаНоменклатуры"	, "ХарактеристикаНоменклатуры");
	СтруктураПолей.Вставить("СерияНоменклатуры"         	, "СерияНоменклатуры");
	СтруктураПолей.Вставить("ВестиПартионныйУчетПоСериям"	, "Номенклатура.ВестиПартионныйУчетПоСериям");
	СтруктураПолей.Вставить("ДокументРезерва"           	, "ДокументРезерва");
	СтруктураПолей.Вставить("Склад"                     	, "Ссылка.Склад");
	СтруктураПолей.Вставить("МаршрутныйЛист"            	, "Ссылка");
	СтруктураПолей.Вставить("ЗаказПокупателя"            	, "ЗаказПокупателя");
	СтруктураПолей.Вставить("Контрагент"            		, "Контрагент");
	СтруктураПолей.Вставить("Возврат"		            	, "Возврат");
	
	РезультатЗапросаПоТоварам 	= ОбщегоНазначения.СформироватьЗапросПоТабличнойЧасти(ЭтотОбъект, "ЗагрузкаМашины", СтруктураПолей);
	ТаблицаПоТоварам 			= ПодготовитьТаблицуТоваров(РезультатЗапросаПоТоварам, СтруктураШапкиДокумента);
	РезультатЗапросаПоПродажам 	= ОбщегоНазначения.СформироватьЗапросПоТабличнойЧасти(ЭтотОбъект, "Продажи", СтруктураПолей);
	ПроверитьЗаполнениеТабличнойЧасти(ТаблицаПоТоварам, СтруктураШапкиДокумента, Отказ, Заголовок, "ЗагрузкаМашины");
	// для возврата на склад товара из ТЧ Продажи, которых уже нет в ТЧ ЗагрузкаМашины
	ТаблицаПоПродажам 			= ПодготовитьТаблицуТоваров(РезультатЗапросаПоПродажам, СтруктураШапкиДокумента);
	Для Каждого СтрПродажи Из ТаблицаПоПродажам Цикл 
		НоваяСтрока = ТаблицаПоТоварам.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, СтрПродажи);
	КонецЦикла;	
	// -		
	
	// Движения по документу - списание со склада в дорогу загруженного товара
	Если Не Отказ Тогда
		ДвиженияПоРегистрамСписание(РежимПроведения, СтруктураШапкиДокумента, ТаблицаПоТоварам, , Отказ, Заголовок);
	КонецЕсли;
	
	// ПРОВЕДЕНИЕ ОПРИХОДОВАНИЯ
	мУчетнаяПолитика   				= ОбщегоНазначения.ПолучитьПараметрыУчетнойПолитики(КонецМесяца(Дата), Отказ);
	ТабУчетнаяПолитика 				= УправлениеЗапасамиПартионныйУчет.ПолучитьУчетнуюПолитику(Дата);
	мТекущаяСхемаНалогообложения 	= НалоговыйУчет.ПолучитьСхемуНалогообложения(Дата, Организация);
	мПорядокСписанияПартий 			= Новый Структура("Упр,Бух,Нал");
	
	Если ОтражатьВУправленческомУчете Тогда
		СтрокаУчетнойПолитики = ТабУчетнаяПолитика[0];
		мПорядокСписанияПартий.Вставить("Упр", СтрокаУчетнойПолитики.СпособОценкиМПЗУпр);
	КонецЕсли;
	
	// для возврата на склад товара из ТЧ ЗагрузкаМашины у которых Возврат
	Если СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Отправлен Тогда 
		ТаблицаПоВозвратам 	= ТаблицаПоТоварам.Скопировать();
		МассивСтрок 		= Новый Массив;
		Для Каждого СтрВозврата Из ТаблицаПоВозвратам Цикл 
			Если (НЕ СтрВозврата.Возврат) Тогда 
				МассивСтрок.Добавить(СтрВозврата);
			КонецЕсли; 	
		КонецЦикла;	
		Для Каждого ЭлементМассива Из МассивСтрок Цикл 
			ТаблицаПоВозвратам.Удалить(ЭлементМассива);
		КонецЦикла;	
	КонецЕсли;
	// -				
	
	// Движения по документу - оприходование на склад с дороги загруженного товара
	Если Не Отказ Тогда
		ДвиженияПоРегистрамОприходование(РежимПроведения, СтруктураШапкиДокумента, ?(СтатусДокумента = Перечисления.СтатусыМаршрутногоЛиста.Отправлен, ТаблицаПоВозвратам, ТаблицаПоТоварам), Отказ, Заголовок);
	КонецЕсли;		
	
	// ПРОВЕДЕНИЕ ВОЗВРАТОВ
	Если Не Отказ Тогда
		СтруктураПолей.Вставить("ЗаказПокупателя"            	, "ЗаказПокупателя");
		СтруктураПолей.Вставить("Контрагент"            		, "Контрагент");
		СтруктураПолей.Вставить("Возврат"		            	, "Возврат");		
		РезультатЗапросаПоВозвратам = ОбщегоНазначения.СформироватьЗапросПоТабличнойЧасти(ЭтотОбъект, "ЗагрузкаМашины", СтруктураПолей);
		ТаблицаПоВозвратам 			= ПодготовитьТаблицуТоваров(РезультатЗапросаПоВозвратам, СтруктураШапкиДокумента);
		ПроверитьЗаполнениеТабличнойЧасти(ТаблицаПоВозвратам, СтруктураШапкиДокумента, Отказ, Заголовок, "ЗагрузкаМашины");		
		ДвиженияПоРегиструВозвраты(РежимПроведения, СтруктураШапкиДокумента, ТаблицаПоВозвратам, Отказ, Заголовок);
	КонецЕсли;			
	
	//ДенедныеСредства, ДвиженияДенежныхСредств
	
	НаборЗаписей = РегистрыНакопления.ДенежныеСредства.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Регистратор.Установить(ЭтотОбъект.Ссылка);
	Грн = Справочники.Валюты.НайтиПоКоду("980");
	Упр = Константы.ВалютаУправленческогоУчета.Получить();
	ГрнКурс = КурсыВалют.Найти(Грн).Курс;
	УпрКурс = КурсыВалют.Найти(Упр).Курс;
	Для Каждого Строка Из Витрати Цикл
		Запись = НаборЗаписей.ДобавитьРасход();
		Запись.Регистратор = ЭтотОбъект.Ссылка;
		Запись.Период = Дата;
		Запись.ВидДенежныхСредств = Перечисления.ВидыДенежныхСредств.Наличные;
		Запись.БанковскийСчетКасса = Справочники.Кассы.НайтиПоКоду("000000001");
		Запись.Организация = Организация;
		Запись.Сумма = Строка.Сума;
		Запись.СуммаУпр = МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(Строка.Сума, Грн, Упр, ГрнКурс, УпрКурс, 1, 1);
	КонецЦикла;
	НаборЗаписей.Записать();  	
	
	НаборЗаписей = РегистрыНакопления.ДвиженияДенежныхСредств.СоздатьНаборЗаписей();
	НаборЗаписей.Отбор.Регистратор.Установить(ЭтотОбъект.Ссылка);
	Для Каждого Строка Из Витрати Цикл 
		Запись = НаборЗаписей.Добавить();
		Запись.Регистратор = ЭтотОбъект.Ссылка;
		Запись.Период = Дата;
		Запись.СтатьяДвиженияДенежныхСредств =  Строка.СтаттяВитрат;
		Запись.БанковскийСчетКасса = Справочники.Кассы.НайтиПоКоду("000000001");
		Запись.ПриходРасход = Перечисления.ВидыДвиженийПриходРасход.Расход;
		Запись.Организация = Организация;
		Запись.ДокументДвижения = ЭтотОбъект.Ссылка;
		Запись.ВидДенежныхСредств = Перечисления.ВидыДенежныхСредств.Наличные;
		Запись.Сумма = Строка.Сума;
		Запись.СуммаУпр = МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(Строка.Сума, Грн, Упр, ГрнКурс, УпрКурс, 1, 1);
	КонецЦикла;
	НаборЗаписей.Записать();
КонецПроцедуры

Процедура ОбработкаУдаленияПроведения(Отказ)
	
	ОбщегоНазначения.УдалитьДвиженияРегистратора(ЭтотОбъект, Отказ);
	
	ОтменаПроведенияСвязанныхДокументов();
	
КонецПроцедуры

Процедура ОтменаПроведенияСвязанныхДокументов()
	
	Таблица = ПолныеПрава.ПолучитьСписокДокументовПоКритериюОтбора("СвязанныеДокументы", Ссылка);
	Для Каждого СтрДок Из Таблица Цикл    // Якщо документ новий (не записаний) То Таблиця містить чомусь дуже багато документів
		//ДокОбъект = СтрДок.Ссылка.ПолучитьОбъект();
		//ДокОбъект.Записать(РежимЗаписиДокумента.ОтменаПроведения);
	КонецЦикла;	
	
КонецПроцедуры	

#Если Клиент Тогда
	Функция ПечатьМаршрутногоЛиста(НазваниеМакета)
		
		ТабДокумент 					= Новый ТабличныйДокумент;
		ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_МаршрутныйЛист";	
		ТабДокумент.ОриентацияСтраницы 	= ОриентацияСтраницы.Портрет;
		ТабДокумент.РазмерСтраницы 		= "A4";
		ТабДокумент.АвтоМасштаб 		= Истина;
		
		// Шапка
		Запрос = Новый Запрос();
		Запрос.УстановитьПараметр("ТекущийДокумент", ЭтотОбъект.Ссылка);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаршрутныйЛист.Номер КАК НомерДокумента,
		|	МаршрутныйЛист.Дата КАК ДатаДокумента,
		|	МаршрутныйЛист.Организация КАК Организация,
		|	МаршрутныйЛист.Автомобиль КАК Автомобиль,
		|	МаршрутныйЛист.Склад КАК Склад,
		|	МаршрутныйЛист.Комментарий,
		|	ЕСТЬNULL(Штрихкоды.Штрихкод, """") КАК Штрихкод,
		|	ЕСТЬNULL(Штрихкоды.ТипШтрихкода, ЗНАЧЕНИЕ(ПланВидовХарактеристик.ТипыШтрихкодов.ПустаяСсылка)) КАК ТипШтрихкода,
		|	ЕСТЬNULL(Штрихкоды.ПредставлениеШтрихкода, """") КАК ПредставлениеШтрихкода
		|ИЗ
		|	Документ.МаршрутныйЛист КАК МаршрутныйЛист
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Штрихкоды КАК Штрихкоды
		|		ПО МаршрутныйЛист.Ссылка = Штрихкоды.Владелец
		|ГДЕ
		|	МаршрутныйЛист.Ссылка = &ТекущийДокумент";
		
		РезультатШапка = Запрос.Выполнить();
		Если РезультатШапка.Пустой() Тогда 
			Возврат ТабДокумент;
		КонецЕсли;		
		Шапка = Запрос.Выполнить().Выбрать();
		Шапка.Следующий();
		
		Макет 					= ПолучитьМакет(НазваниеМакета);
		КодЯзыкаПечать 			= "ru";
		Макет.КодЯзыкаМакета 	= КодЯзыкаПечать;	
		
		Если Шапка.Штрихкод = "" Тогда 
			Сообщить("Документу не присвоен штрихкод.");
			Возврат ТабДокумент;
		КонецЕсли;	
		Попытка
			КомпонентШК = Новый COMОбъект("V8.Barcod.1");
			ОбластьШтрихкод = Макет.Области.ОбластьШтрихкод;
			РисунокШтрихкод = Макет.Рисунки.D9;
			РисунокШтрихкод.Расположить(ОбластьШтрихкод);
			ТипКода = ПолучитьЗначениеТипаШтрихкодаДляЭУ(Шапка.ТипШтрихкода);
			Если РаботаСТорговымОборудованием.ПроверитьШтрихКод(?(ПустаяСтрока(Шапка.ПредставлениеШтрихкода),
				Шапка.Штрихкод,
				Шапка.ПредставлениеШтрихкода),
				Шапка.ТипШтрихкода) Тогда
				
				Макет.Рисунки.D9.Объект.ТипКода   			= ТипКода;
				Макет.Рисунки.D9.Объект.Сообщение 			= ?(ПустаяСтрока(Шапка.ПредставлениеШтрихкода),
				Шапка.Штрихкод,
				Шапка.ПредставлениеШтрихкода);
			КонецЕсли;															  
		Исключение
