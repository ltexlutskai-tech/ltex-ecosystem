	Функция ПечатьМаршрутногоЛистаСОплатой(НазваниеМакета)
		
		ТабДокумент 					= Новый ТабличныйДокумент;
		ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_МаршрутныйЛист";	
		ТабДокумент.ОриентацияСтраницы 	= ОриентацияСтраницы.Портрет;
		ТабДокумент.РазмерСтраницы 		= "A4";
		ТабДокумент.АвтоМасштаб 		= Истина;
		
		// Шапка
		Запрос = Новый Запрос();
		Запрос.УстановитьПараметр("ТекущийДокумент", ЭтотОбъект.Ссылка);
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МаршрутныйЛист.Номер КАК НомерДокумента,
		|	МаршрутныйЛист.Дата КАК ДатаДокумента,
		|	МаршрутныйЛист.Организация КАК Организация,
		|	МаршрутныйЛист.Автомобиль КАК Автомобиль,
		|	МаршрутныйЛист.Склад КАК Склад,
		|	МаршрутныйЛист.Комментарий,
		|	ЕСТЬNULL(Штрихкоды.Штрихкод, """") КАК Штрихкод,
		|	ЕСТЬNULL(Штрихкоды.ТипШтрихкода, ЗНАЧЕНИЕ(ПланВидовХарактеристик.ТипыШтрихкодов.ПустаяСсылка)) КАК ТипШтрихкода,
		|	ЕСТЬNULL(Штрихкоды.ПредставлениеШтрихкода, """") КАК ПредставлениеШтрихкода
		|ИЗ
		|	Документ.МаршрутныйЛист КАК МаршрутныйЛист
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.Штрихкоды КАК Штрихкоды
		|		ПО МаршрутныйЛист.Ссылка = Штрихкоды.Владелец
		|ГДЕ
		|	МаршрутныйЛист.Ссылка = &ТекущийДокумент";
		
		РезультатШапка = Запрос.Выполнить();
		Если РезультатШапка.Пустой() Тогда 
			Возврат ТабДокумент;
		КонецЕсли;		
		Шапка = Запрос.Выполнить().Выбрать();
		Шапка.Следующий();
		
		Макет 					= ПолучитьМакет(НазваниеМакета);
		КодЯзыкаПечать 			= "ru";
		Макет.КодЯзыкаМакета 	= КодЯзыкаПечать;	
		
		Если Шапка.Штрихкод = "" Тогда 
			Сообщить("Документу не присвоен штрихкод.");
			Возврат ТабДокумент;
		КонецЕсли;	
		Попытка
			КомпонентШК = Новый COMОбъект("V8.Barcod.1");
			ОбластьШтрихкод = Макет.Области.ОбластьШтрихкод;
			РисунокШтрихкод = Макет.Рисунки.D9;
			РисунокШтрихкод.Расположить(ОбластьШтрихкод);
			ТипКода = ПолучитьЗначениеТипаШтрихкодаДляЭУ(Шапка.ТипШтрихкода);
			Если РаботаСТорговымОборудованием.ПроверитьШтрихКод(?(ПустаяСтрока(Шапка.ПредставлениеШтрихкода),
				Шапка.Штрихкод,
				Шапка.ПредставлениеШтрихкода),
				Шапка.ТипШтрихкода) Тогда
				
				Макет.Рисунки.D9.Объект.ТипКода   			= ТипКода;
				Макет.Рисунки.D9.Объект.Сообщение 			= ?(ПустаяСтрока(Шапка.ПредставлениеШтрихкода),
				Шапка.Штрихкод,
				Шапка.ПредставлениеШтрихкода);
			КонецЕсли;															  
		Исключение
			Сообщить("Компонента 1С:Печать штрихкодов не установлена на данном компьютере!", СтатусСообщения.Важное);
			Отказ = Истина;
		КонецПопытки;	
		
		СведенияОбОрганизации 						= УправлениеКонтактнойИнформацией.СведенияОЮрФизЛице(Шапка.Организация, Шапка.ДатаДокумента, , ,КодЯзыкаПечать);
		ОбластьМакета 								= Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ОбластьМакета.Параметры.НазваниеОрганизации	= ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации, "ПолноеНаименование,", Ложь,КодЯзыкаПечать);
		ОбластьМакета.Параметры.ЕДРПОУОрганизации	= ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации, "КодПоЕДРПОУ,", Ложь,КодЯзыкаПечать);
		ОбластьМакета.Параметры.ЮридическийАдрес    = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации, "ЮридическийАдрес,", Ложь,КодЯзыкаПечать);
		ТабДокумент.Вывести(ОбластьМакета);
		// -
		
		////////////////////////////////////////////////////////////////////////////////////////////////////////
		ТЗ = Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("Контрагент");
		ТЗ.Колонки.Добавить("Артикул");	
		ТЗ.Колонки.Добавить("Номенклатура");
		ТЗ.Колонки.Добавить("Заказано");
		ТЗ.Колонки.Добавить("Количество");
		ТЗ.Колонки.Добавить("Вес");
		ТЗ.Колонки.Добавить("Цена");
		ТЗ.Колонки.Добавить("Сумма");
		ТЗ.Колонки.Добавить("ЗаказПокупателя");
		ТЗ.Колонки.Добавить("Комментарий");
		ТЗ.Колонки.Добавить("НомерСтрокиВТабЗагрМаш");
		ТЗ.Колонки.Добавить("НомерСтроки");
		ТЗ.Колонки.Добавить("Штрихкод");
		ТЗ.Колонки.Добавить("Характеристика");
		
		
		КонтрагентыТЗ = ПолучитьСписокВсехКонтрагентов();
		
		ДолгПереплата = Новый ТаблицаЗначений;
		ДолгПереплата.Колонки.Добавить("Контрагент");
		ДолгПереплата.Колонки.Добавить("ДолгПереплата");
				
		Для Каждого Строка Из КонтрагентыТЗ Цикл
			Отбор = Новый Структура;
			Отбор.Вставить("Контрагент", Строка.Контрагент);
			СумаДолг = 0;		
			СтрокиДолг = Продажи.НайтиСтроки(Отбор);
			Для Каждого Стр Из СтрокиДолг Цикл
				СумаДолг = СумаДолг + Стр.Сумма;
			КонецЦикла;
			СумаОплата = 0;
			СтрокиОплата = Оплата.НайтиСтроки(Отбор);
			Для Каждого Стр Из СтрокиОплата Цикл
				Евро = Справочники.Валюты.НайтиПоКоду("978");
				Если Стр.Возврат Тогда
					//СумаОплата = СумаОплата - Ценообразование.ПересчитатьЦенуПриИзмененииВалюты(Стр.Сумма,Стр.Валюта,Евро,Стр.КурсУпр,,);
					СумаОплата = СумаОплата - МодульВалютногоУчета.ПересчитатьИзВалютыВВалюту(Стр.Сумма, Стр.Валюта, Евро, 
												Стр.КурсВал, Стр.КурсУпр,1,1);
