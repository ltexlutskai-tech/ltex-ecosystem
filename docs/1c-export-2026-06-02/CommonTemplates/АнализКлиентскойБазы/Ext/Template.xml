		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказыПокупателейОбороты.Регистратор) КАК КоличествоЗаказов,
	ЗаказыПокупателейОбороты.Регистратор.Контрагент КАК Контрагент
ПОМЕСТИТЬ ТабПродажКоличествоЗаказов
ИЗ
	РегистрНакопления.ЗаказыПокупателей.Обороты({(&amp;НачалоМесяца)}, , Регистратор, ЗаказПокупателя.ТорговийАгент = &amp;ТорговийАгент) КАК ЗаказыПокупателейОбороты
ГДЕ
	ЗаказыПокупателейОбороты.Регистратор ССЫЛКА Документ.ЗаказПокупателя

СГРУППИРОВАТЬ ПО
	ЗаказыПокупателейОбороты.Регистратор.Контрагент
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказыПокупателейОбороты.Регистратор) КАК КоличествоЗаказовСНачалаДня,
	ЗаказыПокупателейОбороты.Регистратор.Контрагент КАК Контрагент
ПОМЕСТИТЬ ТабПродажКоличествоЗаказовСНачалаДня
ИЗ
	РегистрНакопления.ЗаказыПокупателей.Обороты({(&amp;НачалоДня)}, , Регистратор, ЗаказПокупателя.ТорговийАгент = &amp;ТорговийАгент) КАК ЗаказыПокупателейОбороты
ГДЕ
	ЗаказыПокупателейОбороты.Регистратор ССЫЛКА Документ.ЗаказПокупателя

СГРУППИРОВАТЬ ПО
	ЗаказыПокупателейОбороты.Регистратор.Контрагент
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ПродажиОбороты.ДокументПродажи.Контрагент КАК Контрагент,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПродажиОбороты.Регистратор) КАК КоличествоПродаж
ПОМЕСТИТЬ ТабПродажКоличествоРеализаций
ИЗ
	РегистрНакопления.Продажи.Обороты({(&amp;НачалоМесяца)}, , Регистратор, ДокументПродажи.ТорговийАгент = &amp;ТорговийАгент) КАК ПродажиОбороты
ГДЕ
	ПродажиОбороты.Регистратор ССЫЛКА Документ.РеализацияТоваровУслуг

СГРУППИРОВАТЬ ПО
	ПродажиОбороты.ДокументПродажи.Контрагент
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ПродажиОбороты.ДокументПродажи.Контрагент КАК Контрагент,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПродажиОбороты.Регистратор) КАК КоличествоПродажСНачалаДня
ПОМЕСТИТЬ ТабПродажКоличествоРеализацийСНачалаДня
ИЗ
	РегистрНакопления.Продажи.Обороты({(&amp;НачалоДня)}, , Регистратор, ДокументПродажи.ТорговийАгент = &amp;ТорговийАгент) КАК ПродажиОбороты
ГДЕ
	ПродажиОбороты.Регистратор ССЫЛКА Документ.РеализацияТоваровУслуг

СГРУППИРОВАТЬ ПО
	ПродажиОбороты.ДокументПродажи.Контрагент
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Контрагенты.Ссылка КАК Контрагент,
	Контрагенты.Область,
	Контрагенты.Город,
	ВЫБОР
		КОГДА Контрагенты.СтатусКонтрагента = ЗНАЧЕНИЕ(Справочник.СтатусыКонтрагентов.Активний)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК Активный,
	ВЫБОР
		КОГДА Контрагенты.СтатусКонтрагента = ЗНАЧЕНИЕ(Справочник.СтатусыКонтрагентов.Малоактивний)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК Малоактивний,
	ВЫБОР
		КОГДА Контрагенты.СтатусКонтрагента = ЗНАЧЕНИЕ(Справочник.СтатусыКонтрагентов.Неактивний)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК Неактивний,
	ВЫБОР
		КОГДА Контрагенты.СтатусКонтрагента = ЗНАЧЕНИЕ(Справочник.СтатусыКонтрагентов.Новий)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК Новий,
	ВЫБОР
		КОГДА Контрагенты.ОперативныйСтатусКонтрагента = ЗНАЧЕНИЕ(Справочник.СтатусыКонтрагентов.Активний)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ОПАктивный,
	ВЫБОР
		КОГДА Контрагенты.ОперативныйСтатусКонтрагента = ЗНАЧЕНИЕ(Справочник.СтатусыКонтрагентов.Малоактивний)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ОПМалоактивний,
	ВЫБОР
		КОГДА Контрагенты.ОперативныйСтатусКонтрагента = ЗНАЧЕНИЕ(Справочник.СтатусыКонтрагентов.Неактивний)
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ОПНеактивний,
	ВЫБОР
		КОГДА Контрагенты.ДатаСоздания &gt;= &amp;НачалоПериодаНеделя
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ОПНовий,
	ТабПродажКоличествоЗаказов.КоличествоЗаказов,
	ТабПродажКоличествоРеализаций.КоличествоПродаж,
	ТабПродажКоличествоЗаказовСНачалаДня.КоличествоЗаказовСНачалаДня,
	ТабПродажКоличествоРеализацийСНачалаДня.КоличествоПродажСНачалаДня
ИЗ
	Справочник.Контрагенты КАК Контрагенты
		ЛЕВОЕ СОЕДИНЕНИЕ ТабПродажКоличествоЗаказов КАК ТабПродажКоличествоЗаказов
		ПО Контрагенты.Ссылка = ТабПродажКоличествоЗаказов.Контрагент
		ЛЕВОЕ СОЕДИНЕНИЕ ТабПродажКоличествоРеализаций КАК ТабПродажКоличествоРеализаций
		ПО Контрагенты.Ссылка = ТабПродажКоличествоРеализаций.Контрагент
		ЛЕВОЕ СОЕДИНЕНИЕ ТабПродажКоличествоЗаказовСНачалаДня КАК ТабПродажКоличествоЗаказовСНачалаДня
		ПО Контрагенты.Ссылка = ТабПродажКоличествоЗаказовСНачалаДня.Контрагент
		ЛЕВОЕ СОЕДИНЕНИЕ ТабПродажКоличествоРеализацийСНачалаДня КАК ТабПродажКоличествоРеализацийСНачалаДня
