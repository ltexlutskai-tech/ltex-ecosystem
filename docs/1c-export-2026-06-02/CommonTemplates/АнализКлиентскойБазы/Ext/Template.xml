КОГДА Сумма(ОПНовий)= 0 И НЕ Сумма(Новий)= 0
ТОГДА Строка(Сумма(Новий))
КОГДА  НЕ Сумма(ОПНовий)= 0 И Сумма(Новий)= 0
ТОГДА " (" + Строка(Сумма(ОПНовий)) + ")" 
ИНАЧЕ Строка(Сумма(Новий)) + " (" + Строка(Сумма(ОПНовий)) + ")"
КОНЕЦ
</expression>
	</totalField>
