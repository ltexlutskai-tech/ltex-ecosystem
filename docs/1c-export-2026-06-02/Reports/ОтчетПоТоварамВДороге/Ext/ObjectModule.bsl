//Представление периода для шапок отчетов
Функция ПолучитьпериодОтчета()Экспорт 
	
	ПериодОтчета = "";
	
	ПериодОтчета = НСтр("ru='на ';uk='на '") + Формат(Период,"ДЛФ=Д");
	
	Возврат ПериодОтчета;
	
