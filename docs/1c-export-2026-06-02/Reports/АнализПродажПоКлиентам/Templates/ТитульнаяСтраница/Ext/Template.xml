		<query>ВЫБРАТЬ
	ПродажиОбороты.Организация,
	ПродажиОбороты.Контрагент,
	ВЫБОР
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 1
			ТОГДА "Січень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 2
			ТОГДА "Лютий"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 3
			ТОГДА "Березень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 4
			ТОГДА "Квітень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 5
			ТОГДА "Травень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 6
			ТОГДА "Червень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 7
			ТОГДА "Липень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 8
			ТОГДА "Серпень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 9
			ТОГДА "Вересень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 10
			ТОГДА "Жовтень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 11
			ТОГДА "Листопад"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 12
			ТОГДА "Грудень"
	КОНЕЦ КАК Месяц,
	МЕСЯЦ(ПродажиОбороты.Период) КАК НомерМесяца,
	СУММА(ПродажиОбороты.КоличествоОборот) КАК КоличествоОборот,
	СУММА(ПродажиОбороты.СтоимостьОборот) КАК СтоимостьОборот,
	СУММА(ПродажиОбороты.КоличествоОборот * ПродажиОбороты.ХарактеристикаНоменклатуры.Вага) КАК Вес
ПОМЕСТИТЬ ВТПродажи
ИЗ
	РегистрНакопления.Продажи.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Запись, Организация = &amp;Организация) КАК ПродажиОбороты

СГРУППИРОВАТЬ ПО
	ПродажиОбороты.Организация,
	ВЫБОР
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 1
			ТОГДА "Січень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 2
			ТОГДА "Лютий"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 3
			ТОГДА "Березень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 4
			ТОГДА "Квітень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 5
			ТОГДА "Травень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 6
			ТОГДА "Червень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 7
			ТОГДА "Липень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 8
			ТОГДА "Серпень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 9
			ТОГДА "Вересень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 10
			ТОГДА "Жовтень"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 11
			ТОГДА "Листопад"
		КОГДА МЕСЯЦ(ПродажиОбороты.Период) = 12
			ТОГДА "Грудень"
	КОНЕЦ,
	ПродажиОбороты.Контрагент,
	МЕСЯЦ(ПродажиОбороты.Период)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Контрагенты.Ссылка,
	Контрагенты.Область,
	Контрагенты.Город,
	Контрагенты.НомерТелефона
ПОМЕСТИТЬ ВТКонтрагенты
ИЗ
	Справочник.Контрагенты КАК Контрагенты
ГДЕ
	Контрагенты.Покупатель

СГРУППИРОВАТЬ ПО
	Контрагенты.Ссылка,
	Контрагенты.Область,
	Контрагенты.Город,
	Контрагенты.НомерТелефона
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ПродажиОбороты.Организация,
	МЕСЯЦ(ПродажиОбороты.Период) КАК Месяц,
	ПродажиОбороты.Контрагент КАК Контрагент,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПродажиОбороты.Регистратор) КАК Накладных
ПОМЕСТИТЬ ВТСделки
ИЗ
	РегистрНакопления.Продажи.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Регистратор, Организация = &amp;Организация) КАК ПродажиОбороты

СГРУППИРОВАТЬ ПО
	ПродажиОбороты.Организация,
	ПродажиОбороты.Контрагент,
	МЕСЯЦ(ПродажиОбороты.Период)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТПродажи.Организация,
	ВТКонтрагенты.Ссылка КАК Контрагент,
	ВТКонтрагенты.Город,
	ВТКонтрагенты.Область,
	ВТКонтрагенты.НомерТелефона,
	ВТПродажи.Месяц,
	ВТПродажи.КоличествоОборот,
	ВТПродажи.СтоимостьОборот,
	ВТПродажи.Вес КАК Вес,
	ВТСделки.Накладных,
	ВТПродажи.НомерМесяца
ИЗ
	ВТКонтрагенты КАК ВТКонтрагенты
		ЛЕВОЕ СОЕДИНЕНИЕ ВТПродажи КАК ВТПродажи
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТСделки КАК ВТСделки
			ПО ВТПродажи.Контрагент = ВТСделки.Контрагент
				И ВТПродажи.НомерМесяца = ВТСделки.Месяц
		ПО ВТКонтрагенты.Ссылка = ВТПродажи.Контрагент</query>
