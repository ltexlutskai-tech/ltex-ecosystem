		<query>ВЫБРАТЬ
	ВложенныйЗапрос.Организация,
	ВложенныйЗапрос.Контрагент,
	СУММА(ВложенныйЗапрос.КоличествоОборот) КАК КоличествоОборот,
	СУММА(ВложенныйЗапрос.СтоимостьОборот) КАК СтоимостьОборот,
	СУММА(ВложенныйЗапрос.Вес) КАК Вес,
	СУММА(ВложенныйЗапрос.КоличествоОборот1) КАК КоличествоОборот1,
	СУММА(ВложенныйЗапрос.СтоимостьОборот1) КАК СтоимостьОборот1,
	СУММА(ВложенныйЗапрос.Вес1) КАК Вес1,
	ВложенныйЗапрос.Номенклатура
ПОМЕСТИТЬ ВТПродажи
ИЗ
	(ВЫБРАТЬ
		ПродажиОбороты.Организация КАК Организация,
		ПродажиОбороты.Контрагент КАК Контрагент,
		СУММА(ПродажиОбороты.КоличествоОборот) КАК КоличествоОборот,
		СУММА(ПродажиОбороты.СтоимостьОборот) КАК СтоимостьОборот,
		СУММА(ПродажиОбороты.КоличествоОборот * ПродажиОбороты.ХарактеристикаНоменклатуры.Вага) КАК Вес,
		0 КАК КоличествоОборот1,
		0 КАК СтоимостьОборот1,
		0 КАК Вес1,
		ПродажиОбороты.Номенклатура КАК Номенклатура
	ИЗ
		РегистрНакопления.Продажи.Обороты({(&amp;НачалоПериода)}, {(&amp;КонецПериода)}, Запись, Организация = &amp;Организация) КАК ПродажиОбороты
	
	СГРУППИРОВАТЬ ПО
		ПродажиОбороты.Организация,
		ПродажиОбороты.Контрагент,
		ПродажиОбороты.Номенклатура
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		ПродажиОбороты.Организация,
		ПродажиОбороты.Контрагент,
		0,
		0,
		0,
		СУММА(ПродажиОбороты.КоличествоОборот),
		СУММА(ПродажиОбороты.СтоимостьОборот),
		СУММА(ПродажиОбороты.КоличествоОборот * ПродажиОбороты.ХарактеристикаНоменклатуры.Вага),
		ПродажиОбороты.Номенклатура
	ИЗ
		РегистрНакопления.Продажи.Обороты({(&amp;НачалоПериода1)}, {(&amp;КонецПериода1)}, Запись, Организация = &amp;Организация) КАК ПродажиОбороты
	
	СГРУППИРОВАТЬ ПО
		ПродажиОбороты.Организация,
		ПродажиОбороты.Контрагент,
		ПродажиОбороты.Номенклатура) КАК ВложенныйЗапрос

СГРУППИРОВАТЬ ПО
	ВложенныйЗапрос.Организация,
	ВложенныйЗапрос.Контрагент,
	ВложенныйЗапрос.Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	Контрагенты.Ссылка,
	Контрагенты.Область,
	Контрагенты.Город,
	Контрагенты.НомерТелефона
ПОМЕСТИТЬ ВТКонтрагенты
ИЗ
	Справочник.Контрагенты КАК Контрагенты
ГДЕ
	Контрагенты.Покупатель

СГРУППИРОВАТЬ ПО
	Контрагенты.Ссылка,
	Контрагенты.Область,
	Контрагенты.Город,
	Контрагенты.НомерТелефона
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВложенныйЗапрос.Организация,
	ВложенныйЗапрос.Контрагент КАК Контрагент,
	СУММА(ВложенныйЗапрос.Накладных) КАК Накладных,
	СУММА(ВложенныйЗапрос.Накладных1) КАК Накладных1
ПОМЕСТИТЬ ВТСделки
ИЗ
	(ВЫБРАТЬ
		ПродажиОбороты.Организация КАК Организация,
		ПродажиОбороты.Контрагент КАК Контрагент,
		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПродажиОбороты.Регистратор) КАК Накладных,
		0 КАК Накладных1
	ИЗ
		РегистрНакопления.Продажи.Обороты({(&amp;НачалоПериода)}, {(&amp;КонецПериода)}, Регистратор, Организация = &amp;Организация) КАК ПродажиОбороты
	
	СГРУППИРОВАТЬ ПО
		ПродажиОбороты.Организация,
		ПродажиОбороты.Контрагент
	
	ОБЪЕДИНИТЬ ВСЕ
	
	ВЫБРАТЬ
		ПродажиОбороты.Организация,
		ПродажиОбороты.Контрагент,
		0,
		КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ПродажиОбороты.Регистратор)
	ИЗ
		РегистрНакопления.Продажи.Обороты({(&amp;НачалоПериода1)}, {(&amp;КонецПериода1)}, Регистратор, Организация = &amp;Организация) КАК ПродажиОбороты
	
	СГРУППИРОВАТЬ ПО
		ПродажиОбороты.Организация,
		ПродажиОбороты.Контрагент) КАК ВложенныйЗапрос

СГРУППИРОВАТЬ ПО
	ВложенныйЗапрос.Организация,
	ВложенныйЗапрос.Контрагент
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВложенныйЗапрос.Ссылка КАК Контрагент,
	ВложенныйЗапрос.Область,
	ВложенныйЗапрос.Город,
	ВложенныйЗапрос.НомерТелефона,
	ВложенныйЗапрос.Номенклатура,
	ВложенныйЗапрос.КоличествоОборот,
	ВложенныйЗапрос.СтоимостьОборот,
	ВложенныйЗапрос.Вес,
	ВложенныйЗапрос.КоличествоОборот1,
	ВложенныйЗапрос.СтоимостьОборот1,
	ВложенныйЗапрос.Вес1,
	ВТСделки.Накладных КАК Накладных,
	ВТСделки.Накладных1 КАК Накладных1
ИЗ
	(ВЫБРАТЬ
		ВТКонтрагенты.Ссылка КАК Ссылка,
		ВТКонтрагенты.Область КАК Область,
		ВТКонтрагенты.Город КАК Город,
		ВТКонтрагенты.НомерТелефона КАК НомерТелефона,
		ВТПродажи.Номенклатура КАК Номенклатура,
		ВТПродажи.КоличествоОборот КАК КоличествоОборот,
		ВТПродажи.СтоимостьОборот КАК СтоимостьОборот,
		ВТПродажи.Вес КАК Вес,
		ВТПродажи.КоличествоОборот1 КАК КоличествоОборот1,
		ВТПродажи.СтоимостьОборот1 КАК СтоимостьОборот1,
		ВТПродажи.Вес1 КАК Вес1
	ИЗ
		ВТКонтрагенты КАК ВТКонтрагенты
			ЛЕВОЕ СОЕДИНЕНИЕ ВТПродажи КАК ВТПродажи
			ПО ВТКонтрагенты.Ссылка = ВТПродажи.Контрагент) КАК ВложенныйЗапрос
		ЛЕВОЕ СОЕДИНЕНИЕ ВТСделки КАК ВТСделки
		ПО ВложенныйЗапрос.Ссылка = ВТСделки.Контрагент</query>
	</dataSet>
