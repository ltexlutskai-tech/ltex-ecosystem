	ЗаполнитьПоказатели("СуммаНезакрытыхОтгрузокНДСВходящийНаНачало","Сумма не закрытых отгрузок на начало (сумма входящего НДС)", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("СуммаТребующаяПодтвержданияНалДокЗаПериод","Сумма взаиморасчетов, требующая подтверждения НД за период", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("ЗарегистрированоОтгрузокЗаПериод","Сумма отгрузок, требующая подтверждения НД за период", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("ВыписноНалДокВзаиморасчетыЗаПериод","Выписано НД за период (сумма взаиморасчетов)", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("ВыписноНалДокНДСЗаПериодВходящий","Выписано НД за период (сумма входящего НДС)", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("СуммаТребующаяПодтвержданияНалДокНаКонец","Сумма взаиморасчетов, требующая подтверждания НД на конец", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("СуммаНезакрытыхОтгрузокОплатНаКонец","Сумма не закрытых отгрузок (оплат) на конец (сумма взаиморасчетов)", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("СуммаНезакрытыхОтгрузокНДСВходящийНаКонец","Сумма не закрытых отгрузок на конец (сумма входящего НДС)", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	
	ЗаполнитьПредставление("Организация",				"Организация", 					ЛОЖЬ, ИСТИНА);
	ЗаполнитьПредставление("ДоговорКонтрагента",		"Договор",      				ЛОЖЬ, ИСТИНА);
	ЗаполнитьПредставление("Контрагент", 				"Контрагент", 					ЛОЖЬ, ИСТИНА);
	ЗаполнитьПредставление("ВозвратнаяТара", 			"Расчеты по таре", 				ЛОЖЬ, ИСТИНА);
	ЗаполнитьПредставление("СтавкаНДС", 				"Оплата/Ставка НДС отгрузки", 	ЛОЖЬ,   ЛОЖЬ);
	ЗаполнитьПредставление("МоментОпределенияБазыНДС",  "Момент определения базы НДС", 	ЛОЖЬ,   ЛОЖЬ);
	
	Текст ="ВЫБРАТЬ
			|	Организация КАК Организация,
			|	ДоговорКонтрагента.Владелец КАК Контрагент,						
			|	ДоговорКонтрагента КАК ДоговорКонтрагента,
			|	ВЫБОР
			|		КОГДА  МоментОпределенияБазыНДС = &НеЗаполненныйМоментОпределенияБазы 
			|		   ИЛИ МоментОпределенияБазыНДС Есть NULL ТОГДА
			|	        ""Не указан момент определения базы НДС!!!""
			|		ИНАЧЕ
			|       	МоментОпределенияБазыНДС
			|   КОНЕЦ КАК МоментОпределенияБазыНДС,
			|	ВЫБОР 
			|		КОГДА ВозвратнаяТара ТОГДА 
			|			""Возвратная тара"" 
			|		ИНАЧЕ 
			|			""Товары, услуги"" 
			|	КОНЕЦ КАК ВозвратнаяТара,
			|	
			|	ВЫБОР 
			|		КОГДА СтавкаНДС = &ПустаяСтавкаНДС ТОГДА 
			|			""Оплата"" 
			|		ИНАЧЕ 
			|			СтавкаНДС 
			|	КОНЕЦ КАК СтавкаНДС,
			|
			|	ВЫБОР 
			|		КОГДА СтавкаНДС = &ПустаяСтавкаНДС	ТОГДА
			|			ВЫБОР 
			|				КОГДА МоментОпределенияБазыНДС = &ПоОплате ТОГДА
			|					ОплОбщНач 
			|				КОГДА МоментОпределенияБазыНДС = &ПоПервомуСобытию ТОГДА 
			|					ВЫБОР 
			|						КОГДА ОтгрОбщНач >= ОплОбщНач 
			|							ТОГДА 
			|								ОтгрОбщНач 
			|							ИНАЧЕ 
			|								ОплОбщНач 
			|					КОНЕЦ 
			|				ИНАЧЕ 
			|					0 
			|			КОНЕЦ 
			|		ИНАЧЕ 
			|			ВЫБОР 
			|				КОГДА МоментОпределенияБазыНДС = &ПоОтгрузке ТОГДА 
			|					ОтгрНачРасчеты
			|				ИНАЧЕ
			|					0
			|			КОНЕЦ
			|	КОНЕЦ КАК СуммаТребующаяПодтвержданияНалДокНаНачало,
			|	
			|	ВЫБОР 
			|		КОГДА СтавкаНДС = &ПустаяСтавкаНДС ТОГДА 
			|       	-ОплОбщНач
			|		ИНАЧЕ
			|           -ОтгрНачРасчеты
			|   КОНЕЦ КАК СуммаНезакрытыхОтгрузокОплатНаНачало,
			|	ВЫБОР 
			|		КОГДА СтавкаНДС = &ПустаяСтавкаНДС ТОГДА 
			|       	0
			|		ИНАЧЕ
			|           -ОтгрНачНДСВход
			|   КОНЕЦ КАК СуммаНезакрытыхОтгрузокНДСВходящийНаНачало,
			|	
			|	ВЫБОР 
			|		КОГДА СтавкаНДС = &ПустаяСтавкаНДС ТОГДА 
			|			ВЫБОР 
			|				КОГДА МоментОпределенияБазыНДС = &ПоОплате ТОГДА 
			|					ОплОбщПрих 
			|				КОГДА МоментОпределенияБазыНДС = &ПоПервомуСобытию ТОГДА 
