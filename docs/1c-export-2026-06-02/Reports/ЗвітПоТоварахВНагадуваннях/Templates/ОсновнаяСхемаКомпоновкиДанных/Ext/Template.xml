		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	НапоминанияТовары.Номенклатура,
	НапоминанияТовары.Номенклатура.Артикул КАК Артикул,
	ВЫБОР
		КОГДА НапоминанияТовары.Ссылка.ИзЗаказа
			ТОГДА 1
		ИНАЧЕ 0
	КОНЕЦ КАК ИзЗаказа,
	ВЫБОР
		КОГДА НапоминанияТовары.Ссылка.ИзЗаказа
			ТОГДА 0
		ИНАЧЕ 1
	КОНЕЦ КАК БезЗаказа,
	НапоминанияТовары.Ссылка.Контрагент КАК Контрагент,
	НапоминанияТовары.Ссылка.ТорговийАгент КАК ТорговийАгент
ИЗ
	Справочник.Напоминания.Товары КАК НапоминанияТовары
ГДЕ
	НапоминанияТовары.Ссылка.НапоминаниеОТоваре
	И НапоминанияТовары.Ссылка.Активно
	И НапоминанияТовары.Ссылка.ДатаСоздания &gt; &amp;ДатаСоздания
	И НапоминанияТовары.Выполнено = ЛОЖЬ</query>
