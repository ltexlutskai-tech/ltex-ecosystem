	ЗаполнитьПредставление("Розница",					"Розничные продажи",			ЛОЖЬ, ИСТИНА);
	ЗаполнитьПредставление("ДоговорКонтрагента",		"Договор",      				ЛОЖЬ, ИСТИНА);
	ЗаполнитьПредставление("Контрагент", 				"Контрагент", 					ЛОЖЬ, ИСТИНА);
	ЗаполнитьПредставление("ВозвратнаяТара", 			"Расчеты по таре", 				ЛОЖЬ, ИСТИНА);
	ЗаполнитьПредставление("СтавкаНДС", 				"Оплата/Ставка НДС отгрузки",	ЛОЖЬ,   ЛОЖЬ);
    ЗаполнитьПредставление("МоментОпределенияБазыНДС",  "Момент определения базы НДС", 	ЛОЖЬ,   ЛОЖЬ);
	
	Текст ="ВЫБРАТЬ
	       |	ВложенныйЗапрос.Организация КАК Организация,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.Розница = ИСТИНА
	       |			ТОГДА ""Розничные продажи""
	       |		ИНАЧЕ ВложенныйЗапрос.Контрагент
	       |	КОНЕЦ КАК Контрагент,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.Розница = ИСТИНА
	       |			ТОГДА ""Розничные продажи""
	       |		ИНАЧЕ ""Оптовые продажи""
	       |	КОНЕЦ КАК Розница,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.Розница = ИСТИНА
	       |			ТОГДА ""Розничные продажи""
	       |		ИНАЧЕ ВложенныйЗапрос.ДоговорКонтрагента
	       |	КОНЕЦ КАК ДоговорКонтрагента,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.МоментОпределенияБазыНДС = &НеЗаполненныйМоментОпределенияБазы
	       |				ИЛИ ВложенныйЗапрос.МоментОпределенияБазыНДС ЕСТЬ NULL 
	       |			ТОГДА ""Не указан момент определения базы НДС!!!""
	       |		ИНАЧЕ ВложенныйЗапрос.МоментОпределенияБазыНДС
	       |	КОНЕЦ КАК МоментОпределенияБазыНДС,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.ВозвратнаяТара
	       |			ТОГДА ""Возвратная тара""
	       |		ИНАЧЕ ""Товары, услуги""
	       |	КОНЕЦ КАК ВозвратнаяТара,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.СтавкаНДС = &ПустаяСтавкаНДС
	       |			ТОГДА ""Оплата""
	       |		ИНАЧЕ ВложенныйЗапрос.СтавкаНДС
	       |	КОНЕЦ КАК СтавкаНДС,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.Розница = ИСТИНА
	       |			ТОГДА ВложенныйЗапрос.ОплНачРасчеты
	       |		КОГДА ВложенныйЗапрос.СтавкаНДС = &ПустаяСтавкаНДС
	       |			ТОГДА ВЫБОР
	       |					КОГДА ВложенныйЗапрос.МоментОпределенияБазыНДС = &ПоОплате
	       |						ТОГДА ВложенныйЗапрос.ОплОбщНач
	       |					КОГДА ВложенныйЗапрос.МоментОпределенияБазыНДС = &ПоПервомуСобытию
	       |						ТОГДА ВЫБОР
	       |								КОГДА ВложенныйЗапрос.ОтгрОбщНач >= ВложенныйЗапрос.ОплОбщНач
	       |									ТОГДА ВложенныйЗапрос.ОтгрОбщНач
	       |								ИНАЧЕ ВложенныйЗапрос.ОплОбщНач
	       |							КОНЕЦ
	       |					ИНАЧЕ 0
	       |				КОНЕЦ
	       |		ИНАЧЕ ВЫБОР
	       |				КОГДА ВложенныйЗапрос.МоментОпределенияБазыНДС = &ПоОтгрузке
	       |					ТОГДА ВложенныйЗапрос.ОтгрНачРасчеты
	       |				ИНАЧЕ 0
	       |			КОНЕЦ
	       |	КОНЕЦ КАК СуммаТребующаяПодтвержданияНалДокНаНачало,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.СтавкаНДС = &ПустаяСтавкаНДС
	       |			ТОГДА -ВложенныйЗапрос.ОплОбщНач
	       |		ИНАЧЕ -ВложенныйЗапрос.ОтгрНачРасчеты
	       |	КОНЕЦ КАК СуммаНезакрытыхОтгрузокОплатНаНачало,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.СтавкаНДС = &ПустаяСтавкаНДС
	       |			ТОГДА 0
	       |		ИНАЧЕ -ВложенныйЗапрос.ОтгрНачНДС
	       |	КОНЕЦ КАК СуммаНезакрытыхОтгрузокНДСНаНачало,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.Розница = ИСТИНА
	       |			ТОГДА ВложенныйЗапрос.ОплПрихРасчеты
	       |		КОГДА ВложенныйЗапрос.СтавкаНДС = &ПустаяСтавкаНДС
	       |			ТОГДА ВЫБОР
	       |					КОГДА ВложенныйЗапрос.МоментОпределенияБазыНДС = &ПоОплате
	       |						ТОГДА ВложенныйЗапрос.ОплОбщПрих
	       |					КОГДА ВложенныйЗапрос.МоментОпределенияБазыНДС = &ПоПервомуСобытию
	       |						ТОГДА ВЫБОР
	       |								КОГДА ВложенныйЗапрос.ОтгрОбщНач + ВложенныйЗапрос.ОтгрОбщПрих > ВложенныйЗапрос.ОплОбщНач + ВложенныйЗапрос.ОплОбщПрих
	       |									ТОГДА ВложенныйЗапрос.ОтгрОбщНач + ВложенныйЗапрос.ОтгрОбщПрих
	       |								ИНАЧЕ ВложенныйЗапрос.ОплОбщНач + ВложенныйЗапрос.ОплОбщПрих
	       |							КОНЕЦ - ВЫБОР
	       |								КОГДА ВложенныйЗапрос.ОтгрОбщНач > ВложенныйЗапрос.ОплОбщНач
	       |									ТОГДА ВложенныйЗапрос.ОтгрОбщНач
	       |								ИНАЧЕ ВложенныйЗапрос.ОплОбщНач
	       |							КОНЕЦ
	       |					ИНАЧЕ 0
	       |				КОНЕЦ
	       |		ИНАЧЕ ВЫБОР
	       |				КОГДА ВложенныйЗапрос.МоментОпределенияБазыНДС = &ПоОтгрузке
	       |					ТОГДА ВложенныйЗапрос.ОтгрОбщПрих
	       |				ИНАЧЕ 0
	       |			КОНЕЦ
	       |	КОНЕЦ КАК СуммаТребующаяПодтвержданияНалДокЗаПериод,
	       |	ВЫБОР
	       |		КОГДА ВложенныйЗапрос.Розница = ИСТИНА
	       |			ТОГДА ВложенныйЗапрос.ОтгрПрихРасчеты
	       |		КОГДА ВложенныйЗапрос.СтавкаНДС = &ПустаяСтавкаНДС
	       |			ТОГДА 0
	       |		ИНАЧЕ ВЫБОР
	       |				КОГДА ВложенныйЗапрос.ОтгрПрихРасчеты > 0
	       |						И ВложенныйЗапрос.ОтгрПрихРасчеты + ВложенныйЗапрос.ОтгрНачРасчеты > 0
	       |						И ВложенныйЗапрос.ОтгрНачРасчеты < 0
	       |						И (НЕ ВложенныйЗапрос.МоментОпределенияБазыНДС = &ПоОплате)
	       |					ТОГДА ВложенныйЗапрос.ОтгрПрихРасчеты + ВложенныйЗапрос.ОтгрНачРасчеты
	       |				ИНАЧЕ 0
	       |			КОНЕЦ
	       |	КОНЕЦ КАК ЗарегистрированоОтгрузокЗаПериод,
	       |	ВЫБОР
