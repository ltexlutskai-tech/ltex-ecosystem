	ЗаполнитьПоказатели("ВыписноНалДокВзаиморасчетыЗаПериод","Выписано НД за период (сумма взаиморасчетов)", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("ВыписноНалДокНДСЗаПериод","Выписано НД за период (сумма НДС)", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("СуммаТребующаяПодтвержданияНалДокНаКонец","Сумма взаиморасчетов, требующая подтверждания НД за конец", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("СуммаНезакрытыхОтгрузокОплатНаКонец","Сумма не закрытых отгрузок (оплат) на конец (сумма взаиморасчетов)", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	ЗаполнитьПоказатели("СуммаНезакрытыхОтгрузокНДСНаКонец","Сумма не закрытых отгрузок на конец (сумма НДС)", ИСТИНА,   "ЧЦ = 15; ЧДЦ = 3");
	
