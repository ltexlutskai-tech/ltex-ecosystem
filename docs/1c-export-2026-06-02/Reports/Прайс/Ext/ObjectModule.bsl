	//		ТабДок.Вывести(ОбластьНоменклатураРодительРодитель);
	//		ВыборкаДетальныеЗаписи = ВыборкаНоменклатураРодитель.Выбрать();
	//		
	//		Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	//			ОбластьДетальныхЗаписей.Параметры.Заполнить(ВыборкаДетальныеЗаписи);
	//			ТабДок.Вывести(ОбластьДетальныхЗаписей, ВыборкаДетальныеЗаписи.Уровень());
	//		КонецЦикла;
	//	КонецЕсли;
	//	ВыборкаНоменклатураРодитель.Сбросить();
	//	Пока ВыборкаНоменклатураРодитель.Следующий() Цикл
	//		Если ВыборкаНоменклатураРодитель.НоменклатураРодитель = Строка.НоменклатураРодительРодитель Тогда
	//			ОбластьНоменклатураРодитель.Параметры.Заполнить(ВыборкаНоменклатураРодитель);
	//			ТабДок.Вывести(ОбластьНоменклатураРодитель, ВыборкаНоменклатураРодитель.Уровень());
	//			Продолжить;
	//		КонецЕсли;
	//		Если ВыборкаНоменклатураРодитель.НоменклатураРодительРодитель = Строка.НоменклатураРодительРодитель Тогда
	//			Если Не ЗначениеЗаполнено(Строка.НоменклатураРодительРодитель) Тогда
	//				ОбластьНоменклатураРодительРодитель.Параметры.НоменклатураРодительРодитель = ВыборкаНоменклатураРодитель.НоменклатураРодитель;
	//				ТабДок.Вывести(ОбластьНоменклатураРодительРодитель);	
	//			Иначе
	//				ОбластьНоменклатураРодитель.Параметры.Заполнить(ВыборкаНоменклатураРодитель);
	//				ТабДок.Вывести(ОбластьНоменклатураРодитель, ВыборкаНоменклатураРодитель.Уровень());
	//			КонецЕсли;
	//			
	//			ВыборкаДетальныеЗаписи = ВыборкаНоменклатураРодитель.Выбрать();
	//			
	//			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
	//				ОбластьДетальныхЗаписей.Параметры.Заполнить(ВыборкаДетальныеЗаписи);
	//				ТабДок.Вывести(ОбластьДетальныхЗаписей, ВыборкаДетальныеЗаписи.Уровень());
	//			КонецЦикла;
	//		КонецЕсли;
	//		
	//	КонецЦикла;
	//КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Група,
	|	Номенклатура.Родитель
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа
	|	И Номенклатура.Ссылка В ИЕРАРХИИ(&СписокГруп)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура.Сортировка";
	Запрос.УстановитьПараметр("СписокГруп", СписокГруп);
	ТЗГрупа = Запрос.Выполнить().Выгрузить();
	
	//Отбор = Новый Структура;
	//Отбор.Вставить("Родитель", 
	
	
	
	Для каждого Стр Из ТЗГрупа Цикл
		Если Стр.Група.Уровень() = 0 Тогда 
			ВыборкаНоменклатураРодитель.Сбросить();
			ОбластьНоменклатураРодительРодитель.Параметры.НоменклатураРодительРодитель = Стр.Група;
			ТабДок.Вывести(ОбластьНоменклатураРодительРодитель);
			
			
			Пока ВыборкаНоменклатураРодитель.Следующий() Цикл
				Если ВыборкаНоменклатураРодитель.НоменклатураРодительРодитель = Стр.Група Тогда
					
					
					ОбластьНоменклатураРодитель.Параметры.Заполнить(ВыборкаНоменклатураРодитель);
					ТабДок.Вывести(ОбластьНоменклатураРодитель, ВыборкаНоменклатураРодитель.Уровень());
					
					ВыборкаДетальныеЗаписи = ВыборкаНоменклатураРодитель.Выбрать();
					
					Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
						ОбластьДетальныхЗаписей.Параметры.Заполнить(ВыборкаДетальныеЗаписи);
						ТабДок.Вывести(ОбластьДетальныхЗаписей, ВыборкаДетальныеЗаписи.Уровень());
					КонецЦикла;
					Для Каждого Строка Из ТЗГрупа Цикл
						Если Строка.Група.Родитель = ВыборкаНоменклатураРодитель.НоменклатураРодитель Тогда
							ОбластьВложенаГрупа.Параметры.ВложенаГрупа = Строка.Група;
							ТабДок.Вывести(ОбластьВложенаГрупа);
			
							Отбор = Новый Структура;
							Отбор.Вставить("НоменклатураРодитель", Строка.Група);
							НомВГрупе = НомТЗ.НайтиСтроки(Отбор);
							Для Каждого Элемент Из НомВГрупе Цикл
								Если ЗначениеЗаполнено(Элемент.НоменклатураНаименование) Тогда
								ОбластьДетальныхЗаписей.Параметры.Заполнить(Элемент);
								ТабДок.Вывести(ОбластьДетальныхЗаписей, ВыборкаДетальныеЗаписи.Уровень());
								КонецЕсли;
							КонецЦикла;
						КонецЕсли;
					КонецЦикла;
				ИначеЕсли ВыборкаНоменклатураРодитель.НоменклатураРодитель = Стр.Група Тогда
					ВыборкаДетальныеЗаписи = ВыборкаНоменклатураРодитель.Выбрать();
					
					Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
						ОбластьДетальныхЗаписей.Параметры.Заполнить(ВыборкаДетальныеЗаписи);
						ТабДок.Вывести(ОбластьДетальныхЗаписей, ВыборкаДетальныеЗаписи.Уровень());
					КонецЦикла;
					Для Каждого Строка Из ТЗГрупа Цикл
						Если Строка.Група.Родитель = ВыборкаНоменклатураРодитель.НоменклатураРодитель Тогда
							ОбластьНоменклатураРодитель.Параметры.НоменклатураРодитель = Строка.Група;
							ТабДок.Вывести(ОбластьНоменклатураРодитель);
			
							Отбор = Новый Структура;
							Отбор.Вставить("НоменклатураРодитель", Строка.Група);
							НомВГрупе = НомТЗ.НайтиСтроки(Отбор);
							Для Каждого Элемент Из НомВГрупе Цикл
								Если ЗначениеЗаполнено(Элемент.НоменклатураНаименование) Тогда
								ОбластьДетальныхЗаписей.Параметры.Заполнить(Элемент);
								ТабДок.Вывести(ОбластьДетальныхЗаписей, ВыборкаДетальныеЗаписи.Уровень());
								КонецЕсли;
							КонецЦикла;
						КонецЕсли;
					КонецЦикла;/////
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
	КонецЦикла;

	
	ТабДок.ЗакончитьАвтогруппировкуСтрок();
	ТабДок.Вывести(ОбластьПодвалТаблицы);
	ТабДок.Вывести(ОбластьПодвал);
	
