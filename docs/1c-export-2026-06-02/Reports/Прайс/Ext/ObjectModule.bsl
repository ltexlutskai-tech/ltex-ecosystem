	
	Процедура ОпределитьДанные(ТабДок) Экспорт
	//{{КОНСТРУКТОР_ЗАПРОСА_С_ОБРАБОТКОЙ_РЕЗУЛЬТАТА
	// Даний фрагмент побудований конструктором.
	// При повторному використанні конструктора, внесені вручну зміни будуть втрачені!!!
	
	Макет = Отчеты.Прайс.ПолучитьМакет("МакетПрайс");
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Артикул КАК Артикул,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.СреднийВес КАК СреднийВес,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.СсылкаНаYouTube КАК НоменклатураСсылкаНаYouTube,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.ПосиланняНаНаявніЛоти КАК НоменклатураПосиланняНаНаявніЛоти,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Родитель КАК НоменклатураРодитель,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Родитель.Родитель КАК НоменклатураРодительРодитель,
		|	ВЫБОР
		|		КОГДА ЦіниАкційні.Цена <> ЦеныНоменклатурыСрезПоследних.Цена
		|			ТОГДА ЦіниАкційні.Цена
		|		ИНАЧЕ 0
		|	КОНЕЦ КАК Акція,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Наименование КАК НоменклатураНаименование,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Родитель.Сортировка КАК НоменклатураРодительСортировка,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.Родитель.Родитель.Сортировка КАК НоменклатураРодительРодительСортировка,
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура.ЭтоГруппа КАК ЭтоГруппа
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|			&ТекущаяДата,
		|			НЕ Номенклатура.ПометкаУдаления
		|				И Номенклатура В ИЕРАРХИИ (&СписокГруп)
		|				И ТипЦен = &ТипЦен) КАК ЦеныНоменклатурыСрезПоследних
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
		|				&ТекущаяДата,
		|				НЕ Номенклатура.ПометкаУдаления
		|					И Номенклатура В ИЕРАРХИИ (&СписокГруп)
		|					И ТипЦен = &ТипЦенАкційний) КАК ЦіниАкційні
		|		ПО ЦеныНоменклатурыСрезПоследних.Номенклатура = ЦіниАкційні.Номенклатура
		|			И ЦеныНоменклатурыСрезПоследних.ХарактеристикаНоменклатуры = ЦіниАкційні.ХарактеристикаНоменклатуры
		|
		|УПОРЯДОЧИТЬ ПО
		|	НоменклатураРодительРодительСортировка,
		|	НоменклатураРодительСортировка,
		|	НоменклатураНаименование
		|ИТОГИ ПО
		|	НоменклатураРодитель";
	Запрос.УстановитьПараметр("ТипЦен", Справочники.ТипыЦенНоменклатуры.ЦенаПродажиВес);
	Запрос.УстановитьПараметр("ТипЦенАкційний", Справочники.ТипыЦенНоменклатуры.ПродажБезАкций);
	Запрос.УстановитьПараметр("ТекущаяДата", ТекущаяДата());
	Запрос.УстановитьПараметр("СписокГруп", СписокГруп);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ОбластьЗаголовок = Макет.ПолучитьОбласть("Заголовок");
	ОбластьПодвал = Макет.ПолучитьОбласть("Подвал");
	ОбластьШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы");
	ОбластьПодвалТаблицы = Макет.ПолучитьОбласть("ПодвалТаблицы");
	ОбластьНоменклатураРодитель = Макет.ПолучитьОбласть("НоменклатураРодитель");
	ОбластьДетальныхЗаписей = Макет.ПолучитьОбласть("Детали");
    ОбластьНоменклатураРодительРодитель = Макет.ПолучитьОбласть("НоменклатураРодительРодитель");
	ОбластьВложенаГрупа = Макет.ПолучитьОбласть("ВложенаГрупа");
	
	ТабДок.Очистить();
	ТабДок.Вывести(ОбластьЗаголовок);
	ТабДок.Вывести(ОбластьШапкаТаблицы);
	ТабДок.НачатьАвтогруппировкуСтрок();
	
	ВыборкаНоменклатураРодитель = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкамСИерархией);
	НомТЗ = РезультатЗапроса.Выгрузить();
	
	ТЗНоменклатураРодительРодитель = РезультатЗапроса.Выгрузить();
	ТЗНоменклатураРодительРодитель.Свернуть("НоменклатураРодительРодитель");
	
	//Для Каждого Строка ИЗ ТЗНоменклатураРодительРодитель Цикл 
	//	Если Не Строка.НоменклатураРодительРодитель.Уровень() = 0 Тогда
	//		Продолжить;
	//	КонецЕсли;
