		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	ЗакупкиОбороты.Контрагент,
	ЗакупкиОбороты.Номенклатура,
	ЗакупкиОбороты.Номенклатура.Артикул КАК Артикул,
	ПоступлениеТоваровУслугТовары.ЦенаЗакупкиВес КАК ЦенаЗакупкиКг,
	ЗакупкиОбороты.Регистратор КАК Регистратор
ИЗ
	(ВЫБРАТЬ
		ЗакупкиОбороты.Контрагент КАК Контрагент,
		ЗакупкиОбороты.Номенклатура КАК Номенклатура,
		МАКСИМУМ(ЗакупкиОбороты.Регистратор.Дата) КАК РегистраторДата
	ИЗ
		РегистрНакопления.Закупки.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Запись, ) КАК ЗакупкиОбороты
	
	СГРУППИРОВАТЬ ПО
		ЗакупкиОбороты.Контрагент,
		ЗакупкиОбороты.Номенклатура) КАК ВложенныйЗапрос
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрНакопления.Закупки.Обороты(&amp;НачалоПериода, &amp;КонецПериода, Запись, ) КАК ЗакупкиОбороты
			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
			ПО ЗакупкиОбороты.Регистратор = ПоступлениеТоваровУслугТовары.Ссылка
				И ЗакупкиОбороты.Номенклатура = ПоступлениеТоваровУслугТовары.Номенклатура
				И ЗакупкиОбороты.ХарактеристикаНоменклатуры = ПоступлениеТоваровУслугТовары.ХарактеристикаНоменклатуры
		ПО ВложенныйЗапрос.Контрагент = ЗакупкиОбороты.Контрагент
			И ВложенныйЗапрос.Номенклатура = ЗакупкиОбороты.Номенклатура
			И ВложенныйЗапрос.РегистраторДата = ЗакупкиОбороты.Регистратор.Дата

СГРУППИРОВАТЬ ПО
	ЗакупкиОбороты.Контрагент,
	ЗакупкиОбороты.Номенклатура,
	ЗакупкиОбороты.Номенклатура.Артикул,
	ПоступлениеТоваровУслугТовары.ЦенаЗакупкиВес,
	ЗакупкиОбороты.Регистратор

ОБЪЕДИНИТЬ ВСЕ

ВЫБРАТЬ
	"Перепаковка",
	ПерепаковкаУпаковка.Номенклатура,
	ПерепаковкаУпаковка.Номенклатура.Артикул,
	ПерепаковкаУпаковка.ЦенаЗакупкиВес,
	ПерепаковкаУпаковка.Ссылка
ИЗ
	(ВЫБРАТЬ
		ПерепаковкаУпаковка.Номенклатура КАК Номенклатура,
		МАКСИМУМ(ПерепаковкаУпаковка.Ссылка.Дата) КАК Дата
	ИЗ
		Документ.Перепаковка.Упаковка КАК ПерепаковкаУпаковка
	ГДЕ
		ПерепаковкаУпаковка.Ссылка.Проведен = ИСТИНА
		И ПерепаковкаУпаковка.Ссылка.Дата МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода
	
	СГРУППИРОВАТЬ ПО
		ПерепаковкаУпаковка.Номенклатура) КАК ВложенныйЗапрос
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.Перепаковка.Упаковка КАК ПерепаковкаУпаковка
		ПО ВложенныйЗапрос.Номенклатура = ПерепаковкаУпаковка.Номенклатура
			И ВложенныйЗапрос.Дата = ПерепаковкаУпаковка.Ссылка.Дата
ГДЕ
	ПерепаковкаУпаковка.Ссылка.Проведен = ИСТИНА
	И ПерепаковкаУпаковка.Ссылка.Дата МЕЖДУ &amp;НачалоПериода И &amp;КонецПериода

СГРУППИРОВАТЬ ПО
	ПерепаковкаУпаковка.Номенклатура,
	ПерепаковкаУпаковка.Номенклатура.Артикул,
	ПерепаковкаУпаковка.ЦенаЗакупкиВес,
	ПерепаковкаУпаковка.Ссылка</query>
