generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Categories (self-relation: category → subcategory) ─────────────────────

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  parentId  String?  @map("parent_id")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products Product[]

  @@index([parentId])
  @@map("categories")
}

// ─── Products (← 1С Номенклатура) ───────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  code1C        String?  @unique @map("code_1c")
  articleCode   String?  @map("article_code")
  name          String
  slug          String   @unique
  categoryId    String   @map("category_id")
  description   String   @default("")
  quality       String
  season        String   @default("")
  country       String
  priceUnit     String   @default("kg") @map("price_unit")
  averageWeight Float?   @map("average_weight")
  videoUrl      String?  @map("video_url")
  inStock       Boolean  @default(true) @map("in_stock")
  gender        String?
  sizes         String?
  unitsPerKg    String?  @map("units_per_kg")
  unitsPerKgMin Float?   @map("units_per_kg_min")
  unitsPerKgMax Float?   @map("units_per_kg_max")
  unitWeight    String?  @map("unit_weight")
  unitWeightMin Float?   @map("unit_weight_min")
  unitWeightMax Float?   @map("unit_weight_max")
  isOversize    Boolean  @default(false) @map("is_oversize")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category           Category            @relation(fields: [categoryId], references: [id])
  images             ProductImage[]
  lots               Lot[]
  prices             Price[]
  orderItems         OrderItem[]
  cartItems          CartItem[]
  videoSubscriptions VideoSubscription[]
  favorites          Favorite[]
  featuredEntry      FeaturedProduct?
  viewLog            ViewLog[]

  @@index([categoryId])
  @@index([quality])
  @@index([inStock])
  @@index([articleCode])
  @@index([unitsPerKgMin])
  @@index([unitsPerKgMax])
  @@index([unitWeightMin])
  @@index([unitWeightMax])
  @@index([isOversize])
  @@map("products")
}

// ─── Product Images (← 1С зображення номенклатури) ──────────────────────────

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  alt       String   @default("")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ─── Lots / Bags (← 1С Серії + ТовариНаСкладах) ────────────────────────────

model Lot {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  barcode   String   @unique
  weight    Float
  quantity  Int      @default(1)
  status    String   @default("free")
  priceEur  Float    @map("price_eur")
  videoUrl  String?  @map("video_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product    Product     @relation(fields: [productId], references: [id])
  barcodes   Barcode[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([productId])
  @@index([status])
  @@map("lots")
}

// ─── Barcodes (← 1С ШтрихКоди) ─────────────────────────────────────────────

model Barcode {
  id    String @id @default(cuid())
  lotId String @map("lot_id")
  code  String @unique
  type  String @default("EAN13")

  lot Lot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([lotId])
  @@map("barcodes")
}

// ─── Prices (← 1С ЦіниНоменклатури) ────────────────────────────────────────

model Price {
  id        String    @id @default(cuid())
  productId String    @map("product_id")
  priceType String    @map("price_type")
  currency  String    @default("EUR")
  amount    Float
  validFrom DateTime  @default(now()) @map("valid_from")
  validTo   DateTime? @map("valid_to")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, priceType])
  @@map("prices")
}

// ─── Customers (← 1С Контрагенти) ──────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  code1C    String?  @unique @map("code_1c")
  name      String
  phone     String?
  email     String?
  telegram  String?
  city      String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders             Order[]
  cart               Cart?
  chatMessages       ChatMessage[]
  videoSubscriptions VideoSubscription[]
  pushTokens         PushToken[]
  favorites          Favorite[]
  notifications      Notification[]
  viewLog            ViewLog[]

  @@map("customers")
}

// ─── Orders (← 1С ЗаказПокупателя) ─────────────────────────────────────────

model Order {
  id           String   @id @default(cuid())
  code1C       String?  @unique @map("code_1c")
  customerId   String   @map("customer_id")
  status       String   @default("draft")
  totalEur     Float    @default(0) @map("total_eur")
  totalUah     Float    @default(0) @map("total_uah")
  exchangeRate Float    @default(0) @map("exchange_rate")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer  Customer    @relation(fields: [customerId], references: [id])
  items     OrderItem[]
  shipments Shipment[]
  payments  Payment[]

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

// ─── Order Items (← табличні секції документів) ─────────────────────────────

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  lotId     String? @map("lot_id")
  productId String  @map("product_id")
  priceEur  Float   @map("price_eur")
  weight    Float
  quantity  Int     @default(1)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lot     Lot?    @relation(fields: [lotId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── Exchange Rates (← 1С КурсиВалют) ──────────────────────────────────────

model ExchangeRate {
  id           String   @id @default(cuid())
  currencyFrom String   @map("currency_from")
  currencyTo   String   @map("currency_to")
  rate         Float
  date         DateTime @default(now())
  source       String   @default("1c")

  @@unique([currencyFrom, currencyTo, date])
  @@map("exchange_rates")
}

// ─── Carts (server-side cart persistence) ───────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  customerId String?  @unique @map("customer_id")
  sessionId  String?  @unique @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String  @map("cart_id")
  lotId     String? @map("lot_id")
  productId String  @map("product_id")
  priceEur  Float   @map("price_eur")
  weight    Float
  quantity  Int     @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  lot     Lot?    @relation(fields: [lotId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([cartId])
  @@map("cart_items")
}

// ─── Chat Messages (customer ↔ manager) ────────────────────────────────────

model ChatMessage {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  sender     String // "customer" | "manager"
  text       String
  imageUrl   String?  @map("image_url")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("chat_messages")
}

// ─── Shipment Tracking (Nova Poshta) ────────────────────────────────────────

model Shipment {
  id              String    @id @default(cuid())
  orderId         String    @map("order_id")
  trackingNumber  String    @map("tracking_number")
  carrier         String    @default("nova_poshta")
  status          String    @default("created")
  statusText      String?   @map("status_text")
  estimatedDate   DateTime? @map("estimated_date")
  recipientCity   String?   @map("recipient_city")
  recipientBranch String?   @map("recipient_branch")
  lastCheckedAt   DateTime? @map("last_checked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, trackingNumber])
  @@index([trackingNumber])
  @@map("shipments")
}

// ─── Video Review Subscriptions ─────────────────────────────────────────────

model VideoSubscription {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("video_subscriptions")
}

// ─── In-app notifications feed (S36) ───────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  customerId String    @map("customer_id")
  type       String // "order_status" | "new_video" | "chat_message" | "system"
  title      String
  body       String
  payload    Json?
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([customerId, readAt])
  @@map("notifications")
}

// ─── Push Notification Tokens ───────────────────────────────────────────────

model PushToken {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  token      String   @unique
  platform   String // "ios" | "android" | "web"
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("push_tokens")
}

// ─── Payments ───────────────────────────────────────────────────────────────

model Payment {
  id         String    @id @default(cuid())
  orderId    String    @map("order_id")
  method     String // "cash" | "card" | "bank_transfer" | "online"
  amount     Float
  currency   String    @default("UAH")
  status     String    @default("pending") // pending | completed | failed | refunded
  externalId String?   @map("external_id") // payment gateway ID
  paidAt     DateTime? @map("paid_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([externalId])
  @@map("payments")
}

// ─── Favorites (wishlists) ──────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("favorites")
}

// ─── Sync Log (tracking 1C sync operations) ────────────────────────────────

model SyncLog {
  id       String   @id @default(cuid())
  entity   String
  entityId String?  @map("entity_id")
  action   String
  payload  Json?
  syncedAt DateTime @default(now()) @map("synced_at")

  @@index([entity, entityId])
  @@index([syncedAt])
  @@map("sync_log")
}

// ─── Featured Products (homepage "Топ товарів", admin-curated) ──────────────

model FeaturedProduct {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  position  Int      @default(0)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([position])
  @@map("featured_products")
}

// ─── Banners (homepage carousel, admin-managed) ─────────────────────────────

model Banner {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  imageUrl  String
  ctaLabel  String?
  ctaHref   String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, position])
  @@map("banners")
}

// ─── Newsletter Subscribers (footer signup) ─────────────────────────────────

model NewsletterSubscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  phone          String?
  subscribedAt   DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  source         String?
  confirmedAt    DateTime? @map("confirmed_at")

  @@index([subscribedAt])
  @@map("newsletter_subscribers")
}

// ─── Promo Stripe (sticky "Гаряча пропозиція" banner, single-row) ──────────

model PromoStripe {
  id        String   @id @default(cuid())
  text      String
  ctaLabel  String?
  ctaHref   String?
  bgColor   String   @default("#dc2626")
  textColor String   @default("#ffffff")
  isActive  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("promo_stripe")
}

// ─── Product View Log (recommendations + analytics) ──────────────────────────

model ViewLog {
  id         String   @id @default(cuid())
  customerId String?  @map("customer_id")
  productId  String   @map("product_id")
  source     String   @default("unknown") // "home" | "catalog" | "search" | "product_detail" | "unknown"
  viewedAt   DateTime @default(now()) @map("viewed_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerId, viewedAt])
  @@index([productId, viewedAt])
  @@map("view_log")
}

// ─── Manager Workstation users (M1.1) ──────────────────────────────────────

enum UserRole {
  manager
  senior_manager
  admin
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole @default(manager)
  isActive     Boolean  @default(true) @map("is_active")

  // 1C bridge (manager-specific, null для non-manager-окремих accounts)
  code1C        String? @unique @map("code_1c")
  warehouseId1C String? @map("warehouse_id_1c")

  // Telegram bot bridge
  telegramChatId    String?  @unique @map("telegram_chat_id")
  telegramLinkToken String?  @unique @map("telegram_link_token")
  notifyChannels    String[] @default([]) @map("notify_channels")

  // Audit
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastSeenAt  DateTime? @map("last_seen_at")
  lastLoginIp String?   @map("last_login_ip")

  // Lockout
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until")

  refreshTokens    UserRefreshToken[]
  passwordResets   PasswordResetToken[]
  assignedClients  ClientAssignment[]
  timelineComments MgrClientTimelineEntry[]

  @@map("users")
}

model UserRefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("user_refresh_tokens")
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  isInvite    Boolean   @default(false) @map("is_invite")
  requestedIp String?   @map("requested_ip")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("password_reset_tokens")
}

model ClientAssignment {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  customerId String   @map("customer_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client MgrClient @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([userId, customerId])
  @@index([customerId])
  @@map("client_assignments")
}

// ─── Manager Clients (M1.3a) ───────────────────────────────────────────────
// Snapshot з 1С `Справочник.Контрагенты` (див. docs/1c-export-mobile/Central/Catalogs/Контрагенты.xml).
// Реальний SOAP-sync з'явиться у M1.5+; зараз — seed-скрипт з фейковими даними.

model MgrClientStatus {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  colorHex  String @map("color_hex")
  sortOrder Int    @default(0) @map("sort_order")

  clientsGeneral     MgrClient[] @relation("MgrClientStatusGeneral")
  clientsOperational MgrClient[] @relation("MgrClientStatusOperational")

  @@map("mgr_client_statuses")
}

model MgrSearchChannel {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")

  clients MgrClient[]

  @@map("mgr_search_channels")
}

model MgrCategoryTT {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")

  clients MgrClient[]

  @@map("mgr_categories_tt")
}

model MgrDeliveryMethod {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")

  clients MgrClient[]

  @@map("mgr_delivery_methods")
}

model MgrAssortmentCode {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")

  clients MgrClient[]

  @@map("mgr_assortment_codes")
}

model MgrRoute {
  id        String   @id @default(cuid())
  code1C    String?  @unique @map("code_1c")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  primaryForClients MgrClient[]                @relation("MgrClientPrimaryRoute")
  assignments       MgrClientRouteAssignment[]

  @@map("mgr_routes")
}

model MgrClient {
  id               String    @id @default(cuid())
  code1C           String?   @unique @map("code_1c")
  uid1C            String?   @unique @map("uid_1c")
  name             String
  phonePrimary     String?   @map("phone_primary")
  city             String?
  region           String?
  street           String?
  house            String?
  novaPoshtaBranch String?   @map("nova_poshta_branch")
  geolocation      String?
  websiteUrl       String?   @map("website_url")
  monthlyVolume    Decimal?  @map("monthly_volume") @db.Decimal(10, 2)
  licenseExpiresAt DateTime? @map("license_expires_at")
  isOwn            Boolean   @default(false) @map("is_own")
  notDirectInput   Boolean   @default(false) @map("not_direct_input")

  debt                  Decimal   @default(0) @db.Decimal(12, 2)
  overdueDebt           Decimal   @default(0) @map("overdue_debt") @db.Decimal(12, 2)
  daysSinceLastPurchase Int?      @map("days_since_last_purchase")
  lastPurchaseAt        DateTime? @map("last_purchase_at")

  statusGeneralId     String? @map("status_general_id")
  statusOperationalId String? @map("status_operational_id")
  searchChannelId     String? @map("search_channel_id")
  categoryTTId        String? @map("category_tt_id")
  deliveryMethodId    String? @map("delivery_method_id")
  primaryRouteId      String? @map("primary_route_id")
  primaryAssortmentId String? @map("primary_assortment_id")

  statusGeneral     MgrClientStatus?   @relation("MgrClientStatusGeneral", fields: [statusGeneralId], references: [id])
  statusOperational MgrClientStatus?   @relation("MgrClientStatusOperational", fields: [statusOperationalId], references: [id])
  searchChannel     MgrSearchChannel?  @relation(fields: [searchChannelId], references: [id])
  categoryTT        MgrCategoryTT?     @relation(fields: [categoryTTId], references: [id])
  deliveryMethod    MgrDeliveryMethod? @relation(fields: [deliveryMethodId], references: [id])
  primaryRoute      MgrRoute?          @relation("MgrClientPrimaryRoute", fields: [primaryRouteId], references: [id])
  primaryAssortment MgrAssortmentCode? @relation(fields: [primaryAssortmentId], references: [id])

  hasNewMessage Boolean @default(false) @map("has_new_message")
  isViberLinked Boolean @default(false) @map("is_viber_linked")
  dialogStatus  String? @map("dialog_status")

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastSyncedAt DateTime? @map("last_synced_at")

  phones          MgrClientPhone[]
  warehouses      MgrClientWarehouse[]
  routes          MgrClientRouteAssignment[]
  messengers      MgrClientMessenger[]
  assortmentItems MgrClientAssortmentItem[]
  timeline        MgrClientTimelineEntry[]
  assignments     ClientAssignment[]

  @@index([statusGeneralId])
  @@index([searchChannelId])
  @@index([region])
  @@index([phonePrimary])
  @@index([name])
  @@map("mgr_clients")
}

model MgrClientPhone {
  id        String  @id @default(cuid())
  clientId  String  @map("client_id")
  phone     String
  label     String?
  messenger String?
  sortOrder Int     @default(0) @map("sort_order")

  client MgrClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([clientId])
  @@map("mgr_client_phones")
}

model MgrClientMessenger {
  id       String  @id @default(cuid())
  clientId String  @map("client_id")
  network  String
  handle   String
  url      String?
  comment  String?

  client MgrClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("mgr_client_messengers")
}

model MgrClientWarehouse {
  id               String    @id @default(cuid())
  clientId         String    @map("client_id")
  code1C           String?   @map("code_1c")
  name             String
  city             String?
  region           String?
  novaPoshtaBranch String?   @map("nova_poshta_branch")
  licenseExpiresAt DateTime? @map("license_expires_at")
  comment          String?

  client MgrClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("mgr_client_warehouses")
}

model MgrClientRouteAssignment {
  id        String @id @default(cuid())
  clientId  String @map("client_id")
  routeId   String @map("route_id")
  sortOrder Int    @default(0) @map("sort_order")

  client MgrClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  route  MgrRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([clientId, routeId])
  @@index([routeId])
  @@map("mgr_client_route_assignments")
}

model MgrClientAssortmentItem {
  id            String    @id @default(cuid())
  clientId      String    @map("client_id")
  productCode   String    @map("product_code")
  productName   String?   @map("product_name")
  lastOrderedAt DateTime? @map("last_ordered_at")

  client MgrClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("mgr_client_assortment")
}

model MgrClientTimelineEntry {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  kind         String
  body         String   @db.Text
  occurredAt   DateTime @map("occurred_at")
  authorUserId String?  @map("author_user_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  client MgrClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User?     @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([clientId, occurredAt(sort: Desc)])
  @@map("mgr_client_timeline")
}

// ─── Email DLQ (persistent retry queue, Session 70) ─────────────────────────

model EmailJob {
  id            String    @id @default(cuid())
  to            String    @map("to_address")
  subject       String
  htmlBody      String    @map("html_body")
  textBody      String?   @map("text_body")
  source        String
  referenceId   String?   @map("reference_id")
  status        String    @default("pending")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5) @map("max_attempts")
  nextAttemptAt DateTime  @default(now()) @map("next_attempt_at")
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  sentAt        DateTime? @map("sent_at")

  @@index([status, nextAttemptAt])
  @@index([source, createdAt])
  @@map("email_jobs")
}
