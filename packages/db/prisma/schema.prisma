  notDirectInput   Boolean   @default(false) @map("not_direct_input")

  // ─── ТЗ 8.0 — «позначка на вилучення» (soft-delete у стилі 1С) ─────────────
  // markedForDeletion — кандидат на видалення, чекає рішення адміна (зникає з
  // робочих списків менеджера, зʼявляється у черзі /manager/admin/deletions).
  // archived — остаточно приховано назавжди (коли фіз. стерти не можна через
  // звʼязки/1С-історію); дані збережені, можна відновити. Деталі — DeletionRequest.
  markedForDeletion Boolean @default(false) @map("marked_for_deletion")
  archived          Boolean @default(false)

  debt                  Decimal   @default(0) @db.Decimal(12, 2)
  overdueDebt           Decimal   @default(0) @map("overdue_debt") @db.Decimal(12, 2)
  daysSinceLastPurchase Int?      @map("days_since_last_purchase")
  lastPurchaseAt        DateTime? @map("last_purchase_at")

  statusGeneralId     String? @map("status_general_id")
  statusOperationalId String? @map("status_operational_id")
  searchChannelId     String? @map("search_channel_id")
  categoryTTId        String? @map("category_tt_id")
  deliveryMethodId    String? @map("delivery_method_id")
  primaryRouteId      String? @map("primary_route_id")
  primaryAssortmentId String? @map("primary_assortment_id")

  statusGeneral     MgrClientStatus?   @relation("MgrClientStatusGeneral", fields: [statusGeneralId], references: [id])
  statusOperational MgrClientStatus?   @relation("MgrClientStatusOperational", fields: [statusOperationalId], references: [id])
  searchChannel     MgrSearchChannel?  @relation(fields: [searchChannelId], references: [id])
  categoryTT        MgrCategoryTT?     @relation(fields: [categoryTTId], references: [id])
  deliveryMethod    MgrDeliveryMethod? @relation(fields: [deliveryMethodId], references: [id])
  primaryRoute      MgrRoute?          @relation("MgrClientPrimaryRoute", fields: [primaryRouteId], references: [id])
  primaryAssortment MgrAssortmentCode? @relation(fields: [primaryAssortmentId], references: [id])

  hasNewMessage Boolean @default(false) @map("has_new_message")
  isViberLinked Boolean @default(false) @map("is_viber_linked")
  dialogStatus  String? @map("dialog_status")

  // Картка клієнта — Фаза 3: ключові слова (теги через кому) для пошуку/фільтра
  // у списку клієнтів. Вільний текст, керується вручну менеджером.
  keywords String? @map("keywords")

  // ─── 5.4.0 — паритет з 1С (Catalog.Контрагенты) ───────────────────────────
  email                 String? @map("email")
  legalType             String? @map("legal_type")
  inn                   String? @map("inn")
  edrpou                String? @map("edrpou")
  fullName              String? @map("full_name")
  comment               String? @map("comment")
  additionalDescription String? @map("additional_description")
  workingHours          String? @map("working_hours")
  parentCode1C          String? @map("parent_code_1c")

  // ─── M1.3c additions (full 1С parity) ─────────────────────────────────────
  tradePointName   String?  @map("trade_point_name")
  tovDebt          Decimal? @map("tov_debt") @db.Decimal(12, 2)
  tovOverdueDebt   Decimal? @map("tov_overdue_debt") @db.Decimal(12, 2)
  agentUserId      String?  @map("agent_user_id")
  viberContact     String?  @map("viber_contact")
  sessionRemainder Decimal? @map("session_remainder") @db.Decimal(12, 2)
  priceTypeId      String?  @map("price_type_id")

  agent     User?         @relation("ClientAgent", fields: [agentUserId], references: [id], onDelete: SetNull)
  priceType MgrPriceType? @relation(fields: [priceTypeId], references: [id], onDelete: SetNull)

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastSyncedAt DateTime? @map("last_synced_at")

  phones            MgrClientPhone[]
  warehouses        MgrClientWarehouse[]
  routes            MgrClientRouteAssignment[]
  messengers        MgrClientMessenger[]
  assortmentItems   MgrClientAssortmentItem[]
  presentations     MgrClientPresentationItem[]
  bankAccounts      MgrClientBankAccount[]
  contacts          MgrClientContact[]
  reminders         MgrReminder[]
  timeline          MgrClientTimelineEntry[]
  debtMovements     MgrDebtMovement[]
