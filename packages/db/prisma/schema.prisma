// ─── Reminders (← 1С Catalog.Нагадування + own private extras) ─────────────
// Етап 1 (блок «Нагадування», M3.0): clientId став опційним (звичайне
// нагадування може бути без клієнта), додано періодичність + прапорці + плоскі
// скаляри lotId/productId для майбутніх авто-дій (без relations, як у Маршрутному
// листі). Тип «Для товарів» (isProductReminder + items[]) — каркас на пізніший
// етап; у Етапі 1 завжди false/порожній.
// ─── Ліди з сайту (7.2 Блок 2 доповнення) ──────────────────────────────────
// Реєстрація на сайті створює ЛІД (не повноцінного клієнта). Менеджер бачить
// їх окремою вкладкою в «Клієнтах» і після контакту / при замовленні конвертує
// у MgrClient (повноцінна картка).
model MgrLead {
  id                String   @id @default(cuid())
  name              String
  phone             String?
  // phoneKey — DB-generated (останні 9 цифр `phone`). Read-only з коду.
  phoneKey          String?  @map("phone_key")
  city              String?
  region            String?
  // Менеджер, підвʼязаний за областю (мапа MgrRegionAgent) уже при реєстрації.
  agentUserId       String?  @map("agent_user_id")
  source            String   @default("site")
  // new | contacted | converted | rejected
  status            String   @default("new")
  note              String?  @db.Text
  convertedClientId String?  @map("converted_client_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  agent User? @relation("LeadAgent", fields: [agentUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([phone])
  @@index([phoneKey])
  @@index([agentUserId])
  @@map("mgr_leads")
}

