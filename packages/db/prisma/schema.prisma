  notes           String?
  createdByUserId String?   @map("created_by_user_id")
  postedAt        DateTime? @map("posted_at")
  postedByUserId  String?   @map("posted_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  items InventoryItem[]
  logs  InventoryLog[]

  @@index([status])
  @@index([docDate(sort: Desc)])
  @@map("mgr_inventories")
}

model InventoryItem {
  id            String   @id @default(cuid())
  inventoryId   String   @map("inventory_id")
  productId     String?  @map("product_id")
  charHex       String?  @map("char_hex")
  barcode       String?
  // ── Інвентаризація по мішках (2026-07-12) — знімок мішка на момент звірки.
  //    Плоскі скаляри (як RepackingItem): БЕЗ FK на Lot, щоб не зав'язувати
  //    менеджерський документ на життєвий цикл лота (лот може стати sold/архів).
  //    lotId — м'яке посилання для follow-up документів (списання нестач /
  //    оприбуткування надлишків «на підставі інвентаризації»).
  lotId         String?  @map("lot_id")
  productName   String?  @map("product_name")
  articleCode   String?  @map("article_code")
  weight        Float    @default(0)
  sector        String?
  sectorId      String?  @map("sector_id")
  unitName      String?  @map("unit_name")
  quality       String?
  qtyAccounting Float    @default(0) @map("qty_accounting")
  qtyActual     Float    @default(0) @map("qty_actual")
  qtyDifference Float    @default(0) @map("qty_difference")
  priceEur      Decimal  @default(0) @map("price_eur") @db.Decimal(12, 2)
  notes         String?
  // ── Спільна робота (хто/коли підтвердив факт) ──
  foundByUserId String?  @map("found_by_user_id")
  foundByName   String?  @map("found_by_name")
  foundAt       DateTime? @map("found_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  document Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId])
  @@index([inventoryId, barcode])
  @@map("mgr_inventory_items")
}

/**
 * Журнал змін документа інвентаризації («папка з логами» по документу).
 * Кожна дія (заповнення / скан / зміна сектора / видалення / проведення)
 * пише запис — щоб відстежити зміни й виправити, якщо щось пішло не так,
 * зокрема при спільній роботі кількох користувачів.
 */
model InventoryLog {
  id          String   @id @default(cuid())
  inventoryId String   @map("inventory_id")
  userId      String?  @map("user_id")
  userName    String?  @map("user_name")
  action      String
  message     String
  barcode     String?
  createdAt   DateTime @default(now()) @map("created_at")

  document Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([inventoryId, createdAt])
  @@map("mgr_inventory_logs")
}

model StockTransfer {
  id              String    @id @default(cuid())
  code1C          String?   @unique @map("code_1c")
  number1C        String?   @map("number_1c")
  docNumber       String    @unique @map("doc_number")
  docDate         DateTime  @default(now()) @map("doc_date")
  fromWarehouseId String?   @map("from_warehouse_id")
  toWarehouseId   String?   @map("to_warehouse_id")
  status          String    @default("draft")
  totalWeight     Float     @default(0) @map("total_weight")
  totalQuantity   Int       @default(0) @map("total_quantity")
  notes           String?
  createdByUserId String?   @map("created_by_user_id")
  postedAt        DateTime? @map("posted_at")
  postedByUserId  String?   @map("posted_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  items StockTransferItem[]

  @@index([status])
  @@index([docDate(sort: Desc)])
  @@map("mgr_stock_transfers")
}

model StockTransferItem {
  id         String   @id @default(cuid())
  transferId String   @map("transfer_id")
  productId  String?  @map("product_id")
  charHex    String?  @map("char_hex")
  barcode    String?
  weight     Float    @default(0)
  quantity   Int      @default(1)
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  document StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@map("mgr_stock_transfer_items")
}

// ─── Журнал злиттів дублікатів номенклатури (Сесія 7.1) ─────────────────────
// 1С-номенклатура містить дублікати одного артикула (старий запис з історією +
// новий актуальний, різні code1C). Скрипт `merge-duplicate-products.ts` зливає
// історію на актуальний (survivor) і видаляє старий Product. Цей запис —
// (а) журнал, (б) мапа для імпортера: майбутні реімпорти по старому code1C
// НЕ відтворюють видалений товар, а маршрутизуються на survivor.
model ProductMerge {
  id              String   @id @default(cuid())
  // hex(_IDRRef) старого (видаленого) 1С-товару — унікальний ключ мапи.
  oldCode1C       String   @unique @map("old_code_1c")
  // Товар-survivor, на який перенесено історію.
  targetProductId String   @map("target_product_id")
  // Назва старого товару на момент злиття (для аудиту).
  oldName         String   @map("old_name")
  mergedAt        DateTime @default(now()) @map("merged_at")

  target Product @relation("ProductMergeTarget", fields: [targetProductId], references: [id], onDelete: Restrict)

  @@index([targetProductId])
  @@map("product_merges")
}

// ═══════════════════════════════════════════════════════════════════════════
// ВНУТРІШНІЙ КОРПОРАТИВНИЙ МЕСЕНДЖЕР (2026-07-11)
// Спілкування співробітників (User) між собою — окреме від клієнтського
// чат-inbox (ChatConversation). План: docs/INTERNAL_MESSENGER_PLAN.md.
// Етап 1: особисті чати 1-на-1 + текст + «прочитано».
// Поля kind/editedAt/deletedAt (Message) і role/leftAt (Member) додані наперед
// під Етапи 2-3 (групи, редагування/видалення), щоб не плодити міграції.
// ═══════════════════════════════════════════════════════════════════════════

enum MessengerConversationType {
  direct
  group

  @@map("messenger_conversation_type")
}

enum MessengerMemberRole {
  member
  admin

  @@map("messenger_member_role")
}

enum MessengerMessageKind {
  text
  system

  @@map("messenger_message_kind")
}

enum MessengerAttachmentKind {
  image
  file

  @@map("messenger_attachment_kind")
}

// Розмова: direct (1-на-1) або group. Для direct — детермінований `directKey`
// (відсортована пара user.id через ":") гарантує один чат на пару людей.
model MessengerConversation {
  id            String                    @id @default(cuid())
  type          MessengerConversationType @default(direct)
  title         String? // назва групи (для group; direct — null, показуємо ім'я співрозмовника)
  directKey     String?                   @unique @map("direct_key")
  createdById   String?                   @map("created_by_id")
  lastMessageAt DateTime                  @default(now()) @map("last_message_at")
  createdAt     DateTime                  @default(now()) @map("created_at")
  updatedAt     DateTime                  @updatedAt @map("updated_at")

  createdBy User?              @relation("MessengerConversationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members   MessengerMember[]
  messages  MessengerMessage[]

  @@index([lastMessageAt(sort: Desc)])
  @@map("mgr_messenger_conversations")
}

// Учасник розмови. `lastReadAt` — межа прочитаного (непрочитані = повідомлення
// інших авторів після цієї мітки). `leftAt` — вихід із групи (Етап 2).
model MessengerMember {
  id             String              @id @default(cuid())
  conversationId String              @map("conversation_id")
  userId         String              @map("user_id")
  role           MessengerMemberRole @default(member)
  lastReadAt     DateTime?           @map("last_read_at")
  joinedAt       DateTime            @default(now()) @map("joined_at")
  leftAt         DateTime?           @map("left_at")

  conversation MessengerConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User                  @relation("MessengerMembership", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("mgr_messenger_members")
}

// Повідомлення. `deletedAt` — м'яке видалення (зникає у співрозмовників, owner
// бачить в архіві). `editedAt` — позначка «змінено». `kind=system` — службові
// записи («X додав Y») для Етапу 2.
model MessengerMessage {
  id             String               @id @default(cuid())
  conversationId String               @map("conversation_id")
  authorId       String?              @map("author_id")
  kind           MessengerMessageKind @default(text)
  text           String
  replyToId      String?              @map("reply_to_id")
  forwardedFrom  String?              @map("forwarded_from")
  docRef         Json?                @map("doc_ref")
  pinnedAt       DateTime?            @map("pinned_at")
  editedAt       DateTime?            @map("edited_at")
  deletedAt      DateTime?            @map("deleted_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  conversation MessengerConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User?                 @relation("MessengerMessageAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  replyTo      MessengerMessage?     @relation("MessengerReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      MessengerMessage[]    @relation("MessengerReply")
  attachments  MessengerAttachment[]
  reactions    MessengerReaction[]

  @@index([conversationId, createdAt])
  @@map("mgr_messenger_messages")
}

// Реакції-emoji на повідомлення (Етап 5). Один запис = одна реакція одного
// користувача. Унікальність (messageId, userId, emoji) не дає дублів.
model MessengerReaction {
  id        String   @id @default(cuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message MessengerMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation("MessengerReactionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("mgr_messenger_reactions")
}

// Вкладення повідомлення (Етап 4): фото (image) або файл (PDF/Excel/…).
// Файли зберігаються self-hosted через lib/media/storage.ts.
model MessengerAttachment {
  id        String                  @id @default(cuid())
  messageId String                  @map("message_id")
  kind      MessengerAttachmentKind
  url       String
  name      String
  mimeType  String                  @map("mime_type")
  sizeBytes Int                     @map("size_bytes")
  width     Int?
  height    Int?
  createdAt DateTime                @default(now()) @map("created_at")

  message MessengerMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("mgr_messenger_attachments")
}
