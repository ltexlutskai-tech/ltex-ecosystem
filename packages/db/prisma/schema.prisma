  reservedClientId    String?   @map("reserved_client_id")
  reservedUntil       DateTime? @map("reserved_until")
  sector              String?
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([lotId])
  @@index([barcode])
  @@index([recorderDocId])
  @@index([occurredAt(sort: Desc)])
  @@map("lot_state_history")
}

