generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Categories (self-relation: category → subcategory) ─────────────────────

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  parentId  String?  @map("parent_id")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products Product[]

  @@index([parentId])
  @@map("categories")
}

// ─── Products (← 1С Номенклатура) ───────────────────────────────────────────

model Product {
  id            String   @id @default(cuid())
  code1C        String?  @unique @map("code_1c")
  articleCode   String?  @map("article_code")
  name          String
  slug          String   @unique
  categoryId    String   @map("category_id")
  description   String   @default("")
  quality       String
  season        String   @default("")
  country       String
  priceUnit     String   @default("kg") @map("price_unit")
  averageWeight Float?   @map("average_weight")
  videoUrl      String?  @map("video_url")
  inStock       Boolean  @default(true) @map("in_stock")
  gender        String?
  sizes         String?
  unitsPerKg    String?  @map("units_per_kg")
  unitsPerKgMin Float?   @map("units_per_kg_min")
  unitsPerKgMax Float?   @map("units_per_kg_max")
  unitWeight    String?  @map("unit_weight")
  unitWeightMin Float?   @map("unit_weight_min")
  unitWeightMax Float?   @map("unit_weight_max")
  isOversize    Boolean  @default(false) @map("is_oversize")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category           Category            @relation(fields: [categoryId], references: [id])
  images             ProductImage[]
  lots               Lot[]
  prices             Price[]
  orderItems         OrderItem[]
  saleItems          SaleItem[]
  cartItems          CartItem[]
  receivingItems     ReceivingItem[]
  purchasePrices     PurchasePrice[]
  videoSubscriptions VideoSubscription[]
  favorites          Favorite[]
  featuredEntry      FeaturedProduct?
  viewLog            ViewLog[]

  @@index([categoryId])
  @@index([quality])
  @@index([inStock])
  @@index([articleCode])
  @@index([unitsPerKgMin])
  @@index([unitsPerKgMax])
  @@index([unitWeightMin])
  @@index([unitWeightMax])
  @@index([isOversize])
  @@map("products")
}

// ─── Product Images (← 1С зображення номенклатури) ──────────────────────────

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  alt       String   @default("")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ─── Lots / Bags (← 1С Серії + ТовариНаСкладах) ────────────────────────────

model Lot {
  id                  String    @id @default(cuid())
  productId           String    @map("product_id")
  barcode             String    @unique
  weight              Float
  quantity            Int       @default(1)
  status              String    @default("free")
  priceEur            Float     @map("price_eur")
  videoUrl            String?   @map("video_url")
  isTarget            Boolean   @default(false) @map("is_target")
  arrivalDate         DateTime? @map("arrival_date")
  sector              String?   @map("sector")
  isOpen              Boolean   @default(false) @map("is_open")
  comment             String?   @map("comment")
  description         String?   @map("description")
  videoDate           DateTime? @map("video_date")
  // ── 5.4.0 — паритет з 1С (ХарактеристикиНоменклатуры: Ефір/ЕфірНаДоставку) ──
  onAir               Boolean   @default(false) @map("on_air")
  onAirDelivery       Boolean   @default(false) @map("on_air_delivery")
  // ── Бронь (Етап 4, денормалізована — як у 1С зберігається рядком; БЕЗ FK
  //    щоб уникнути cross-concern relations між магазином і менеджеркою) ──
  reservedForClientId String?   @map("reserved_for_client_id")
  reservedForName     String?   @map("reserved_for_name")
  reservedByUserId    String?   @map("reserved_by_user_id")
  reservedByName      String?   @map("reserved_by_name")
  reservedUntil       DateTime? @map("reserved_until")
  // ── Поступлення товарів (Тиждень 2, 2026-06-04) ────────────────────────────
  // Постачальник прописується у КОЖНОМУ лоті для звітів «продажі за
  // постачальниками» — узгоджено з user 2026-06-03 (питання 2).
  supplierId          String?   @map("supplier_id")
  // Документ поступлення що створив цей лот (null для legacy-лотів з 1С).
  receivingId         String?   @map("receiving_id")
  // Закупкова ціна (€/кг) — собівартість партії, для маржі.
  purchasePriceEur    Float?    @map("purchase_price_eur")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  product        Product         @relation(fields: [productId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  receiving      Receiving?      @relation(fields: [receivingId], references: [id])
  barcodes       Barcode[]
  orderItems     OrderItem[]
  saleItems      SaleItem[]
  cartItems      CartItem[]
  receivingItems ReceivingItem[]

  @@index([productId])
  @@index([status])
  @@index([isTarget])
  @@index([supplierId])
  @@index([receivingId])
  @@map("lots")
}

// ─── Barcodes (← 1С ШтрихКоди) ─────────────────────────────────────────────

model Barcode {
  id    String @id @default(cuid())
  lotId String @map("lot_id")
  code  String @unique
  type  String @default("EAN13")

  lot Lot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([lotId])
  @@map("barcodes")
}

// ─── Prices (← 1С ЦіниНоменклатури) ────────────────────────────────────────

model Price {
  id        String    @id @default(cuid())
  productId String    @map("product_id")
  priceType String    @map("price_type")
  currency  String    @default("EUR")
  amount    Float
  validFrom DateTime  @default(now()) @map("valid_from")
  validTo   DateTime? @map("valid_to")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, priceType])
  @@map("prices")
}

// ─── Customers (← 1С Контрагенти) ──────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  code1C    String?  @unique @map("code_1c")
  name      String
  phone     String?
  email     String?
  telegram  String?
  city      String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders             Order[]
  sales              Sale[]
  cashOrders         MgrCashOrder[]
  cart               Cart?
  chatMessages       ChatMessage[]
  videoSubscriptions VideoSubscription[]
  pushTokens         PushToken[]
  favorites          Favorite[]
  notifications      Notification[]
  viewLog            ViewLog[]

  @@map("customers")
}

// ─── Orders (← 1С ЗаказПокупателя) ─────────────────────────────────────────

model Order {
  id           String  @id @default(cuid())
  code1C       String? @unique @map("code_1c")
  // Людський номер документа з 1С (_Number, напр. "L0000002477"). НЕ унікальний
  // (1С нумерує щорічно з 0 → номери повторюються по роках; дата документа
  // disambiguate). Унікальний ключ лишається `code1C` = hex(_IDRRef).
  number1C     String? @map("number_1c")
  customerId   String  @map("customer_id")
  status       String  @default("draft")
  totalEur     Float   @default(0) @map("total_eur")
  totalUah     Float   @default(0) @map("total_uah")
  exchangeRate Float   @default(0) @map("exchange_rate")
  notes        String?
  agentName    String? @map("agent_name") // ТорговийАгент._Description (історичний імпорт 5.4.6a)

  // ─── Manager order fields (← 1С Document.Заказ, Етап 1) ──────────────────
  // Тип цін — id з довідника MgrPriceType (зберігаємо id, без жорсткого FK,
  // бо order — спільна з магазином модель). Доставка — delivery|post|pickup.
  priceTypeId         String? @map("price_type_id")
  deliveryMethod      String? @map("delivery_method")
  cashOnDelivery      Boolean @default(false) @map("cash_on_delivery")
  assignedAgentUserId String? @map("assigned_agent_user_id")
  exportTo1C          Boolean @default(true) @map("export_to_1c")
  // Проведено в 1С (ставиться на етапі обмінів) + актуальність.
  archived            Boolean @default(false)
  isActual            Boolean @default(true) @map("is_actual")
  routeSheetId        String? @map("route_sheet_id") // зворотне посилання на МЛ (1С Заказ.МаршрутныйЛист)

  // ─── Закриття замовлень (Етап 3 блоку Замовлення, 2026-06-09) ────────────
  closedAt       DateTime? @map("closed_at")
  closeReasonId  String?   @map("close_reason_id")
  closedByUserId String?   @map("closed_by_user_id")
  closeNotes     String?   @map("close_notes")

  // ─── Auto-нагадування (Етап 3) ───────────────────────────────────────────
  lastReminderAt          DateTime? @map("last_reminder_at")
  remindersSentCount      Int       @default(0) @map("reminders_sent_count")
  escalatedToSupervisorAt DateTime? @map("escalated_to_supervisor_at")

  // ─── Optimistic lock (Етап 4) ────────────────────────────────────────────
  // Інкрементується при кожному PATCH. Клієнт надсилає поточну версію —
  // якщо у БД більша → 409 і вимога перезавантажити.
  version Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer    Customer          @relation(fields: [customerId], references: [id])
  closeReason OrderCloseReason? @relation(fields: [closeReasonId], references: [id])
  closedBy    User?             @relation("OrderClosedBy", fields: [closedByUserId], references: [id])
  items       OrderItem[]
  shipments   Shipment[]
  payments    Payment[]
  sales       Sale[]            @relation("SaleOrder")

  @@index([customerId])
  @@index([status])
  @@index([routeSheetId])
  @@index([closedAt])
  @@index([lastReminderAt])
  @@index([number1C])
  @@map("orders")
}

// ─── Довідник причин закриття замовлень (Етап 3 блоку Замовлення) ─────────
model OrderCloseReason {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  orders Order[]

  @@index([isActive, sortOrder])
  @@map("order_close_reasons")
}

// ─── Order Items (← табличні секції документів) ─────────────────────────────

model OrderItem {
  id              String  @id @default(cuid())
  orderId         String  @map("order_id")
  lotId           String? @map("lot_id")
  productId       String  @map("product_id")
  priceEur        Float   @map("price_eur")
  weight          Float
  quantity        Int     @default(1)
  // ── 5.4.0 — паритет з 1С (ЦенаПродажиВес / ПроцентСкидкиНаценки) ──
  unitPriceEur    Float?  @map("unit_price_eur")
  discountPercent Float?  @map("discount_percent")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lot     Lot?    @relation(fields: [lotId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── Realizations / Sales (← 1С Document.РеализацияТоваровУслуг, M1.6) ─────
// Реалізація — окремий документ, що фіксує факт продажу/відвантаження клієнту
// (борг клієнта; у central — списання складу). Усі поля additive, магазину
// не заважають. Зразок — Order/OrderItem + Payment.

model Sale {
  id                  String   @id @default(cuid())
  code1C              String?  @unique @map("code_1c")
  number1C            String?  @map("number_1c") // 1С _Number (напр. "L0000001335"), display-only
  docNumber           Int      @default(autoincrement()) @map("doc_number")
  customerId          String   @map("customer_id")
  status              String   @default("draft") // draft|sent|posted|cancelled
  totalEur            Float    @default(0) @map("total_eur")
  totalUah            Float    @default(0) @map("total_uah")
  exchangeRateEur     Float    @default(0) @map("exchange_rate_eur")
  exchangeRateUsd     Float    @default(0) @map("exchange_rate_usd")
  priceTypeId         String?  @map("price_type_id")
  deliveryMethod      String?  @map("delivery_method") // delivery|post|pickup
  novaPoshtaBranch    String?  @map("nova_poshta_branch")
  cashOnDelivery      Boolean  @default(false) @map("cash_on_delivery")
  codAmountUah        Float?   @map("cod_amount_uah")
  assignedAgentUserId String?  @map("assigned_agent_user_id")
  onTradeAgent        Boolean  @default(true) @map("on_trade_agent")
  exportTo1C          Boolean  @default(true) @map("export_to_1c")
  expressWaybill      String?  @map("express_waybill")
  notes               String?
  agentName           String?  @map("agent_name") // ТорговийАгент._Description (історичний імпорт 5.4.6a)
  orderId             String?  @map("order_id")
  routeId             String?  @map("route_id")
  archived            Boolean  @default(false)
  isActual            Boolean  @default(true) @map("is_actual")
  routeSheetId        String?  @map("route_sheet_id") // зворотне посилання на МЛ
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  customer   Customer       @relation(fields: [customerId], references: [id])
  order      Order?         @relation("SaleOrder", fields: [orderId], references: [id], onDelete: SetNull)
  items      SaleItem[]
  cashOrders MgrCashOrder[]

  @@index([customerId])
  @@index([status])
  @@index([routeSheetId])
  @@index([orderId])
  @@index([number1C])
  @@map("mgr_sales")
}

// ─── Cash orders / Каса (← 1С КассовыйОрдер, M1.6 Етап 4) ──────────────────
// Повний касовий ордер: оплата у 3 валютах (грн/EUR/USD) + безнал грн,
// авто-розрахунок здачі та авто-створення ордера-розходу (`type=expense`,
// `changeForId` → прихідний ордер) коли здача > 0. Усі суми зберігаються
// «сирими» по валюті; порівняння йдуть через грн за курсами Sale-знімка.

model MgrCashOrder {
  id                String   @id @default(cuid())
  code1C            String?  @unique @map("code_1c")
  number1C          String?  @map("number_1c") // 1С _Number, display-only
  docNumber         Int      @default(autoincrement()) @map("doc_number")
  saleId            String?  @map("sale_id")
  customerId        String?  @map("customer_id") // Контрагент (standalone-оплата без реалізації)
  type              String // income | expense (Приход/Расход)
  amountUah         Float    @default(0) @map("amount_uah")
  amountEur         Float    @default(0) @map("amount_eur")
  amountUsd         Float    @default(0) @map("amount_usd")
  amountUahCashless Float    @default(0) @map("amount_uah_cashless")
  changeCurrency    String?  @map("change_currency") // deprecated (3-валютна здача — у amount* expense-ордера)
  changeForId       String?  @map("change_for_id") // expense → його прихідний ордер
  // Довідники (← 1С БанковскиеСчета / СтатьиДвиженияДенежныхСредств).
  bankAccountId     String?  @map("bank_account_id")
  cashFlowArticleId String?  @map("cash_flow_article_id")
  bankAccount       String?  @map("bank_account") // deprecated free-text (заміщено bankAccountId)
  cashFlowArticle   String?  @map("cash_flow_article") // deprecated free-text
  // Курси-знімок (КурсEUR/КурсUSD = грн за €/$) + зведена сума у EUR (СуммаДокумента).
  rateEur           Float    @default(0) @map("rate_eur")
  rateUsd           Float    @default(0) @map("rate_usd")
  documentSumEur    Float    @default(0) @map("document_sum_eur")
  // Коректировка боргу (знижка на залишок без реалізації) + ключ корекції.
  debtCorrection    Float    @default(0) @map("debt_correction")
  correctionUid     String?  @map("correction_uid")
  // Мультивалютні бізнес-ключі обміну (УИДГРН / ПКО_УИД / УИДUSD).
  uidUah            String?  @map("uid_uah")
  uidEur            String?  @map("uid_eur")
  uidUsd            String?  @map("uid_usd")
  archived          Boolean  @default(false)
  routeSheetId      String?  @map("route_sheet_id") // зворотне посилання на МЛ
  comment           String?
  agentUserId       String?  @map("agent_user_id")
  paidAt            DateTime @default(now()) @map("paid_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  sale               Sale?               @relation(fields: [saleId], references: [id], onDelete: SetNull)
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  bankAccountRef     MgrBankAccount?     @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  cashFlowArticleRef MgrCashFlowArticle? @relation(fields: [cashFlowArticleId], references: [id], onDelete: SetNull)
  changeFor          MgrCashOrder?       @relation("CashOrderChange", fields: [changeForId], references: [id])
  changes            MgrCashOrder[]      @relation("CashOrderChange")

  @@index([saleId])
  @@index([customerId])
  @@index([archived])
  @@index([routeSheetId])
  @@index([number1C])
  @@map("mgr_cash_orders")
}

// ─── Довідник банк. рахунків (← 1С Catalog.БанковскиеСчета) ─────────────────
// Рахунки L-TEX для прийому безготівки. `hiddenInApp` = НеВідображатиВДодатку
// (не можна вибирати при приході). Поки порожній — наповнюється вручну / з 1С.

model MgrBankAccount {
  id          String   @id @default(cuid())
  code1C      String?  @unique @map("code_1c")
  name        String
  description String?
  hiddenInApp Boolean  @default(false) @map("hidden_in_app")
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cashOrders MgrCashOrder[]

  @@map("mgr_bank_accounts")
}

// ─── Довідник статей руху коштів (← 1С Catalog.СтатьиДвиженияДенежныхСредств) ─
// Стаття обов'язкова для Расход-ордерів. 2-рівнева ієрархія через parentId.

model MgrCashFlowArticle {
  id        String   @id @default(cuid())
  code1C    String?  @unique @map("code_1c")
  code      String?
  name      String
  parentId  String?  @map("parent_id")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent     MgrCashFlowArticle?  @relation("CashFlowArticleTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   MgrCashFlowArticle[] @relation("CashFlowArticleTree")
  cashOrders MgrCashOrder[]

  @@map("mgr_cash_flow_articles")
}

model SaleItem {
  id         String  @id @default(cuid())
  saleId     String  @map("sale_id")
  productId  String  @map("product_id")
  lotId      String? @map("lot_id")
  barcode    String?
  pricePerKg Float   @map("price_per_kg")
  weight     Float
  quantity   Int     @default(1)
  priceEur   Float   @map("price_eur") // line total = pricePerKg*weight*quantity

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  lot     Lot?    @relation(fields: [lotId], references: [id])

  @@index([saleId])
  @@map("mgr_sale_items")
}

// ─── Exchange Rates (← 1С КурсиВалют) ──────────────────────────────────────

model ExchangeRate {
  id           String   @id @default(cuid())
  currencyFrom String   @map("currency_from")
  currencyTo   String   @map("currency_to")
  rate         Float
  date         DateTime @default(now())
  source       String   @default("1c")

  @@unique([currencyFrom, currencyTo, date])
  @@map("exchange_rates")
}

// ─── Carts (server-side cart persistence) ───────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  customerId String?  @unique @map("customer_id")
  sessionId  String?  @unique @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer?  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String  @map("cart_id")
  lotId     String? @map("lot_id")
  productId String  @map("product_id")
  priceEur  Float   @map("price_eur")
  weight    Float
  quantity  Int     @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  lot     Lot?    @relation(fields: [lotId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([cartId])
  @@map("cart_items")
}

// ─── Chat Messages (customer ↔ manager) ────────────────────────────────────

model ChatMessage {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  sender     String // "customer" | "manager"
  text       String
  imageUrl   String?  @map("image_url")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("chat_messages")
}

// ─── Shipment Tracking (Nova Poshta) ────────────────────────────────────────

model Shipment {
  id              String    @id @default(cuid())
  orderId         String    @map("order_id")
  trackingNumber  String    @map("tracking_number")
  carrier         String    @default("nova_poshta")
  status          String    @default("created")
  statusText      String?   @map("status_text")
  estimatedDate   DateTime? @map("estimated_date")
  recipientCity   String?   @map("recipient_city")
  recipientBranch String?   @map("recipient_branch")
  lastCheckedAt   DateTime? @map("last_checked_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, trackingNumber])
  @@index([trackingNumber])
  @@map("shipments")
}

// ─── Video Review Subscriptions ─────────────────────────────────────────────

model VideoSubscription {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("video_subscriptions")
}

// ─── In-app notifications feed (S36) ───────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  customerId String    @map("customer_id")
  type       String // "order_status" | "new_video" | "chat_message" | "system"
  title      String
  body       String
  payload    Json?
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([customerId, readAt])
  @@map("notifications")
}

// ─── Push Notification Tokens ───────────────────────────────────────────────

model PushToken {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  token      String   @unique
  platform   String // "ios" | "android" | "web"
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("push_tokens")
}

// ─── Payments ───────────────────────────────────────────────────────────────

model Payment {
  id         String    @id @default(cuid())
  orderId    String    @map("order_id")
  method     String // "cash" | "card" | "bank_transfer" | "online"
  amount     Float
  currency   String    @default("UAH")
  status     String    @default("pending") // pending | completed | failed | refunded
  externalId String?   @map("external_id") // payment gateway ID
  paidAt     DateTime? @map("paid_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([externalId])
  @@map("payments")
}

// ─── Favorites (wishlists) ──────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("favorites")
}

// ─── Sync Log (tracking 1C sync operations) ────────────────────────────────

model SyncLog {
  id       String   @id @default(cuid())
  entity   String
  entityId String?  @map("entity_id")
  action   String
  payload  Json?
  syncedAt DateTime @default(now()) @map("synced_at")

  @@index([entity, entityId])
  @@index([syncedAt])
  @@map("sync_log")
}

// ─── Featured Products (homepage "Топ товарів", admin-curated) ──────────────

model FeaturedProduct {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  position  Int      @default(0)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([position])
  @@map("featured_products")
}

// ─── Banners (homepage carousel, admin-managed) ─────────────────────────────

model Banner {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  imageUrl  String
  ctaLabel  String?
  ctaHref   String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, position])
  @@map("banners")
}

// ─── Newsletter Subscribers (footer signup) ─────────────────────────────────

model NewsletterSubscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  phone          String?
  subscribedAt   DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  source         String?
  confirmedAt    DateTime? @map("confirmed_at")

  @@index([subscribedAt])
  @@map("newsletter_subscribers")
}

// ─── Promo Stripe (sticky "Гаряча пропозиція" banner, single-row) ──────────

model PromoStripe {
  id        String   @id @default(cuid())
  text      String
  ctaLabel  String?
  ctaHref   String?
  bgColor   String   @default("#dc2626")
  textColor String   @default("#ffffff")
  isActive  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("promo_stripe")
}

// ─── Suppliers / Warehouses / Receivings (Тиждень 2 блоку Поступлення) ─────
// Документ-аналог 1С `ПоступленняТоварівУслуг`. Склад приймає товар →
// створює документ → проводить → автоматично створюються лоти у `Lot`.
// Постачальник прописується у КОЖНОМУ лоті (для звітів продажі/закупки за
// постачальниками — узгоджено з user 2026-06-03).

model Supplier {
  id          String   @id @default(cuid())
  code1C      String?  @unique @map("code_1c")
  name        String
  fullName    String?  @map("full_name")
  edrpou      String?
  phone       String?
  email       String?
  address     String?
  country     String?
  bankAccount String?  @map("bank_account")
  currency    String   @default("EUR")
  isActive    Boolean  @default(true) @map("is_active")
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lots           Lot[]
  receivings     Receiving[]
  purchasePrices PurchasePrice[]

  @@index([name])
  @@index([isActive])
  @@map("suppliers")
}

model Warehouse {
  id        String   @id @default(cuid())
  code1C    String?  @unique @map("code_1c")
  name      String
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  isDefault Boolean  @default(false) @map("is_default")
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  receivings Receiving[]
  sectors    WarehouseSector[]

  @@index([name])
  @@map("warehouses")
}

// ── Регістр історії цін закупки (← Хвиля 2 правок Поступлення) ────────────
// При проведенні поступлення для кожного рядка з ціною > 0 пишеться запис.
// Endpoint last-purchase-price підтягує останню ціну для (товар, постачальник)
// → автопідстановка у форму при наступному додаванні.
model PurchasePrice {
  id              String   @id @default(cuid())
  productId       String   @map("product_id")
  supplierId      String   @map("supplier_id")
  priceEur        Float    @map("price_eur")
  validFrom       DateTime @default(now()) @map("valid_from")
  source          String   @default("receiving") // 'receiving' | 'manual'
  receivingId     String?  @map("receiving_id")
  receivingItemId String?  @map("receiving_item_id")
  createdAt       DateTime @default(now()) @map("created_at")

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier  Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  receiving Receiving? @relation(fields: [receivingId], references: [id], onDelete: SetNull)

  @@index([productId, supplierId, validFrom(sort: Desc)])
  @@index([supplierId])
  @@map("purchase_prices")
}

// Довідник секторів складу (← Хвиля 2).
// Поки що використовується тільки як autocomplete-джерело у формі
// поступлення — `receiving_items.sector` залишається вільним стрингом.
model WarehouseSector {
  id          String   @id @default(cuid())
  warehouseId String?  @map("warehouse_id")
  name        String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  warehouse Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@map("warehouse_sectors")
}

model Receiving {
  id                String    @id @default(cuid())
  code1C            String?   @unique @map("code_1c")
  // Внутрішній номер документа (LT-RCV-YYYYMM-NNNN — auto-генерується)
  docNumber         String    @unique @map("doc_number")
  docDate           DateTime  @default(now()) @map("doc_date")
  // Постачальник + склад (RESTRICT — не дозволити випадковий drop)
  supplierId        String    @map("supplier_id")
  warehouseId       String    @map("warehouse_id")
  // Валюта документа + курс на дату (для конвертації EUR/UAH)
  currency          String    @default("EUR")
  exchangeRate      Float     @default(1) @map("exchange_rate")
  // Вхідний № і дата документа від постачальника (PDF / email)
  inboundDocNumber  String?   @map("inbound_doc_number")
  inboundDocDate    DateTime? @map("inbound_doc_date") @db.Date
  // Сумарні значення (заповнюються автоматично при збереженні рядків)
  totalWeight       Float     @default(0) @map("total_weight")
  totalQuantity     Int       @default(0) @map("total_quantity")
  totalAmount       Float     @default(0) @map("total_amount")
  // Статус: draft → posted → cancelled
  status            String    @default("draft")
  notes             String?
  createdByUserId   String?   @map("created_by_user_id")
  postedAt          DateTime? @map("posted_at")
  postedByUserId    String?   @map("posted_by_user_id")
  cancelledAt       DateTime? @map("cancelled_at")
  cancelledByUserId String?   @map("cancelled_by_user_id")
  cancelReason      String?   @map("cancel_reason")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  supplier        Supplier        @relation(fields: [supplierId], references: [id])
  warehouse       Warehouse       @relation(fields: [warehouseId], references: [id])
  createdBy       User?           @relation("ReceivingCreatedBy", fields: [createdByUserId], references: [id])
  postedBy        User?           @relation("ReceivingPostedBy", fields: [postedByUserId], references: [id])
  cancelledBy     User?           @relation("ReceivingCancelledBy", fields: [cancelledByUserId], references: [id])
  items           ReceivingItem[]
  lots            Lot[]
  purchasePrices  PurchasePrice[]
  reviewReminders MgrReminder[]

  @@index([status])
  @@index([supplierId])
  @@index([warehouseId])
  @@index([docDate(sort: Desc)])
  @@map("receivings")
}

// Рядок документа поступлення. Один рядок = один мішок або партія
// однакових мішків (за `quantity > 1` створюється N лотів при проведенні).
model ReceivingItem {
  id            String   @id @default(cuid())
  receivingId   String   @map("receiving_id")
  productId     String   @map("product_id")
  weight        Float
  quantity      Int      @default(1)
  // Ціна закупки за кг (у валюті документа `receivings.currency`)
  purchasePrice Float    @default(0) @map("purchase_price")
  // Ціна продажу (€/кг) — vid admin/owner для актуалізації прайсу при
  // проведенні. Null = ціна не змінювалась (← правки 2026-06-05).
  salePrice     Float?   @map("sale_price")
  lineAmount    Float    @default(0) @map("line_amount")
  // Штрихкод. null коли треба згенерувати при проведенні (3-й сценарій).
  barcode       String?
  // Метод поступлення штрихкоду — для аудиту + UI:
  //   'scanned'   — зчитано сканером (зашита інфо у штрихкоді)
  //   'manual'    — введено вручну (наклеєна бірка)
  //   'generated' — згенерує система при проведенні (default)
  barcodeSource String   @default("generated") @map("barcode_source")
  // Сектор на складі (← правки 2026-06-05). Вільний ввід або сканування
  // штрихкоду сектора. Переходить на `lot.sector` при проведенні.
  sector        String?
  createdLotId  String?  @map("created_lot_id")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  receiving  Receiving @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id])
  createdLot Lot?      @relation(fields: [createdLotId], references: [id])

  @@index([receivingId])
  @@index([productId])
  @@index([createdLotId])
  @@map("receiving_items")
}

// ─── Product View Log (recommendations + analytics) ──────────────────────────

model ViewLog {
  id         String   @id @default(cuid())
  customerId String?  @map("customer_id")
  productId  String   @map("product_id")
  source     String   @default("unknown") // "home" | "catalog" | "search" | "product_detail" | "unknown"
  viewedAt   DateTime @default(now()) @map("viewed_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerId, viewedAt])
  @@index([productId, viewedAt])
  @@map("view_log")
}

// ─── Manager Workstation users (M1.1) ──────────────────────────────────────

enum UserRole {
  manager
  senior_manager
  admin
  // ── Розширення (Тиждень 1 блоку Ролі, 2026-06-03) ─────────────────────────
  // Власник бізнесу — повний доступ + усі дії логуються в `audit_logs` з
  // is_owner_action=true для окремого фільтру у admin-UI.
  owner
  // Старший менеджер — бачить ВСІ замовлення усіх менеджерів + Telegram-
  // сповіщення про прострочені (Етап 3 блоку Замовлень).
  supervisor
  // Аналітик — read-only до фінансів/звітів, повний доступ до експорту.
  analyst
  // Складський працівник — приймає товар (Поступлення), генерує лоти,
  // готує замовлення до відвантаження. Без цін закупки і маржі.
  warehouse
  // Експедитор — водій маршрутних листів (доставка/завантаження)
  expeditor
  // Бухгалтер — каса/банк/оплати/взаєморозрахунки. Без редагування товарів/
  // клієнтів/замовлень.
  bookkeeper
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole @default(manager)
  isActive     Boolean  @default(true) @map("is_active")

  // 1C bridge (manager-specific, null для non-manager-окремих accounts)
  code1C        String? @unique @map("code_1c")
  warehouseId1C String? @map("warehouse_id_1c")

  // Telegram bot bridge
  telegramChatId    String?  @unique @map("telegram_chat_id")
  telegramLinkToken String?  @unique @map("telegram_link_token")
  notifyChannels    String[] @default([]) @map("notify_channels")

  // Audit
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  lastSeenAt  DateTime? @map("last_seen_at")
  lastLoginIp String?   @map("last_login_ip")

  // Lockout
  failedLoginCount Int       @default(0) @map("failed_login_count")
  lockedUntil      DateTime? @map("locked_until")

  // Per-user permission overrides (← Тиждень 1 блоку Ролі). NULL = успадковує
  // дефолти ролі з `lib/permissions/role-permissions.ts`. Структура:
  // `{ "<resource>": { "view": bool, "create": bool, "edit": bool, ... } }`.
  permissions Json?

  refreshTokens        UserRefreshToken[]
  passwordResets       PasswordResetToken[]
  assignedClients      ClientAssignment[]
  timelineComments     MgrClientTimelineEntry[]
  agentForClients      MgrClient[]              @relation("ClientAgent")
  reminders            MgrReminder[]            @relation("UserReminders")
  viewPrefs            MgrUserViewPrefs[]
  routeSheetsExpedited RouteSheet[]             @relation("RouteSheetExpeditor")
  routeSheetsCreated   RouteSheet[]             @relation("RouteSheetCreatedBy")
  chatConversations    ChatConversation[]       @relation("ChatConversationAgent")
  chatInboxMessages    ChatInboxMessage[]       @relation("ChatInboxMessageAuthor")
  regionAgents         MgrRegionAgent[]         @relation("RegionAgentUser")
  auditLogs            AuditLog[]               @relation("AuditLogUser")
  receivingsCreated    Receiving[]              @relation("ReceivingCreatedBy")
  receivingsPosted     Receiving[]              @relation("ReceivingPostedBy")
  receivingsCancelled  Receiving[]              @relation("ReceivingCancelledBy")
  ordersClosed         Order[]                  @relation("OrderClosedBy")

  @@map("users")
}

// ─── Audit Log (← Тиждень 1 блоку Ролі, 2026-06-03) ────────────────────────
// Універсальна таблиця подій усієї системи. Кожна мутаційна дія
// (create/update/delete у будь-якій моделі) пише сюди один запис.
// Для дій власника (`role = owner`) додатково ставиться `isOwnerAction=true`
// — для швидкого фільтру у admin-UI `/manager/admin/audit?ownerOnly=true`.
// Запис ніколи не редагується після створення (append-only журнал).
model AuditLog {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  userEmail     String?  @map("user_email")
  userRole      String   @map("user_role")
  action        String // create / update / delete / login / logout / failed_login / ...
  resource      String // order / client / lot / payment / receiving / ...
  resourceId    String?  @map("resource_id")
  summary       String?
  dataBefore    Json?    @map("data_before")
  dataAfter     Json?    @map("data_after")
  ip            String?
  userAgent     String?  @map("user_agent")
  isOwnerAction Boolean  @default(false) @map("is_owner_action")
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_logs")
}

model UserRefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("user_refresh_tokens")
}

model PasswordResetToken {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  isInvite    Boolean   @default(false) @map("is_invite")
  requestedIp String?   @map("requested_ip")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@map("password_reset_tokens")
}

model ClientAssignment {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  customerId String   @map("customer_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client MgrClient @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([userId, customerId])
  @@index([customerId])
  @@map("client_assignments")
}

// ─── Manager Clients (M1.3a) ───────────────────────────────────────────────
// Snapshot з 1С `Справочник.Контрагенты` (див. docs/1c-export-mobile/Central/Catalogs/Контрагенты.xml).
// Реальний SOAP-sync з'явиться у M1.5+; зараз — seed-скрипт з фейковими даними.

model MgrClientStatus {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  colorHex  String @map("color_hex")
  sortOrder Int    @default(0) @map("sort_order")

  clientsGeneral     MgrClient[] @relation("MgrClientStatusGeneral")
  clientsOperational MgrClient[] @relation("MgrClientStatusOperational")

  @@map("mgr_client_statuses")
}

model MgrSearchChannel {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")

  clients MgrClient[]

  @@map("mgr_search_channels")
}

model MgrCategoryTT {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")

  clients MgrClient[]

  @@map("mgr_categories_tt")
}

model MgrDeliveryMethod {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")

  clients MgrClient[]

  @@map("mgr_delivery_methods")
}

model MgrAssortmentCode {
  id        String @id @default(cuid())
  code      String @unique
  label     String
  sortOrder Int    @default(0) @map("sort_order")

  clients MgrClient[]

  @@map("mgr_assortment_codes")
}

model MgrRoute {
  id        String   @id @default(cuid())
  code1C    String?  @unique @map("code_1c")
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  primaryForClients MgrClient[]                @relation("MgrClientPrimaryRoute")
  assignments       MgrClientRouteAssignment[]
  routeSheets       RouteSheet[]

  @@map("mgr_routes")
}

// ─── Route Sheets / Маршрутні листи (← 1С Document.МаршрутныйЛист, M1.9) ────
// Документ-агрегатор дня виїзду: Замовлення → Загрузка(скан) → Реалізації →
// Оплати → Бракує(обчислюване). Реалізації/Оплати реюзають Sale/MgrCashOrder
// через зворотні посилання routeSheetId. Cross-model id-поля у дочірніх — плоскі
// скаляри (резолв через batch-lookup у застосунку), щоб не плодити inverse-
// relations на спільних з магазином моделях; FK+cascade лише child→RouteSheet.

model RouteSheet {
  id              String    @id @default(cuid())
  code1C          String?   @unique @map("code_1c")
  number1C        String?   @map("number_1c") // 1С _Number, display-only
  docNumber       Int       @default(autoincrement()) @map("doc_number")
  date            DateTime  @default(now())
  arrivalDate     DateTime? @map("arrival_date")
  status          String    @default("draft") // draft|dispatched|completed
  routeId         String?   @map("route_id")
  expeditorUserId String?   @map("expeditor_user_id")
  createdByUserId String?   @map("created_by_user_id")
  totalUah        Float     @default(0) @map("total_uah")
  totalEur        Float     @default(0) @map("total_eur")
  comment         String?
  mileageStartKm  Float?    @map("mileage_start_km")
  mileageEndKm    Float?    @map("mileage_end_km")
  gpsLat          Float?    @map("gps_lat")
  gpsLng          Float?    @map("gps_lng")
  archived        Boolean   @default(false)
  exportTo1C      Boolean   @default(true) @map("export_to_1c")
  posted          Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  route     MgrRoute? @relation(fields: [routeId], references: [id], onDelete: SetNull)
  expeditor User?     @relation("RouteSheetExpeditor", fields: [expeditorUserId], references: [id], onDelete: SetNull)
  createdBy User?     @relation("RouteSheetCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  orders    RouteSheetOrder[]
  items     RouteSheetItem[]
  loading   RouteSheetLoading[]
  sales     RouteSheetSale[]
  saleItems RouteSheetSaleItem[]
  payments  RouteSheetPayment[]
  tasks     RouteSheetTask[]
  expenses  RouteSheetExpense[]

  @@index([status])
  @@index([routeId])
  @@index([expeditorUserId])
  @@index([archived])
  @@index([number1C])
  @@map("mgr_route_sheets")
}

model RouteSheetOrder {
  id           String  @id @default(cuid())
  routeSheetId String  @map("route_sheet_id")
  orderId      String  @map("order_id")
  customerId   String? @map("customer_id")
  city         String?

  routeSheet RouteSheet @relation(fields: [routeSheetId], references: [id], onDelete: Cascade)

  @@index([routeSheetId])
