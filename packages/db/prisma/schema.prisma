  createdAt  DateTime @default(now()) @map("created_at")

  reminder MgrReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId])
  @@map("mgr_reminder_items")
}

model MgrClientTimelineEntry {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  kind         String
  body         String   @db.Text
  occurredAt   DateTime @map("occurred_at")
  authorUserId String?  @map("author_user_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  client MgrClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User?     @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([clientId, occurredAt(sort: Desc)])
  @@map("mgr_client_timeline")
}

// ─── 5.4.5 — регістр рухів боргу (живий борг клієнтів) ──────────────────────
// Кожне проведення документа = підписаний рядок руху; MgrClient.debt = Σ
// amountEur по рухах (кеш). Дзеркалить 1С _AccumRg5269 ВзаиморасчетыСКонтрагентами.
// `opening` — агрегований початковий залишок з історичного імпорту; `sale` /
// `payment` / `correction` — живі рухи (5.4.5b/5.4.5c).

enum MgrDebtMovementKind {
  opening
  sale
  payment
  correction

  @@map("mgr_debt_movement_kind")
}

model MgrDebtMovement {
  id              String              @id @default(cuid())
  clientId        String              @map("client_id")
  client          MgrClient           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amountEur       Decimal             @map("amount_eur") @db.Decimal(12, 2) // + борг клієнта зростає, − зменшується
  kind            MgrDebtMovementKind
  sourceType      String?             @map("source_type") // "accum_rg5269" | "sale" | "cash_order" | "manual"
  sourceId        String?             @map("source_id")
  occurredAt      DateTime            @map("occurred_at")
  note            String?
  createdByUserId String?             @map("created_by_user_id")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@unique([kind, sourceType, sourceId], name: "mgr_debt_movement_source")
  @@index([clientId, occurredAt])
  @@map("mgr_debt_movements")
}

// ─── Регістри-обороти (Фаза 2, 5.6) ─────────────────────────────────────────
// Матеріалізовані рухи 1С AccumulationRegisters. Патерн дзеркалить MgrDebtMovement:
// окрема таблиця рухів + idempotent-ключ джерела (recorderCode1C + lineNo). Усі
// FK-резолви (productId/clientId/lotId) — best-effort: при недоступному словнику
// лишаємо *Code1C (hex) і резолвимо id пізніше. Виміри/ресурси кожного регістра —
// у docs/1C_REGISTRY_INVENTORY.md (ЧАСТИНА C1).

/// 1С `AccumRg Продажи` (_AccumRg5604) — обороти продажів.
/// recordKind: 0=прихід (звичайна реалізація), 1=розхід (повернення).
model SalesMovement {
  id                   String   @id @default(cuid())
  occurredAt           DateTime @map("occurred_at")
  recorderCode1C       String   @map("recorder_code_1c") // hex(_RecorderRRef) документа-реєстратора
  lineNo               Int      @map("line_no")
  productCode1C        String?  @map("product_code_1c") // hex(Номенклатура)
  productId            String?  @map("product_id")
  lotCode1C            String?  @map("lot_code_1c") // hex(ХарактеристикаНоменклатуры)
  clientCode1C         String?  @map("client_code_1c") // hex(Контрагент)
  clientId             String?  @map("client_id")
  agentCode1C          String?  @map("agent_code_1c") // hex(ТорговийАгент) — якщо є на регістрі
  orderCode1C          String?  @map("order_code_1c") // hex(ЗаказПокупателя)
  saleCode1C           String?  @map("sale_code_1c") // hex(ДокументПродажи)
  qty                  Decimal  @db.Decimal(15, 3) // Количество
  weightKg             Decimal? @map("weight_kg") @db.Decimal(15, 3) // Вес
  revenueEur           Decimal  @map("revenue_eur") @db.Decimal(15, 2) // Стоимость
  revenueNoDiscountEur Decimal? @map("revenue_no_discount_eur") @db.Decimal(15, 2) // СтоимостьБезСкидок
  costEur              Decimal? @map("cost_eur") @db.Decimal(15, 2) // собівартість (Фаза 3, поки null)
  recordKind           Int      @map("record_kind") // 0=прихід / 1=розхід
  createdAt            DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo], name: "sales_movement_src")
  @@index([clientCode1C, occurredAt])
  @@index([productCode1C])
  @@index([occurredAt])
  @@map("sales_movements")
}

/// 1С `AccumRg ДвиженияДенежныхСредств` (_AccumRg5309) — рух коштів (ДДС).
/// direction: 0=прихід / 1=розхід (ПриходРасход).
model CashFlowMovement {
  id             String   @id @default(cuid())
  occurredAt     DateTime @map("occurred_at")
  recorderCode1C String   @map("recorder_code_1c")
  lineNo         Int      @map("line_no")
  accountCode1C  String?  @map("account_code_1c") // hex(БанковскийСчетКасса)
  articleCode1C  String?  @map("article_code_1c") // hex(СтатьяДвиженияДенежныхСредств)
  direction      Int // 0=прихід / 1=розхід
  clientCode1C   String?  @map("client_code_1c") // hex(Контрагент)
  amountUah      Decimal  @map("amount_uah") @db.Decimal(15, 2) // Сумма
  amountUpr      Decimal? @map("amount_upr") @db.Decimal(15, 2) // СуммаУпр (EUR)
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo], name: "cash_flow_movement_src")
  @@index([articleCode1C, occurredAt])
  @@index([occurredAt])
  @@map("cash_flow_movements")
}

/// 1С `AccumRg ТоварыНаСкладах` (_AccumRg5788) + вага `ТовариНаСкладахУВазі`
/// (_AccumRg6608). Залишковий регістр: recordKind 0=прихід / 1=розхід.
model StockMovement {
  id             String   @id @default(cuid())
  occurredAt     DateTime @map("occurred_at")
  recorderCode1C String   @map("recorder_code_1c")
  lineNo         Int      @map("line_no")
  warehouseCode1C String? @map("warehouse_code_1c") // hex(Склад)
  productCode1C  String   @map("product_code_1c") // hex(Номенклатура)
  productId      String?  @map("product_id")
  lotCode1C      String?  @map("lot_code_1c") // hex(ХарактеристикаНоменклатуры)
  quality        String? // hex(Качество) або текст
  qty            Decimal  @db.Decimal(15, 3) // Количество (шт)
  weightKg       Decimal? @map("weight_kg") @db.Decimal(15, 3) // кг (з _AccumRg6608)
  recordKind     Int      @map("record_kind") // 0=прихід / 1=розхід
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo, productCode1C], name: "stock_movement_src")
  @@index([productCode1C, occurredAt])
  @@index([warehouseCode1C])
  @@index([occurredAt])
  @@map("stock_movements")
}

/// 1С `AccumRg ЗаказыПокупателей` (_AccumRg5374) — залишки замовлень.
/// recordKind 0=прихід (замовлено) / 1=розхід (відвантажено/закрито).
model OrderRemainderMovement {
  id             String   @id @default(cuid())
  occurredAt     DateTime @map("occurred_at")
  recorderCode1C String   @map("recorder_code_1c")
  lineNo         Int      @map("line_no")
  orderCode1C    String   @map("order_code_1c") // hex(ЗаказПокупателя)
  orderId        String?  @map("order_id")
  productCode1C  String?  @map("product_code_1c") // hex(Номенклатура)
  productId      String?  @map("product_id")
  qty            Decimal  @db.Decimal(15, 3) // Количество
  recordKind     Int      @map("record_kind")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo, orderCode1C], name: "order_remainder_movement_src")
  @@index([orderCode1C, occurredAt])
  @@index([occurredAt])
  @@map("order_remainder_movements")
}

// ─── Email DLQ (persistent retry queue, Session 70) ─────────────────────────

model EmailJob {
  id            String    @id @default(cuid())
  to            String    @map("to_address")
  subject       String
  htmlBody      String    @map("html_body")
  textBody      String?   @map("text_body")
  source        String
  referenceId   String?   @map("reference_id")
  status        String    @default("pending")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5) @map("max_attempts")
  nextAttemptAt DateTime  @default(now()) @map("next_attempt_at")
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  sentAt        DateTime? @map("sent_at")

  @@index([status, nextAttemptAt])
  @@index([source, createdAt])
  @@map("email_jobs")
}

// ─── Manager view preferences (M1.3e) ───────────────────────────────────────
// Per-user JSON-config для customizable таблиці клієнтів та панелі фільтрів.
// `viewKey` ∈ {"clients_table", "clients_filters"}; shape конфігу валідовано
// на API-рівні (lib/manager/view-defaults.ts + lib/validations/view-prefs.ts).
model MgrUserViewPrefs {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  viewKey   String   @map("view_key")
  config    Json
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, viewKey])
  @@map("mgr_user_view_prefs")
}

// ─── Manager sync queue (M1.5) — outbound write-back to 1С ──────────────────
// Кожна зміна картки клієнта / замовлення / оплати на стороні менеджера
// створює row у цій черзі. Cron `/api/cron/process-sync-queue` періодично
// дренує її викликаючи services/manager-sync proxy.
//
// Lifecycle: pending → retrying ⇄ pending → sent
//                                ↘ failed (attempts ≥ maxAttempts)
//
// `idempotencyKey` — UUID; передається у SOAP-call щоб 1С міг dedup
// duplicate retries. Backoff schedule: 1m / 5m / 30m / 2h / 6h.

enum SyncJobStatus {
  pending
  retrying
  sent
  failed

  @@map("mgr_sync_job_status")
}

enum SyncEntityType {
  client
  order
  payment
  realization
  cash_order
  route_sheet

  @@map("mgr_sync_entity_type")
}

model MgrSyncJob {
  id             String         @id @default(cuid())
  entityType     SyncEntityType @map("entity_type")
  entityId       String         @map("entity_id")
  action         String
  payload        Json
  status         SyncJobStatus  @default(pending)
  attempts       Int            @default(0)
  maxAttempts    Int            @default(5) @map("max_attempts")
  nextAttemptAt  DateTime       @default(now()) @map("next_attempt_at")
  lastError      String?        @map("last_error")
  idempotencyKey String         @unique @map("idempotency_key")
  sentAt         DateTime?      @map("sent_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([status, nextAttemptAt])
  @@index([entityType, entityId])
  @@map("mgr_sync_jobs")
}

// ─── Manager sync state (M3.3 — INBOUND polling) ────────────────────────────
// Простий key/value store для збереження курсорів синхронізації pull-mode
// (cron `/api/cron/pull-from-1c`). На сьогодні єдиний ключ —
// `last_sync_cursor` (ISO-timestamp останнього успішного pull-у з 1С).
// Cursor зсувається тільки коли всі inbound endpoints успішно прийняли дані.

model MgrSyncState {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("mgr_sync_state")
}

// ─── Manager message templates (M1.7 / Прайс Stage 5b) ──────────────────────
// Простий довідник готових фраз {назва, текст} — відтворює 1С
// Catalog.ШаблоныСообщений. Спільний для всіх менеджерів (як довідник 1С):
// будь-який залогінений менеджер створює / редагує / видаляє шаблони і швидко
// вставляє їх у вікно «Поділитися». `createdByUserId` — лише для інфо (без FK).

model MgrMessageTemplate {
  id              String   @id @default(cuid())
  name            String
  text            String
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("mgr_message_templates")
}

// ─── Chat inbox (M1.8 Phase 1a) ────────────────────────────────────────────
// Об'єднаний чат-inbox для менеджерів: Telegram + Viber (далі WhatsApp/Instagram).
// Окремо від наявного `ChatMessage` (внутрішній чат магазину). Підстава —
// docs/CHAT_INBOX_PLAN.md.

enum ChatPlatform {
  telegram
  viber
  whatsapp
  instagram

  @@map("chat_platform")
}

enum ChatDirection {
  in
  out

  @@map("chat_direction")
}

enum ChatSender {
  client
  manager
  system

  @@map("chat_sender")
}

// Phase 2 — стан реєстрації нового клієнта через бот.
// NULL у `ChatConversation.registrationStep` = legacy розмова (Phase 1),
// у такій реєстрація не запускається (handleRegistrationStep → noop).
enum ChatRegistrationStep {
  awaiting_phone
  awaiting_region
  completed
  unassigned

  @@map("chat_registration_step")
}

model ChatConversation {
  id               String                @id @default(cuid())
  platform         ChatPlatform
  externalUserId   String                @map("external_user_id")
  externalUserName String?               @map("external_user_name")
  phone            String?
  clientId         String?               @map("client_id")
  agentUserId      String?               @map("agent_user_id")
  status           String                @default("active")
  unreadForManager Int                   @default(0) @map("unread_for_manager")
  registrationStep ChatRegistrationStep? @map("registration_step")
  pendingPhone     String?               @map("pending_phone")
  lastMessageAt    DateTime              @default(now()) @map("last_message_at")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  client   MgrClient?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  agent    User?              @relation("ChatConversationAgent", fields: [agentUserId], references: [id], onDelete: SetNull)
  messages ChatInboxMessage[]

  @@unique([platform, externalUserId])
  @@index([agentUserId, lastMessageAt(sort: Desc)])
  @@index([clientId])
  @@index([status, lastMessageAt(sort: Desc)])
  @@map("mgr_chat_conversations")
}

model ChatInboxMessage {
  id                String        @id @default(cuid())
  conversationId    String        @map("conversation_id")
  direction         ChatDirection
  sender            ChatSender
  text              String
  mediaUrl          String?       @map("media_url")
  externalMessageId String?       @map("external_message_id")
  authorUserId      String?       @map("author_user_id")
  isRead            Boolean       @default(false) @map("is_read")
  createdAt         DateTime      @default(now()) @map("created_at")

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User?            @relation("ChatInboxMessageAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@map("mgr_chat_inbox_messages")
}

// Phase 2 — мапа область→торговий (адмін-налаштовувана).
// При реєстрації нового клієнта через бот: клієнт обирає область → шукаємо
// агента → MgrClient.agentUserId. Якщо мапа не містить регіону → conversation
// переходить у `unassigned`, admin розрулить вручну.
model MgrRegionAgent {
  id        String   @id @default(cuid())
  region    String   @unique
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation("RegionAgentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("mgr_region_agents")
}
