  @@map("mgr_reminders")
}

// ─── Reminder items (← 1С TabularSection.Товары; тип «Для товарів») ─────────
// productId — плоский скаляр (без relation), як у дочірніх Маршрутного листа.
model MgrReminderItem {
  id         String   @id @default(cuid())
  reminderId String   @map("reminder_id")
  productId  String   @map("product_id")
  quantity   Int      @default(1)
  done       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  reminder MgrReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([reminderId])
  @@map("mgr_reminder_items")
}

model MgrClientTimelineEntry {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  kind         String
  body         String   @db.Text
  occurredAt   DateTime @map("occurred_at")
  authorUserId String?  @map("author_user_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  client MgrClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User?     @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([clientId, occurredAt(sort: Desc)])
  @@map("mgr_client_timeline")
}

// ─── 5.4.5 — регістр рухів боргу (живий борг клієнтів) ──────────────────────
// Кожне проведення документа = підписаний рядок руху; MgrClient.debt = Σ
// amountEur по рухах (кеш). Дзеркалить 1С _AccumRg5269 ВзаиморасчетыСКонтрагентами.
// `opening` — агрегований початковий залишок з історичного імпорту; `sale` /
// `payment` / `correction` — живі рухи (5.4.5b/5.4.5c).

enum MgrDebtMovementKind {
  opening
  sale
  payment
  correction

  @@map("mgr_debt_movement_kind")
}

model MgrDebtMovement {
  id              String              @id @default(cuid())
  clientId        String              @map("client_id")
  client          MgrClient           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amountEur       Decimal             @map("amount_eur") @db.Decimal(12, 2) // + борг клієнта зростає, − зменшується
  kind            MgrDebtMovementKind
  sourceType      String?             @map("source_type") // "accum_rg5269" | "sale" | "cash_order" | "manual"
  sourceId        String?             @map("source_id")
  occurredAt      DateTime            @map("occurred_at")
  note            String?
  createdByUserId String?             @map("created_by_user_id")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@unique([kind, sourceType, sourceId], name: "mgr_debt_movement_source")
  @@index([clientId, occurredAt])
  @@map("mgr_debt_movements")
}

// ─── Фаза 8 — дрібні / службові регістри (5.6+) ─────────────────────────────
// Усі — плоскі таблиці з 1С-кодами (`*Code1C` = hex(_IDRRef)); резолв у назви —
// best-effort через batch-lookup у UI/звітах. Без back-relations на спільні
// моделі (Product/MgrClient/User) — щоб лишити міграцію суто адитивною.

// СтатусДня (Enum СтатусДня: Початок/Кінець дня) — тайм-трекінг робочого дня
// агента. `kind` ∈ {"start", "end"}. `userId` → User.id (наш агент); якщо
// імпорт із 1С — резолв 1С-агента у User через code1C.
model AgentDayLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id") // наш User.id (агент); null якщо не зматчено
  code1C    String?  @map("code_1c") // hex(1С-агента) — джерело резолву userId
  date      DateTime @db.Date // календарний день
  kind      String // "start" | "end"
  at        DateTime // момент події (timestamp)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, date])
  @@index([date])
  @@map("agent_day_logs")
}

// НормыЗапасов (InformationRegister) — норма запасу по номенклатурі/складу.
// Виміри: Номенклатура (+Характеристика, +ОВ), Склад опційно. Ресурс — Количество.
model StockNorm {
  id              String   @id @default(cuid())
  productCode1C   String   @map("product_code_1c") // hex(Номенклатура._IDRRef)
  warehouseCode1C String?  @map("warehouse_code_1c") // hex(Склад) якщо є
  charCode1C      String?  @map("char_code_1c") // hex(ХарактеристикаНоменклатуры)
  unitCode1C      String?  @map("unit_code_1c") // hex(ЕдиницаИзмерения)
  norm            Decimal  @db.Decimal(14, 3) // Количество (норма)
  setAt           DateTime @map("set_at") // _Period / Дата запису норми
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([productCode1C, warehouseCode1C, charCode1C, unitCode1C], name: "stock_norm_key")
  @@index([productCode1C])
  @@map("stock_norms")
}

// НадежностьПоставщиков (InformationRegister, периодичність День) — оцінка
// надійності постачальника (Enum Важность). Зберігаємо як вільний текст-код.
model SupplierReliability {
  id             String   @id @default(cuid())
  supplierCode1C String   @map("supplier_code_1c") // hex(Контрагент._IDRRef)
  reliability    String // мапа з Enum Важность (low/medium/high) або hex-код
  occurredAt     DateTime @map("occurred_at") // _Period (день)
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([supplierCode1C, occurredAt], name: "supplier_reliability_key")
  @@index([supplierCode1C])
  @@map("supplier_reliabilities")
}

// ИсторияСтатусовКонтрагентов (InformationRegister, періодичність День) —
// історія зміни статусу контрагента. СтатусКонтрагента + ОперативныйСтатус.
model ClientStatusHistory {
  id                String   @id @default(cuid())
  clientCode1C      String   @map("client_code_1c") // hex(Контрагент._IDRRef)
  statusCode1C      String?  @map("status_code_1c") // hex(СтатусыКонтрагентов)
  operationalStatus String?  @map("operational_status") // hex/назва ОперативныйСтатус
  changedAt         DateTime @map("changed_at") // _Period (день зміни)
  createdAt         DateTime @default(now()) @map("created_at")

  @@unique([clientCode1C, changedAt], name: "client_status_history_key")
  @@index([clientCode1C])
  @@map("client_status_history")
}

// ─── Регістри-обороти (Фаза 2, 5.6) ─────────────────────────────────────────
// Матеріалізовані рухи 1С AccumulationRegisters. Патерн дзеркалить MgrDebtMovement:
// окрема таблиця рухів + idempotent-ключ джерела (recorderCode1C + lineNo). Усі
// FK-резолви (productId/clientId/lotId) — best-effort: при недоступному словнику
// лишаємо *Code1C (hex) і резолвимо id пізніше. Виміри/ресурси кожного регістра —
// у docs/1C_REGISTRY_INVENTORY.md (ЧАСТИНА C1).

/// 1С `AccumRg Продажи` (_AccumRg5604) — обороти продажів.
/// recordKind: 0=прихід (звичайна реалізація), 1=розхід (повернення).
model SalesMovement {
  id                   String   @id @default(cuid())
  occurredAt           DateTime @map("occurred_at")
  recorderCode1C       String   @map("recorder_code_1c") // hex(_RecorderRRef) документа-реєстратора
  lineNo               Int      @map("line_no")
  productCode1C        String?  @map("product_code_1c") // hex(Номенклатура)
  productId            String?  @map("product_id")
  lotCode1C            String?  @map("lot_code_1c") // hex(ХарактеристикаНоменклатуры)
  clientCode1C         String?  @map("client_code_1c") // hex(Контрагент)
  clientId             String?  @map("client_id")
  agentCode1C          String?  @map("agent_code_1c") // hex(ТорговийАгент) — якщо є на регістрі
  orderCode1C          String?  @map("order_code_1c") // hex(ЗаказПокупателя)
  saleCode1C           String?  @map("sale_code_1c") // hex(ДокументПродажи)
  qty                  Decimal  @db.Decimal(15, 3) // Количество
  weightKg             Decimal? @map("weight_kg") @db.Decimal(15, 3) // Вес
  revenueEur           Decimal  @map("revenue_eur") @db.Decimal(15, 2) // Стоимость
  revenueNoDiscountEur Decimal? @map("revenue_no_discount_eur") @db.Decimal(15, 2) // СтоимостьБезСкидок
  costEur              Decimal? @map("cost_eur") @db.Decimal(15, 2) // собівартість (Фаза 3, поки null)
  recordKind           Int      @map("record_kind") // 0=прихід / 1=розхід
  createdAt            DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo], name: "sales_movement_src")
  @@index([clientCode1C, occurredAt])
  @@index([productCode1C])
  @@index([occurredAt])
  @@map("sales_movements")
}

/// 1С `AccumRg ДвиженияДенежныхСредств` (_AccumRg5309) — рух коштів (ДДС).
/// direction: 0=прихід / 1=розхід (ПриходРасход).
model CashFlowMovement {
  id             String   @id @default(cuid())
  occurredAt     DateTime @map("occurred_at")
  recorderCode1C String   @map("recorder_code_1c")
  lineNo         Int      @map("line_no")
  accountCode1C  String?  @map("account_code_1c") // hex(БанковскийСчетКасса)
  articleCode1C  String?  @map("article_code_1c") // hex(СтатьяДвиженияДенежныхСредств)
  direction      Int // 0=прихід / 1=розхід
  clientCode1C   String?  @map("client_code_1c") // hex(Контрагент)
  amountUah      Decimal  @map("amount_uah") @db.Decimal(15, 2) // Сумма (у валюті рахунку/каси)
  amountUpr      Decimal? @map("amount_upr") @db.Decimal(15, 2) // СуммаУпр (EUR, управл. облік)
  // Валюта рахунку/каси руху: "UAH" | "EUR" | "USD" (null/UAH коли невідомо).
  // Резолвиться імпортером: БанковскийСчетКасса → ВалютаДенежныхСредств.
  currencyCode   String?  @map("currency_code")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo], name: "cash_flow_movement_src")
  @@index([articleCode1C, occurredAt])
  @@index([occurredAt])
  @@map("cash_flow_movements")
}

/// 1С `AccumRg ТоварыНаСкладах` (_AccumRg5788) + вага `ТовариНаСкладахУВазі`
/// (_AccumRg6608). Залишковий регістр: recordKind 0=прихід / 1=розхід.
model StockMovement {
  id              String   @id @default(cuid())
  occurredAt      DateTime @map("occurred_at")
  recorderCode1C  String   @map("recorder_code_1c")
  lineNo          Int      @map("line_no")
  warehouseCode1C String?  @map("warehouse_code_1c") // hex(Склад)
  productCode1C   String   @map("product_code_1c") // hex(Номенклатура)
  productId       String?  @map("product_id")
  lotCode1C       String?  @map("lot_code_1c") // hex(ХарактеристикаНоменклатуры)
  quality         String? // hex(Качество) або текст
  qty             Decimal  @db.Decimal(15, 3) // Количество (шт)
  weightKg        Decimal? @map("weight_kg") @db.Decimal(15, 3) // кг (з _AccumRg6608)
  recordKind      Int      @map("record_kind") // 0=прихід / 1=розхід
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo, productCode1C], name: "stock_movement_src")
  @@index([productCode1C, occurredAt])
  @@index([warehouseCode1C])
  @@index([occurredAt])
  @@map("stock_movements")
}

/// 1С `AccumRg ТоварыВДороге` — товари в дорозі (маршрут). Блок А.
/// Лот при відправці МЛ списується зі складу «в дорогу» (прихід, recordKind=0);
/// при продажу/поверненні — вибуває з дороги (розхід, recordKind=1). Баланс =
/// що зараз фізично в машинах. recorder = локальний RouteSheet.id.
model TransitMovement {
  id             String   @id @default(cuid())
  occurredAt     DateTime @map("occurred_at")
  recorderCode1C String   @map("recorder_code_1c") // RouteSheet.id (локальний) / hex 1С
  lineNo         Int      @map("line_no")
  productCode1C  String   @map("product_code_1c") // hex(Номенклатура) або barcode/синтет.
  productId      String?  @map("product_id")
  lotCode1C      String?  @map("lot_code_1c") // barcode лота
  lotId          String?  @map("lot_id")
  clientCode1C   String?  @map("client_code_1c") // hex(Контрагент) — кому везуть
  qty            Decimal  @db.Decimal(15, 3) // Количество (шт)
  weightKg       Decimal? @map("weight_kg") @db.Decimal(15, 3) // кг
  recordKind     Int      @map("record_kind") // 0=в дорогу / 1=з дороги
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo, productCode1C], name: "transit_movement_src")
  @@index([productCode1C, occurredAt])
  @@index([lotId])
  @@index([occurredAt])
  @@map("transit_movements")
}

/// 1С `AccumRg ЗаказыПокупателей` (_AccumRg5374) — залишки замовлень.
/// recordKind 0=прихід (замовлено) / 1=розхід (відвантажено/закрито).
model OrderRemainderMovement {
  id             String   @id @default(cuid())
  occurredAt     DateTime @map("occurred_at")
  recorderCode1C String   @map("recorder_code_1c")
  lineNo         Int      @map("line_no")
  orderCode1C    String   @map("order_code_1c") // hex(ЗаказПокупателя)
  orderId        String?  @map("order_id")
  productCode1C  String?  @map("product_code_1c") // hex(Номенклатура)
  productId      String?  @map("product_id")
  qty            Decimal  @db.Decimal(15, 3) // Количество
  recordKind     Int      @map("record_kind")
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo, orderCode1C], name: "order_remainder_movement_src")
  @@index([orderCode1C, occurredAt])
  @@index([occurredAt])
  @@map("order_remainder_movements")
}

// ─── Фаза 3: собівартість продажів (ПродажиСебестоимость _AccumRg5634) ───────
// ЄДИНЕ джерело історичної собівартості → звіт «Маржа/Валовий прибуток».
// Джойн із виручкою по recorderCode1C (= Sale.code1C).
model CostMovement {
  id             String   @id @default(cuid())
  recorderCode1C String   @map("recorder_code_1c") // hex(_IDRRef реалізації) = Sale.code1C
  lineNo         Int      @map("line_no")
  productCode1C  String?  @map("product_code_1c") // hex номенклатури = Product.code1C
  productId      String?  @map("product_id") // best-effort резолв при імпорті
  qty            Decimal  @default(0) @db.Decimal(15, 3) // Количество (кг/шт)
  costEur        Decimal  @default(0) @map("cost_eur") @db.Decimal(15, 2) // Стоимость (собівартість, EUR)
  occurredAt     DateTime @map("occurred_at") // _Period (рух)
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([recorderCode1C, lineNo], name: "cost_movement_recorder_line")
  @@index([recorderCode1C])
  @@index([productCode1C])
  @@index([occurredAt])
  @@map("cost_movements")
}

// ─── Фаза 6: фінансові документи банк/каса ──────────────────────────────────
// Безготівкові платіжні доручення (вхідне = надходження від клієнта, вихідне =
// оплата постачальнику/витрата). Проведення вхідного зменшує борг клієнта через
// `MgrDebtMovement` (best-effort). `code1C` = hex(_IDRRef) — унікальний ключ
// імпорту. `number1C` (1С _Number) — лише для відображення.

model BankPaymentIncoming {
  id                String    @id @default(cuid())
  code1C            String?   @unique @map("code_1c")
  number1C          String?   @map("number_1c")
  docNumber         Int       @default(autoincrement()) @map("doc_number")
  customerId        String?   @map("customer_id") // Контрагент-платник
  bankAccountId     String?   @map("bank_account_id") // рахунок L-TEX
  cashFlowArticleId String?   @map("cash_flow_article_id") // стаття ДДС
  amount            Float     @default(0) // сума у валюті документа
  currency          String    @default("UAH") // UAH | EUR | USD
  amountEur         Float     @default(0) @map("amount_eur") // зведена сума EUR
  rateEur           Float     @default(0) @map("rate_eur") // курс-знімок (грн за €)
  iban              String? // IBAN рахунку платника
  purpose           String? // призначення платежу
  status            String    @default("draft") // draft | posted | cancelled
  archived          Boolean   @default(false)
  comment           String?
  paidAt            DateTime  @default(now()) @map("paid_at")
  postedAt          DateTime? @map("posted_at")
  createdByUserId   String?   @map("created_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  bankAccountRef     MgrBankAccount?     @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  cashFlowArticleRef MgrCashFlowArticle? @relation(fields: [cashFlowArticleId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([archived])
  @@index([paidAt])
  @@map("bank_payments_incoming")
}

model BankPaymentOutgoing {
  id                String    @id @default(cuid())
  code1C            String?   @unique @map("code_1c")
  number1C          String?   @map("number_1c")
  docNumber         Int       @default(autoincrement()) @map("doc_number")
  customerId        String?   @map("customer_id") // Контрагент-отримувач
  bankAccountId     String?   @map("bank_account_id") // рахунок L-TEX
  cashFlowArticleId String?   @map("cash_flow_article_id") // стаття ДДС
  amount            Float     @default(0)
  currency          String    @default("UAH")
  amountEur         Float     @default(0) @map("amount_eur")
  rateEur           Float     @default(0) @map("rate_eur")
  iban              String? // IBAN рахунку отримувача
  purpose           String?
  status            String    @default("draft") // draft | posted | cancelled
  archived          Boolean   @default(false)
  comment           String?
  paidAt            DateTime  @default(now()) @map("paid_at")
  postedAt          DateTime? @map("posted_at")
  createdByUserId   String?   @map("created_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  bankAccountRef     MgrBankAccount?     @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  cashFlowArticleRef MgrCashFlowArticle? @relation(fields: [cashFlowArticleId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([archived])
  @@index([paidAt])
  @@map("bank_payments_outgoing")
}

// Переміщення готівки: каса↔каса / інкасація каса↔банк. fromAccount/toAccount —
// банк-рахунки (або null для готівкової каси). `cashFlowArticleId` — стаття.

model CashTransfer {
  id                String    @id @default(cuid())
  code1C            String?   @unique @map("code_1c")
  number1C          String?   @map("number_1c")
  docNumber         Int       @default(autoincrement()) @map("doc_number")
  fromAccountId     String?   @map("from_account_id") // рахунок-джерело (null = готівкова каса)
  toAccountId       String?   @map("to_account_id") // рахунок-призначення (null = готівкова каса)
  cashFlowArticleId String?   @map("cash_flow_article_id")
  amount            Float     @default(0)
  currency          String    @default("UAH")
  amountEur         Float     @default(0) @map("amount_eur")
  rateEur           Float     @default(0) @map("rate_eur")
  status            String    @default("draft") // draft | posted | cancelled
  archived          Boolean   @default(false)
  comment           String?
  transferredAt     DateTime  @default(now()) @map("transferred_at")
  postedAt          DateTime? @map("posted_at")
  createdByUserId   String?   @map("created_by_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  fromAccountRef     MgrBankAccount?     @relation("CashTransferFrom", fields: [fromAccountId], references: [id], onDelete: SetNull)
  toAccountRef       MgrBankAccount?     @relation("CashTransferTo", fields: [toAccountId], references: [id], onDelete: SetNull)
  cashFlowArticleRef MgrCashFlowArticle? @relation(fields: [cashFlowArticleId], references: [id], onDelete: SetNull)

  @@index([archived])
  @@index([transferredAt])
  @@map("cash_transfers")
}

// ─── Email DLQ (persistent retry queue, Session 70) ─────────────────────────

model EmailJob {
  id            String    @id @default(cuid())
  to            String    @map("to_address")
  subject       String
  htmlBody      String    @map("html_body")
  textBody      String?   @map("text_body")
  source        String
  referenceId   String?   @map("reference_id")
  status        String    @default("pending")
  attempts      Int       @default(0)
  maxAttempts   Int       @default(5) @map("max_attempts")
  nextAttemptAt DateTime  @default(now()) @map("next_attempt_at")
  lastError     String?   @map("last_error")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  sentAt        DateTime? @map("sent_at")

  @@index([status, nextAttemptAt])
  @@index([source, createdAt])
  @@map("email_jobs")
}

