generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Categories (self-relation: category → subcategory) ─────────────────────

model Category {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  parentId  String?  @map("parent_id")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  products Product[]

  @@index([parentId])
  @@map("categories")
}

// ─── Products (← 1С Номенклатура) ───────────────────────────────────────────

model Product {
  id              String   @id @default(cuid())
  code1C          String?  @unique @map("code_1c")
  articleCode     String?  @map("article_code")
  name            String
  slug            String   @unique
  categoryId      String   @map("category_id")
  description     String   @default("")
  quality         String
  season          String   @default("")
  country         String
  priceUnit       String   @default("kg") @map("price_unit")
  averageWeight   Float?   @map("average_weight")
  videoUrl        String?  @map("video_url")
  inStock         Boolean  @default(true) @map("in_stock")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  category           Category           @relation(fields: [categoryId], references: [id])
  images             ProductImage[]
  lots               Lot[]
  prices             Price[]
  orderItems         OrderItem[]
  cartItems          CartItem[]
  videoSubscriptions VideoSubscription[]
  favorites          Favorite[]
  featuredEntry      FeaturedProduct?
  viewLog            ViewLog[]

  @@index([categoryId])
  @@index([quality])
  @@index([inStock])
  @@index([articleCode])
  @@map("products")
}

// ─── Product Images (← 1С зображення номенклатури) ──────────────────────────

model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  alt       String   @default("")
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

// ─── Lots / Bags (← 1С Серії + ТовариНаСкладах) ────────────────────────────

model Lot {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  barcode   String   @unique
  weight    Float
  quantity  Int      @default(1)
  status    String   @default("free")
  priceEur  Float    @map("price_eur")
  videoUrl  String?  @map("video_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product    Product     @relation(fields: [productId], references: [id])
  barcodes   Barcode[]
  orderItems OrderItem[]
  cartItems  CartItem[]

  @@index([productId])
  @@index([status])
  @@map("lots")
}

// ─── Barcodes (← 1С ШтрихКоди) ─────────────────────────────────────────────

model Barcode {
  id    String @id @default(cuid())
  lotId String @map("lot_id")
  code  String @unique
  type  String @default("EAN13")

  lot Lot @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([lotId])
  @@map("barcodes")
}

// ─── Prices (← 1С ЦіниНоменклатури) ────────────────────────────────────────

model Price {
  id        String    @id @default(cuid())
  productId String    @map("product_id")
  priceType String    @map("price_type")
  currency  String    @default("EUR")
  amount    Float
  validFrom DateTime  @default(now()) @map("valid_from")
  validTo   DateTime? @map("valid_to")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, priceType])
  @@map("prices")
}

// ─── Customers (← 1С Контрагенти) ──────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  code1C    String?  @unique @map("code_1c")
  name      String
  phone     String?
  email     String?
  telegram  String?
  city      String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders             Order[]
  cart               Cart?
  chatMessages       ChatMessage[]
  videoSubscriptions VideoSubscription[]
  pushTokens         PushToken[]
  favorites          Favorite[]
  notifications      Notification[]
  viewLog            ViewLog[]

  @@map("customers")
}

// ─── Orders (← 1С ЗаказПокупателя) ─────────────────────────────────────────

model Order {
  id           String   @id @default(cuid())
  code1C       String?  @unique @map("code_1c")
  customerId   String   @map("customer_id")
  status       String   @default("draft")
  totalEur     Float    @default(0) @map("total_eur")
  totalUah     Float    @default(0) @map("total_uah")
  exchangeRate Float    @default(0) @map("exchange_rate")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  customer  Customer    @relation(fields: [customerId], references: [id])
  items     OrderItem[]
  shipments Shipment[]
  payments  Payment[]

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

// ─── Order Items (← табличні секції документів) ─────────────────────────────

model OrderItem {
  id        String @id @default(cuid())
  orderId   String @map("order_id")
  lotId     String @map("lot_id")
  productId String @map("product_id")
  priceEur  Float  @map("price_eur")
  weight    Float
  quantity  Int    @default(1)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lot     Lot     @relation(fields: [lotId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── Exchange Rates (← 1С КурсиВалют) ──────────────────────────────────────

model ExchangeRate {
  id           String   @id @default(cuid())
  currencyFrom String   @map("currency_from")
  currencyTo   String   @map("currency_to")
  rate         Float
  date         DateTime @default(now())
  source       String   @default("1c")

  @@unique([currencyFrom, currencyTo, date])
  @@map("exchange_rates")
}

// ─── Carts (server-side cart persistence) ───────────────────────────────────

model Cart {
  id         String   @id @default(cuid())
  customerId String?  @unique @map("customer_id")
  sessionId  String?  @unique @map("session_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String @map("cart_id")
  lotId     String @map("lot_id")
  productId String @map("product_id")
  priceEur  Float  @map("price_eur")
  weight    Float
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  lot     Lot     @relation(fields: [lotId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, lotId])
  @@index([cartId])
  @@map("cart_items")
}

// ─── Chat Messages (customer ↔ manager) ────────────────────────────────────

model ChatMessage {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  sender     String   // "customer" | "manager"
  text       String
  imageUrl   String?  @map("image_url")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@map("chat_messages")
}

// ─── Shipment Tracking (Nova Poshta) ────────────────────────────────────────

model Shipment {
  id              String   @id @default(cuid())
  orderId         String   @map("order_id")
  trackingNumber  String   @map("tracking_number")
  carrier         String   @default("nova_poshta")
  status          String   @default("created")
  statusText      String?  @map("status_text")
  estimatedDate   DateTime? @map("estimated_date")
  recipientCity   String?  @map("recipient_city")
  recipientBranch String?  @map("recipient_branch")
  lastCheckedAt   DateTime? @map("last_checked_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, trackingNumber])
  @@index([trackingNumber])
  @@map("shipments")
}

// ─── Video Review Subscriptions ─────────────────────────────────────────────

model VideoSubscription {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("video_subscriptions")
}

// ─── In-app notifications feed (S36) ───────────────────────────────────────

model Notification {
  id         String    @id @default(cuid())
  customerId String    @map("customer_id")
  type       String    // "order_status" | "new_video" | "chat_message" | "system"
  title      String
  body       String
  payload    Json?
  readAt     DateTime? @map("read_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
  @@index([customerId, readAt])
  @@map("notifications")
}

// ─── Push Notification Tokens ───────────────────────────────────────────────

model PushToken {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  token      String   @unique
  platform   String   // "ios" | "android" | "web"
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("push_tokens")
}

// ─── Payments ───────────────────────────────────────────────────────────────

model Payment {
  id            String   @id @default(cuid())
  orderId       String   @map("order_id")
  method        String   // "cash" | "card" | "bank_transfer" | "online"
  amount        Float
  currency      String   @default("UAH")
  status        String   @default("pending") // pending | completed | failed | refunded
  externalId    String?  @map("external_id")  // payment gateway ID
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([externalId])
  @@map("payments")
}

// ─── Favorites (wishlists) ──────────────────────────────────────────────────

model Favorite {
  id         String   @id @default(cuid())
  customerId String   @map("customer_id")
  productId  String   @map("product_id")
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@map("favorites")
}

// ─── Sync Log (tracking 1C sync operations) ────────────────────────────────

model SyncLog {
  id        String   @id @default(cuid())
  entity    String
  entityId  String?  @map("entity_id")
  action    String
  payload   Json?
  syncedAt  DateTime @default(now()) @map("synced_at")

  @@index([entity, entityId])
  @@index([syncedAt])
  @@map("sync_log")
}

// ─── Featured Products (homepage "Топ товарів", admin-curated) ──────────────

model FeaturedProduct {
  id        String   @id @default(cuid())
  productId String   @unique @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  position  Int      @default(0)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([position])
  @@map("featured_products")
}

// ─── Banners (homepage carousel, admin-managed) ─────────────────────────────

model Banner {
  id         String   @id @default(cuid())
  title      String
  subtitle   String?
  imageUrl   String
  ctaLabel   String?
  ctaHref    String?
  position   Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive, position])
  @@map("banners")
}

// ─── Newsletter Subscribers (footer signup) ─────────────────────────────────

model NewsletterSubscriber {
  id             String    @id @default(uuid())
  email          String    @unique
  phone          String?
  subscribedAt   DateTime  @default(now()) @map("subscribed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  source         String?
  confirmedAt    DateTime? @map("confirmed_at")

  @@index([subscribedAt])
  @@map("newsletter_subscribers")
}

// ─── Promo Stripe (sticky "Гаряча пропозиція" banner, single-row) ──────────

model PromoStripe {
  id        String   @id @default(cuid())
  text      String
  ctaLabel  String?
  ctaHref   String?
  bgColor   String   @default("#dc2626")
  textColor String   @default("#ffffff")
  isActive  Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@map("promo_stripe")
}

// ─── Product View Log (recommendations + analytics) ──────────────────────────

model ViewLog {
  id         String   @id @default(cuid())
  customerId String?  @map("customer_id")
  productId  String   @map("product_id")
  source     String   @default("unknown") // "home" | "catalog" | "search" | "product_detail" | "unknown"
  viewedAt   DateTime @default(now()) @map("viewed_at")

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([customerId, viewedAt])
  @@index([productId, viewedAt])
  @@map("view_log")
}
