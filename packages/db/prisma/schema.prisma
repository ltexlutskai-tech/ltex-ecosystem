// ─── ТЗ 8.0 — черга «позначок на вилучення» (1С «Видалення позначених») ──────
// Полиморфна: одна таблиця для всіх типів обʼєктів (клієнти/документи/довідники).
// Звичайний менеджер створює запит (status="pending") з обовʼязковою причиною →
// обʼєкт зникає з його списків. Адміністратор у /manager/admin/deletions рішає:
// approve (фіз. видалення, ЛИШЕ якщо 0 посилань і code1C=null; інакше авто-архів)
// або reject (зняти позначку, повернути обʼєкт). Без FK — тримає лише entityId +
// знімок назви, щоб черга пережила фізичне видалення обʼєкта.
model DeletionRequest {
  id                String    @id @default(cuid())
  entityType        String    @map("entity_type") // client|order|sale|cash_order|route_sheet|dictionary|category|product
  entityId          String    @map("entity_id")
  entityLabel       String    @map("entity_label") // знімок назви/номера для черги
  dictType          String?   @map("dict_type") // лише для entityType="dictionary"
  reason            String    @db.Text // причина від користувача (обовʼязкова)
  status            String    @default("pending") // pending|approved|rejected
  outcome           String? // при approve: "deleted" | "archived"
  requestedByUserId String    @map("requested_by_user_id")
  requestedByName   String?   @map("requested_by_name")
  requestedAt       DateTime  @default(now()) @map("requested_at")
  resolvedByUserId  String?   @map("resolved_by_user_id")
  resolvedAt        DateTime? @map("resolved_at")
  resolutionNote    String?   @map("resolution_note") @db.Text

  @@index([status, requestedAt])
  @@index([entityType, entityId])
  @@map("deletion_requests")
}

// ─── Лічильник візитів сайту (7.2 Блок 4) ──────────────────────────────────
