# L-TEX Manager Sync — proxy service між Next.js та 1С SOAP.
# Запуск: `pnpm --filter @ltex/manager-sync start`
# Production: керується PM2 (див. ecosystem.config.js).

# Port на якому слухає proxy. Default 3001 (не конфліктує з Next.js :3000).
MANAGER_SYNC_PORT=3001

# Shared secret між Next.js (apps/store) і цим proxy. ≥16 chars.
# Генерувати: openssl rand -base64 24
MANAGER_SYNC_SHARED_SECRET=

# Mock mode (default true): не робить real SOAP, симулює delay 100-500ms.
# Коли 1С-розробник реалізує SOAP-модулі (див. docs/1C_SYNC_MODULES_SPEC.md) —
# виставити false і налаштувати ONEC_* нижче.
SYNC_MOCK_MODE=true

# 1С SOAP URL — заповнити коли SYNC_MOCK_MODE=false.
# Формат: https://<1c-server>/<base>/ws/MobileExchange.1cws
ONEC_SOAP_URL=

# Shared secret з 1С constant `СинкПароль`.
ONEC_SOAP_PASSWORD=

# Optional: HTTP timeout для SOAP-calls (ms). Default 30000.
# ONEC_SOAP_TIMEOUT_MS=30000
