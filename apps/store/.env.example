# Supabase
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — server-only, bypasses RLS, used for admin storage operations.
# NEVER expose to client (no NEXT_PUBLIC_ prefix). Get from Supabase dashboard
# → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=""

# Self-hosted media (product photos + banners saved to the server's disk
# instead of Supabase Storage — session 6.0 Task A). Files are written under
# MEDIA_ROOT and served back by the app at /media/<path>.
#   MEDIA_ROOT       — absolute path to the media folder on the server.
#   MEDIA_PUBLIC_URL — public base URL of the site, no trailing slash.
# ⚠️ Back up MEDIA_ROOT daily alongside the DB.
MEDIA_ROOT="E:\\ltex-storage\\media"
MEDIA_PUBLIC_URL="https://new.ltex.com.ua"

# 1C Sync API
SYNC_API_KEY=""

# App
NEXT_PUBLIC_SITE_URL="https://ltex.com.ua"

# Telegram notifications (optional)
# TELEGRAM_CHAT_ID         — operations chat for new orders (notifyNewOrder).
# NEWSLETTER_TELEGRAM_CHAT_ID — manager chat for lead capture: newsletter
#   signups *and* new customer leads (notifyNewLead). Two different chats so
#   leads don't drown out the order stream.
TELEGRAM_BOT_TOKEN=""
# Окремий бот ТІЛЬКИ для server→admin сповіщень (order/newsletter/lead alerts).
# Якщо не виставлено — fallback на TELEGRAM_BOT_TOKEN (single-bot режим).
TELEGRAM_NOTIFICATIONS_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
NEWSLETTER_TELEGRAM_CHAT_ID=""
TELEGRAM_WEBHOOK_SECRET=""

# Viber notifications (optional)
VIBER_AUTH_TOKEN=""
VIBER_ADMIN_USER_ID=""
VIBER_WEBHOOK_URL=""

# Nova Poshta (optional)
NOVA_POSHTA_API_KEY=""

# Mobile app (optional)
EXPO_PUBLIC_API_URL=""

# Umami Analytics (optional — cookieless tracking)
NEXT_PUBLIC_UMAMI_SCRIPT_URL=""  # e.g. https://analytics.example.com/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""  # UUID from Umami dashboard

# Web customer auth secret (≥32 chars) — signs the ltex_customer cookie
# (S73 phone+name login). Generate via: openssl rand -hex 32
CUSTOMER_AUTH_SECRET=""

# Cron secret (≥16 chars) — required for /api/cron/* endpoints
# Used by: /api/cron/cleanup-viewlog, /api/cron/process-email-queue (S70).
# Generate via: openssl rand -hex 32
# Pass as `x-cron-secret: <secret>` header (preferred), `Authorization: Bearer ...`,
# or `?token=<secret>` query param. See docs/EMAIL_QUEUE.md for Windows Task Scheduler setup.
CRON_SECRET=""

# Manager Workstation (M1.x)
# Signs the manager session access tokens (HMAC-SHA256). Required ≥32 chars.
# Generate via: openssl rand -base64 48
MANAGER_JWT_SECRET=""

# 1C SOAP exchange endpoint (M1.5 — placeholders, real calls wired up later)
MOBILE_EXCHANGE_SOAP_URL=""
MOBILE_EXCHANGE_SOAP_USER=""
MOBILE_EXCHANGE_SOAP_PASSWORD=""

# Manager sync proxy (M1.5)
# Next.js queue-processor викликає HTTP-proxy services/manager-sync який потім
# робить SOAP-call у 1С. Mock-режим default — повний real handshake у M1.5b.
# URL до services/manager-sync proxy (PM2 instance, port 3001).
MANAGER_SYNC_URL="http://localhost:3001"
# Shared secret між Next.js і manager-sync proxy (≥16 chars).
# Генерувати: openssl rand -base64 24
MANAGER_SYNC_SHARED_SECRET=""

# Seed first admin (одноразово при першому deploy, потім видалити з env):
#   SEED_ADMIN_EMAIL=ltex.lutsk.ai@gmail.com
#   SEED_ADMIN_PASSWORD=<тимчасовий 12+ chars>
#   SEED_ADMIN_NAME=Адміністратор L-TEX
# Запустити: pnpm --filter @ltex/store exec tsx scripts/seed-admin-user.ts
