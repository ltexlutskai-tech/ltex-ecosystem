{
  "expo": {
    "name": "L-TEX",
    "slug": "ltex-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "ltex",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#16a34a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ua.com.ltex.client",
      "associatedDomains": ["applinks:ltex.com.ua"],
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["ltex"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#16a34a"
      },
      "package": "ua.com.ltex.client",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "ltex"
            },
            {
              "scheme": "https",
              "host": "ltex.com.ua",
              "pathPrefix": "/product"
            },
            {
              "scheme": "https",
              "host": "ltex.com.ua",
              "pathPrefix": "/order"
            },
            {
              "scheme": "https",
              "host": "ltex.com.ua",
              "pathPrefix": "/catalog"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#16a34a"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://new.ltex.com.ua/api",
      "eas": {
        "projectId": ""
      }
    }
  }
}
