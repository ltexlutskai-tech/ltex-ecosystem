# ─── Database (required) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/ltex-ecosystem
DIRECT_URL=postgresql://user:password@host:5432/ltex-ecosystem

# ─── Supabase (required) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Site URL (required for SEO, bots) ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://ltex.com.ua

# ─── 1C Sync API (required for sync endpoints) ──────────────────────────────
SYNC_API_KEY=your-secure-bearer-token

# ─── Mobile API auth (REQUIRED if /api/mobile/* is exposed) ────────────────
# Secret used to sign short-lived session tokens issued by /api/mobile/auth.
# Must be at least 32 characters. Generate via: openssl rand -hex 32
# Without this set, all /api/mobile/* endpoints refuse requests with 503.
MOBILE_JWT_SECRET=

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# TELEGRAM_WEBHOOK_SECRET is REQUIRED if /api/telegram/webhook is exposed —
# without it the endpoint returns 503. Generate via: openssl rand -hex 32
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# ─── Viber Bot ───────────────────────────────────────────────────────────────
# VIBER_AUTH_TOKEN is REQUIRED if /api/viber/webhook is exposed — webhook
# enforces HMAC-SHA256 signature verification and rejects unsigned requests.
VIBER_AUTH_TOKEN=
VIBER_WEBHOOK_URL=

# ─── Nova Poshta (optional, for shipment tracking) ──────────────────────────
NOVA_POSHTA_API_KEY=

# ─── Email Notifications (optional, choose SMTP or Resend) ─────────────────
# SMTP (nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ltex.com.ua
# OR Resend API
RESEND_API_KEY=

# ─── Mobile App (Expo) ──────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://ltex.com.ua/api

# ─── Umami Analytics (optional — cookieless tracking) ──────────────────────
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
